              <tr><td>venir</td><td class="hl-ps">vint</td><td class="hl-ps">vinrent</td><td>v-int</td></tr>
              <tr><td>tenir</td><td class="hl-ps">tint</td><td class="hl-ps">tinrent</td><td>t-int</td></tr>
              <tr><td>mourir</td><td class="hl-ps">mourut</td><td class="hl-ps">moururent</td><td>mouru-</td></tr>
              <tr><td>naître</td><td class="hl-ps">naquit</td><td class="hl-ps">naquirent</td><td>naqu-</td></tr>
              <tr><td>courir</td><td class="hl-ps">courut</td><td class="hl-ps">coururent</td><td>couru-</td></tr>
              <tr><td>partir</td><td class="hl-ps">partit</td><td class="hl-ps">partirent</td><td>parti-</td></tr>
