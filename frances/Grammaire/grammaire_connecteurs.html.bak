<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Connecteurs Logiques</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ede9df;
  --card: #faf7f1;
  --border: #c4bead;
  --text: #1a1814;
  --text2: #44413a;
  --text3: #706c64;
  --accent: #7a5a0a;
  --accent-light: #f0e0c0;
  --accent-mid: #b89050;
  --warn-bg: #fdf0cc;
  --shadow: 0 2px 14px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.08);
  --radius: 14px;
  --radius-sm: 8px;
  --green: #1a6028;  --green-bg: #e4f2e8;
  --red: #a81e2e;    --red-bg: #fce6e8;
  --blue: #163494;   --blue-bg: #e6ebf8;
  --purple: #6a1a8a; --purple-bg: #f2e6f8;
  /* relation colours */
  --ca-color: #163494;  --ca-bg: #e6ebf8;   /* cause        — blue   */
  --co-color: #1a6028;  --co-bg: #e4f2e8;   /* conséquence  — green  */
  --op-color: #8b1a4a;  --op-bg: #f8e6ee;   /* opposition   — wine   */
  --cn-color: #6a1a8a;  --cn-bg: #f2e6f8;   /* concession   — purple */
  --cd-color: #7a5a0a;  --cd-bg: #f0e0c0;   /* condition    — gold   */
  --il-color: #0e6e6e;  --il-bg: #e0f4f4;   /* illustration — teal   */
  --fs: 15px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; font-size: var(--fs); }

.site-header { background: var(--card); border-bottom: 2px solid var(--border); padding: 20px 20px 14px; }
.header-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 3px; flex-wrap: wrap; }
.site-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.2rem,5vw,1.85rem); font-weight: 700; color: var(--text); }
.header-tag { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); background: var(--accent-light); border: 1px solid var(--accent-mid); border-radius: 20px; padding: 3px 10px; }
.subtitle { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; }
.stats-row { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; }
.stat-pill { border-radius: 20px; padding: 4px 11px; font-size: 0.76rem; font-weight: 600; border: 1px solid; }
.stat-pill.ca { background: var(--ca-bg); color: var(--ca-color); border-color: var(--ca-color); }
.stat-pill.co { background: var(--co-bg); color: var(--co-color); border-color: var(--co-color); }
.stat-pill.op { background: var(--op-bg); color: var(--op-color); border-color: var(--op-color); }
.stat-pill.cn { background: var(--cn-bg); color: var(--cn-color); border-color: var(--cn-color); }
.stat-pill.cd { background: var(--cd-bg); color: var(--cd-color); border-color: var(--cd-color); }
.stat-pill.il { background: var(--il-bg); color: var(--il-color); border-color: var(--il-color); }
.stat-pill.neu { background: var(--bg); color: var(--text2); border-color: var(--border); font-weight: 500; }
.fs-wrap { display: flex; align-items: center; gap: 7px; margin-left: auto; }
.fs-slider { width: 76px; accent-color: var(--accent); cursor: pointer; }
.fs-sz { color: var(--text3); font-weight: 700; }

.mode-toggle { display: flex; border-bottom: 2px solid var(--border); background: var(--card); }
.mode-btn { flex: 1; padding: 12px 8px; font-family: 'DM Sans', sans-serif; font-size: 0.84rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; margin-bottom: -2px; }
.mode-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.section-nav { position: sticky; top: 0; z-index: 200; background: var(--card); border-bottom: 2px solid var(--border); box-shadow: var(--shadow-sm); }
.section-nav-inner { display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.section-nav-inner::-webkit-scrollbar { display: none; }
.snav-btn { flex-shrink: 0; padding: 11px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.snav-btn:hover { color: var(--text2); }
.snav-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

.main-layout { max-width: 860px; margin: 0 auto; padding: 16px 16px 40px; }
.panel { display: none; } .panel.active { display: block; }
.sec-block { display: none; } .sec-block.active { display: block; }
.gram-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 14px; overflow: hidden; }
.gram-card-body { padding: 18px; }

.def-box { background: var(--warn-bg); border-left: 4px solid var(--accent); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 12px 15px; margin-bottom: 14px; line-height: 1.65; }
.def-box strong { color: var(--accent); font-weight: 700; }
.warn-box { background: #fff4e0; border: 1px solid #c8900a; border-radius: var(--radius-sm); padding: 10px 13px; margin: 10px 0; font-size: 0.9em; display: flex; gap: 8px; align-items: flex-start; }
.warn-icon { flex-shrink: 0; margin-top: 1px; }
.warn-text { color: var(--text2); line-height: 1.55; }
.warn-text strong { color: #7a4400; font-weight: 700; }
.note-box { background: var(--purple-bg); border-left: 4px solid var(--purple); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.note-box strong { color: var(--purple); font-weight: 700; }
.green-box { background: var(--green-bg); border-left: 4px solid var(--green); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.green-box strong { color: var(--green); font-weight: 700; }

.example-block { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 8px 0; }
.example-block.ca { background: var(--ca-bg); border-left: 4px solid var(--ca-color); }
.example-block.co { background: var(--co-bg); border-left: 4px solid var(--co-color); }
.example-block.op { background: var(--op-bg); border-left: 4px solid var(--op-color); }
.example-block.cn { background: var(--cn-bg); border-left: 4px solid var(--cn-color); }
.example-block.cd { background: var(--cd-bg); border-left: 4px solid var(--cd-color); }
.example-block.il { background: var(--il-bg); border-left: 4px solid var(--il-color); }
.example-block.neu { background: var(--blue-bg); border-left: 4px solid var(--blue); }
.ex-fr { font-weight: 600; margin-bottom: 3px; color: var(--text); }
.eca { color: var(--ca-color); font-weight: 700; }
.eco { color: var(--co-color); font-weight: 700; }
.eop { color: var(--op-color); font-weight: 700; }
.ecn { color: var(--cn-color); font-weight: 700; }
.ecd { color: var(--cd-color); font-weight: 700; }
.eil { color: var(--il-color); font-weight: 700; }
.ex-es { color: var(--text2); font-size: 0.88em; font-style: italic; }
.ex-note { font-size: 0.78em; color: var(--text3); margin-top: 3px; font-weight: 500; }

.table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 14px; border-radius: var(--radius-sm); border: 1px solid var(--border); }
.gram-table { width: 100%; border-collapse: collapse; min-width: 280px; }
.gram-table th { background: var(--bg); border-bottom: 2px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; text-align: left; font-size: 0.72em; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text3); }
.gram-table td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; vertical-align: top; }
.gram-table tr:last-child td { border-bottom: none; }
.gram-table tr:nth-child(even) td { background: #f4f0e6; }
.gram-table td:last-child, .gram-table th:last-child { border-right: none; }
.hl-ca { color: var(--ca-color); font-weight: 700; }
.hl-co { color: var(--co-color); font-weight: 700; }
.hl-op { color: var(--op-color); font-weight: 700; }
.hl-cn { color: var(--cn-color); font-weight: 700; }
.hl-cd { color: var(--cd-color); font-weight: 700; }
.hl-il { color: var(--il-color); font-weight: 700; }
.hl    { color: var(--accent);   font-weight: 700; }
.dim   { color: var(--text3); font-size: 0.88em; }
.ok-cell  { color: var(--green); font-weight: 700; }
.err-cell { color: var(--red);   font-weight: 600; font-style: italic; }

/* connector tag */
.conn-tag { display: inline-block; border-radius: 4px; padding: 1px 7px; font-size: 0.8em; font-weight: 700; margin-right: 4px; white-space: nowrap; }
.conn-tag.ca { background: var(--ca-bg); color: var(--ca-color); border: 1px solid var(--ca-color); }
.conn-tag.co { background: var(--co-bg); color: var(--co-color); border: 1px solid var(--co-color); }
.conn-tag.op { background: var(--op-bg); color: var(--op-color); border: 1px solid var(--op-color); }
.conn-tag.cn { background: var(--cn-bg); color: var(--cn-color); border: 1px solid var(--cn-color); }
.conn-tag.cd { background: var(--cd-bg); color: var(--cd-color); border: 1px solid var(--cd-color); }
.conn-tag.il { background: var(--il-bg); color: var(--il-color); border: 1px solid var(--il-color); }

/* register badge */
.reg { display: inline-block; font-size: 0.72em; font-weight: 700; border-radius: 3px; padding: 1px 5px; vertical-align: middle; margin-left: 4px; }
.reg.oral  { background: #e0f4f4; color: #0e5e5e; }
.reg.ecrit { background: var(--warn-bg); color: var(--accent); }
.reg.soutenu { background: var(--purple-bg); color: var(--purple); }
.reg.neutre { background: var(--bg); color: var(--text3); border: 1px solid var(--border); }

.chip-bar { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.chip { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; white-space: nowrap; }
.chip:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); }
.chip.active    { background: var(--accent);    color: #fff; border-color: var(--accent); }
.chip.ca.active { background: var(--ca-color);  border-color: var(--ca-color); }
.chip.co.active { background: var(--co-color);  border-color: var(--co-color); }
.chip.op.active { background: var(--op-color);  border-color: var(--op-color); }
.chip.cn.active { background: var(--cn-color);  border-color: var(--cn-color); }
.chip.cd.active { background: var(--cd-color);  border-color: var(--cd-color); }
.chip.il.active { background: var(--il-color);  border-color: var(--il-color); }
.chip-panel { display: none; } .chip-panel.active { display: block; }

.sec-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); margin: 14px 0 7px; }

.trap-cards { display: flex; flex-direction: column; gap: 10px; }
.trap-card { border: 1.5px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
.trap-card-header { padding: 11px 14px; background: var(--bg); }
.trap-name { font-weight: 700; font-size: 0.9em; color: var(--text); margin-bottom: 7px; }
.trap-vs { display: flex; gap: 8px; flex-wrap: wrap; }
.trap-wrong { background: var(--red-bg);  border: 1.5px solid #d09098; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--red);   font-weight: 500; }
.trap-right { background: var(--green-bg); border: 1.5px solid #80b890; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--green); font-weight: 500; }
.trap-expl { padding: 10px 14px 12px; font-size: 0.86em; color: var(--text2); line-height: 1.6; border-top: 1px solid var(--border); background: var(--card); }
.trap-expl strong { color: var(--text); font-weight: 700; }

.exercise-controls { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 14px; box-shadow: var(--shadow-sm); }
.exercise-controls h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 14px; color: var(--text); }
.ctrl-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 7px; display: block; }
.ex-options { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.ex-opt-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.ex-opt-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
.row-btns { display: flex; gap: 7px; margin-bottom: 14px; flex-wrap: wrap; }
.pill-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.pill-btn:hover:not(.active) { background: var(--border); }
.pill-btn.active { background: var(--text); color: var(--bg); border-color: var(--text); }
.pill-btn.diff.active.A2 { background: var(--green); border-color: var(--green); color: #fff; }
.pill-btn.diff.active.B1 { background: var(--blue);  border-color: var(--blue);  color: #fff; }
.pill-btn.diff.active.B2 { background: var(--accent); border-color: var(--accent); color: #fff; }
.btn-generate { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: none; border-radius: 10px; padding: 13px; font-family: 'DM Sans', sans-serif; font-size: 0.92em; font-weight: 700; cursor: pointer; background: var(--accent); color: white; transition: all 0.18s; margin-top: 4px; }
.btn-generate:hover:not(:disabled) { filter: brightness(1.1); box-shadow: 0 4px 14px rgba(122,90,10,0.32); }
.btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
.spinner { display: none; animation: spin 0.8s linear infinite; }
.btn-generate.loading .spinner { display: inline; }
.btn-generate.loading .btn-icon { display: none; }
@keyframes spin { to { transform: rotate(360deg); } }
.progress-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; margin-bottom: 14px; display: none; }
.progress-wrap.visible { display: block; }
.progress-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.progress-label { font-size: 0.78em; color: var(--text3); font-weight: 600; }
.progress-frac  { font-size: 0.92em; font-weight: 700; color: var(--accent); }
.progress-track { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill  { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.35s ease; }
.progress-score { display: flex; gap: 14px; margin-top: 9px; font-size: 0.8em; flex-wrap: wrap; align-items: center; }
.score-item { display: flex; align-items: center; gap: 5px; font-weight: 500; color: var(--text2); }
.score-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.score-dot.g { background: var(--green); } .score-dot.r { background: var(--red); }
.btn-retry { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 13px; font-family: 'DM Sans', sans-serif; font-size: 0.78em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; margin-left: auto; }
.btn-retry:hover { background: var(--border); }
.final-score-bar { display: none; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 14px; }
.final-score-bar.visible { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.final-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
.final-label { font-size: 0.74em; color: var(--text3); }
.final-track { flex: 1; min-width: 80px; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.final-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
.final-msg { font-size: 0.84em; color: var(--text2); width: 100%; font-weight: 500; }
.exercise-area { display: none; } .exercise-area.visible { display: block; }
.exercise-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 12px; overflow: hidden; }
.exercise-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--bg); border-bottom: 1px solid var(--border); }
.ex-num { font-weight: 700; color: var(--accent); font-size: 0.88em; }
.ex-type-badge { font-size: 0.68em; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; background: var(--accent-light); color: var(--accent); border: 1px solid var(--accent-mid); border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge { font-size: 0.68em; font-weight: 700; border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge.A2 { background: var(--green-bg); color: var(--green); border: 1px solid #80b890; }
.ex-diff-badge.B1 { background: var(--blue-bg);  color: var(--blue);  border: 1px solid #90a8e0; }
.ex-diff-badge.B2 { background: var(--warn-bg);  color: var(--accent); border: 1px solid var(--accent-mid); }
.ex-status { margin-left: auto; }
.exercise-body { padding: 16px 18px; }
.exercise-prompt { line-height: 1.7; margin-bottom: 12px; color: var(--text); }
.exercise-prompt em { color: var(--accent); font-style: italic; font-weight: 600; }
.fill-input { border: none; border-bottom: 2px solid var(--accent-mid); background: var(--accent-light); padding: 2px 8px; border-radius: 4px 4px 0 0; font-family: 'DM Sans', sans-serif; font-size: 1em; color: var(--text); min-width: 140px; outline: none; transition: border-color 0.15s; }
.fill-input:focus { border-bottom-color: var(--accent); }
.fill-input.ok  { background: var(--green-bg); border-bottom-color: var(--green); }
.fill-input.err { background: var(--red-bg);   border-bottom-color: var(--red); }
.choices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; margin-bottom: 10px; }
.choice-btn { border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.88em; font-weight: 500; cursor: pointer; text-align: left; background: var(--bg); color: var(--text); transition: all 0.15s; }
.choice-btn:hover:not(:disabled) { border-color: var(--accent); background: var(--accent-light); }
.choice-btn.ok  { background: var(--green-bg); border-color: var(--green); color: var(--green); font-weight: 700; }
.choice-btn.err { background: var(--red-bg);   border-color: var(--red);   color: var(--red); }
.choice-btn:disabled { cursor: default; }
.transform-input { width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.9em; background: var(--bg); color: var(--text); outline: none; margin-bottom: 8px; transition: border-color 0.15s; }
.transform-input:focus { border-color: var(--accent); }
.transform-input.ok  { background: var(--green-bg); border-color: var(--green); }
.transform-input.err { background: var(--red-bg);   border-color: var(--red); }
.btn-check { border: 1.5px solid var(--accent); border-radius: 20px; padding: 7px 18px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 700; cursor: pointer; background: transparent; color: var(--accent); transition: all 0.15s; }
.btn-check:hover:not(:disabled) { background: var(--accent); color: white; }
.btn-check:disabled { opacity: 0.35; cursor: default; }
.ex-feedback { display: none; border-radius: var(--radius-sm); padding: 11px 14px; line-height: 1.55; margin-top: 10px; font-size: 0.9em; }
.ex-feedback.visible { display: block; }
.ex-feedback.ok  { background: var(--green-bg); border: 1.5px solid #80b890; color: #0e4818; }
.ex-feedback.err { background: var(--red-bg);   border: 1.5px solid #c08090; color: #700018; }
.fb-rule-link { display: inline-flex; align-items: center; gap: 4px; margin-top: 8px; font-size: 0.84em; font-weight: 700; color: var(--accent); cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }
.skeleton-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 12px; }
.skel { background: linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%); background-size: 200% 100%; animation: skel 1.4s infinite; border-radius: 4px; height: 13px; margin-bottom: 9px; }
@keyframes skel { to { background-position: -200% 0; } }
.state-msg { text-align: center; padding: 40px 20px; color: var(--text3); }
.state-icon { font-size: 2rem; margin-bottom: 10px; }
.state-msg p { max-width: 260px; margin: 0 auto; line-height: 1.6; font-weight: 500; }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <h1>Les Connecteurs Logiques</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill ca">Cause</div>
    <div class="stat-pill co">Conséquence</div>
    <div class="stat-pill op">Opposition</div>
    <div class="stat-pill cn">Concession</div>
    <div class="stat-pill cd">Condition</div>
    <div class="stat-pill il">Illustration</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:0.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>

<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>

<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-cause',this)">2. Cause</button>
    <button class="snav-btn"        onclick="showSection('s-consequence',this)">3. Conséquence</button>
    <button class="snav-btn"        onclick="showSection('s-opposition',this)">4. Opposition</button>
    <button class="snav-btn"        onclick="showSection('s-concession',this)">5. Concession</button>
    <button class="snav-btn"        onclick="showSection('s-condition',this)">6. Condition</button>
    <button class="snav-btn"        onclick="showSection('s-illustration',this)">7. Illustration</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">8. Trampas</button>
  </div>
</div>

<div class="main-layout">
<div class="panel active" id="panel-ref">

  <!-- 1. PANORAMA -->
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los <strong>conectores lógicos</strong> articulan el discurso expresando relaciones de sentido entre proposiciones: causa, consecuencia, oposición, concesión, condición e ilustración. Son imprescindibles para la producción escrita del DELF y están directamente evaluados en los criterios de coherencia y cohesión.
      </div>

      <div class="sec-label">Tabla de referencia rápida</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Relación</th><th>Conectores principales</th><th>Construcción</th></tr></thead>
        <tbody>
          <tr><td><strong class="hl-ca">Cause</strong></td><td class="hl-ca">parce que · car · puisque · étant donné que · vu que</td><td>+ indicatif</td></tr>
          <tr><td><strong class="hl-co">Conséquence</strong></td><td class="hl-co">donc · c'est pourquoi · ainsi · par conséquent · si bien que</td><td>divers</td></tr>
          <tr><td><strong class="hl-op">Opposition</strong></td><td class="hl-op">mais · alors que · tandis que · en revanche · au contraire</td><td>divers</td></tr>
          <tr><td><strong class="hl-cn">Concession</strong></td><td class="hl-cn">bien que · quoique · même si · pourtant · cependant · malgré</td><td>+ subjonctif / indicatif</td></tr>
          <tr><td><strong class="hl-cd">Condition</strong></td><td class="hl-cd">si · à condition que · pourvu que · à moins que · en cas de</td><td>divers</td></tr>
          <tr><td><strong class="hl-il">Illustration</strong></td><td class="hl-il">par exemple · notamment · comme · tel que · c'est le cas de</td><td>divers</td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Leyenda de registros</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px">
        <span class="reg oral">oral / familier</span>
        <span class="reg neutre">neutre</span>
        <span class="reg ecrit">écrit formel</span>
        <span class="reg soutenu">soutenu / littéraire</span>
      </div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Para el DELF escrito:</strong> el examinador valora la <em>variedad</em> de conectores. Repetir siempre <em>mais, donc, parce que</em> baja la nota de cohésion. El objetivo es dominar al menos 3 conectores por relación con registros distintos.</div>
      </div>
    </div></div>
  </div>

  <!-- 2. CAUSE -->
  <div class="sec-block" id="s-cause">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>causa</strong> responden a la pregunta <em>pourquoi ?</em> e introducen la razón o motivo de lo que se afirma. Todos rigen indicatif pero difieren en matiz y registro.
      </div>

      <div class="chip-bar">
        <button class="chip ca active" onclick="selectChip('cause',0)">parce que</button>
        <button class="chip ca"        onclick="selectChip('cause',1)">car</button>
        <button class="chip ca"        onclick="selectChip('cause',2)">puisque</button>
        <button class="chip ca"        onclick="selectChip('cause',3)">étant donné que · vu que</button>
        <button class="chip ca"        onclick="selectChip('cause',4)">grâce à · à cause de · en raison de</button>
      </div>
      <div id="cause-panels">

        <div class="chip-panel active" id="cause-p-0">
          <div class="def-box"><span class="reg neutre">neutre</span> — La causa más directa. Responde a la pregunta <em>pourquoi ?</em>. Puede ir al inicio o en el interior de la frase. Es el conector de causa más frecuente.</div>
          <div class="example-block ca"><div class="ex-fr">Je reste à la maison <span class="eca">parce qu'</span>il pleut.</div><div class="ex-es">Me quedo en casa porque llueve.</div></div>
          <div class="example-block ca"><div class="ex-fr">Elle a réussi <span class="eca">parce qu'</span>elle a beaucoup travaillé.</div><div class="ex-es">Tuvo éxito porque trabajó mucho.</div></div>
          <div class="example-block ca"><div class="ex-fr">Il est absent <span class="eca">parce qu'</span>il est malade.</div><div class="ex-es">Está ausente porque está enfermo.</div></div>
          <div class="example-block ca"><div class="ex-fr">Nous avons annulé le voyage <span class="eca">parce que</span> les billets étaient trop chers.</div><div class="ex-es">Cancelamos el viaje porque los billetes eran demasiado caros.</div></div>
          <div class="example-block ca"><div class="ex-fr">C'est <span class="eca">parce qu'</span>il ne mange pas assez qu'il se sent fatigué.</div><div class="ex-es">Es porque no come suficiente por lo que se siente cansado.</div><div class="ex-note">Estructura c'est parce que… que: énfasis en la causa</div></div>
        </div>

        <div class="chip-panel" id="cause-p-1">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — Une causa presentada como explicación o justificación. <strong>No puede ir al inicio de la frase</strong>. Se usa más en registros escritos.</div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Car no va al principio de frase.</strong> <em>Car il pleut, je reste.</em> ✗ — <em>Je reste, car il pleut.</em> ✓</div></div>
          <div class="example-block ca"><div class="ex-fr">Il faut partir tôt, <span class="eca">car</span> les embouteillages sont importants le matin.</div><div class="ex-es">Hay que salir pronto, porque los atascos son importantes por la mañana.</div></div>
          <div class="example-block ca"><div class="ex-fr">Ce projet est risqué, <span class="eca">car</span> les données sont insuffisantes.</div><div class="ex-es">Este proyecto es arriesgado, porque los datos son insuficientes.</div></div>
          <div class="example-block ca"><div class="ex-fr">Elle ne viendra pas, <span class="eca">car</span> elle a un rendez-vous médical.</div><div class="ex-es">No vendrá, porque tiene una cita médica.</div></div>
          <div class="example-block ca"><div class="ex-fr">Cette solution est préférable, <span class="eca">car</span> elle est moins coûteuse et plus efficace.</div><div class="ex-es">Esta solución es preferible, porque es menos costosa y más eficaz.</div></div>
        </div>

        <div class="chip-panel" id="cause-p-2">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — La causa es presentada como <strong>conocida, evidente o compartida</strong> por el interlocutor. Tiene un matiz de "dado que, ya que (tú lo sabes)". No introduce información nueva.</div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Puisque</em> presupone que la causa ya es conocida. No se usa para causa nueva: <em>Je sors puisqu'il fait beau</em> (implies: tú ya sabes que hace buen tiempo). Si la causa es nueva → <em>parce que</em>.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Puisque</span> tu refuses de coopérer, je me passerai de toi.</div><div class="ex-es">Ya que te niegas a cooperar, prescindiré de ti.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Puisque</span> tout le monde est d'accord, on peut commencer.</div><div class="ex-es">Ya que todo el mundo está de acuerdo, podemos empezar.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Puisque</span> c'est comme ça, je m'en vais.</div><div class="ex-es">Ya que es así, me voy. (causa evidente, implícita)</div></div>
          <div class="example-block ca"><div class="ex-fr">Aide-moi, <span class="eca">puisque</span> tu as le temps.</div><div class="ex-es">Ayúdame, ya que tienes tiempo. (el hablante presupone que lo sabe)</div></div>
        </div>

        <div class="chip-panel" id="cause-p-3">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — Presentan la causa como un <strong>dato objetivo, una constatación</strong>. Más formales que <em>parce que</em>. Equivalen a "dado que, en vista de que, habida cuenta de que".</div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Étant donné que</span> les résultats sont insuffisants, des mesures s'imposent.</div><div class="ex-es">Dado que los resultados son insuficientes, se imponen medidas.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Vu que</span> la situation s'est améliorée, nous pouvons reprendre.</div><div class="ex-es">En vista de que la situación ha mejorado, podemos retomar.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Étant donné</span> sa jeune expérience, il a bien géré la crise. <span class="ex-note">(+ nom → sans que)</span></div><div class="ex-es">Dado su poca experiencia, ha gestionado bien la crisis.</div></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Vu</span> les circonstances, nous avons décidé de reporter le projet.</div><div class="ex-es">En vista de las circunstancias, hemos decidido aplazar el proyecto.</div></div>
        </div>

        <div class="chip-panel" id="cause-p-4">
          <div class="def-box">Preposiciones de causa seguidas de un <strong>sustantivo</strong> (no de verbo conjugado).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Matiz</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-ca">grâce à</strong></td><td>causa positiva (gracias a)</td><td><em>Grâce à son aide</em>, j'ai réussi.</td></tr>
              <tr><td><strong class="hl-ca">à cause de</strong></td><td>causa negativa (a causa de)</td><td><em>À cause de la pluie</em>, on est restés.</td></tr>
              <tr><td><strong class="hl-ca">en raison de</strong></td><td>causa objetiva/formal</td><td><em>En raison des travaux</em>, la rue est fermée.</td></tr>
              <tr><td><strong class="hl-ca">faute de</strong></td><td>causa por falta de algo</td><td><em>Faute de temps</em>, elle n'a pas pu finir.</td></tr>
              <tr><td><strong class="hl-ca">par</strong></td><td>causa como motivación</td><td>Il l'a fait <em>par amour</em>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ca"><div class="ex-fr"><span class="eca">Grâce à</span> sa détermination, elle a obtenu le poste.</div><div class="ex-es">Gracias a su determinación, obtuvo el puesto.</div></div>
          <div class="example-block ca"><div class="ex-fr">Le match a été annulé <span class="eca">à cause de</span> la tempête.</div><div class="ex-es">El partido fue cancelado a causa de la tormenta.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>grâce à ≠ à cause de.</strong> <em>Grâce à</em> para causas positivas. <em>À cause de</em> para causas negativas. <em>Grâce à la pluie, le match a été annulé</em> ✗ → <em>à cause de la pluie</em> ✓</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 3. CONSÉQUENCE -->
  <div class="sec-block" id="s-consequence">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>consecuencia</strong> introducen el resultado, el efecto o la conclusión que se deriva de lo dicho anteriormente.
      </div>

      <div class="chip-bar">
        <button class="chip co active" onclick="selectChip('cons',0)">donc · alors</button>
        <button class="chip co"        onclick="selectChip('cons',1)">c'est pourquoi · c'est pour ça que</button>
        <button class="chip co"        onclick="selectChip('cons',2)">par conséquent · ainsi · de ce fait</button>
        <button class="chip co"        onclick="selectChip('cons',3)">si bien que · tellement… que · tant… que</button>
      </div>
      <div id="cons-panels">

        <div class="chip-panel active" id="cons-p-0">
          <div class="def-box"><span class="reg neutre">neutre</span> — <em>Donc</em> es el conector de consecuencia más frecuente. <em>Alors</em> es más oral y más inmediato.</div>
          <div class="example-block co"><div class="ex-fr">Il est malade, <span class="eco">donc</span> il ne viendra pas.</div><div class="ex-es">Está enfermo, así que no vendrá.</div></div>
          <div class="example-block co"><div class="ex-fr">Il pleut, <span class="eco">alors</span> je prends mon parapluie.</div><div class="ex-es">Llueve, así que cojo mi paraguas.</div></div>
          <div class="example-block co"><div class="ex-fr">Tu n'as pas travaillé, <span class="eco">donc</span> tu n'as pas réussi.</div><div class="ex-es">No has trabajado, así que no has tenido éxito.</div></div>
          <div class="example-block co"><div class="ex-fr">Le budget est limité, <span class="eco">donc</span> nous devons faire des choix.</div><div class="ex-es">El presupuesto es limitado, por tanto tenemos que hacer elecciones.</div></div>
          <div class="example-block co"><div class="ex-fr">Elle a tout préparé, <span class="eco">alors</span> on peut commencer.</div><div class="ex-es">Lo ha preparado todo, así que podemos empezar.</div></div>
        </div>

        <div class="chip-panel" id="cons-p-1">
          <div class="def-box"><span class="reg neutre">neutre</span> — Introducen la consecuencia al inicio de la frase siguiente. Más solemnes que <em>donc</em>, resaltan el enlace causal.</div>
          <div class="example-block co"><div class="ex-fr">Les résultats sont insuffisants. <span class="eco">C'est pourquoi</span> nous devons changer de stratégie.</div><div class="ex-es">Los resultados son insuficientes. Por eso debemos cambiar de estrategia.</div></div>
          <div class="example-block co"><div class="ex-fr">Elle a beaucoup investi dans sa formation. <span class="eco">C'est pourquoi</span> elle occupe aujourd'hui un poste important.</div><div class="ex-es">Invirtió mucho en su formación. Por eso hoy ocupa un puesto importante.</div></div>
          <div class="example-block co"><div class="ex-fr">Il y avait trop d'incertitudes. <span class="eco">C'est pour ça qu'</span>on a décidé d'attendre. <span class="reg oral">oral</span></div><div class="ex-es">Había demasiadas incertidumbres. Por eso decidimos esperar.</div></div>
          <div class="note-box"><strong>Posición:</strong> <em>C'est pourquoi</em> siempre al inicio de la nueva frase (no en medio). Introduce la consecuencia como una nueva oración.</div>
        </div>

        <div class="chip-panel" id="cons-p-2">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — Conectores formales de consecuencia, frecuentes en textos argumentativos, artículos, ensayos.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Matiz</th><th>Posición habitual</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-co">par conséquent</strong></td><td>consecuencia lógica, formal</td><td>inicio de oración o tras coma</td></tr>
              <tr><td><strong class="hl-co">ainsi</strong></td><td>consecuencia + resumen</td><td>inicio de oración (inversión: <em>ainsi peut-on</em>)</td></tr>
              <tr><td><strong class="hl-co">de ce fait</strong></td><td>"por este hecho" — objetiva</td><td>inicio o interior</td></tr>
              <tr><td><strong class="hl-co">dès lors</strong></td><td>"desde entonces / por tanto"</td><td>inicio o interior</td></tr>
              <tr><td><strong class="hl-co">en conséquence</strong></td><td>formal, administrativo</td><td>inicio</td></tr>
            </tbody>
          </table></div>
          <div class="example-block co"><div class="ex-fr">Le marché a chuté. <span class="eco">Par conséquent</span>, les investisseurs ont perdu confiance.</div><div class="ex-es">El mercado cayó. Por consiguiente, los inversores perdieron confianza.</div></div>
          <div class="example-block co"><div class="ex-fr">Les négociations ont échoué ; <span class="eco">de ce fait</span>, le projet a été suspendu.</div><div class="ex-es">Las negociaciones fracasaron; por este motivo, el proyecto fue suspendido.</div></div>
          <div class="example-block co"><div class="ex-fr"><span class="eco">Ainsi</span>, peut-on conclure que la situation s'améliore. <span class="reg soutenu">soutenu</span></div><div class="ex-es">Así pues, se puede concluir que la situación mejora.</div></div>
        </div>

        <div class="chip-panel" id="cons-p-3">
          <div class="def-box">Estructuras de consecuencia intensificada: introducen una consecuencia derivada de una <strong>intensidad o cantidad excesiva</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Estructura</th><th>Uso</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-co">si + adj/adv + que</strong></td><td>tan… que (adj/adv)</td><td>Il est <em>si fatigué</em> <strong>qu'</strong>il dort debout.</td></tr>
              <tr><td><strong class="hl-co">tellement + adj/adv + que</strong></td><td>tan… que (adj/adv)</td><td>Elle est <em>tellement gentille</em> <strong>que</strong> tout le monde l'aime.</td></tr>
              <tr><td><strong class="hl-co">tant de + nom + que</strong></td><td>tanto/a… que (nom)</td><td>Il y a <em>tant de travail</em> <strong>qu'</strong>on n'en voit pas le bout.</td></tr>
              <tr><td><strong class="hl-co">si bien que</strong></td><td>de modo que, tanto es así que</td><td>Il a tout révisé, <em>si bien qu'</em>il a réussi.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block co"><div class="ex-fr">Il fait <span class="eco">tellement</span> chaud <span class="eco">qu'</span>on ne peut pas travailler.</div><div class="ex-es">Hace tanto calor que no se puede trabajar.</div></div>
          <div class="example-block co"><div class="ex-fr">Elle a travaillé sans relâche, <span class="eco">si bien qu'</span>elle a obtenu une promotion.</div><div class="ex-es">Trabajó sin descanso, tanto es así que obtuvo un ascenso.</div></div>
          <div class="example-block co"><div class="ex-fr">Il y avait <span class="eco">tant de</span> bruit <span class="eco">qu'</span>on ne s'entendait plus parler.</div><div class="ex-es">Había tanto ruido que ya no nos oíamos hablar.</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 4. OPPOSITION -->
  <div class="sec-block" id="s-opposition">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>oposición</strong> contrastan dos realidades distintas sin que una invalide a la otra. Expresan un contraste, una diferencia o una realidad contraria a la esperada.
      </div>

      <div class="chip-bar">
        <button class="chip op active" onclick="selectChip('oppo',0)">mais · par contre · en revanche</button>
        <button class="chip op"        onclick="selectChip('oppo',1)">alors que · tandis que</button>
        <button class="chip op"        onclick="selectChip('oppo',2)">au contraire · à l'inverse · contrairement à</button>
        <button class="chip op"        onclick="selectChip('oppo',3)">d'un côté… de l'autre · d'une part… d'autre part</button>
      </div>
      <div id="oppo-panels">

        <div class="chip-panel active" id="oppo-p-0">
          <div class="def-box"><em>Mais</em> es el más básico. <em>En revanche</em> y <em>par contre</em> son intercambiables en la práctica aunque <em>en revanche</em> sea más formal.</div>
          <div class="example-block op"><div class="ex-fr">Il aime le sport, <span class="eop">mais</span> il déteste courir.</div><div class="ex-es">Le gusta el deporte, pero odia correr.</div></div>
          <div class="example-block op"><div class="ex-fr">Ce restaurant est cher ; <span class="eop">en revanche</span>, la qualité est excellente.</div><div class="ex-es">Este restaurante es caro; en cambio, la calidad es excelente.</div></div>
          <div class="example-block op"><div class="ex-fr">Il parle bien l'anglais ; <span class="eop">par contre</span>, son espagnol est limité.</div><div class="ex-es">Habla bien inglés; en cambio, su español es limitado.</div></div>
          <div class="example-block op"><div class="ex-fr">Elle est très timide à l'écrit, <span class="eop">mais</span> très à l'aise à l'oral.</div><div class="ex-es">Es muy tímida por escrito, pero muy cómoda oralmente.</div></div>
          <div class="note-box"><strong>Par contre vs. en revanche:</strong> en la práctica son equivalentes. Algunos puristas prefieren <em>en revanche</em> en el escrito formal, pero el DELF acepta los dos.</div>
        </div>

        <div class="chip-panel" id="oppo-p-1">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — Introducen dos realidades simultáneas pero contrastadas. Equivalen a "mientras que, en tanto que".</div>
          <div class="example-block op"><div class="ex-fr">Il préfère rester chez lui, <span class="eop">alors que</span> sa femme adore sortir.</div><div class="ex-es">Él prefiere quedarse en casa, mientras que su mujer adora salir.</div></div>
          <div class="example-block op"><div class="ex-fr"><span class="eop">Tandis que</span> les uns travaillent, les autres se reposent.</div><div class="ex-es">Mientras unos trabajan, otros descansan.</div></div>
          <div class="example-block op"><div class="ex-fr">Les ventes ont augmenté en Europe, <span class="eop">alors qu'</span>elles ont chuté en Asie.</div><div class="ex-es">Las ventas aumentaron en Europa, mientras que cayeron en Asia.</div></div>
          <div class="example-block op"><div class="ex-fr">Elle a réussi du premier coup, <span class="eop">alors que</span> lui a dû s'y reprendre à trois fois.</div><div class="ex-es">Ella lo consiguió al primer intento, mientras que él tuvo que intentarlo tres veces.</div></div>
          <div class="note-box"><strong>Alors que vs. tandis que:</strong> <em>Alors que</em> puede usarse con valor concesivo (a pesar de que): <em>Il est sorti alors qu'il était malade</em>. <em>Tandis que</em> es más puramente temporal/contrastivo.</div>
        </div>

        <div class="chip-panel" id="oppo-p-2">
          <div class="def-box">Refuerzan el contraste señalando que la realidad es <strong>opuesta</strong> a lo que se podría esperar o a lo anterior.</div>
          <div class="example-block op"><div class="ex-fr">Il pensait échouer ; <span class="eop">au contraire</span>, il a brillamment réussi.</div><div class="ex-es">Pensaba que iba a fracasar; al contrario, triunfó brillantemente.</div></div>
          <div class="example-block op"><div class="ex-fr"><span class="eop">À l'inverse</span> de son frère, elle est très sociable.</div><div class="ex-es">Al contrario que su hermano, ella es muy sociable.</div></div>
          <div class="example-block op"><div class="ex-fr"><span class="eop">Contrairement à</span> ce qu'on pourrait croire, la situation s'améliore.</div><div class="ex-es">Contrariamente a lo que se podría creer, la situación mejora.</div></div>
          <div class="example-block op"><div class="ex-fr">La réforme n'a pas aggravé la situation. <span class="eop">Au contraire</span>, elle a permis des progrès réels.</div><div class="ex-es">La reforma no ha agravado la situación. Al contrario, ha permitido avances reales.</div></div>
        </div>

        <div class="chip-panel" id="oppo-p-3">
          <div class="def-box">Estructuras en <strong>dos partes</strong> que presentan dos aspectos contrastados de una misma cuestión. Muy útiles en la producción escrita B2 para estructurar un argumento.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Primera parte</th><th>Segunda parte</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-op">d'un côté</strong></td><td><strong class="hl-op">de l'autre (côté)</strong></td></tr>
              <tr><td><strong class="hl-op">d'une part</strong></td><td><strong class="hl-op">d'autre part</strong></td></tr>
              <tr><td><strong class="hl-op">d'un côté</strong></td><td><strong class="hl-op">mais de l'autre</strong></td></tr>
            </tbody>
          </table></div>
          <div class="example-block op"><div class="ex-fr"><span class="eop">D'un côté</span>, le télétravail offre plus de flexibilité ; <span class="eop">de l'autre</span>, il peut accentuer l'isolement.</div><div class="ex-es">Por un lado, el teletrabajo ofrece más flexibilidad; por otro, puede acentuar el aislamiento.</div></div>
          <div class="example-block op"><div class="ex-fr"><span class="eop">D'une part</span>, les prix ont augmenté ; <span class="eop">d'autre part</span>, les salaires sont restés stables.</div><div class="ex-es">Por una parte, los precios han aumentado; por otra, los salarios han permanecido estables.</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 5. CONCESSION -->
  <div class="sec-block" id="s-concession">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>concesión</strong> admiten un hecho adverso pero afirman que no impide la realización de otro. Equivalen a "aunque, a pesar de, sin embargo". Son el punto más difícil porque algunos rigen <strong>subjonctif</strong>.
      </div>

      <div class="chip-bar">
        <button class="chip cn active" onclick="selectChip('conce',0)">bien que · quoique (+ subjonctif)</button>
        <button class="chip cn"        onclick="selectChip('conce',1)">même si (+ indicatif)</button>
        <button class="chip cn"        onclick="selectChip('conce',2)">pourtant · cependant · néanmoins</button>
        <button class="chip cn"        onclick="selectChip('conce',3)">malgré · en dépit de (+ nom)</button>
        <button class="chip cn"        onclick="selectChip('conce',4)">avoir beau + inf.</button>
      </div>
      <div id="conce-panels">

        <div class="chip-panel active" id="conce-p-0">
          <div class="def-box"><strong>Bien que + subjonctif.</strong> La concesión más formal. Puede ir al inicio o en el interior de la frase. <em>Quoique</em> es sinónimo pero más literario.</div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Bien qu'</span>il <em>soit</em> fatigué, il continue à travailler.</div><div class="ex-es">Aunque está cansado, sigue trabajando.</div></div>
          <div class="example-block cn"><div class="ex-fr">Elle est sortie <span class="ecn">bien qu'</span>il <em>fasse</em> froid.</div><div class="ex-es">Salió aunque hacía frío.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Bien que</span> la situation <em>soit</em> difficile, nous restons optimistes.</div><div class="ex-es">Aunque la situación es difícil, seguimos siendo optimistas.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Quoiqu'</span>il <em>ait</em> fait des erreurs, son bilan est positif.</div><div class="ex-es">Aunque haya cometido errores, su balance es positivo.</div></div>
          <div class="example-block cn"><div class="ex-fr">Elle a réussi <span class="ecn">bien qu'</span>elle n'<em>ait</em> pas eu de soutien.</div><div class="ex-es">Triunfó aunque no tuvo apoyo.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Bien que + subjonctif SIEMPRE.</strong> <em>Bien qu'il est fatigué</em> ✗ — <em>bien qu'il soit fatigué</em> ✓. Error muy frecuente en el DELF.</div></div>
        </div>

        <div class="chip-panel" id="conce-p-1">
          <div class="def-box"><strong>Même si + indicatif.</strong> La concesión hipotética. A diferencia de <em>bien que</em>, no requiere subjonctif. Según el tiempo, la hipótesis puede ser real o irreal.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Hipótesis</th><th>Même si (proposición)</th><th>Principal</th></tr></thead>
            <tbody>
              <tr><td>Real / probable</td><td>même si + <span class="hl-cd">présent</span></td><td><span class="hl">futur</span></td></tr>
              <tr><td>Irreal / improbable</td><td>même si + <span class="hl-cd">imparfait</span></td><td><span class="hl">conditionnel</span></td></tr>
              <tr><td>Irreal pasado</td><td>même si + <span class="hl-cd">PQP</span></td><td><span class="hl">cond. passé</span></td></tr>
            </tbody>
          </table></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Même si</span> tu <em>insistes</em>, je ne changerai pas d'avis.</div><div class="ex-es">Aunque insistas, no cambiaré de opinión.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Même si</span> j'<em>avais</em> le temps, je ne le ferais pas.</div><div class="ex-es">Aunque tuviera tiempo, no lo haría.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Même si</span> elle <em>avait voulu</em> partir, elle ne l'<em>aurait</em> pas pu.</div><div class="ex-es">Aunque hubiera querido irse, no habría podido.</div></div>
        </div>

        <div class="chip-panel" id="conce-p-2">
          <div class="def-box"><span class="reg ecrit">écrit formel</span> — Adverbios de concesión que no introducen subordinada sino que conectan dos oraciones independientes.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Registro</th><th>Posición</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-cn">pourtant</strong></td><td><span class="reg neutre">neutre</span></td><td>inicio o interior</td></tr>
              <tr><td><strong class="hl-cn">cependant</strong></td><td><span class="reg ecrit">formel</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-cn">néanmoins</strong></td><td><span class="reg soutenu">soutenu</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-cn">toutefois</strong></td><td><span class="reg ecrit">formel</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-cn">quand même</strong></td><td><span class="reg oral">oral</span></td><td>fin o interior</td></tr>
            </tbody>
          </table></div>
          <div class="example-block cn"><div class="ex-fr">La situation est grave ; <span class="ecn">pourtant</span>, il reste serein.</div><div class="ex-es">La situación es grave; sin embargo, él sigue tranquilo.</div></div>
          <div class="example-block cn"><div class="ex-fr">Les résultats sont positifs. <span class="ecn">Cependant</span>, des efforts supplémentaires sont nécessaires.</div><div class="ex-es">Los resultados son positivos. Sin embargo, son necesarios esfuerzos adicionales.</div></div>
          <div class="example-block cn"><div class="ex-fr">La tâche est difficile ; <span class="ecn">néanmoins</span>, nous y sommes parvenus.</div><div class="ex-es">La tarea es difícil; no obstante, lo hemos conseguido.</div></div>
          <div class="example-block cn"><div class="ex-fr">Il n'avait pas envie, mais il est venu <span class="ecn">quand même</span>.</div><div class="ex-es">No tenía ganas, pero vino de todas formas.</div></div>
        </div>

        <div class="chip-panel" id="conce-p-3">
          <div class="def-box">Preposiciones de concesión seguidas de un <strong>sustantivo o infinitif passé</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>+ que sigue</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-cn">malgré</strong></td><td>+ nom</td><td><em>Malgré la pluie</em>, ils sont sortis.</td></tr>
              <tr><td><strong class="hl-cn">en dépit de</strong></td><td>+ nom (formal)</td><td><em>En dépit des obstacles</em>, elle a réussi.</td></tr>
              <tr><td><strong class="hl-cn">malgré + inf. passé</strong></td><td>+ avoir/être + p.p.</td><td><em>Malgré avoir tout tenté</em>, il a échoué.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Malgré</span> ses efforts, elle n'a pas obtenu le poste.</div><div class="ex-es">A pesar de sus esfuerzos, no obtuvo el puesto.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">En dépit de</span> la crise, l'entreprise a maintenu ses effectifs.</div><div class="ex-es">A pesar de la crisis, la empresa mantuvo su plantilla.</div></div>
          <div class="example-block cn"><div class="ex-fr"><span class="ecn">Malgré</span> tout, la vie continue.</div><div class="ex-es">A pesar de todo, la vida continúa.</div></div>
        </div>

        <div class="chip-panel" id="conce-p-4">
          <div class="def-box"><strong>Avoir beau + infinitif</strong> expresa que un esfuerzo o una acción no logra el resultado esperado. Es una estructura específicamente francesa sin equivalente directo simple.</div>
          <div class="example-block cn"><div class="ex-fr">Il a <span class="ecn">beau</span> travailler dur, il n'avance pas.</div><div class="ex-es">Por más que trabaje duro, no avanza.</div></div>
          <div class="example-block cn"><div class="ex-fr">J'ai <span class="ecn">beau</span> chercher, je ne trouve pas mes clés.</div><div class="ex-es">Por más que busco, no encuentro mis llaves.</div></div>
          <div class="example-block cn"><div class="ex-fr">Elle avait <span class="ecn">beau</span> insister, personne ne l'écoutait.</div><div class="ex-es">Por más que insistía, nadie la escuchaba.</div></div>
          <div class="example-block cn"><div class="ex-fr">Vous avez <span class="ecn">beau</span> protester, la décision est prise.</div><div class="ex-es">Por más que protesten, la decisión está tomada.</div></div>
          <div class="example-block cn"><div class="ex-fr">Ils ont <span class="ecn">beau</span> être riches, ils ne sont pas heureux.</div><div class="ex-es">Por más que sean ricos, no son felices.</div></div>
          <div class="note-box"><strong>Conjugación:</strong> <em>avoir</em> se conjuga con el tiempo principal. <em>Beau</em> es invariable. El infinitivo que sigue es siempre presente.</div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 6. CONDITION -->
  <div class="sec-block" id="s-condition">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>condición</strong> expresan que una acción depende del cumplimiento de otra. <em>Si</em> es el más básico; los demás añaden matices de restricción, exclusión o eventualidad.
      </div>

      <div class="chip-bar">
        <button class="chip cd active" onclick="selectChip('cond',0)">si (sistema completo)</button>
        <button class="chip cd"        onclick="selectChip('cond',1)">à condition que · pourvu que (+ subj.)</button>
        <button class="chip cd"        onclick="selectChip('cond',2)">à moins que (+ subj.) · sauf si (+ indic.)</button>
        <button class="chip cd"        onclick="selectChip('cond',3)">en cas de · au cas où</button>
      </div>
      <div id="cond-panels">

        <div class="chip-panel active" id="cond-p-0">
          <div class="def-box">Ver bloque de futuros y condicional para el sistema completo. Resumen rápido:</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Tipo</th><th>Si + (proposición)</th><th>Principal</th></tr></thead>
            <tbody>
              <tr><td>Probable</td><td>si + <span class="hl-cd">présent</span></td><td><span class="hl">futur simple</span></td></tr>
              <tr><td>Improbable</td><td>si + <span class="hl-cd">imparfait</span></td><td><span class="hl">conditionnel présent</span></td></tr>
              <tr><td>Irreal pasado</td><td>si + <span class="hl-cd">PQP</span></td><td><span class="hl">conditionnel passé</span></td></tr>
            </tbody>
          </table></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">Si</span> tu <em>travailles</em> bien, tu <em>réussiras</em>.</div><div class="ex-es">Si trabajas bien, tendrás éxito.</div></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">Si</span> j'<em>avais</em> le temps, je <em>viendrais</em>.</div><div class="ex-es">Si tuviera tiempo, vendría.</div></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">Si</span> tu m'<em>avais</em> prévenu, j'<em>aurais</em> pu t'aider.</div><div class="ex-es">Si me hubieras avisado, podría haberte ayudado.</div></div>
        </div>

        <div class="chip-panel" id="cond-p-1">
          <div class="def-box"><strong>Condición positiva con subjonctif:</strong> la condición es <em>necesaria</em> para que ocurra lo principal.</div>
          <div class="example-block cd"><div class="ex-fr">Je viendrai <span class="ecd">à condition que</span> tu <em>sois</em> là.</div><div class="ex-es">Vendré con la condición de que estés allí.</div></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">Pourvu qu'</span>il <em>fasse</em> beau, on ira à la plage.</div><div class="ex-es">Con tal de que haga buen tiempo, iremos a la playa.</div></div>
          <div class="example-block cd"><div class="ex-fr">Ce projet réussira <span class="ecd">à condition que</span> chacun <em>s'implique</em> vraiment.</div><div class="ex-es">Este proyecto triunfará con la condición de que cada uno se implique de verdad.</div></div>
          <div class="example-block cd"><div class="ex-fr">Je t'aiderai <span class="ecd">pourvu que</span> tu <em>fasses</em> ta part du travail.</div><div class="ex-es">Te ayudaré con tal de que hagas tu parte del trabajo.</div></div>
          <div class="note-box"><strong>À condition de + infinitif</strong> (mismo sujeto): <em>Je viendrai à condition <strong>d'être</strong> prêt à temps.</em></div>
        </div>

        <div class="chip-panel" id="cond-p-2">
          <div class="def-box"><strong>Condición negativa / exclusión:</strong> la condición que <em>impediría</em> lo principal.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Construcción</th><th>Matiz</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-cd">à moins que</strong></td><td>+ subjonctif</td><td>a menos que (excepción)</td></tr>
              <tr><td><strong class="hl-cd">sauf si</strong></td><td>+ indicatif</td><td>salvo si (excepción oral/neutra)</td></tr>
              <tr><td><strong class="hl-cd">à moins de</strong></td><td>+ infinitif (mismo suj.)</td><td>a menos de (mismo sujeto)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block cd"><div class="ex-fr">Je pars, <span class="ecd">à moins qu'</span>il ne <em>pleuve</em>.</div><div class="ex-es">Me voy, a menos que llueva.</div><div class="ex-note">ne explétif optional pero frecuente con à moins que</div></div>
          <div class="example-block cd"><div class="ex-fr">Nous partirons comme prévu, <span class="ecd">sauf si</span> la météo empire.</div><div class="ex-es">Saldremos según lo previsto, salvo si el tiempo empeora.</div></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">À moins de</span> travailler jour et nuit, tu ne finiras pas à temps.</div><div class="ex-es">A menos de trabajar día y noche, no terminarás a tiempo.</div></div>
        </div>

        <div class="chip-panel" id="cond-p-3">
          <div class="def-box">Condición expresada con preposición (sustantivo) o con indicatif/conditionnel.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Sigue de</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-cd">en cas de</strong></td><td>+ nom</td><td><em>En cas de problème</em>, appelez-nous.</td></tr>
              <tr><td><strong class="hl-cd">en cas où</strong></td><td>+ conditionnel</td><td><em>En cas où il viendrait</em>, prévenez-moi.</td></tr>
              <tr><td><strong class="hl-cd">au cas où</strong></td><td>+ conditionnel</td><td><em>Au cas où tu aurais besoin</em>, je suis là.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block cd"><div class="ex-fr"><span class="ecd">En cas de</span> panne, appelez le service d'urgence.</div><div class="ex-es">En caso de avería, llame al servicio de urgencias.</div></div>
          <div class="example-block cd"><div class="ex-fr">Prends ton imperméable <span class="ecd">au cas où</span> il <em>pleuvrait</em>.</div><div class="ex-es">Llévate el impermeable por si acaso llueve.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Au cas où</strong> rige siempre <strong>conditionnel</strong>: <em>au cas où il viendrait</em> ✓ — <em>au cas où il vient</em> ✗.</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 7. ILLUSTRATION -->
  <div class="sec-block" id="s-illustration">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los conectores de <strong>ilustración, adición y estructuración</strong> apoyan un argumento con ejemplos, añaden información, reformulan o concluyen. Son muy frecuentes en producción escrita B1–B2.
      </div>

      <div class="chip-bar">
        <button class="chip il active" onclick="selectChip('illu',0)">Exemple (par exemple, notamment…)</button>
        <button class="chip il"        onclick="selectChip('illu',1)">Addition (de plus, en outre, par ailleurs…)</button>
        <button class="chip il"        onclick="selectChip('illu',2)">Reformulation (c'est-à-dire, autrement dit…)</button>
        <button class="chip il"        onclick="selectChip('illu',3)">Conclusion (en conclusion, en résumé, bref…)</button>
      </div>
      <div id="illu-panels">

        <div class="chip-panel active" id="illu-p-0">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Registro</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-il">par exemple</strong></td><td><span class="reg neutre">neutre</span></td><td>Certains sports, <em>par exemple</em> la natation, sont bénéfiques.</td></tr>
              <tr><td><strong class="hl-il">notamment</strong></td><td><span class="reg ecrit">formel</span></td><td>Les jeunes, <em>notamment</em> les 18-25 ans, sont touchés.</td></tr>
              <tr><td><strong class="hl-il">comme</strong></td><td><span class="reg neutre">neutre</span></td><td>Des pays <em>comme</em> la France ou l'Espagne sont concernés.</td></tr>
              <tr><td><strong class="hl-il">tel que / tels que</strong></td><td><span class="reg ecrit">formel</span></td><td>Des solutions <em>telles que</em> le recyclage existent.</td></tr>
              <tr><td><strong class="hl-il">c'est le cas de</strong></td><td><span class="reg neutre">neutre</span></td><td><em>C'est le cas de</em> nombreuses entreprises innovantes.</td></tr>
              <tr><td><strong class="hl-il">ainsi</strong></td><td><span class="reg ecrit">formel</span></td><td><em>Ainsi</em>, Paris a réduit ses émissions de 20%.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block il"><div class="ex-fr">Certains aliments, <span class="eil">par exemple</span> les légumineuses, sont très riches en protéines.</div><div class="ex-es">Ciertos alimentos, por ejemplo las legumbres, son muy ricos en proteínas.</div></div>
          <div class="example-block il"><div class="ex-fr">Les nouvelles technologies, <span class="eil">notamment</span> l'intelligence artificielle, transforment le marché du travail.</div><div class="ex-es">Las nuevas tecnologías, especialmente la inteligencia artificial, transforman el mercado laboral.</div></div>
        </div>

        <div class="chip-panel" id="illu-p-1">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Registro</th><th>Posición</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-il">de plus</strong></td><td><span class="reg neutre">neutre</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-il">en outre</strong></td><td><span class="reg ecrit">formel</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-il">par ailleurs</strong></td><td><span class="reg ecrit">formel</span></td><td>inicio de oración</td></tr>
              <tr><td><strong class="hl-il">également / aussi</strong></td><td><span class="reg neutre">neutre</span></td><td>interior (adj. al verbo)</td></tr>
              <tr><td><strong class="hl-il">qui plus est</strong></td><td><span class="reg soutenu">soutenu</span></td><td>inicio (añade énfasis)</td></tr>
              <tr><td><strong class="hl-il">sans oublier</strong></td><td><span class="reg neutre">neutre</span></td><td>inicio o interior</td></tr>
              <tr><td><strong class="hl-il">voire</strong></td><td><span class="reg ecrit">formel</span></td><td>entre dos elementos (incluso)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block il"><div class="ex-fr">Le projet est innovant. <span class="eil">De plus</span>, il est économiquement viable.</div><div class="ex-es">El proyecto es innovador. Además, es económicamente viable.</div></div>
          <div class="example-block il"><div class="ex-fr">Il est compétent. <span class="eil">Par ailleurs</span>, il a une excellente capacité de communication.</div><div class="ex-es">Es competente. Por otro lado, tiene una excelente capacidad de comunicación.</div></div>
          <div class="example-block il"><div class="ex-fr">Cette mesure est inefficace, <span class="eil">voire</span> contre-productive.</div><div class="ex-es">Esta medida es ineficaz, cuando no contraproducente.</div></div>
        </div>

        <div class="chip-panel" id="illu-p-2">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Función</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-il">c'est-à-dire</strong></td><td>reformulación/explicación</td><td>La mesure s'applique à tous, <em>c'est-à-dire</em> sans exception.</td></tr>
              <tr><td><strong class="hl-il">autrement dit</strong></td><td>reformulación equivalente</td><td><em>Autrement dit</em>, le projet est abandonné.</td></tr>
              <tr><td><strong class="hl-il">en d'autres termes</strong></td><td>reformulación formal</td><td><em>En d'autres termes</em>, c'est une révolution.</td></tr>
              <tr><td><strong class="hl-il">à savoir</strong></td><td>especificación de lista</td><td>Trois critères, <em>à savoir</em> la qualité, le prix et le délai.</td></tr>
              <tr><td><strong class="hl-il">soit</strong></td><td>reformulación matemática/lógica</td><td>La moitié, <em>soit</em> 50%, est concernée.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block il"><div class="ex-fr">Il faut revoir le budget, <span class="eil">c'est-à-dire</span> réduire les dépenses non essentielles.</div><div class="ex-es">Hay que revisar el presupuesto, es decir, reducir los gastos no esenciales.</div></div>
          <div class="example-block il"><div class="ex-fr">Le projet n'est pas rentable. <span class="eil">Autrement dit</span>, nous allons perdre de l'argent.</div><div class="ex-es">El proyecto no es rentable. En otras palabras, vamos a perder dinero.</div></div>
        </div>

        <div class="chip-panel" id="illu-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Conector</th><th>Registro</th><th>Uso</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-il">en conclusion</strong></td><td><span class="reg ecrit">formel</span></td><td>párrafo de conclusión</td></tr>
              <tr><td><strong class="hl-il">en résumé</strong></td><td><span class="reg neutre">neutre</span></td><td>recapitulación</td></tr>
              <tr><td><strong class="hl-il">pour conclure</strong></td><td><span class="reg ecrit">formel</span></td><td>párrafo final</td></tr>
              <tr><td><strong class="hl-il">en somme</strong></td><td><span class="reg ecrit">formel</span></td><td>síntesis</td></tr>
              <tr><td><strong class="hl-il">bref</strong></td><td><span class="reg oral">oral</span></td><td>resumen corto oral</td></tr>
              <tr><td><strong class="hl-il">finalement</strong></td><td><span class="reg neutre">neutre</span></td><td>última consideración</td></tr>
              <tr><td><strong class="hl-il">en définitive</strong></td><td><span class="reg soutenu">soutenu</span></td><td>conclusión definitiva</td></tr>
            </tbody>
          </table></div>
          <div class="example-block il"><div class="ex-fr"><span class="eil">En conclusion</span>, le développement durable est une nécessité, non un choix.</div><div class="ex-es">En conclusión, el desarrollo sostenible es una necesidad, no una opción.</div></div>
          <div class="example-block il"><div class="ex-fr"><span class="eil">En résumé</span>, trois facteurs expliquent ce succès : la qualité, le prix et le service.</div><div class="ex-es">En resumen, tres factores explican este éxito: la calidad, el precio y el servicio.</div></div>
          <div class="example-block il"><div class="ex-fr"><span class="eil">Bref</span>, il faut agir vite. <span class="reg oral">oral</span></div><div class="ex-es">En fin, hay que actuar rápido.</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <!-- 8. TRAMPAS -->
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">Los 8 errores más frecuentes con los conectores lógicos en el DELF B1–B2.</div>
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>

</div><!-- /panel-ref -->
</div><!-- /main-layout -->

<script>
/* DATA */
const TRAPS = [
  {name:"Car no puede ir al principio de frase",
   wrong:"Car il pleut, je reste à la maison.",
   right:"Je reste à la maison, car il pleut.",
   expl:"<strong>Car</strong> es una conjunción de coordination que nunca puede iniciar una frase independiente. Siempre introduce la justificación en posición media o final. Para iniciar con la causa → <em>parce que, puisque, étant donné que</em>."},
  {name:"Bien que + indicatif (error gravísimo)",
   wrong:"Bien qu'il est fatigué, il continue.",
   right:"Bien qu'il soit fatigué, il continue.",
   expl:"<strong>Bien que</strong> (y quoique) rigen siempre <strong>subjonctif</strong>. Es el error más frecuente con la concesión en el DELF. Memorizar: <em>bien que</em> → subjonctif. La confusión viene de que <em>même si</em> (concesión hipotética) rige indicatif."},
  {name:"Même si + subjonctif (error inverso)",
   wrong:"Même qu'il soit malade, il travaille.",
   right:"Même s'il est malade, il travaille. / Même s'il était malade, il travaillerait.",
   expl:"<strong>Même si</strong> rige siempre <strong>indicatif</strong> (o conditionnel en la principal), nunca subjonctif. Es el inverso del error anterior: <em>même si</em> → indicatif. <em>Bien que</em> → subjonctif. Ambas expresan concesión pero con modos distintos."},
  {name:"Grâce à vs. à cause de: connotación positiva/negativa",
   wrong:"Grâce à la tempête, le match a été annulé. / À cause de lui, j'ai réussi.",
   right:"À cause de la tempête, le match a été annulé. / Grâce à lui, j'ai réussi.",
   expl:"<strong>Grâce à</strong> introduce una causa con resultado <em>positivo</em>. <strong>À cause de</strong> introduce una causa con resultado <em>negativo o neutro</em>. Mezclarlos es un error semántico grave: anunciar una tormenta con <em>grâce à</em> o un éxito con <em>à cause de</em> da un sentido irónico o incorrecto."},
  {name:"Puisque: causa conocida vs. causa nueva",
   wrong:"Je reste à la maison puisqu'il pleut. (si el interlocutor no sabe que llueve)",
   right:"Je reste à la maison parce qu'il pleut. (causa nueva) / Puisqu'il pleut, reste donc à la maison ! (causa conocida, reproche)",
   expl:"<strong>Puisque</strong> presupone que la causa ya es <em>conocida por el interlocutor</em>. Si la causa es información nueva, se usa <em>parce que</em>. El error es usar <em>puisque</em> para justificarse ante alguien que no sabe la razón."},
  {name:"Au cas où + indicatif (en lugar de conditionnel)",
   wrong:"Prends ton parapluie au cas où il pleut.",
   right:"Prends ton parapluie au cas où il pleuvrait.",
   expl:"<strong>Au cas où</strong> rige siempre <strong>conditionnel</strong>, nunca indicatif: <em>au cas où il <strong>pleuvrait</strong></em> ✓. Es una regla absoluta. Lo mismo para <em>en cas où</em> (más raro)."},
  {name:"Avoir beau: confusión en la conjugación",
   wrong:"Il a beau à travailler, il n'avance pas. / Il est beau travailler.",
   right:"Il a beau travailler, il n'avance pas.",
   expl:"Estructura: sujeto + <strong>avoir</strong> (conjugado) + <strong>beau</strong> (invariable) + <strong>infinitif</strong>. Sin preposición <em>à</em> entre <em>beau</em> y el infinitivo. Sin <em>être</em>. <em>Avoir</em> se conjuga en el tiempo de la oración principal."},
  {name:"Par contre vs. en revanche: uso en escrito formal",
   wrong:"Par contre (en un ensayo académico como único conector de contraste)",
   right:"En revanche (preferible en registro formal escrito)",
   expl:"En registro oral y neutro, <em>par contre</em> y <em>en revanche</em> son equivalentes. En el escrito formal del DELF B2, se prefiere <em>en revanche</em>. No es un error grave usar <em>par contre</em> en el escrito, pero demostrar conocimiento de <em>en revanche</em> mejora la nota de registro."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

/* CHIP SELECT */
function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c, i) => c.classList.toggle("active", i === idx));
    }
  });
  const el = document.getElementById(ns + "-panels");
  if (el) el.querySelectorAll(":scope > .chip-panel").forEach((p, i) => p.classList.toggle("active", i === idx));
}

/* NAV */
function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

/* EXERCISE STATE */
let exType = "fill", exDiff = "B1", exQty = 5, exFoco = "mix";
let exTotal = 0, exAnswered = 0, exCorrect = 0, exWrong = 0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));

function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active", "A2", "B1", "B2");
    if (b.textContent.trim() === d) b.classList.add("active", d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim()) === q));
}

/* GENERATE */
const FOCO_DESC = {
  mix:         "todos los tipos de conectores lógicos: causa (parce que/car/puisque/grâce à/à cause de), consecuencia (donc/c'est pourquoi/par conséquent/si bien que), oposición (mais/en revanche/alors que/au contraire), concesión (bien que+subj./même si+indic./pourtant/malgré), condición (si/à condition que/au cas où), ilustración/adición (par exemple/de plus/en outre/notamment)",
  cause:       "conectores de causa con matices precisos: parce que (causa directa), car (justificación, no inicio de frase), puisque (causa conocida), étant donné que/vu que (causa objetiva formal), grâce à (causa positiva), à cause de (causa negativa), en raison de (formal)",
  consequence: "conectores de conséquence: donc, alors, c'est pourquoi, par conséquent, ainsi, de ce fait, si bien que, tellement...que, tant de...que; el alumno debe elegir según el registro y la estructura requerida",
  opposition:  "conectores de oposición: mais (básico), en revanche (formel), par contre (neutre), alors que (simultáneo), tandis que (simultáneo formal), au contraire, à l'inverse, contrairement à, d'un côté...de l'autre, d'une part...d'autre part",
  concession:  "conectores de concesión con modo verbal correcto: bien que+subjonctif, même si+indicatif, pourtant/cependant/néanmoins (adverbios, sin verbo subordinado), malgré+nom, avoir beau+infinitif; el alumno debe conjugar el verbo correctamente",
  register:    "distinción de registro: elegir entre el conector formal (car, par conséquent, en outre, en revanche, cependant) y el coloquial (parce que, donc, aussi, mais, pourtant) según el contexto (carta formal vs. conversation, essai vs. email informel)",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe el conector correcto o, si hay verbo entre paréntesis, la forma verbal adecuada según el conector (bien que → subj., même si → indic., etc.)",
  choice:    "elección múltiple: 4 conectores plausibles (misma categoría lógica o distintas), solo uno correcto según el contexto, el registro y la construcción gramatical requerida",
  transform: "reformulación: reformular la frase usando el conector indicado sin cambiar el sentido; puede implicar cambio de modo verbal (parce que → bien que: indicatif → subjonctif)",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS = {
  "s-intro":       "Panorama",
  "s-cause":       "Cause",
  "s-consequence": "Conséquence",
  "s-opposition":  "Opposition",
  "s-concession":  "Concession",
  "s-condition":   "Condition",
  "s-illustration":"Illustration / Adición",
  "s-trampas":     "Trampas"
};

function renderExercises(exs) {
  const area = document.getElementById("exercise-area");
  const labels = { fill: "Completar", choice: "Elección múltiple", transform: "Reformulación" };
  area.innerHTML = exs.map((ex, i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref || ""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i + 1}</span>
        <span class="ex-type-badge">${labels[ex.type] || ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex, i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex, i) => {
    const chk = document.getElementById("chk-" + i);
    if (chk) chk.addEventListener("click", () => checkAnswer(ex, i));
    const inp = document.getElementById("inp-" + i);
    if (inp) inp.addEventListener("keydown", e => { if (e.key === "Enter") checkAnswer(ex, i); });
  });
}

function buildBody(ex, i) {
  if (ex.type === "fill")
    return `<div class="exercise-prompt">${ex.prompt_parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint || "…"}" autocomplete="off" spellcheck="false">${ex.prompt_parts[1] || ""}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  if (ex.type === "choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o, j) => `<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if (ex.type === "transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase reformulada completa…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex, i) {
  const inp = document.getElementById("inp-" + i);
  if (!inp || inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok ? "ok" : "err"); inp.disabled = true;
  const chk = document.getElementById("chk-" + i); if (chk) chk.disabled = true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0 || c0.disabled) return;
  for (let j = 0; j < 4; j++) {
    const b = document.getElementById(`ch-${idx}-${j}`);
    if (!b) continue; b.disabled = true;
    if (j === correct) b.classList.add("ok"); else if (j === chosen) b.classList.add("err");
  }
  const card = document.getElementById("ex-card-" + idx);
  showFeedback(idx, chosen === correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen === correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById("ex-st-" + i).textContent = ok ? "✅" : "❌";
  const fb = document.getElementById("ex-fb-" + i);
  fb.className = "ex-feedback visible " + (ok ? "ok" : "err");
  const link = RULE_LABELS[ruleRef]
    ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : "";
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans ? ` — Respuesta: <strong>${ans}</strong>` : ""}`;
  if (expl) html += `<br><span style="font-size:0.88em;opacity:0.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML = html;
}

function goToRule(ref) {
  switchMode("ref", document.querySelector(".mode-btn"));
  setTimeout(() => {
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({ behavior: "smooth", block: "start" });
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if (ok) exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal > 0 ? (exAnswered / exTotal) * 100 : 0;
  document.getElementById("progress-frac").textContent = `${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width = pct + "%";
  document.getElementById("score-correct").textContent = `${exCorrect} correcta${exCorrect !== 1 ? "s" : ""}`;
  document.getElementById("score-wrong").textContent = `${exWrong} error${exWrong !== 1 ? "es" : ""}`;
  if (exAnswered >= exTotal && exTotal > 0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect / exTotal) * 100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent = `${exCorrect} / ${exTotal}`;
  const fill = document.getElementById("final-fill");
  fill.style.width = pct + "%";
  fill.style.background = pct >= 80 ? "var(--green)" : pct >= 50 ? "var(--accent)" : "var(--red)";
  const msgs = {
    100: "Parfait ! Dominas los conectores lógicos. 🎉",
    80:  "Très bien ! Repasa los errores marcados.",
    50:  "Bien, pero refuerza los bloques señalados.",
    0:   "Vuelve a Referencia antes de repetir."
  };
  document.getElementById("final-msg").textContent = msgs[pct === 100 ? 100 : pct >= 80 ? 80 : pct >= 50 ? 50 : 0];
  document.getElementById("score-pill").style.display = "";
  document.getElementById("score-pill-val").textContent = `${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById("exercise-area").innerHTML = `<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display = "none";
  exAnswered = 0; exCorrect = 0; exWrong = 0;
}

function esc(s) { return (s || "").replace(/"/g, "&quot;").replace(/</g, "&lt;"); }

renderTraps();
</script>
</body>
</html>
