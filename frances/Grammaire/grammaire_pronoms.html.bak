<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Pronoms Personnels</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ede9df;
  --card: #faf7f1;
  --border: #c4bead;
  --text: #1a1814;
  --text2: #44413a;
  --text3: #706c64;
  --accent: #7a5a0a;
  --accent-light: #f0e0c0;
  --accent-mid: #b89050;
  --warn-bg: #fdf0cc;
  --shadow: 0 2px 14px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.08);
  --radius: 14px;
  --radius-sm: 8px;
  --green: #1a6028;
  --green-bg: #e4f2e8;
  --red: #a81e2e;
  --red-bg: #fce6e8;
  --blue: #163494;
  --blue-bg: #e6ebf8;
  --purple: #6a1a8a;
  --purple-bg: #f2e6f8;
  --cod-color: #163494;
  --cod-bg: #e6ebf8;
  --coi-color: #1a6028;
  --coi-bg: #e4f2e8;
  --en-color: #8b1a4a;
  --en-bg: #f8e6ee;
  --y-color: #6a1a8a;
  --y-bg: #f2e6f8;
  --fs: 15px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; font-size: var(--fs); }

.site-header { background: var(--card); border-bottom: 2px solid var(--border); padding: 20px 20px 14px; }
.header-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 3px; flex-wrap: wrap; }
.site-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.2rem,5vw,1.9rem); font-weight: 700; color: var(--text); }
.header-tag { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); background: var(--accent-light); border: 1px solid var(--accent-mid); border-radius: 20px; padding: 3px 10px; }
.subtitle { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; }
.stats-row { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; }
.stat-pill { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 4px 11px; font-size: 0.76rem; font-weight: 500; color: var(--text2); }
.stat-pill.cod { border-color: var(--cod-color); color: var(--cod-color); background: var(--cod-bg); }
.stat-pill.coi { border-color: var(--coi-color); color: var(--coi-color); background: var(--coi-bg); }
.stat-pill.en  { border-color: var(--en-color);  color: var(--en-color);  background: var(--en-bg); }
.stat-pill.y   { border-color: var(--y-color);   color: var(--y-color);   background: var(--y-bg); }
.fs-wrap { display: flex; align-items: center; gap: 7px; margin-left: auto; }
.fs-slider { width: 76px; accent-color: var(--accent); cursor: pointer; }
.fs-sz { color: var(--text3); font-weight: 700; }

.mode-toggle { display: flex; border-bottom: 2px solid var(--border); background: var(--card); }
.mode-btn { flex: 1; padding: 12px 8px; font-family: 'DM Sans', sans-serif; font-size: 0.84rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; margin-bottom: -2px; }
.mode-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.section-nav { position: sticky; top: 0; z-index: 200; background: var(--card); border-bottom: 2px solid var(--border); box-shadow: var(--shadow-sm); }
.section-nav-inner { display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.section-nav-inner::-webkit-scrollbar { display: none; }
.snav-btn { flex-shrink: 0; padding: 11px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.snav-btn:hover { color: var(--text2); }
.snav-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

.main-layout { max-width: 860px; margin: 0 auto; padding: 16px 16px 40px; }
.panel { display: none; } .panel.active { display: block; }
.sec-block { display: none; } .sec-block.active { display: block; }
.gram-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 14px; overflow: hidden; }
.gram-card-body { padding: 18px; }

.def-box { background: var(--warn-bg); border-left: 4px solid var(--accent); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 12px 15px; margin-bottom: 14px; line-height: 1.65; color: var(--text); }
.def-box strong { color: var(--accent); font-weight: 700; }
.warn-box { background: #fff4e0; border: 1px solid #c8900a; border-radius: var(--radius-sm); padding: 10px 13px; margin: 10px 0; font-size: 0.9em; display: flex; gap: 8px; align-items: flex-start; }
.warn-icon { flex-shrink: 0; margin-top: 1px; }
.warn-text { color: var(--text2); line-height: 1.55; }
.warn-text strong { color: #7a4400; font-weight: 700; }
.note-box { background: var(--purple-bg); border-left: 4px solid var(--purple); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.note-box strong { color: var(--purple); font-weight: 700; }
.green-box { background: var(--green-bg); border-left: 4px solid var(--green); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.green-box strong { color: var(--green); font-weight: 700; }

.example-block { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 8px 0; }
.example-block.cod { background: var(--cod-bg); border-left: 4px solid var(--cod-color); }
.example-block.coi { background: var(--coi-bg); border-left: 4px solid var(--coi-color); }
.example-block.en  { background: var(--en-bg);  border-left: 4px solid var(--en-color); }
.example-block.yy  { background: var(--y-bg);   border-left: 4px solid var(--y-color); }
.example-block.mix { background: #f0f0f8;        border-left: 4px solid #606080; }
.example-block.neu { background: var(--blue-bg); border-left: 4px solid var(--blue); }
.ex-fr { font-weight: 600; margin-bottom: 3px; color: var(--text); }
.ecod { color: var(--cod-color); font-weight: 700; }
.ecoi { color: var(--coi-color); font-weight: 700; }
.een  { color: var(--en-color);  font-weight: 700; }
.ey   { color: var(--y-color);   font-weight: 700; }
.ex-fr em { color: var(--blue);  font-style: normal; font-weight: 700; }
.ex-es { color: var(--text2); font-size: 0.88em; font-style: italic; }
.ex-note { font-size: 0.78em; color: var(--text3); margin-top: 3px; font-weight: 500; }

.table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 14px; border-radius: var(--radius-sm); border: 1px solid var(--border); }
.gram-table { width: 100%; border-collapse: collapse; min-width: 280px; }
.gram-table th { background: var(--bg); border-bottom: 2px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; text-align: left; font-size: 0.72em; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text3); }
.gram-table td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; vertical-align: top; color: var(--text); }
.gram-table tr:last-child td { border-bottom: none; }
.gram-table tr:nth-child(even) td { background: #f4f0e6; }
.gram-table td:last-child, .gram-table th:last-child { border-right: none; }
.hl-cod { color: var(--cod-color); font-weight: 700; }
.hl-coi { color: var(--coi-color); font-weight: 700; }
.hl-en  { color: var(--en-color);  font-weight: 700; }
.hl-y   { color: var(--y-color);   font-weight: 700; }
.hl     { color: var(--accent);    font-weight: 700; }
.dim    { color: var(--text3); }
.ok-cell  { color: var(--green); font-weight: 700; }
.err-cell { color: var(--red);   font-weight: 600; font-style: italic; }

/* Order diagram */
.order-diagram { display: flex; align-items: center; gap: 5px; flex-wrap: wrap; background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 14px 16px; margin: 12px 0; }
.od-slot { border-radius: 6px; padding: 6px 12px; font-weight: 700; font-size: 0.84em; text-align: center; border: 1.5px solid; white-space: nowrap; }
.od-slot.subj  { background: #f5f0e8; border-color: var(--border); color: var(--text2); }
.od-slot.ne    { background: #fff4e0; border-color: #c8900a; color: #7a4400; }
.od-slot.cod   { background: var(--cod-bg); border-color: var(--cod-color); color: var(--cod-color); }
.od-slot.coi   { background: var(--coi-bg); border-color: var(--coi-color); color: var(--coi-color); }
.od-slot.en    { background: var(--en-bg);  border-color: var(--en-color);  color: var(--en-color); }
.od-slot.y     { background: var(--y-bg);   border-color: var(--y-color);   color: var(--y-color); }
.od-slot.vrb   { background: var(--warn-bg); border-color: var(--accent); color: var(--accent); }
.od-slot.pas   { background: #fff4e0; border-color: #c8900a; color: #7a4400; }
.od-arrow { color: var(--text3); font-size: 1em; font-weight: 700; flex-shrink: 0; }
.od-label { font-size: 0.7em; color: var(--text3); width: 100%; margin-top: 4px; }

.chip-bar { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.chip { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; white-space: nowrap; }
.chip:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); }
.chip.active    { background: var(--accent);    color: #fff; border-color: var(--accent); }
.chip.cod.active { background: var(--cod-color); border-color: var(--cod-color); }
.chip.coi.active { background: var(--coi-color); border-color: var(--coi-color); }
.chip.en.active  { background: var(--en-color);  border-color: var(--en-color); }
.chip.yy.active  { background: var(--y-color);   border-color: var(--y-color); }
.chip-panel { display: none; } .chip-panel.active { display: block; }

.sec-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); margin: 14px 0 7px; }

.trap-cards { display: flex; flex-direction: column; gap: 10px; }
.trap-card { border: 1.5px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
.trap-card-header { padding: 11px 14px; background: var(--bg); }
.trap-name { font-weight: 700; font-size: 0.9em; color: var(--text); margin-bottom: 7px; }
.trap-vs { display: flex; gap: 8px; flex-wrap: wrap; }
.trap-wrong { background: var(--red-bg);   border: 1.5px solid #d09098; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--red);   font-weight: 500; }
.trap-right { background: var(--green-bg); border: 1.5px solid #80b890; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--green); font-weight: 500; }
.trap-expl { padding: 10px 14px 12px; font-size: 0.86em; color: var(--text2); line-height: 1.6; border-top: 1px solid var(--border); background: var(--card); }
.trap-expl strong { color: var(--text); font-weight: 700; }

.exercise-controls { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 14px; box-shadow: var(--shadow-sm); }
.exercise-controls h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 14px; color: var(--text); }
.ctrl-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 7px; display: block; }
.ex-options { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.ex-opt-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.ex-opt-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
.row-btns { display: flex; gap: 7px; margin-bottom: 14px; flex-wrap: wrap; }
.pill-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.pill-btn:hover:not(.active) { background: var(--border); }
.pill-btn.active { background: var(--text); color: var(--bg); border-color: var(--text); }
.pill-btn.diff.active.A2 { background: var(--green); border-color: var(--green); color:#fff; }
.pill-btn.diff.active.B1 { background: var(--blue);  border-color: var(--blue);  color:#fff; }
.pill-btn.diff.active.B2 { background: var(--accent); border-color: var(--accent); color:#fff; }
.btn-generate { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: none; border-radius: 10px; padding: 13px; font-family: 'DM Sans', sans-serif; font-size: 0.92em; font-weight: 700; cursor: pointer; background: var(--accent); color: white; transition: all 0.18s; margin-top: 4px; }
.btn-generate:hover:not(:disabled) { filter: brightness(1.1); box-shadow: 0 4px 14px rgba(122,90,10,0.32); }
.btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
.spinner { display: none; animation: spin 0.8s linear infinite; }
.btn-generate.loading .spinner { display: inline; }
.btn-generate.loading .btn-icon { display: none; }
@keyframes spin { to { transform: rotate(360deg); } }
.progress-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; margin-bottom: 14px; display: none; }
.progress-wrap.visible { display: block; }
.progress-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.progress-label { font-size: 0.78em; color: var(--text3); font-weight: 600; }
.progress-frac  { font-size: 0.92em; font-weight: 700; color: var(--accent); }
.progress-track { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill  { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.35s ease; }
.progress-score { display: flex; gap: 14px; margin-top: 9px; font-size: 0.8em; flex-wrap: wrap; align-items: center; }
.score-item { display: flex; align-items: center; gap: 5px; font-weight: 500; color: var(--text2); }
.score-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.score-dot.g { background: var(--green); } .score-dot.r { background: var(--red); }
.btn-retry { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 13px; font-family: 'DM Sans', sans-serif; font-size: 0.78em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; margin-left: auto; }
.btn-retry:hover { background: var(--border); }
.final-score-bar { display: none; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 14px; }
.final-score-bar.visible { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.final-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
.final-label { font-size: 0.74em; color: var(--text3); }
.final-track { flex: 1; min-width: 80px; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.final-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
.final-msg { font-size: 0.84em; color: var(--text2); width: 100%; font-weight: 500; }
.exercise-area { display: none; } .exercise-area.visible { display: block; }
.exercise-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 12px; overflow: hidden; }
.exercise-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--bg); border-bottom: 1px solid var(--border); }
.ex-num { font-weight: 700; color: var(--accent); font-size: 0.88em; }
.ex-type-badge { font-size: 0.68em; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; background: var(--accent-light); color: var(--accent); border: 1px solid var(--accent-mid); border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge { font-size: 0.68em; font-weight: 700; border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge.A2 { background: var(--green-bg); color: var(--green); border: 1px solid #80b890; }
.ex-diff-badge.B1 { background: var(--blue-bg);  color: var(--blue);  border: 1px solid #90a8e0; }
.ex-diff-badge.B2 { background: var(--warn-bg);  color: var(--accent); border: 1px solid var(--accent-mid); }
.ex-status { margin-left: auto; }
.exercise-body { padding: 16px 18px; }
.exercise-prompt { line-height: 1.7; margin-bottom: 12px; color: var(--text); }
.exercise-prompt em { color: var(--accent); font-style: italic; font-weight: 600; }
.fill-input { border: none; border-bottom: 2px solid var(--accent-mid); background: var(--accent-light); padding: 2px 8px; border-radius: 4px 4px 0 0; font-family: 'DM Sans', sans-serif; font-size: 1em; color: var(--text); min-width: 120px; outline: none; transition: border-color 0.15s; }
.fill-input:focus { border-bottom-color: var(--accent); }
.fill-input.ok  { background: var(--green-bg); border-bottom-color: var(--green); }
.fill-input.err { background: var(--red-bg);   border-bottom-color: var(--red); }
.choices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; margin-bottom: 10px; }
.choice-btn { border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.88em; font-weight: 500; cursor: pointer; text-align: left; background: var(--bg); color: var(--text); transition: all 0.15s; }
.choice-btn:hover:not(:disabled) { border-color: var(--accent); background: var(--accent-light); }
.choice-btn.ok  { background: var(--green-bg); border-color: var(--green); color: var(--green); font-weight: 700; }
.choice-btn.err { background: var(--red-bg);   border-color: var(--red);   color: var(--red); }
.choice-btn:disabled { cursor: default; }
.transform-input { width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.9em; background: var(--bg); color: var(--text); outline: none; margin-bottom: 8px; transition: border-color 0.15s; }
.transform-input:focus { border-color: var(--accent); }
.transform-input.ok  { background: var(--green-bg); border-color: var(--green); }
.transform-input.err { background: var(--red-bg);   border-color: var(--red); }
.btn-check { border: 1.5px solid var(--accent); border-radius: 20px; padding: 7px 18px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 700; cursor: pointer; background: transparent; color: var(--accent); transition: all 0.15s; }
.btn-check:hover:not(:disabled) { background: var(--accent); color: white; }
.btn-check:disabled { opacity: 0.35; cursor: default; }
.ex-feedback { display: none; border-radius: var(--radius-sm); padding: 11px 14px; line-height: 1.55; margin-top: 10px; font-size: 0.9em; }
.ex-feedback.visible { display: block; }
.ex-feedback.ok  { background: var(--green-bg); border: 1.5px solid #80b890; color: #0e4818; }
.ex-feedback.err { background: var(--red-bg);   border: 1.5px solid #c08090; color: #700018; }
.fb-rule-link { display: inline-flex; align-items: center; gap: 4px; margin-top: 8px; font-size: 0.84em; font-weight: 700; color: var(--accent); cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }
.skeleton-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 12px; }
.skel { background: linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%); background-size: 200% 100%; animation: skel 1.4s infinite; border-radius: 4px; height: 13px; margin-bottom: 9px; }
@keyframes skel { to { background-position: -200% 0; } }
.state-msg { text-align: center; padding: 40px 20px; color: var(--text3); }
.state-icon { font-size: 2rem; margin-bottom: 10px; }
.state-msg p { max-width: 260px; margin: 0 auto; line-height: 1.6; font-weight: 500; }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <a href="index_grammaire.html" class="back-btn" aria-label="Volver al índice de gramática" title="Volver al índice">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="M12 19l-7-7 7-7"/></svg>
    </a>
    <h1>Les Pronoms Personnels</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill cod">COD</div>
    <div class="stat-pill coi">COI</div>
    <div class="stat-pill en">en</div>
    <div class="stat-pill y">y</div>
    <div class="stat-pill" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:0.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Cambiar tema claro/oscuro" title="Tema claro/oscuro">
        <svg class="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        <svg class="icon-sun"  width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
      </button>
    </div>
  </div>
</header>

<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>

<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-cod',this)">2. COD</button>
    <button class="snav-btn"        onclick="showSection('s-coi',this)">3. COI</button>
    <button class="snav-btn"        onclick="showSection('s-en',this)">4. EN</button>
    <button class="snav-btn"        onclick="showSection('s-y',this)">5. Y</button>
    <button class="snav-btn"        onclick="showSection('s-orden',this)">6. Orden</button>
    <button class="snav-btn"        onclick="showSection('s-posicion',this)">7. Posición</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">8. Trampas</button>
  </div>
  <div class="scroll-progress"><div class="scroll-progress-fill" id="scroll-progress-fill"></div></div>
</div>

<div class="main-layout">
<div class="panel active" id="panel-ref">

  <!-- 1. PANORAMA -->
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los pronombres personales átonos sustituyen a un sintagma nominal ya mencionado para evitar la repetición. En francés, su <strong>posición es fija</strong> (antes del verbo en casi todos los casos) y su <strong>orden cuando hay varios</strong> sigue reglas estrictas.
      </div>

      <div class="sec-label">Tabla de referencia completa</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Persona</th><th class="hl-cod">COD</th><th class="hl-coi">COI</th><th class="hl-en">EN</th><th class="hl-y">Y</th></tr></thead>
        <tbody>
          <tr><td><strong>1ª sing.</strong></td><td class="hl-cod">me (m')</td><td class="hl-coi">me (m')</td><td rowspan="6" class="hl-en" style="vertical-align:middle;text-align:center">en<br><span class="dim" style="font-size:0.82em;font-weight:400">sustituye<br>de + cosa/cantidad</span></td><td rowspan="6" class="hl-y" style="vertical-align:middle;text-align:center">y<br><span class="dim" style="font-size:0.82em;font-weight:400">sustituye<br>à + lugar/cosa</span></td></tr>
          <tr><td><strong>2ª sing.</strong></td><td class="hl-cod">te (t')</td><td class="hl-coi">te (t')</td></tr>
          <tr><td><strong>3ª sing. masc.</strong></td><td class="hl-cod">le (l')</td><td class="hl-coi">lui</td></tr>
          <tr><td><strong>3ª sing. fem.</strong></td><td class="hl-cod">la (l')</td><td class="hl-coi">lui</td></tr>
          <tr><td><strong>1ª pl.</strong></td><td class="hl-cod">nous</td><td class="hl-coi">nous</td></tr>
          <tr><td><strong>2ª pl.</strong></td><td class="hl-cod">vous</td><td class="hl-coi">vous</td></tr>
          <tr><td><strong>3ª pl. masc.</strong></td><td class="hl-cod">les</td><td class="hl-coi">leur</td><td></td><td></td></tr>
          <tr><td><strong>3ª pl. fem.</strong></td><td class="hl-cod">les</td><td class="hl-coi">leur</td><td></td><td></td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Orden estándar ante el verbo</div>
      <div class="order-diagram">
        <div class="od-slot subj">Sujeto</div>
        <div class="od-arrow">+</div>
        <div class="od-slot ne">ne</div>
        <div class="od-arrow">+</div>
        <div class="od-slot cod">me/te/se<br>nous/vous</div>
        <div class="od-arrow">→</div>
        <div class="od-slot cod">le/la/les</div>
        <div class="od-arrow">→</div>
        <div class="od-slot coi">lui/leur</div>
        <div class="od-arrow">→</div>
        <div class="od-slot y">y</div>
        <div class="od-arrow">→</div>
        <div class="od-slot en">en</div>
        <div class="od-arrow">+</div>
        <div class="od-slot vrb">VERBO</div>
        <div class="od-arrow">+</div>
        <div class="od-slot pas">pas</div>
        <div class="od-label">Este orden es válido para présent, passé composé, imparfait, futur, conditionnel y subjonctif.</div>
      </div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Regla fundamental:</strong> en todos los tiempos simples y compuestos (excepto impératif afirmativo), los pronombres van <strong>antes del verbo conjugado</strong>. En impératif afirmativo van después, con guion.</div>
      </div>
    </div></div>
  </div>

  <!-- 2. COD -->
  <div class="sec-block" id="s-cod">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El <strong>COD</strong> (complément d'objet direct) sustituye al objeto directo del verbo — el sintagma que responde a <em>¿qué?</em> o <em>¿a quién?</em> sin preposición. Formas: <strong class="hl-cod">me · te · le · la · nous · vous · les</strong>.
      </div>

      <div class="sec-label">Identificar el COD</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Pregunta</th><th>Verbo + COD explícito</th><th>Con pronombre COD</th></tr></thead>
        <tbody>
          <tr><td>¿Qué?</td><td>Je mange <span class="hl-cod">le gâteau</span>.</td><td>Je <span class="hl-cod">le</span> mange.</td></tr>
          <tr><td>¿Qué?</td><td>Elle lit <span class="hl-cod">la lettre</span>.</td><td>Elle <span class="hl-cod">la</span> lit.</td></tr>
          <tr><td>¿Qué?</td><td>Ils prennent <span class="hl-cod">les billets</span>.</td><td>Ils <span class="hl-cod">les</span> prennent.</td></tr>
          <tr><td>¿A quién?</td><td>Tu appelles <span class="hl-cod">ta mère</span>.</td><td>Tu <span class="hl-cod">l'</span>appelles.</td></tr>
          <tr><td>¿A quién?</td><td>Il nous invite <span class="hl-cod">nous</span>.</td><td>Il <span class="hl-cod">nous</span> invite.</td></tr>
        </tbody>
      </table></div>

      <div class="chip-bar">
        <button class="chip cod active" onclick="selectChip('cod',0)">Présent</button>
        <button class="chip cod"        onclick="selectChip('cod',1)">Passé composé + accord</button>
        <button class="chip cod"        onclick="selectChip('cod',2)">Futur / Conditionnel</button>
        <button class="chip cod"        onclick="selectChip('cod',3)">Infinitif</button>
        <button class="chip cod"        onclick="selectChip('cod',4)">Négation</button>
      </div>
      <div id="cod-panels">
        <div class="chip-panel active" id="cod-p-0">
          <div class="example-block cod"><div class="ex-fr">Tu connais ce film ? — Oui, je <span class="ecod">le</span> connais bien.</div><div class="ex-es">¿Conoces esa película? — Sí, la conozco bien.</div></div>
          <div class="example-block cod"><div class="ex-fr">Elle cherche ses clés ? — Oui, elle <span class="ecod">les</span> cherche partout.</div><div class="ex-es">¿Busca sus llaves? — Sí, las busca por todas partes.</div></div>
          <div class="example-block cod"><div class="ex-fr">Tu <span class="ecod">m'</span>entends bien ?</div><div class="ex-es">¿Me oyes bien?</div></div>
          <div class="example-block cod"><div class="ex-fr">Je <span class="ecod">vous</span> remercie pour votre aide.</div><div class="ex-es">Les agradezco su ayuda.</div></div>
          <div class="example-block cod"><div class="ex-fr">On <span class="ecod">te</span> comprend, ne t'inquiète pas.</div><div class="ex-es">Te entendemos, no te preocupes.</div></div>
        </div>
        <div class="chip-panel" id="cod-p-1">
          <div class="def-box">En passé composé con auxiliar <em>avoir</em>, el participio <strong>concuerda en género y número con el COD si éste está antepuesto</strong> (es decir, si hay pronombre COD).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Sin pronombre (sin acuerdo)</th><th>Con pronombre COD (con acuerdo)</th></tr></thead>
            <tbody>
              <tr><td>J'ai mangé <span class="hl-cod">la tarte</span>.</td><td>Je <span class="hl-cod">l'</span>ai mangé<span class="hl-cod">e</span>.</td></tr>
              <tr><td>Il a pris <span class="hl-cod">les billets</span>.</td><td>Il <span class="hl-cod">les</span> a pris<span class="hl-cod">.</span> (masc.pl. = sans -e)</td></tr>
              <tr><td>Elle a regardé <span class="hl-cod">les photos</span>.</td><td>Elle <span class="hl-cod">les</span> a regardé<span class="hl-cod">es</span>.</td></tr>
              <tr><td>Tu as appelé <span class="hl-cod">ta sœur</span>.</td><td>Tu <span class="hl-cod">l'</span>as appelé<span class="hl-cod">e</span>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block cod"><div class="ex-fr">Ces lettres ? Je <span class="ecod">les</span> ai envoyé<span class="ecod">es</span> hier.</div><div class="ex-es">¿Esas cartas? Las envié ayer. (femenino plural → -es)</div></div>
          <div class="example-block cod"><div class="ex-fr">Ta veste, tu <span class="ecod">l'</span>as trouvé<span class="ecod">e</span> ?</div><div class="ex-es">¿Tu chaqueta, la encontraste? (femenino → -e)</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Solo con avoir.</strong> Con être (verbos de movimiento, pronominaux) el participio siempre concuerda con el sujeto, haya o no pronombre.</div></div>
        </div>
        <div class="chip-panel" id="cod-p-2">
          <div class="def-box">En futur simple, conditionnel, subjonctif e imparfait: el pronombre sigue antes del verbo conjugado, misma posición que en présent.</div>
          <div class="example-block cod"><div class="ex-fr">Je <span class="ecod">te</span> rappellerai demain.</div><div class="ex-es">Te llamaré mañana. (futur)</div></div>
          <div class="example-block cod"><div class="ex-fr">Il <span class="ecod">la</span> verrait si elle venait.</div><div class="ex-es">La vería si ella viniera. (conditionnel)</div></div>
          <div class="example-block cod"><div class="ex-fr">Je veux qu'il <span class="ecod">me</span> comprenne.</div><div class="ex-es">Quiero que me entienda. (subjonctif)</div></div>
          <div class="example-block cod"><div class="ex-fr">Elle <span class="ecod">nous</span> attendait tous les jours.</div><div class="ex-es">Nos esperaba todos los días. (imparfait)</div></div>
          <div class="example-block cod"><div class="ex-fr">Il faut que tu <span class="ecod">les</span> appelles.</div><div class="ex-es">Hay que llamarlos. (subjonctif)</div></div>
        </div>
        <div class="chip-panel" id="cod-p-3">
          <div class="def-box">Con una construcción verbo conjugado + infinitivo, el pronombre va <strong>antes del infinitivo</strong> (el verbo del que depende semánticamente).</div>
          <div class="example-block cod"><div class="ex-fr">Je veux <span class="ecod">le</span> voir.</div><div class="ex-es">Quiero verlo.</div><div class="ex-note">le va ante voir, no ante veux</div></div>
          <div class="example-block cod"><div class="ex-fr">Elle peut <span class="ecod">nous</span> aider.</div><div class="ex-es">Puede ayudarnos.</div></div>
          <div class="example-block cod"><div class="ex-fr">Tu dois <span class="ecod">la</span> rappeler.</div><div class="ex-es">Debes llamarla.</div></div>
          <div class="example-block cod"><div class="ex-fr">Il va <span class="ecod">les</span> inviter.</div><div class="ex-es">Va a invitarlos.</div></div>
          <div class="example-block cod"><div class="ex-fr">Je préfère <span class="ecod">te</span> parler en personne.</div><div class="ex-es">Prefiero hablarte en persona.</div></div>
        </div>
        <div class="chip-panel" id="cod-p-4">
          <div class="def-box">En negación: <strong>ne + pronombre + verbo + pas</strong>. El pronombre sigue antes del verbo, entre ne y el verbo.</div>
          <div class="example-block cod"><div class="ex-fr">Je ne <span class="ecod">le</span> connais pas.</div><div class="ex-es">No lo conozco.</div></div>
          <div class="example-block cod"><div class="ex-fr">Elle ne <span class="ecod">les</span> a pas vus.</div><div class="ex-es">No los ha visto.</div></div>
          <div class="example-block cod"><div class="ex-fr">Tu ne <span class="ecod">me</span> comprends pas.</div><div class="ex-es">No me entiendes.</div></div>
          <div class="example-block cod"><div class="ex-fr">Il ne <span class="ecod">la</span> rappellera jamais.</div><div class="ex-es">No la llamará nunca.</div></div>
          <div class="example-block cod"><div class="ex-fr">Nous ne <span class="ecod">vous</span> avons pas invités.</div><div class="ex-es">No os hemos invitado. (accord: masc. pl.)</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 3. COI -->
  <div class="sec-block" id="s-coi">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El <strong>COI</strong> (complément d'objet indirect) sustituye al objeto introducido por la preposición <em>à</em> cuando se refiere a <strong>personas</strong>. Formas: <strong class="hl-coi">me · te · lui · nous · vous · leur</strong>. No hay distinción de género en 3ª persona.
      </div>

      <div class="warn-box"><span class="warn-icon">⚠️</span>
        <div class="warn-text"><strong>COI solo sustituye personas con à.</strong> Si es una <em>cosa</em> introducida por <em>à</em>, se usa <strong>y</strong>. Si es una persona o cosa introducida por <em>de</em>, se usa <strong>en</strong> (cosas) o pronombre tónico (personas).</div>
      </div>

      <div class="chip-bar">
        <button class="chip coi active" onclick="selectChip('coi',0)">Verbos de comunicación</button>
        <button class="chip coi"        onclick="selectChip('coi',1)">Verbos de dar / enviar</button>
        <button class="chip coi"        onclick="selectChip('coi',2)">lui vs. le — trampa clásica</button>
        <button class="chip coi"        onclick="selectChip('coi',3)">COI en passé composé</button>
      </div>
      <div id="coi-panels">
        <div class="chip-panel active" id="coi-p-0">
          <div class="def-box">Verbos como <em>parler à, téléphoner à, écrire à, répondre à, demander à, dire à</em> → COI de persona.</div>
          <div class="example-block coi"><div class="ex-fr">Je parle à Marie → Je <span class="ecoi">lui</span> parle.</div><div class="ex-es">Le hablo. (a ella)</div></div>
          <div class="example-block coi"><div class="ex-fr">Tu téléphones à tes parents → Tu <span class="ecoi">leur</span> téléphones.</div><div class="ex-es">Les llamas por teléfono.</div></div>
          <div class="example-block coi"><div class="ex-fr">Elle m'a écrit une longue lettre.</div><div class="ex-es">Me ha escrito una carta larga.</div></div>
          <div class="example-block coi"><div class="ex-fr">Il ne <span class="ecoi">leur</span> a pas répondu.</div><div class="ex-es">No les ha respondido.</div></div>
          <div class="example-block coi"><div class="ex-fr">Dis-<span class="ecoi">lui</span> de venir demain.</div><div class="ex-es">Dile que venga mañana.</div></div>
        </div>
        <div class="chip-panel" id="coi-p-1">
          <div class="def-box">Verbos como <em>donner à, envoyer à, offrir à, prêter à, montrer à, rendre à</em> → COI de persona.</div>
          <div class="example-block coi"><div class="ex-fr">Je donne le livre à Pierre → Je <span class="ecoi">lui</span> donne le livre.</div><div class="ex-es">Le doy el libro. (a él)</div></div>
          <div class="example-block coi"><div class="ex-fr">Elle nous a offert des fleurs.</div><div class="ex-es">Nos regaló flores.</div></div>
          <div class="example-block coi"><div class="ex-fr">Tu peux <span class="ecoi">me</span> prêter ton stylo ?</div><div class="ex-es">¿Puedes prestarme tu bolígrafo?</div></div>
          <div class="example-block coi"><div class="ex-fr">Il <span class="ecoi">leur</span> a montré la route.</div><div class="ex-es">Les indicó la ruta.</div></div>
          <div class="example-block coi"><div class="ex-fr">Rends-<span class="ecoi">lui</span> son argent !</div><div class="ex-es">¡Devuélvele su dinero!</div></div>
        </div>
        <div class="chip-panel" id="coi-p-2">
          <div class="def-box">La distinción COD (<em>le/la/les</em>) vs. COI (<em>lui/leur</em>) depende del verbo. Algunos verbos construidos con COD en español usan COI en francés y viceversa.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo</th><th>Construcción</th><th>Pronombre correcto</th></tr></thead>
            <tbody>
              <tr><td><strong>téléphoner</strong></td><td>téléphoner <em>à</em> qqn</td><td class="hl-coi">lui / leur</td></tr>
              <tr><td><strong>ressembler</strong></td><td>ressembler <em>à</em> qqn</td><td class="hl-coi">lui / leur</td></tr>
              <tr><td><strong>obéir</strong></td><td>obéir <em>à</em> qqn</td><td class="hl-coi">lui / leur</td></tr>
              <tr><td><strong>plaire</strong></td><td>plaire <em>à</em> qqn</td><td class="hl-coi">lui / leur</td></tr>
              <tr><td><strong>appeler</strong></td><td>appeler qqn (directo)</td><td class="hl-cod">le / la / les</td></tr>
              <tr><td><strong>regarder</strong></td><td>regarder qqn (directo)</td><td class="hl-cod">le / la / les</td></tr>
              <tr><td><strong>attendre</strong></td><td>attendre qqn (directo)</td><td class="hl-cod">le / la / les</td></tr>
            </tbody>
          </table></div>
          <div class="example-block coi"><div class="ex-fr">Ce film me <span class="ecoi">lui</span> plaît beaucoup. → Ce film <span class="ecoi">lui</span> plaît.</div><div class="ex-es">Esa película le gusta mucho. (plaire à → COI)</div></div>
          <div class="example-block cod"><div class="ex-fr">J'attends ma mère → Je <span class="ecod">l'</span>attends.</div><div class="ex-es">La espero. (attendre qqn → COD, no COI)</div></div>
        </div>
        <div class="chip-panel" id="coi-p-3">
          <div class="def-box">El participio passé <strong>nunca concuerda con el COI</strong>, aunque esté antepuesto. Esta es una diferencia clave con el COD.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>COD → acuerdo</th><th>COI → sin acuerdo</th></tr></thead>
            <tbody>
              <tr><td>Je <span class="hl-cod">les</span> ai vu<span class="hl-cod">es</span>. (fém. pl.)</td><td>Je <span class="hl-coi">leur</span> ai parlé. (sin -e/-s)</td></tr>
              <tr><td>Il <span class="hl-cod">l'</span>a appelé<span class="hl-cod">e</span>. (fém.)</td><td>Il <span class="hl-coi">lui</span> a téléphoné. (sin -e)</td></tr>
              <tr><td>Elle <span class="hl-cod">les</span> a invité<span class="hl-cod">s</span>. (masc. pl.)</td><td>Elle <span class="hl-coi">leur</span> a écrit. (sin -s)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block coi"><div class="ex-fr">Marie ? Je <span class="ecoi">lui</span> ai écrit hier. (no: écrite)</div><div class="ex-es">¿Marie? Le escribí ayer.</div></div>
          <div class="example-block coi"><div class="ex-fr">Mes parents ? Je <span class="ecoi">leur</span> ai téléphoné ce matin. (no: téléphoné<strong>s</strong>)</div><div class="ex-es">¿Mis padres? Les llamé esta mañana.</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 4. EN -->
  <div class="sec-block" id="s-en">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong>En</strong> sustituye a un sintagma introducido por <em>de</em> cuando se refiere a <strong>cosas, lugares o cantidades</strong>. También sustituye a los partitivos y artículos indefinidos. Va siempre <strong>antes del verbo</strong>.
      </div>

      <div class="chip-bar">
        <button class="chip en active" onclick="selectChip('en',0)">de + cosa / lugar</button>
        <button class="chip en"        onclick="selectChip('en',1)">Partitivo / artículo indefinido</button>
        <button class="chip en"        onclick="selectChip('en',2)">Cantidad + en</button>
        <button class="chip en"        onclick="selectChip('en',3)">Verbos con de (parler de, avoir besoin de…)</button>
      </div>
      <div id="en-panels">
        <div class="chip-panel active" id="en-p-0">
          <div class="def-box">Sustituye a <em>de + sustantivo</em> (cosa o lugar) en complementos preposicionales y de lugar.</div>
          <div class="example-block en"><div class="ex-fr">Tu reviens de Paris ? — Oui, j'<span class="een">en</span> reviens.</div><div class="ex-es">¿Vuelves de París? — Sí, vengo de allí.</div></div>
          <div class="example-block en"><div class="ex-fr">Il sort du bureau → Il <span class="een">en</span> sort.</div><div class="ex-es">Sale de la oficina → Sale de allí.</div></div>
          <div class="example-block en"><div class="ex-fr">Tu te souviens de ce film ? — Oui, je m'<span class="een">en</span> souviens.</div><div class="ex-es">¿Te acuerdas de esa película? — Sí, me acuerdo.</div></div>
          <div class="example-block en"><div class="ex-fr">Elle est contente de son travail → Elle <span class="een">en</span> est contente.</div><div class="ex-es">Está contenta con su trabajo.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Con personas: se prefiere el pronombre tónico precedido de <em>de</em>: <em>Tu parles de Pierre ? Je parle de <strong>lui</strong>.</em> (no <em>j'en parle</em> para personas en registro formal).</div></div>
        </div>
        <div class="chip-panel" id="en-p-1">
          <div class="def-box">Sustituye a <em>un/une/des + sustantivo</em> o <em>du/de la/de l' + sustantivo</em> (partitivo) cuando la cantidad no está especificada.</div>
          <div class="example-block en"><div class="ex-fr">Tu veux du café ? — Oui, j'<span class="een">en</span> veux.</div><div class="ex-es">¿Quieres café? — Sí, quiero. (no se repite "du café")</div></div>
          <div class="example-block en"><div class="ex-fr">Il a une voiture ? — Oui, il <span class="een">en</span> a une.</div><div class="ex-es">¿Tiene coche? — Sí, tiene uno.</div></div>
          <div class="example-block en"><div class="ex-fr">Elle achète des livres ? — Non, elle n'<span class="een">en</span> achète pas.</div><div class="ex-es">¿Compra libros? — No, no compra.</div></div>
          <div class="example-block en"><div class="ex-fr">Vous mangez de la viande ? — Rarement, on <span class="een">en</span> mange peu.</div><div class="ex-es">¿Coméis carne? — Raramente, comemos poca.</div></div>
          <div class="note-box"><strong>Atención:</strong> en négation, el partitivo desaparece (<em>pas de café</em>), pero <em>en</em> se mantiene: <em>Tu veux du café ? — Non, je n'<strong>en</strong> veux pas.</em></div>
        </div>
        <div class="chip-panel" id="en-p-2">
          <div class="def-box">Cuando hay una cantidad especificada (número, adverbio de cantidad), <em>en</em> sustituye al sustantivo pero la cantidad se <strong>mantiene al final</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Con sustantivo</th><th>Con en + cantidad</th></tr></thead>
            <tbody>
              <tr><td>J'ai trois frères.</td><td>J'<span class="hl-en">en</span> ai <strong>trois</strong>.</td></tr>
              <tr><td>Elle a beaucoup de travail.</td><td>Elle <span class="hl-en">en</span> a <strong>beaucoup</strong>.</td></tr>
              <tr><td>Tu veux un peu de sel ?</td><td>Tu <span class="hl-en">en</span> veux <strong>un peu</strong> ?</td></tr>
              <tr><td>Il a acheté plusieurs livres.</td><td>Il <span class="hl-en">en</span> a acheté <strong>plusieurs</strong>.</td></tr>
              <tr><td>Je mange deux croissants.</td><td>J'<span class="hl-en">en</span> mange <strong>deux</strong>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block en"><div class="ex-fr">Des enfants ? Ils <span class="een">en</span> ont trois.</div><div class="ex-es">¿Hijos? Tienen tres.</div></div>
          <div class="example-block en"><div class="ex-fr">Tu as pris du retard ? — Oui, j'<span class="een">en</span> ai pris beaucoup.</div><div class="ex-es">¿Te has retrasado? — Sí, mucho.</div></div>
        </div>
        <div class="chip-panel" id="en-p-3">
          <div class="def-box">Verbos que rigen <em>de + complément</em> usan <em>en</em> para sustituir ese complemento (solo para cosas).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo + de</th><th>Ejemplo</th><th>Con en</th></tr></thead>
            <tbody>
              <tr><td>parler de</td><td>parler de ce problème</td><td><span class="hl-en">en</span> parler</td></tr>
              <tr><td>avoir besoin de</td><td>avoir besoin d'aide</td><td><span class="hl-en">en</span> avoir besoin</td></tr>
              <tr><td>avoir envie de</td><td>avoir envie de vacances</td><td><span class="hl-en">en</span> avoir envie</td></tr>
              <tr><td>avoir peur de</td><td>avoir peur du chien</td><td><span class="hl-en">en</span> avoir peur</td></tr>
              <tr><td>profiter de</td><td>profiter du soleil</td><td><span class="hl-en">en</span> profiter</td></tr>
              <tr><td>se passer de</td><td>se passer du téléphone</td><td><span class="hl-en">en</span> se passer</td></tr>
            </tbody>
          </table></div>
          <div class="example-block en"><div class="ex-fr">Tu as besoin d'argent ? — Oui, j'<span class="een">en</span> ai besoin.</div><div class="ex-es">¿Necesitas dinero? — Sí, lo necesito.</div></div>
          <div class="example-block en"><div class="ex-fr">Vous parlez de ce projet ? — Oui, on <span class="een">en</span> parle souvent.</div><div class="ex-es">¿Hablan de ese proyecto? — Sí, hablamos de ello a menudo.</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 5. Y -->
  <div class="sec-block" id="s-y">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong>Y</strong> sustituye a un complemento introducido por <em>à</em> cuando se refiere a <strong>cosas, lugares o ideas</strong> (nunca personas). También sustituye a complementos de lugar introducidos por otras preposiciones (en, dans, sur, chez…).
      </div>

      <div class="chip-bar">
        <button class="chip yy active" onclick="selectChip('yy',0)">à + cosa / idea</button>
        <button class="chip yy"        onclick="selectChip('yy',1)">Complemento de lugar</button>
        <button class="chip yy"        onclick="selectChip('yy',2)">Verbos con à (penser à, croire à…)</button>
        <button class="chip yy"        onclick="selectChip('yy',3)">Y vs. COI — la distinción clave</button>
      </div>
      <div id="yy-panels">
        <div class="chip-panel active" id="yy-p-0">
          <div class="def-box">Sustituye a <em>à + sustantivo</em> cuando la cosa o idea ya ha sido mencionada.</div>
          <div class="example-block yy"><div class="ex-fr">Tu penses à ce problème ? — Oui, j'<span class="ey">y</span> pense souvent.</div><div class="ex-es">¿Piensas en ese problema? — Sí, pienso en ello a menudo.</div></div>
          <div class="example-block yy"><div class="ex-fr">Il croit à cette théorie → Il <span class="ey">y</span> croit.</div><div class="ex-es">Cree en esa teoría → Cree en ello.</div></div>
          <div class="example-block yy"><div class="ex-fr">Elle participe à la réunion → Elle <span class="ey">y</span> participe.</div><div class="ex-es">Participa en la reunión → Participa en ella.</div></div>
          <div class="example-block yy"><div class="ex-fr">Il s'intéresse à la musique → Il s'<span class="ey">y</span> intéresse.</div><div class="ex-es">Se interesa por la música → Se interesa por ello.</div></div>
          <div class="example-block yy"><div class="ex-fr">Tu as répondu à sa question ? — Oui, j'<span class="ey">y</span> ai répondu.</div><div class="ex-es">¿Respondiste a su pregunta? — Sí, respondí.</div></div>
        </div>
        <div class="chip-panel" id="yy-p-1">
          <div class="def-box">Sustituye a cualquier complemento de lugar (à, en, dans, sur, chez, devant…) ya mencionado.</div>
          <div class="example-block yy"><div class="ex-fr">Tu vas à Paris ? — Oui, j'<span class="ey">y</span> vais la semaine prochaine.</div><div class="ex-es">¿Vas a París? — Sí, voy la semana que viene.</div></div>
          <div class="example-block yy"><div class="ex-fr">Il est dans sa chambre → Il <span class="ey">y</span> est.</div><div class="ex-es">Está en su habitación → Está allí.</div></div>
          <div class="example-block yy"><div class="ex-fr">On reste chez nos amis → On <span class="ey">y</span> reste.</div><div class="ex-es">Nos quedamos en casa de nuestros amigos → Nos quedamos allí.</div></div>
          <div class="example-block yy"><div class="ex-fr">Elle habite en France → Elle <span class="ey">y</span> habite.</div><div class="ex-es">Vive en Francia → Vive allí.</div></div>
          <div class="example-block yy"><div class="ex-fr">Les clés sont sur la table → Elles <span class="ey">y</span> sont.</div><div class="ex-es">Las llaves están sobre la mesa → Están allí.</div></div>
        </div>
        <div class="chip-panel" id="yy-p-2">
          <div class="def-box">Verbos que rigen <em>à + complément de chose</em> y usan <em>y</em> para sustituirlo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo + à</th><th>Ejemplo</th><th>Con y</th></tr></thead>
            <tbody>
              <tr><td>penser à</td><td>penser à ses vacances</td><td><span class="hl-y">y</span> penser</td></tr>
              <tr><td>réfléchir à</td><td>réfléchir à ce projet</td><td><span class="hl-y">y</span> réfléchir</td></tr>
              <tr><td>s'intéresser à</td><td>s'intéresser à l'art</td><td>s'<span class="hl-y">y</span> intéresser</td></tr>
              <tr><td>participer à</td><td>participer à une réunion</td><td><span class="hl-y">y</span> participer</td></tr>
              <tr><td>croire à</td><td>croire à la chance</td><td><span class="hl-y">y</span> croire</td></tr>
              <tr><td>tenir à</td><td>tenir à cette idée</td><td><span class="hl-y">y</span> tenir</td></tr>
              <tr><td>renoncer à</td><td>renoncer à ce plan</td><td><span class="hl-y">y</span> renoncer</td></tr>
            </tbody>
          </table></div>
          <div class="example-block yy"><div class="ex-fr">Tu as réfléchi à ma proposition ? — Oui, j'<span class="ey">y</span> ai beaucoup réfléchi.</div><div class="ex-es">¿Reflexionaste sobre mi propuesta? — Sí, reflexioné mucho.</div></div>
        </div>
        <div class="chip-panel" id="yy-p-3">
          <div class="def-box">La diferencia entre <em>y</em> y el COI (<em>lui/leur</em>) depende de si el complemento es una <strong>persona o una cosa</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Complemento</th><th>Pronombre</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>à + <strong>persona</strong></td><td class="hl-coi">lui / leur</td><td>Je parle à Marie → Je <span class="hl-coi">lui</span> parle.</td></tr>
              <tr><td>à + <strong>cosa / lugar / idea</strong></td><td class="hl-y">y</td><td>Je pense à ce problème → J'<span class="hl-y">y</span> pense.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block coi"><div class="ex-fr">Je téléphone à mon frère → Je <span class="ecoi">lui</span> téléphone. (persona)</div><div class="ex-es">Le llamo por teléfono.</div></div>
          <div class="example-block yy"><div class="ex-fr">Je pense à mon frère → Je pense à <strong>lui</strong>. (persona → pronombre tónico, no y)</div><div class="ex-es">Pienso en mi hermano. (tónico, no y)</div></div>
          <div class="example-block yy"><div class="ex-fr">Je pense à ce projet → J'<span class="ey">y</span> pense. (cosa → y)</div><div class="ex-es">Pienso en ese proyecto.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Con personas, <em>penser à</em> y <em>s'habituer à</em> usan pronombre <strong>tónico</strong>, no <em>y</em>: <em>Je pense à <strong>lui</strong></em>, no <em>j'y pense</em> (salvo referencia a cosa o idea).</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 6. ORDEN -->
  <div class="sec-block" id="s-orden">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Cuando hay <strong>dos pronombres</strong> juntos, siguen un orden fijo. El error de orden es uno de los más frecuentes en el DELF B2.
      </div>

      <div class="sec-label">Orden en frases afirmativas e interrogativas (y negativas)</div>
      <div class="order-diagram">
        <div class="od-slot cod" style="font-size:0.78em">me/te/se<br>nous/vous</div>
        <div class="od-arrow">→</div>
        <div class="od-slot cod" style="font-size:0.78em">le/la/les<br>(COD 3ª)</div>
        <div class="od-arrow">→</div>
        <div class="od-slot coi" style="font-size:0.78em">lui/leur<br>(COI 3ª)</div>
        <div class="od-arrow">→</div>
        <div class="od-slot y" style="font-size:0.78em">y</div>
        <div class="od-arrow">→</div>
        <div class="od-slot en" style="font-size:0.78em">en</div>
        <div class="od-arrow">+</div>
        <div class="od-slot vrb">VERBO</div>
      </div>

      <div class="chip-bar">
        <button class="chip active" onclick="selectChip('orden',0)">COD + COI (le/la/les + lui/leur)</button>
        <button class="chip"        onclick="selectChip('orden',1)">me/te/nous/vous + COD</button>
        <button class="chip"        onclick="selectChip('orden',2)">Pronombre + en</button>
        <button class="chip"        onclick="selectChip('orden',3)">Pronombre + y</button>
        <button class="chip"        onclick="selectChip('orden',4)">Impératif afirmativo (orden inverso)</button>
      </div>
      <div id="orden-panels">
        <div class="chip-panel active" id="orden-p-0">
          <div class="def-box">Cuando coinciden un COD de 3ª persona y un COI de 3ª persona: <strong>COD (le/la/les) antes de COI (lui/leur)</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Dos complementos explícitos</th><th>Con los dos pronombres</th></tr></thead>
            <tbody>
              <tr><td>Je donne le livre à Pierre.</td><td>Je <span class="hl-cod">le</span> <span class="hl-coi">lui</span> donne.</td></tr>
              <tr><td>Elle envoie les photos à ses amis.</td><td>Elle <span class="hl-cod">les</span> <span class="hl-coi">leur</span> envoie.</td></tr>
              <tr><td>Il prête sa voiture à Marie.</td><td>Il <span class="hl-cod">la</span> <span class="hl-coi">lui</span> prête.</td></tr>
              <tr><td>Tu montres le chemin aux touristes.</td><td>Tu <span class="hl-cod">le</span> <span class="hl-coi">leur</span> montres.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block mix"><div class="ex-fr">Ce document ? Je <span class="ecod">le</span> <span class="ecoi">lui</span> ai envoyé hier.</div><div class="ex-es">¿Ese documento? Se lo envié ayer.</div></div>
          <div class="example-block mix"><div class="ex-fr">Les clés ? Donne-<span class="ecod">les</span>-<span class="ecoi">lui</span> ! (impératif aff.)</div><div class="ex-es">¿Las llaves? ¡Dáselas!</div></div>
        </div>
        <div class="chip-panel" id="orden-p-1">
          <div class="def-box">Cuando el COI es de 1ª o 2ª persona (me/te/nous/vous), va <strong>antes</strong> del COD de 3ª persona (le/la/les).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Dos complementos</th><th>Con los dos pronombres</th></tr></thead>
            <tbody>
              <tr><td>Il me donne le livre.</td><td>Il <span class="hl-coi">me</span> <span class="hl-cod">le</span> donne.</td></tr>
              <tr><td>Elle te prête sa voiture.</td><td>Elle <span class="hl-coi">te</span> <span class="hl-cod">la</span> prête.</td></tr>
              <tr><td>Il nous envoie les documents.</td><td>Il <span class="hl-coi">nous</span> <span class="hl-cod">les</span> envoie.</td></tr>
              <tr><td>Elle vous montre le chemin.</td><td>Elle <span class="hl-coi">vous</span> <span class="hl-cod">le</span> montre.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block mix"><div class="ex-fr">Il <span class="ecoi">me</span> <span class="ecod">l'</span>a expliqué très clairement.</div><div class="ex-es">Me lo explicó muy claramente.</div></div>
          <div class="example-block mix"><div class="ex-fr">Elle <span class="ecoi">te</span> <span class="ecod">les</span> enverra demain.</div><div class="ex-es">Te los enviará mañana.</div></div>
        </div>
        <div class="chip-panel" id="orden-p-2">
          <div class="def-box"><em>En</em> siempre va en última posición, después de todos los demás pronombres. Los más frecuentes: <em>m'en, t'en, nous en, vous en, lui en, leur en</em>.</div>
          <div class="example-block mix"><div class="ex-fr">Il <span class="ecoi">m'</span><span class="een">en</span> a parlé. (COI me + en)</div><div class="ex-es">Me habló de ello.</div></div>
          <div class="example-block mix"><div class="ex-fr">Elle <span class="ecoi">lui</span> <span class="een">en</span> a donné. (COI lui + en)</div><div class="ex-es">Le dio de ello.</div></div>
          <div class="example-block mix"><div class="ex-fr">Je <span class="ecoi">vous</span> <span class="een">en</span> parlerai demain. (vous + en)</div><div class="ex-es">Os hablaré de ello mañana.</div></div>
          <div class="example-block mix"><div class="ex-fr">On <span class="ecoi">nous</span> <span class="een">en</span> a offert beaucoup.</div><div class="ex-es">Nos ofrecieron mucho de ello.</div></div>
          <div class="example-block mix"><div class="ex-fr">Il <span class="ecoi">leur</span> <span class="een">en</span> a remis deux. (COI + en + cantidad)</div><div class="ex-es">Les entregó dos.</div></div>
        </div>
        <div class="chip-panel" id="orden-p-3">
          <div class="def-box"><em>Y</em> también va en posición final, antes de <em>en</em> si los dos aparecen juntos (raro). La combinación <em>y en</em> casi no existe en francés moderno.</div>
          <div class="example-block mix"><div class="ex-fr">Tu <span class="ey">y</span> <span class="een">en</span> trouveras. (lugar + en — muy raro en oral)</div><div class="ex-es">Encontrarás allí.</div></div>
          <div class="example-block yy"><div class="ex-fr">Il <span class="ey">y</span> est allé ? — Oui, il <span class="ey">y</span> est allé.</div><div class="ex-es">¿Fue allí? — Sí, fue.</div></div>
          <div class="example-block yy"><div class="ex-fr">On <span class="ey">y</span> va ? — Oui, on <span class="ey">y</span> va !</div><div class="ex-es">¿Vamos? — ¡Sí, vamos!</div></div>
          <div class="note-box"><strong>Nota:</strong> en la práctica, la combinación <em>y en</em> se evita. Se prefiere reformular: <em>Il y en a</em> (hay) es una excepción fija muy frecuente.</div>
        </div>
        <div class="chip-panel" id="orden-p-4">
          <div class="def-box">En impératif <strong>afirmativo</strong>, el orden cambia: COD antes de COI (igual que en frases normales) pero <em>todo va después del verbo</em> con guion. <em>me → moi, te → toi</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Frase normal</th><th>Impératif afirmatif (orden aff.)</th></tr></thead>
            <tbody>
              <tr><td>Je <span class="hl-cod">le</span> <span class="hl-coi">lui</span> donne.</td><td>Donne-<span class="hl-cod">le</span>-<span class="hl-coi">lui</span> !</td></tr>
              <tr><td>Elle <span class="hl-coi">me</span> <span class="hl-cod">le</span> prête.</td><td>Prête-<span class="hl-cod">le</span>-<span class="hl-coi">moi</span> !</td></tr>
              <tr><td>Il <span class="hl-coi">nous</span> <span class="hl-cod">les</span> envoie.</td><td>Envoyez-<span class="hl-cod">les</span>-<span class="hl-coi">nous</span> !</td></tr>
            </tbody>
          </table></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">En impératif afirmatif con dos pronombres, el <strong>COD siempre va primero</strong>, aunque sea me/te: <em>Prête-<strong>le</strong>-<strong>moi</strong></em> (COD le, COI moi) — al contrario que en frase normal (<em>me le prête</em>).</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 7. POSICIÓN SEGÚN TIEMPO -->
  <div class="sec-block" id="s-posicion">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La posición del pronombre cambia según la estructura verbal. La regla es siempre la misma: el pronombre va <strong>inmediatamente antes del verbo del que depende semánticamente</strong>.
      </div>

      <div class="chip-bar">
        <button class="chip active" onclick="selectChip('posic',0)">Tiempos simples</button>
        <button class="chip"        onclick="selectChip('posic',1)">Temps composés (PC, PQP…)</button>
        <button class="chip"        onclick="selectChip('posic',2)">Verbe + infinitif</button>
        <button class="chip"        onclick="selectChip('posic',3)">Impératif afirmatif</button>
        <button class="chip"        onclick="selectChip('posic',4)">Impératif négatif</button>
      </div>
      <div id="posic-panels">
        <div class="chip-panel active" id="posic-p-0">
          <div class="def-box">Présent, imparfait, futur simple, conditionnel, subjonctif: pronombre <strong>antes del verbo conjugado</strong>.</div>
          <div class="example-block neu"><div class="ex-fr">Je <span class="ecod">le</span> lis. (présent)</div><div class="ex-es">Lo leo.</div></div>
          <div class="example-block neu"><div class="ex-fr">Elle <span class="ecoi">lui</span> parlait souvent. (imparfait)</div><div class="ex-es">Le hablaba a menudo.</div></div>
          <div class="example-block neu"><div class="ex-fr">Tu <span class="ecod">le</span> verras demain. (futur simple)</div><div class="ex-es">Lo verás mañana.</div></div>
          <div class="example-block neu"><div class="ex-fr">Il <span class="ecoi">leur</span> dirait la vérité. (conditionnel)</div><div class="ex-es">Les diría la verdad.</div></div>
          <div class="example-block neu"><div class="ex-fr">Je veux qu'il <span class="ecod">les</span> voie. (subjonctif)</div><div class="ex-es">Quiero que los vea.</div></div>
        </div>
        <div class="chip-panel" id="posic-p-1">
          <div class="def-box">Passé composé, plus-que-parfait, futur antérieur, conditionnel passé: pronombre <strong>antes del auxiliar</strong> (no del participio).</div>
          <div class="example-block neu"><div class="ex-fr">Je <span class="ecod">l'</span>ai vu hier. (passé composé)</div><div class="ex-es">Lo vi ayer.</div></div>
          <div class="example-block neu"><div class="ex-fr">Elle <span class="ecoi">lui</span> avait déjà parlé. (plus-que-parfait)</div><div class="ex-es">Ya le había hablado.</div></div>
          <div class="example-block neu"><div class="ex-fr">Quand tu <span class="ecod">l'</span>auras lu, rends-le-moi. (futur antérieur)</div><div class="ex-es">Cuando lo hayas leído, devuélvemelo.</div></div>
          <div class="example-block neu"><div class="ex-fr">Il <span class="ecod">les</span> aurait vus s'il était venu. (conditionnel passé)</div><div class="ex-es">Los habría visto si hubiera venido.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">El pronombre va <strong>antes del auxiliar</strong>, nunca entre el auxiliar y el participio: <em>Je l'ai vu</em> ✓ — <em>J'ai le vu</em> ✗</div></div>
        </div>
        <div class="chip-panel" id="posic-p-2">
          <div class="def-box">Con <em>verbo modal/de movimiento + infinitivo</em>, el pronombre va <strong>antes del infinitivo</strong>, no del verbo conjugado.</div>
          <div class="example-block neu"><div class="ex-fr">Je veux <span class="ecod">le</span> voir. (no: je le veux voir)</div><div class="ex-es">Quiero verlo.</div></div>
          <div class="example-block neu"><div class="ex-fr">Elle peut <span class="ecoi">lui</span> parler. (no: elle lui peut parler)</div><div class="ex-es">Puede hablarle.</div></div>
          <div class="example-block neu"><div class="ex-fr">Tu dois <span class="een">en</span> prendre. (no: tu en dois prendre)</div><div class="ex-es">Debes tomar algo.</div></div>
          <div class="example-block neu"><div class="ex-fr">On va <span class="ey">y</span> aller demain.</div><div class="ex-es">Vamos a ir allí mañana.</div></div>
          <div class="note-box"><strong>Excepción — faire + inf.:</strong> con <em>faire causatif</em>, el pronombre va antes de <em>faire</em>: <em>Je <span class="ecod">le</span> fais réparer</em> (lo hago reparar).</div>
        </div>
        <div class="chip-panel" id="posic-p-3">
          <div class="def-box">Impératif afirmatif: pronombre <strong>después del verbo con guion</strong>. <em>me → moi, te → toi</em>.</div>
          <div class="example-block neu"><div class="ex-fr">Mange-<span class="ecod">le</span> !</div><div class="ex-es">¡Cómetelo!</div></div>
          <div class="example-block neu"><div class="ex-fr">Parle-<span class="ecoi">lui</span> !</div><div class="ex-es">¡Háblale!</div></div>
          <div class="example-block neu"><div class="ex-fr">Écoute-<span class="ecod">moi</span> !</div><div class="ex-es">¡Escúchame!</div></div>
          <div class="example-block neu"><div class="ex-fr">Prends-<span class="een">en</span> !</div><div class="ex-es">¡Coge alguno/un poco!</div></div>
          <div class="example-block neu"><div class="ex-fr">Vas-<span class="ey">y</span> !</div><div class="ex-es">¡Ve allá! / ¡Adelante!</div></div>
        </div>
        <div class="chip-panel" id="posic-p-4">
          <div class="def-box">Impératif négatif: igual que en todos los tiempos simples, el pronombre vuelve <strong>antes del verbo</strong>, entre <em>ne</em> y el verbo. <em>moi → me, toi → te</em>.</div>
          <div class="example-block neu"><div class="ex-fr">Ne <span class="ecod">le</span> mange pas !</div><div class="ex-es">¡No te lo comas!</div></div>
          <div class="example-block neu"><div class="ex-fr">Ne <span class="ecoi">lui</span> parle pas !</div><div class="ex-es">¡No le hables!</div></div>
          <div class="example-block neu"><div class="ex-fr">Ne <span class="ecod">m'</span>écoute pas !</div><div class="ex-es">¡No me escuches!</div></div>
          <div class="example-block neu"><div class="ex-fr">N'<span class="een">en</span> prends pas !</div><div class="ex-es">¡No cojas ninguno!</div></div>
          <div class="example-block neu"><div class="ex-fr">N'<span class="ey">y</span> va pas !</div><div class="ex-es">¡No vayas allá!</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 8. TRAMPAS -->
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">Los 8 errores más frecuentes con los pronombres personales en el DELF B1–B2.</div>
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>

</div><!-- /panel-ref -->

<footer class="page-end">
  <button class="page-end-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="Volver arriba">
    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
    Volver arriba
  </button>
</footer>
</div><!-- /main-layout -->

<script>
/* DATA */
const TRAPS = [
  {name:"COD vs. COI: le/la/les vs. lui/leur",
   wrong:"Je lui appelle. / Je le téléphone.",
   right:"Je l'appelle. / Je lui téléphone.",
   expl:"<strong>Appeler qqn</strong> es verbo directo → COD (le/la). <strong>Téléphoner à qqn</strong> es verbo con à → COI (lui/leur). Hay que saber si el verbo es directo o indirecto para elegir el pronombre correcto."},
  {name:"Accord du participe avec COD antéposé",
   wrong:"Je les ai mangé. (fém. pl.) / Elle l'a appelé. (fém.)",
   right:"Je les ai mangées. / Elle l'a appelée.",
   expl:"Con auxiliar <strong>avoir</strong>, el participio concuerda en género y número con el <strong>COD si está antepuesto</strong> (es decir, cuando hay pronombre COD). No concuerda nunca con el COI."},
  {name:"Y vs. pronombre tónico con penser à + personne",
   wrong:"Je pense à Marie → J'y pense.",
   right:"Je pense à Marie → Je pense à elle.",
   expl:"Con personas, <em>penser à, s'habituer à, faire attention à</em> usan <strong>pronombre tónico</strong>, no <em>y</em>: <em>je pense à <strong>lui/elle/eux/elles</strong></em>. Y solo sustituye a cosas, lugares e ideas."},
  {name:"Posición del pronombre en temps composés",
   wrong:"J'ai le vu. / Elle a leur parlé.",
   right:"Je l'ai vu. / Elle leur a parlé.",
   expl:"En tiempos compuestos (passé composé, etc.), el pronombre va <strong>antes del auxiliar</strong> (avoir/être), nunca entre el auxiliar y el participio."},
  {name:"Posición con verbe + infinitif",
   wrong:"Je le veux voir. / Elle lui peut parler.",
   right:"Je veux le voir. / Elle peut lui parler.",
   expl:"Con <em>verbe conjugué + infinitif</em>, el pronombre va <strong>antes del infinitivo</strong> (el verbo del que depende semánticamente), no antes del verbo conjugado."},
  {name:"Orden COD + COI (le/la/les avant lui/leur)",
   wrong:"Je lui le donne. / Elle leur les envoie.",
   right:"Je le lui donne. / Elle les leur envoie.",
   expl:"Cuando hay COD (le/la/les) y COI de 3ª persona (lui/leur), el <strong>COD va primero</strong>: <em>le lui, la lui, les leur…</em> Es el orden contrario al español (se lo)."},
  {name:"EN con cantidad: mantener el número al final",
   wrong:"J'en ai. (cuando había número concreto)",
   right:"J'en ai trois. / J'en ai beaucoup.",
   expl:"Cuando la frase original incluye una <strong>cantidad especificada</strong> (número, beaucoup, peu, plusieurs…), al usar <em>en</em> hay que mantener esa cantidad al final: <em>J'en ai trois / beaucoup / un peu.</em>"},
  {name:"COI no concuerda con el participio",
   wrong:"Je lui ai parlé. → participe: parlée (fém.)",
   right:"Je lui ai parlé. → participe invariable",
   expl:"El participio pasado <strong>nunca concuerda con el COI</strong>. Solo concuerda con el COD antepuesto. <em>Je leur ai écrit</em> (no: écrit<strong>s</strong>). <em>Je les ai vus</em> (acuerdo con COD les, masc. pl.)."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

/* CHIP SELECT */
function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c,i) => c.classList.toggle("active", i===idx));
    }
  });
  const panelsEl = document.getElementById(ns + "-panels");
  if (panelsEl) panelsEl.querySelectorAll(":scope > .chip-panel").forEach((p,i) => p.classList.toggle("active", i===idx));
}

/* NAV */
function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

/* EXERCISE STATE */
let exType = "fill", exDiff = "B1", exQty = 5, exFoco = "mix";
let exTotal = 0, exAnswered = 0, exCorrect = 0, exWrong = 0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));

function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active", "A2", "B1", "B2");
    if (b.textContent.trim() === d) b.classList.add("active", d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim()) === q));
}

/* GENERATE */
const FOCO_DESC = {
  mix:    "general de pronombres personales: COD (le/la/les/me/te), COI (lui/leur/me/te), en, y, orden con dos pronombres, posición según el tiempo verbal",
  cod:    "pronombres COD: le/la/les para 3ª persona, me/te/nous/vous; posición antes del verbo; acuerdo del participio con COD antepuesto en passé composé",
  coi:    "pronombres COI: lui/leur para 3ª persona, me/te/nous/vous; distinción COD vs COI (verbo directo vs. con à); sin acuerdo del participio con COI",
  en:     "pronombre EN: sustitución de de+cosa, partitivos, cantidades (en+nombre al final), verbos con de (avoir besoin de, parler de, avoir envie de...)",
  y:      "pronombre Y: sustitución de à+cosa/lugar/idea, complementos de lugar; distinción Y (cosa) vs lui/leur (persona) vs pronombre tónico (penser à + personne)",
  orden:  "orden de dos pronombres: COD+COI (le lui, les leur), me/te/nous/vous antes de COD 3ª, en al final, impératif afirmatif (COD avant COI avec guion)",
  accord: "acuerdo del participio pasado con el COD antepuesto: concordancia en género y número cuando hay pronombre COD con avoir; sin acuerdo con COI",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe el pronombre correcto o la forma verbal completa",
  choice:    "elección múltiple: 4 opciones de pronombres o formas verbales, solo una correcta",
  transform: "transformación: sustituir el complemento subrayado por el pronombre adecuado, reescribiendo la frase completa",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS = {
  "s-intro": "Panorama general",
  "s-cod": "COD",
  "s-coi": "COI",
  "s-en": "EN",
  "s-y": "Y",
  "s-orden": "Orden de pronombres",
  "s-posicion": "Posición según tiempo",
  "s-trampas": "Trampas"
};

function renderExercises(exs) {
  const area = document.getElementById("exercise-area");
  const labels = { fill: "Completar", choice: "Elección múltiple", transform: "Transformación" };
  area.innerHTML = exs.map((ex, i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref || ""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i + 1}</span>
        <span class="ex-type-badge">${labels[ex.type] || ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex, i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex, i) => {
    const chk = document.getElementById("chk-" + i);
    if (chk) chk.addEventListener("click", () => checkAnswer(ex, i));
    const inp = document.getElementById("inp-" + i);
    if (inp) inp.addEventListener("keydown", e => { if (e.key === "Enter") checkAnswer(ex, i); });
  });
}

function buildBody(ex, i) {
  if (ex.type === "fill")
    return `<div class="exercise-prompt">${ex.prompt_parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint || "…"}" autocomplete="off" spellcheck="false">${ex.prompt_parts[1] || ""}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  if (ex.type === "choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o, j) => `<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if (ex.type === "transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Tu respuesta…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex, i) {
  const inp = document.getElementById("inp-" + i);
  if (!inp || inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok ? "ok" : "err"); inp.disabled = true;
  const chk = document.getElementById("chk-" + i); if (chk) chk.disabled = true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0 || c0.disabled) return;
  for (let j = 0; j < 4; j++) {
    const b = document.getElementById(`ch-${idx}-${j}`);
    if (!b) continue; b.disabled = true;
    if (j === correct) b.classList.add("ok"); else if (j === chosen) b.classList.add("err");
  }
  const card = document.getElementById("ex-card-" + idx);
  showFeedback(idx, chosen === correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen === correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById("ex-st-" + i).textContent = ok ? "✅" : "❌";
  const fb = document.getElementById("ex-fb-" + i);
  fb.className = "ex-feedback visible " + (ok ? "ok" : "err");
  const link = RULE_LABELS[ruleRef]
    ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : "";
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans ? ` — Respuesta: <strong>${ans}</strong>` : ""}`;
  if (expl) html += `<br><span style="font-size:0.88em;opacity:0.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML = html;
}

function goToRule(ref) {
  switchMode("ref", document.querySelector(".mode-btn"));
  setTimeout(() => {
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({ behavior: "smooth", block: "start" });
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if (ok) exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal > 0 ? (exAnswered / exTotal) * 100 : 0;
  document.getElementById("progress-frac").textContent = `${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width = pct + "%";
  document.getElementById("score-correct").textContent = `${exCorrect} correcta${exCorrect !== 1 ? "s" : ""}`;
  document.getElementById("score-wrong").textContent = `${exWrong} error${exWrong !== 1 ? "es" : ""}`;
  if (exAnswered >= exTotal && exTotal > 0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect / exTotal) * 100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent = `${exCorrect} / ${exTotal}`;
  const fill = document.getElementById("final-fill");
  fill.style.width = pct + "%";
  fill.style.background = pct >= 80 ? "var(--green)" : pct >= 50 ? "var(--accent)" : "var(--red)";
  const msgs = { 100: "Parfait ! Dominas los pronombres. 🎉", 80: "Très bien ! Repasa los errores marcados.", 50: "Bien, pero refuerza los bloques señalados.", 0: "Vuelve a Referencia antes de repetir." };
  document.getElementById("final-msg").textContent = msgs[pct === 100 ? 100 : pct >= 80 ? 80 : pct >= 50 ? 50 : 0];
  document.getElementById("score-pill").style.display = "";
  document.getElementById("score-pill-val").textContent = `${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById("exercise-area").innerHTML = `<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display = "none";
  exAnswered = 0; exCorrect = 0; exWrong = 0;
}

function esc(s) { return (s || "").replace(/"/g, "&quot;").replace(/</g, "&lt;"); }

/* INIT */
renderTraps();
</script>
</body>
</html>
