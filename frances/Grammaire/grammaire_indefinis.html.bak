<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Indéfinis</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ede9df;--card:#faf7f1;--border:#c4bead;
  --text:#1a1814;--text2:#44413a;--text3:#706c64;
  --accent:#7a5a0a;--accent-light:#f0e0c0;--accent-mid:#b89050;
  --warn-bg:#fdf0cc;
  --shadow:0 2px 14px rgba(0,0,0,.11),0 1px 4px rgba(0,0,0,.06);
  --shadow-sm:0 1px 6px rgba(0,0,0,.08);
  --radius:14px;--radius-sm:8px;
  --green:#1a6028;--green-bg:#e4f2e8;
  --red:#a81e2e;--red-bg:#fce6e8;
  --blue:#163494;--blue-bg:#e6ebf8;
  --purple:#6a1a8a;--purple-bg:#f2e6f8;
  --qu-color:#163494;--qu-bg:#e6ebf8;
  --to-color:#1a6028;--to-bg:#e4f2e8;
  --ni-color:#6a1a8a;--ni-bg:#f2e6f8;
  --au-color:#8b1a4a;--au-bg:#f8e6ee;
  --fs:15px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:var(--fs);}
.site-header{background:var(--card);border-bottom:2px solid var(--border);padding:20px 20px 14px;}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px;flex-wrap:wrap;}
.site-header h1{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,5vw,1.9rem);font-weight:700;}
.header-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-mid);border-radius:20px;padding:3px 10px;}
.subtitle{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.stats-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;}
.stat-pill{border-radius:20px;padding:4px 11px;font-size:.76rem;font-weight:600;border:1px solid;}
.stat-pill.qu{background:var(--qu-bg);color:var(--qu-color);border-color:var(--qu-color);}
.stat-pill.to{background:var(--to-bg);color:var(--to-color);border-color:var(--to-color);}
.stat-pill.ni{background:var(--ni-bg);color:var(--ni-color);border-color:var(--ni-color);}
.stat-pill.au{background:var(--au-bg);color:var(--au-color);border-color:var(--au-color);}
.stat-pill.neu{background:var(--bg);color:var(--text2);border-color:var(--border);font-weight:500;}
.fs-wrap{display:flex;align-items:center;gap:7px;margin-left:auto;}
.fs-slider{width:76px;accent-color:var(--accent);cursor:pointer;}
.fs-sz{color:var(--text3);font-weight:700;}
.mode-toggle{display:flex;border-bottom:2px solid var(--border);background:var(--card);}
.mode-btn{flex:1;padding:12px 8px;font-family:'DM Sans',sans-serif;font-size:.84rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.mode-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.section-nav{position:sticky;top:0;z-index:200;background:var(--card);border-bottom:2px solid var(--border);box-shadow:var(--shadow-sm);}
.section-nav-inner{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.section-nav-inner::-webkit-scrollbar{display:none;}
.snav-btn{flex-shrink:0;padding:11px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;}
.snav-btn:hover{color:var(--text2);}
.snav-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.main-layout{max-width:860px;margin:0 auto;padding:16px 16px 40px;}
.panel{display:none;}.panel.active{display:block;}
.sec-block{display:none;}.sec-block.active{display:block;}
.gram-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:14px;overflow:hidden;}
.gram-card-body{padding:18px;}
.def-box{background:var(--warn-bg);border-left:4px solid var(--accent);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:12px 15px;margin-bottom:14px;line-height:1.65;}
.def-box strong{color:var(--accent);font-weight:700;}
.warn-box{background:#fff4e0;border:1px solid #c8900a;border-radius:var(--radius-sm);padding:10px 13px;margin:10px 0;font-size:.9em;display:flex;gap:8px;align-items:flex-start;}
.warn-icon{flex-shrink:0;margin-top:1px;}
.warn-text{color:var(--text2);line-height:1.55;}
.warn-text strong{color:#7a4400;font-weight:700;}
.note-box{background:var(--purple-bg);border-left:4px solid var(--purple);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.note-box strong{color:var(--purple);font-weight:700;}
.green-box{background:var(--green-bg);border-left:4px solid var(--green);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.green-box strong{color:var(--green);font-weight:700;}
.example-block{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:8px 0;}
.example-block.qu{background:var(--qu-bg);border-left:4px solid var(--qu-color);}
.example-block.to{background:var(--to-bg);border-left:4px solid var(--to-color);}
.example-block.ni{background:var(--ni-bg);border-left:4px solid var(--ni-color);}
.example-block.au{background:var(--au-bg);border-left:4px solid var(--au-color);}
.example-block.neu{background:var(--blue-bg);border-left:4px solid var(--blue);}
.ex-fr{font-weight:600;margin-bottom:3px;color:var(--text);}
.equ{color:var(--qu-color);font-weight:700;}
.eto{color:var(--to-color);font-weight:700;}
.eni{color:var(--ni-color);font-weight:700;}
.eau{color:var(--au-color);font-weight:700;}
.ex-es{color:var(--text2);font-size:.88em;font-style:italic;}
.ex-note{font-size:.78em;color:var(--text3);margin-top:3px;font-weight:500;}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:14px;border-radius:var(--radius-sm);border:1px solid var(--border);}
.gram-table{width:100%;border-collapse:collapse;min-width:280px;}
.gram-table th{background:var(--bg);border-bottom:2px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;text-align:left;font-size:.72em;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.gram-table td{border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;vertical-align:top;}
.gram-table tr:last-child td{border-bottom:none;}
.gram-table tr:nth-child(even) td{background:#f4f0e6;}
.gram-table td:last-child,.gram-table th:last-child{border-right:none;}
.hl-qu{color:var(--qu-color);font-weight:700;}
.hl-to{color:var(--to-color);font-weight:700;}
.hl-ni{color:var(--ni-color);font-weight:700;}
.hl-au{color:var(--au-color);font-weight:700;}
.hl{color:var(--accent);font-weight:700;}
.dim{color:var(--text3);font-size:.88em;}
.ok-cell{color:var(--green);font-weight:700;}
.err-cell{color:var(--red);font-weight:600;font-style:italic;}
.chip-bar{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.chip{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;white-space:nowrap;}
.chip:hover{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.chip.qu.active{background:var(--qu-color);border-color:var(--qu-color);}
.chip.to.active{background:var(--to-color);border-color:var(--to-color);}
.chip.ni.active{background:var(--ni-color);border-color:var(--ni-color);}
.chip.au.active{background:var(--au-color);border-color:var(--au-color);}
.chip-panel{display:none;}.chip-panel.active{display:block;}
.sec-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px;}
.trap-cards{display:flex;flex-direction:column;gap:10px;}
.trap-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.trap-card-header{padding:11px 14px;background:var(--bg);}
.trap-name{font-weight:700;font-size:.9em;color:var(--text);margin-bottom:7px;}
.trap-vs{display:flex;gap:8px;flex-wrap:wrap;}
.trap-wrong{background:var(--red-bg);border:1.5px solid #d09098;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--red);font-weight:500;}
.trap-right{background:var(--green-bg);border:1.5px solid #80b890;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--green);font-weight:500;}
.trap-expl{padding:10px 14px 12px;font-size:.86em;color:var(--text2);line-height:1.6;border-top:1px solid var(--border);background:var(--card);}
.trap-expl strong{color:var(--text);font-weight:700;}
.exercise-controls{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:var(--shadow-sm);}
.exercise-controls h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:14px;}
.ctrl-label{font-size:.7em;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:7px;display:block;}
.ex-options{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ex-opt-btn{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.ex-opt-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.row-btns{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.pill-btn{border:1.5px solid var(--border);border-radius:20px;padding:5px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.pill-btn:hover:not(.active){background:var(--border);}
.pill-btn.active{background:var(--text);color:var(--bg);border-color:var(--text);}
.pill-btn.diff.active.A2{background:var(--green);border-color:var(--green);color:#fff;}
.pill-btn.diff.active.B1{background:var(--blue);border-color:var(--blue);color:#fff;}
.pill-btn.diff.active.B2{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-generate{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:.92em;font-weight:700;cursor:pointer;background:var(--accent);color:white;transition:all .18s;margin-top:4px;}
.btn-generate:hover:not(:disabled){filter:brightness(1.1);box-shadow:0 4px 14px rgba(122,90,10,.32);}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;}
.spinner{display:none;animation:spin .8s linear infinite;}
.btn-generate.loading .spinner{display:inline;}
.btn-generate.loading .btn-icon{display:none;}
@keyframes spin{to{transform:rotate(360deg);}}
.progress-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:14px;display:none;}
.progress-wrap.visible{display:block;}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-size:.78em;color:var(--text3);font-weight:600;}
.progress-frac{font-size:.92em;font-weight:700;color:var(--accent);}
.progress-track{height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .35s ease;}
.progress-score{display:flex;gap:14px;margin-top:9px;font-size:.8em;flex-wrap:wrap;align-items:center;}
.score-item{display:flex;align-items:center;gap:5px;font-weight:500;color:var(--text2);}
.score-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.score-dot.g{background:var(--green);}.score-dot.r{background:var(--red);}
.btn-retry{border:1.5px solid var(--border);border-radius:20px;padding:5px 13px;font-family:'DM Sans',sans-serif;font-size:.78em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;margin-left:auto;}
.btn-retry:hover{background:var(--border);}
.final-score-bar{display:none;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;}
.final-score-bar.visible{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.final-num{font-size:1.5rem;font-weight:700;color:var(--accent);}
.final-label{font-size:.74em;color:var(--text3);}
.final-track{flex:1;min-width:80px;height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.final-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.final-msg{font-size:.84em;color:var(--text2);width:100%;font-weight:500;}
.exercise-area{display:none;}.exercise-area.visible{display:block;}
.exercise-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;}
.exercise-card-header{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg);border-bottom:1px solid var(--border);}
.ex-num{font-weight:700;color:var(--accent);font-size:.88em;}
.ex-type-badge{font-size:.68em;font-weight:700;letter-spacing:.07em;text-transform:uppercase;background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-mid);border-radius:12px;padding:2px 8px;}
.ex-diff-badge{font-size:.68em;font-weight:700;border-radius:12px;padding:2px 8px;}
.ex-diff-badge.A2{background:var(--green-bg);color:var(--green);border:1px solid #80b890;}
.ex-diff-badge.B1{background:var(--blue-bg);color:var(--blue);border:1px solid #90a8e0;}
.ex-diff-badge.B2{background:var(--warn-bg);color:var(--accent);border:1px solid var(--accent-mid);}
.ex-status{margin-left:auto;}
.exercise-body{padding:16px 18px;}
.exercise-prompt{line-height:1.7;margin-bottom:12px;color:var(--text);}
.exercise-prompt em{color:var(--accent);font-style:italic;font-weight:600;}
.fill-input{border:none;border-bottom:2px solid var(--accent-mid);background:var(--accent-light);padding:2px 8px;border-radius:4px 4px 0 0;font-family:'DM Sans',sans-serif;font-size:1em;color:var(--text);min-width:150px;outline:none;transition:border-color .15s;}
.fill-input:focus{border-bottom-color:var(--accent);}
.fill-input.ok{background:var(--green-bg);border-bottom-color:var(--green);}
.fill-input.err{background:var(--red-bg);border-bottom-color:var(--red);}
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.choice-btn{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.88em;font-weight:500;cursor:pointer;text-align:left;background:var(--bg);color:var(--text);transition:all .15s;}
.choice-btn:hover:not(:disabled){border-color:var(--accent);background:var(--accent-light);}
.choice-btn.ok{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:700;}
.choice-btn.err{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.choice-btn:disabled{cursor:default;}
.transform-input{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.9em;background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;transition:border-color .15s;}
.transform-input:focus{border-color:var(--accent);}
.transform-input.ok{background:var(--green-bg);border-color:var(--green);}
.transform-input.err{background:var(--red-bg);border-color:var(--red);}
.btn-check{border:1.5px solid var(--accent);border-radius:20px;padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:700;cursor:pointer;background:transparent;color:var(--accent);transition:all .15s;}
.btn-check:hover:not(:disabled){background:var(--accent);color:white;}
.btn-check:disabled{opacity:.35;cursor:default;}
.ex-feedback{display:none;border-radius:var(--radius-sm);padding:11px 14px;line-height:1.55;margin-top:10px;font-size:.9em;}
.ex-feedback.visible{display:block;}
.ex-feedback.ok{background:var(--green-bg);border:1.5px solid #80b890;color:#0e4818;}
.ex-feedback.err{background:var(--red-bg);border:1.5px solid #c08090;color:#700018;}
.fb-rule-link{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:.84em;font-weight:700;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;}
.skeleton-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:12px;}
.skel{background:linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.4s infinite;border-radius:4px;height:13px;margin-bottom:9px;}
@keyframes skel{to{background-position:-200% 0;}}
.state-msg{text-align:center;padding:40px 20px;color:var(--text3);}
.state-icon{font-size:2rem;margin-bottom:10px;}
.state-msg p{max-width:260px;margin:0 auto;line-height:1.6;font-weight:500;}
</style>
</head>
<body>
<header class="site-header">
  <div class="header-top">
    <h1>Les Indéfinis</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1</div>
  <div class="stats-row">
    <div class="stat-pill qu">Quantité partielle</div>
    <div class="stat-pill to">Totalité / tout</div>
    <div class="stat-pill ni">Négation / aucun</div>
    <div class="stat-pill au">Autres indéfinis</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>
<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>
<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-quantite',this)">2. Quantité partielle</button>
    <button class="snav-btn"        onclick="showSection('s-tout',this)">3. Tout / toute / tous</button>
    <button class="snav-btn"        onclick="showSection('s-negatifs',this)">4. Indéfinis négatifs</button>
    <button class="snav-btn"        onclick="showSection('s-autres',this)">5. Autres indéfinis</button>
    <button class="snav-btn"        onclick="showSection('s-nimporte',this)">6. N'importe qui/quoi/où</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">7. Trampas</button>
  </div>
</div>
<div class="main-layout">
<div class="panel active" id="panel-ref">
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los <strong>indéfinis</strong> expresan cantidad, identidad o referencia de forma imprecisa o no especificada. Son extraordinariamente frecuentes en francés — aparecen en casi todos los textos de comprensión lectora del DELF B1 y son necesarios para la producción. Sus errores de acuerdo y construcción son los más sistemáticos entre hispanohablantes.
      </div>

      <div class="sec-label">Clasificación por función</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Categoría</th><th>Indéfinis</th><th>Función</th></tr></thead>
        <tbody>
          <tr><td><strong class="hl-qu">Quantité partielle</strong></td><td>quelques, plusieurs, certains/es, beaucoup de, peu de, la plupart de, la majorité de</td><td>Cantidad imprecisa</td></tr>
          <tr><td><strong class="hl-to">Totalité</strong></td><td>tout / toute / tous / toutes, chaque, chacun/e</td><td>Totalidad, cada uno</td></tr>
          <tr><td><strong class="hl-ni">Négatifs</strong></td><td>aucun/e, personne, rien, nul</td><td>Negación total</td></tr>
          <tr><td><strong class="hl-au">Identité imprécise</strong></td><td>quelqu'un, quelque chose, certain/s, même, autre, tel/le, l'un l'autre</td><td>Persona/cosa indeterminada</td></tr>
          <tr><td><strong class="hl-au">Indiscriminés</strong></td><td>n'importe qui/quoi/où/quand/comment/quel</td><td>Sin restricción, cualquier</td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Puntos críticos de acuerdo</div>
      <div class="green-box">
        <strong>1. Certains/certaines</strong> — concuerda con el género del sustantivo.<br>
        <strong>2. Tout/toute/tous/toutes</strong> — cuatro formas según género y número.<br>
        <strong>3. Chacun/chacune</strong> — concuerda con el género.<br>
        <strong>4. Aucun/aucune + singular</strong> — sustantivo siempre en singular.<br>
        <strong>5. Quelqu'un + de + adjectif</strong> — <em>de</em> es obligatorio.
      </div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>La plupart de</strong> rige siempre el verbo en <strong>plural</strong> aunque parezca singular: <em>La plupart des gens <strong>pensent</strong></em> ✓ — <em>pense</em> ✗. Es la trampa más frecuente con los indéfinis de cantidad.</div>
      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-quantite">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los indéfinis de cantidad parcial expresan una parte o una cantidad imprecisa de un conjunto. Los errores más frecuentes son de acuerdo (certains/certaines) y de concordancia verbal (la plupart → plural).
      </div>

      <div class="chip-bar">
        <button class="chip qu active" onclick="selectChip('quant',0)">Quelques / plusieurs</button>
        <button class="chip qu"        onclick="selectChip('quant',1)">Certains / certaines</button>
        <button class="chip qu"        onclick="selectChip('quant',2)">La plupart de / la majorité de</button>
        <button class="chip qu"        onclick="selectChip('quant',3)">Beaucoup de / peu de / assez de / trop de</button>
      </div>
      <div id="quant-panels">

        <div class="chip-panel active" id="quant-p-0">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-qu">Quelques</th><th class="hl-qu">Plusieurs</th></tr></thead>
            <tbody>
              <tr><td><strong>Significado</strong></td><td>unos pocos (cantidad pequeña)</td><td>varios (más de dos, cantidad notable)</td></tr>
              <tr><td><strong>Acuerdo</strong></td><td>invariable (siempre pl.)</td><td>invariable (siempre pl.)</td></tr>
              <tr><td><strong>Artículo</strong></td><td>sin artículo</td><td>sin artículo</td></tr>
              <tr><td><strong>Posición</strong></td><td>antes del sustantivo</td><td>antes del sustantivo o solo</td></tr>
            </tbody>
          </table></div>
          <div class="example-block qu">
            <div class="ex-fr">J'ai acheté <span class="equ">quelques</span> livres ce week-end.</div>
            <div class="ex-es">He comprado unos libros este fin de semana. <em>(pocos)</em></div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Il reste encore <span class="equ">quelques</span> places disponibles.</div>
            <div class="ex-es">Quedan todavía algunas plazas disponibles.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">J'ai visité <span class="equ">plusieurs</span> villes pendant mon voyage.</div>
            <div class="ex-es">Visité varias ciudades durante mi viaje. <em>(más de dos)</em></div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Elle a essayé <span class="equ">plusieurs</span> fois sans succès.</div>
            <div class="ex-es">Lo intentó varias veces sin éxito.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">— Tu as des amis là-bas ? — Oui, <span class="equ">quelques-uns</span>.</div>
            <div class="ex-es">— ¿Tienes amigos allí? — Sí, algunos.</div>
            <div class="ex-note">quelques-uns / quelques-unes = pronom</div>
          </div>
        </div>

        <div class="chip-panel" id="quant-p-1">
          <div class="def-box"><strong>Certains / certaines</strong> concuerda en género con el sustantivo al que acompaña o al que sustituye. Error muy frecuente: usar siempre <em>certains</em> sin respetar el femenino.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Género</th><th>Forma</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Masc. pl.</td><td class="hl-qu">certains</td><td><em>Certains étudiants ont réussi.</em></td></tr>
              <tr><td>Fém. pl.</td><td class="hl-qu">certaines</td><td><em>Certaines étudiantes ont réussi.</em></td></tr>
              <tr><td>Masc. pl. (pronom)</td><td class="hl-qu">certains</td><td><em>Certains pensent que…</em></td></tr>
              <tr><td>Fém. pl. (pronom)</td><td class="hl-qu">certaines</td><td><em>Certaines sont d'accord.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Certaines</span> personnes préfèrent le télétravail.</div>
            <div class="ex-es">Algunas personas prefieren el teletrabajo.</div>
            <div class="ex-note">personnes = fém. → certaines ✓</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Certains</span> problèmes n'ont pas encore été résolus.</div>
            <div class="ex-es">Algunos problemas no han sido aún resueltos.</div>
            <div class="ex-note">problèmes = masc. → certains ✓</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Certaines</span> de ses idées sont vraiment originales.</div>
            <div class="ex-es">Algunas de sus ideas son realmente originales.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Certains</span> affirment que la situation va s'améliorer.</div>
            <div class="ex-es">Algunos afirman que la situación va a mejorar.</div>
          </div>
        </div>

        <div class="chip-panel" id="quant-p-2">
          <div class="def-box"><strong>La plupart de</strong> y <strong>la majorité de</strong> van siempre seguidos de un sustantivo plural y rigen el verbo en <strong>plural</strong>.</div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">La plupart des</span> gens <strong>pensent</strong> que le changement est nécessaire.</div>
            <div class="ex-es">La mayoría de la gente piensa que el cambio es necesario.</div>
            <div class="ex-note">verbo en plural aunque "la plupart" parezca singular</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">La plupart du</span> temps, il arrive en retard.</div>
            <div class="ex-es">La mayoría de las veces, llega tarde.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">La majorité des</span> étudiants <strong>ont</strong> choisi cette option.</div>
            <div class="ex-es">La mayoría de los estudiantes eligieron esta opción.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">La plupart</span> <strong>sont</strong> d'accord avec cette décision.</div>
            <div class="ex-es">La mayoría está de acuerdo con esta decisión.</div>
            <div class="ex-note">sin sustantivo → pronom → siempre plural</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Un grand nombre de</span> participants <strong>ont</strong> répondu au sondage.</div>
            <div class="ex-es">Un gran número de participantes respondió a la encuesta.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>La plupart des gens <strong>pense</strong></em> ✗ — <em>la plupart des gens <strong>pensent</strong></em> ✓. El verbo va siempre en plural con <em>la plupart, la majorité, un grand nombre</em>.</div></div>
        </div>

        <div class="chip-panel" id="quant-p-3">
          <div class="def-box">Estas expresiones de cantidad van directamente seguidas de un sustantivo <strong>sin artículo</strong>. Con un sustantivo definido, el artículo se fusiona: <em>beaucoup du / beaucoup de la</em> ✗ → siempre <em>beaucoup de</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Expresión</th><th>Significado</th><th>Construcción</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-qu">beaucoup de</strong></td><td>mucho/a/os/as</td><td>beaucoup de + nom (sin artículo)</td></tr>
              <tr><td><strong class="hl-qu">peu de</strong></td><td>poco/a/os/as</td><td>peu de + nom (sin artículo)</td></tr>
              <tr><td><strong class="hl-qu">assez de</strong></td><td>bastante/s</td><td>assez de + nom (sin artículo)</td></tr>
              <tr><td><strong class="hl-qu">trop de</strong></td><td>demasiado/a/os/as</td><td>trop de + nom (sin artículo)</td></tr>
              <tr><td><strong class="hl-qu">autant de</strong></td><td>tanto/a/os/as</td><td>autant de + nom (sin artículo)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block qu">
            <div class="ex-fr">Il y a <span class="equ">beaucoup de</span> travail en ce moment.</div>
            <div class="ex-es">Hay mucho trabajo en este momento.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Elle a <span class="equ">peu de</span> temps libre depuis sa promotion.</div>
            <div class="ex-es">Tiene poco tiempo libre desde su ascenso.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Il y a <span class="equ">trop de</span> bruit ici pour se concentrer.</div>
            <div class="ex-es">Hay demasiado ruido aquí para concentrarse.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Tu as <span class="equ">assez de</span> temps pour finir ce soir.</div>
            <div class="ex-es">Tienes bastante tiempo para terminar esta noche.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Beaucoup des livres</em> ✗ — <em>beaucoup de livres</em> ✓. Nunca artículo tras estas expresiones. Excepción con referente específico: <em>beaucoup de ces livres</em> (de + ces = ok).</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-tout">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong>Tout</strong> tiene cuatro formas que cambian completamente de función: como déterminant, como pronom, como adverbe y en expresiones fijas. La confusión entre estas formas es uno de los errores más frecuentes del DELF B1.
      </div>

      <div class="chip-bar">
        <button class="chip to active" onclick="selectChip('tout',0)">Tout comme déterminant</button>
        <button class="chip to"        onclick="selectChip('tout',1)">Tous / toutes comme pronom</button>
        <button class="chip to"        onclick="selectChip('tout',2)">Tout comme adverbe</button>
        <button class="chip to"        onclick="selectChip('tout',3)">Chaque / chacun / chacune</button>
      </div>
      <div id="tout-panels">

        <div class="chip-panel active" id="tout-p-0">
          <div class="def-box">Como <strong>déterminant</strong>, precede a un artículo y un sustantivo. Las cuatro formas dependen del género y número del sustantivo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Forma</th><th>Uso</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-to">tout le</td><td>masc. sing.</td><td><em>tout le monde, tout le temps</em></td></tr>
              <tr><td class="hl-to">toute la</td><td>fém. sing.</td><td><em>toute la nuit, toute la journée</em></td></tr>
              <tr><td class="hl-to">tous les</td><td>masc. pl.</td><td><em>tous les jours, tous les étudiants</em></td></tr>
              <tr><td class="hl-to">toutes les</td><td>fém. pl.</td><td><em>toutes les femmes, toutes les semaines</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Tout le monde</span> est d'accord avec cette décision.</div>
            <div class="ex-es">Todo el mundo está de acuerdo con esta decisión.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Elle travaille <span class="eto">tous les jours</span> sans exception.</div>
            <div class="ex-es">Trabaja todos los días sin excepción.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Il a dormi <span class="eto">toute la nuit</span> sans se réveiller.</div>
            <div class="ex-es">Durmió toda la noche sin despertarse.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Toutes les</span> informations sont disponibles sur le site.</div>
            <div class="ex-es">Toda la información está disponible en el sitio web.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Il appelle sa mère <span class="eto">tous les</span> soirs.</div>
            <div class="ex-es">Llama a su madre todas las noches.</div>
          </div>
        </div>

        <div class="chip-panel" id="tout-p-1">
          <div class="def-box">Como <strong>pronom</strong>, <em>tous/toutes</em> sustituye a un sustantivo ya mencionado. La <strong>s de <em>tous</em> se pronuncia</strong> cuando es pronom (/tus/). Cuando es déterminant, la s no se pronuncia (/tu/).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Pronom</th><th>Pronunciación</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-to">tous</td><td>/tus/ — s pronunciada</td><td><em>Ils sont <strong>tous</strong> venus.</em></td></tr>
              <tr><td class="hl-to">toutes</td><td>/tut/ — s muda</td><td><em>Elles sont <strong>toutes</strong> d'accord.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block to">
            <div class="ex-fr">Les étudiants sont <span class="eto">tous</span> arrivés à l'heure. <span class="ex-note">(/tus/ — pronom)</span></div>
            <div class="ex-es">Los estudiantes han llegado todos a tiempo.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Les candidates sont <span class="eto">toutes</span> excellentes.</div>
            <div class="ex-es">Las candidatas son todas excelentes.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">J'ai invité mes amis et ils sont <span class="eto">tous</span> venus.</div>
            <div class="ex-es">Invité a mis amigos y vinieron todos.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Mes clés ? Je les ai <span class="eto">toutes</span> perdues !</div>
            <div class="ex-es">¿Mis llaves? ¡Las he perdido todas!</div>
          </div>
          <div class="note-box"><strong>Tout comme pronom neutre:</strong> <em>Tout va bien</em> (todo va bien). <em>Il a tout mangé</em> (lo comió todo). <em>Tout</em> neutro es siempre masc. sing.</div>
        </div>

        <div class="chip-panel" id="tout-p-2">
          <div class="def-box">Como <strong>adverbe</strong> (= completamente, totalmente), <em>tout</em> es generalmente <strong>invariable</strong>. Excepción: ante un adjetivo femenino que empieza por consonante → <em>toute</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Contexto</th><th>Forma</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Ante adj. masc. o fém. + voyelle</td><td class="hl-to">tout</td><td><em>Il est <strong>tout</strong> surpris. / Elle est <strong>tout</strong> étonnée.</em></td></tr>
              <tr><td>Ante adj. fém. + consonne</td><td class="hl-to">toute</td><td><em>Elle est <strong>toute</strong> petite. / Elle est <strong>toute</strong> contente.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block to">
            <div class="ex-fr">Il est <span class="eto">tout</span> surpris par cette nouvelle.</div>
            <div class="ex-es">Está completamente sorprendido por esta noticia.</div>
            <div class="ex-note">surpris = adj. masc. → tout (invariable)</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Elle est <span class="eto">toute</span> petite mais très courageuse.</div>
            <div class="ex-es">Es muy pequeñita pero muy valiente.</div>
            <div class="ex-note">petite = adj. fém. commençant par consonne → toute</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Elle était <span class="eto">tout</span> émue en recevant son prix.</div>
            <div class="ex-es">Estaba muy emocionada al recibir su premio.</div>
            <div class="ex-note">émue = fém. commençant par voyelle → tout (invariable)</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">C'est <span class="eto">tout</span> à fait normal dans cette situation.</div>
            <div class="ex-es">Es totalmente normal en esta situación.</div>
          </div>
        </div>

        <div class="chip-panel" id="tout-p-3">
          <div class="def-box"><strong>Chaque</strong> (adjectif, invariable) se usa con sustantivo singular. <strong>Chacun / chacune</strong> (pronom) concuerda en género y puede usarse solo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-to">Chaque</th><th class="hl-to">Chacun / Chacune</th></tr></thead>
            <tbody>
              <tr><td><strong>Función</strong></td><td>Adjectif + nom sing.</td><td>Pronom</td></tr>
              <tr><td><strong>Acuerdo</strong></td><td>Invariable</td><td>Chacun (masc.) / Chacune (fém.)</td></tr>
              <tr><td><strong>Ejemplo</strong></td><td><em>Chaque élève a répondu.</em></td><td><em>Chacun a répondu.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Chaque</span> étudiant doit rendre son devoir vendredi.</div>
            <div class="ex-es">Cada estudiante debe entregar su tarea el viernes.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Chacun</span> est responsable de ses propres actions.</div>
            <div class="ex-es">Cada uno es responsable de sus propias acciones.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Chacune</span> des candidates a présenté son projet.</div>
            <div class="ex-es">Cada una de las candidatas presentó su proyecto.</div>
            <div class="ex-note">candidates = fém. → chacune ✓</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr">Il a offert un cadeau à <span class="eto">chacun</span> de ses collègues.</div>
            <div class="ex-es">Le dio un regalo a cada uno de sus colegas.</div>
          </div>
          <div class="example-block to">
            <div class="ex-fr"><span class="eto">Chaque</span> fois que je le vois, il est de bonne humeur.</div>
            <div class="ex-es">Cada vez que lo veo, está de buen humor.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-negatifs">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los indéfinis négatifs niegan la existencia de personas, cosas o cantidad. Se combinan siempre con <strong>ne</strong> para formar la negación. Su posición en la frase y en los temps composés sigue reglas específicas ya vistas en el bloque de négation.
      </div>

      <div class="chip-bar">
        <button class="chip ni active" onclick="selectChip('neg',0)">Aucun / aucune</button>
        <button class="chip ni"        onclick="selectChip('neg',1)">Personne</button>
        <button class="chip ni"        onclick="selectChip('neg',2)">Rien</button>
        <button class="chip ni"        onclick="selectChip('neg',3)">Como sujeto — Aucun ne / Personne ne / Rien ne</button>
      </div>
      <div id="neg-panels">

        <div class="chip-panel active" id="neg-p-0">
          <div class="def-box"><strong>Aucun / aucune</strong> = ningún / ninguna. Determina un sustantivo siempre en <strong>singular</strong>. Concuerda en género. Requiere <em>ne</em> antes del verbo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Forma</th><th>Género</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-ni">aucun</td><td>masc. sing.</td><td><em>Il n'a fait <strong>aucun</strong> effort.</em></td></tr>
              <tr><td class="hl-ni">aucune</td><td>fém. sing.</td><td><em>Elle n'a <strong>aucune</strong> idée.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block ni">
            <div class="ex-fr">Je <span class="eni">ne</span> vois <span class="eni">aucun</span> problème avec cette solution.</div>
            <div class="ex-es">No veo ningún problema con esta solución.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Elle <span class="eni">n'</span>a <span class="eni">aucune</span> raison de se plaindre.</div>
            <div class="ex-es">No tiene ninguna razón para quejarse.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Il <span class="eni">n'</span>y a <span class="eni">aucun</span> doute : il a tort.</div>
            <div class="ex-es">No hay ninguna duda: está equivocado.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Ils <span class="eni">n'</span>ont pris <span class="eni">aucune</span> décision concrète.</div>
            <div class="ex-es">No tomaron ninguna decisión concreta.</div>
            <div class="ex-note">temps composé: aucune + nom après p.p.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Sustantivo tras <em>aucun/aucune</em> siempre en <strong>singular</strong>: <em>aucun problème</em> ✓ — <em>aucuns problèmes</em> ✗. Solo excepción: pluralia tantum (<em>aucuns frais</em>).</div></div>
        </div>

        <div class="chip-panel" id="neg-p-1">
          <div class="def-box"><strong>Personne</strong> = nadie. Como COD va después del verbo (temps simples) o después del participio (temps composés). Invariable.</div>
          <div class="example-block ni">
            <div class="ex-fr">Je <span class="eni">ne</span> connais <span class="eni">personne</span> ici.</div>
            <div class="ex-es">No conozco a nadie aquí.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Il <span class="eni">n'</span>a invité <span class="eni">personne</span> à sa fête.</div>
            <div class="ex-es">No invitó a nadie a su fiesta.</div>
            <div class="ex-note">temps composé: personne APRÈS le p.p. ✓</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Elle <span class="eni">ne</span> veut voir <span class="eni">personne</span> en ce moment.</div>
            <div class="ex-es">No quiere ver a nadie en este momento.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">On <span class="eni">ne</span> peut faire confiance à <span class="eni">personne</span>.</div>
            <div class="ex-es">No se puede confiar en nadie.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Il <span class="eni">n'</span>a parlé à <span class="eni">personne</span> de ce projet.</div>
            <div class="ex-es">No le habló a nadie de ese proyecto.</div>
          </div>
        </div>

        <div class="chip-panel" id="neg-p-2">
          <div class="def-box"><strong>Rien</strong> = nada. Como COD va después del verbo (temps simples) o <strong>antes del participio</strong> (temps composés). Invariable.</div>
          <div class="example-block ni">
            <div class="ex-fr">Il <span class="eni">ne</span> dit <span class="eni">rien</span>.</div>
            <div class="ex-es">No dice nada.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Je <span class="eni">n'</span>ai <span class="eni">rien</span> compris à cette explication.</div>
            <div class="ex-es">No he entendido nada de esta explicación.</div>
            <div class="ex-note">temps composé: rien AVANT le p.p. ✓</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">On <span class="eni">n'</span>a <span class="eni">rien</span> trouvé de suspect.</div>
            <div class="ex-es">No encontramos nada sospechoso.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr">Elle <span class="eni">ne</span> mange <span class="eni">rien</span> depuis ce matin.</div>
            <div class="ex-es">No come nada desde esta mañana.</div>
          </div>
          <div class="note-box"><strong>Rien + de + adjectif:</strong> <em>Il n'y a rien <strong>d'</strong>intéressant ici</em>. Como <em>quelque chose</em>, el adjectif va precedido de <em>de</em>.</div>
        </div>

        <div class="chip-panel" id="neg-p-3">
          <div class="def-box">Los tres indéfinis négatifs pueden ser <strong>sujetos</strong>. En ese caso van al inicio de la frase y <em>ne</em> va justo antes del verbo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Como COD</th><th>Como sujeto</th></tr></thead>
            <tbody>
              <tr><td>Il ne voit <span class="hl-ni">rien</span>.</td><td><span class="hl-ni">Rien</span> ne se passe.</td></tr>
              <tr><td>Il ne voit <span class="hl-ni">personne</span>.</td><td><span class="hl-ni">Personne</span> ne sait pourquoi.</td></tr>
              <tr><td>Il n'a fait <span class="hl-ni">aucun</span> effort.</td><td><span class="hl-ni">Aucun</span> élève n'a répondu.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ni">
            <div class="ex-fr"><span class="eni">Rien</span> ne va plus.</div>
            <div class="ex-es">Ya nada va bien.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr"><span class="eni">Personne</span> n'était au courant de cette décision.</div>
            <div class="ex-es">Nadie estaba al corriente de esta decisión.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr"><span class="eni">Aucune</span> solution n'a été trouvée pour l'instant.</div>
            <div class="ex-es">No se ha encontrado ninguna solución por el momento.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr"><span class="eni">Rien</span> n'est impossible si on le veut vraiment.</div>
            <div class="ex-es">Nada es imposible si de verdad se quiere.</div>
          </div>
          <div class="example-block ni">
            <div class="ex-fr"><span class="eni">Personne</span> ne l'a vu partir ce soir-là.</div>
            <div class="ex-es">Nadie lo vio marcharse aquella noche.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-autres">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Indéfinis de identidad imprecisa: <strong>quelqu'un, quelque chose</strong> (personas y cosas indefinidas), <strong>même</strong> (identidad/énfasis), <strong>autre</strong> (diferencia), <strong>l'un l'autre</strong> (reciprocidad). Todos tienen trampas de construcción específicas.
      </div>

      <div class="chip-bar">
        <button class="chip au active" onclick="selectChip('aut',0)">Quelqu'un / quelque chose + de + adj.</button>
        <button class="chip au"        onclick="selectChip('aut',1)">Même</button>
        <button class="chip au"        onclick="selectChip('aut',2)">Autre / d'autres / l'un l'autre</button>
        <button class="chip au"        onclick="selectChip('aut',3)">Tel / telle</button>
      </div>
      <div id="aut-panels">

        <div class="chip-panel active" id="aut-p-0">
          <div class="def-box">Tras <strong>quelqu'un, quelque chose, personne, rien</strong>, el adjectif va precedido obligatoriamente de <strong>de</strong>. Sin el <em>de</em> es error sistemático.</div>
          <div class="green-box">
            <strong>Regla:</strong> quelqu'un / quelque chose / personne / rien + <strong>de</strong> + adjectif masculin singulier<br>
            <em>quelqu'un <strong>d'</strong>intéressant, quelque chose <strong>de</strong> nouveau, rien <strong>d'</strong>important</em>
          </div>
          <div class="example-block au">
            <div class="ex-fr">J'ai rencontré <span class="eau">quelqu'un d'</span>extraordinaire ce soir.</div>
            <div class="ex-es">Conocí a alguien extraordinario esta noche.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il y a <span class="eau">quelque chose d'</span>étrange dans cette histoire.</div>
            <div class="ex-es">Hay algo extraño en esta historia.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il <span class="eau">n'</span>y a <span class="eau">rien de</span> nouveau à signaler.</div>
            <div class="ex-es">No hay nada nuevo que señalar.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Est-ce qu'il y a <span class="eau">quelqu'un de</span> disponible pour m'aider ?</div>
            <div class="ex-es">¿Hay alguien disponible para ayudarme?</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Je cherche <span class="eau">quelque chose de</span> pas trop cher.</div>
            <div class="ex-es">Busco algo no demasiado caro.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Quelqu'un intéressant</em> ✗ — <em>quelqu'un <strong>d'</strong>intéressant</em> ✓. El adjectif va siempre en masculin singulier independientemente del género de la persona referida.</div></div>
        </div>

        <div class="chip-panel" id="aut-p-1">
          <div class="def-box"><strong>Même</strong> tiene tres usos distintos: como adjectif (mismo/a), como adverbe (incluso), y en locuciones enfáticas (moi-même, lui-même…).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Uso</th><th>Forma</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Adjectif (mismo/a)</td><td>même + nom (concuerda)</td><td><em>Ils ont <strong>le même</strong> problème.</em></td></tr>
              <tr><td>Adverbe (incluso)</td><td>même + verbe/adj. (invariable)</td><td><em>Il travaille <strong>même</strong> le dimanche.</em></td></tr>
              <tr><td>Emphatique (mismo/a)</td><td>pronom disjoint + même</td><td><em>Je l'ai fait <strong>moi-même</strong>.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block au">
            <div class="ex-fr">Nous avons <span class="eau">les mêmes</span> goûts musicaux.</div>
            <div class="ex-es">Tenemos los mismos gustos musicales.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il a réparé la voiture <span class="eau">lui-même</span>.</div>
            <div class="ex-es">Reparó el coche él mismo.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Même</span> les experts ne comprennent pas ce phénomène.</div>
            <div class="ex-es">Incluso los expertos no entienden este fenómeno.</div>
            <div class="ex-note">même adverbe = incluso, invariable</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">C'est toujours <span class="eau">la même</span> chose avec lui.</div>
            <div class="ex-es">Siempre es lo mismo con él.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Elle a fait ça <span class="eau">elle-même</span> sans l'aide de personne.</div>
            <div class="ex-es">Lo hizo ella misma sin la ayuda de nadie.</div>
          </div>
        </div>

        <div class="chip-panel" id="aut-p-2">
          <div class="def-box"><strong>Autre</strong> expresa diferencia o alteridad. <strong>L'un l'autre / les uns les autres</strong> expresa reciprocidad.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Forma</th><th>Uso</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-au">un autre / une autre</td><td>otro/a (sing.)</td><td><em>Donne-moi <strong>un autre</strong> exemple.</em></td></tr>
              <tr><td class="hl-au">d'autres</td><td>otros/as (pl.)</td><td><em>Il y a <strong>d'autres</strong> solutions.</em></td></tr>
              <tr><td class="hl-au">les autres</td><td>los demás</td><td><em>Pense aux <strong>autres</strong>.</em></td></tr>
              <tr><td class="hl-au">l'un l'autre</td><td>el uno al otro (reciprocidad)</td><td><em>Ils s'aiment <strong>l'un l'autre</strong>.</em></td></tr>
              <tr><td class="hl-au">les uns les autres</td><td>unos a otros (pl.)</td><td><em>Aidons-nous <strong>les uns les autres</strong>.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block au">
            <div class="ex-fr">Ce n'est pas la bonne réponse — essaie <span class="eau">une autre</span> fois.</div>
            <div class="ex-es">No es la respuesta correcta — inténtalo otra vez.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il y a <span class="eau">d'autres</span> façons de résoudre ce problème.</div>
            <div class="ex-es">Hay otras formas de resolver este problema.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Ils se regardaient <span class="eau">l'un l'autre</span> sans rien dire.</div>
            <div class="ex-es">Se miraban el uno al otro sin decir nada.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Dans cette équipe, ils s'aident <span class="eau">les uns les autres</span>.</div>
            <div class="ex-es">En este equipo, se ayudan unos a otros.</div>
          </div>
        </div>

        <div class="chip-panel" id="aut-p-3">
          <div class="def-box"><strong>Tel / telle / tels / telles</strong> expresa identidad imprecisa o introduce un ejemplo. Concuerda en género y número.</div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Tel</span> père, <span class="eau">tel</span> fils.</div>
            <div class="ex-es">De tal palo, tal astilla. <em>(expresión fija)</em></div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">De <span class="eau">tels</span> comportements ne sont pas acceptables.</div>
            <div class="ex-es">Tales comportamientos no son aceptables.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Elle a vécu des expériences <span class="eau">telles</span> que peu de gens peuvent imaginer.</div>
            <div class="ex-es">Ha vivido experiencias tales que poca gente puede imaginar.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Des villes <span class="eau">telles que</span> Paris ou Lyon attirent de nombreux touristes.</div>
            <div class="ex-es">Ciudades como París o Lyon atraen a numerosos turistas.</div>
            <div class="ex-note">tel que = como, por ejemplo</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-nimporte">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Las expresiones <strong>n'importe</strong> expresan ausencia total de restricción o elección: cualquier persona, cualquier cosa, en cualquier sitio, en cualquier momento. Son muy frecuentes en oral y en textos informales. <em>N'importe quel/quelle</em> concuerda con el sustantivo que le sigue.
      </div>

      <div class="chip-bar">
        <button class="chip au active" onclick="selectChip('nim',0)">N'importe qui / quoi</button>
        <button class="chip au"        onclick="selectChip('nim',1)">N'importe où / quand / comment</button>
        <button class="chip au"        onclick="selectChip('nim',2)">N'importe quel / quelle</button>
        <button class="chip au"        onclick="selectChip('nim',3)">Uso y matiz vs. quelqu'un / quelque chose</button>
      </div>
      <div id="nim-panels">

        <div class="chip-panel active" id="nim-p-0">
          <div class="def-box"><strong>N'importe qui</strong> = cualquier persona (sin restricción). <strong>N'importe quoi</strong> = cualquier cosa / cualquier tontería.</div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">N'importe qui</span> peut s'inscrire à ce cours, c'est gratuit.</div>
            <div class="ex-es">Cualquier persona puede inscribirse en este curso, es gratuito.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Ce travail ne peut pas être fait par <span class="eau">n'importe qui</span> — il faut de l'expérience.</div>
            <div class="ex-es">Este trabajo no puede hacerlo cualquiera — hace falta experiencia.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il mange <span class="eau">n'importe quoi</span> sans faire attention à sa santé.</div>
            <div class="ex-es">Come cualquier cosa sin prestar atención a su salud.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Ne dis pas <span class="eau">n'importe quoi</span> — réfléchis avant de parler.</div>
            <div class="ex-es">No digas cualquier tontería — piensa antes de hablar.</div>
            <div class="ex-note">n'importe quoi en oral = una barbaridad, una tontería</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Tu peux demander à <span class="eau">n'importe qui</span> dans la rue.</div>
            <div class="ex-es">Puedes preguntarle a cualquiera en la calle.</div>
          </div>
        </div>

        <div class="chip-panel" id="nim-p-1">
          <div class="def-box">Expresiones de lugar, tiempo y manera sin restricción. Todas invariables.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Expresión</th><th>Significado</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-au">n'importe où</td><td>en cualquier sitio</td><td><em>Tu peux t'asseoir <strong>n'importe où</strong>.</em></td></tr>
              <tr><td class="hl-au">n'importe quand</td><td>en cualquier momento</td><td><em>Appelle-moi <strong>n'importe quand</strong>.</em></td></tr>
              <tr><td class="hl-au">n'importe comment</td><td>de cualquier manera</td><td><em>Il fait tout <strong>n'importe comment</strong>.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block au">
            <div class="ex-fr">Avec Internet, on peut travailler <span class="eau">n'importe où</span> dans le monde.</div>
            <div class="ex-es">Con Internet, se puede trabajar en cualquier parte del mundo.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Tu peux passer me voir <span class="eau">n'importe quand</span>, je suis toujours là.</div>
            <div class="ex-es">Puedes venir a verme cuando quieras, siempre estoy aquí.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il habille ses enfants <span class="eau">n'importe comment</span> — c'est un désastre.</div>
            <div class="ex-es">Viste a sus hijos de cualquier manera — es un desastre.</div>
            <div class="ex-note">n'importe comment en oral = mal, sin cuidado</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Je peux livrer la commande <span class="eau">n'importe où</span> en France métropolitaine.</div>
            <div class="ex-es">Puedo entregar el pedido en cualquier lugar de la Francia metropolitana.</div>
          </div>
        </div>

        <div class="chip-panel" id="nim-p-2">
          <div class="def-box"><strong>N'importe quel / quelle / quels / quelles</strong> + nom. Concuerda en género y número con el sustantivo que le sigue.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Forma</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-au">n'importe quel</td><td><em>n'importe <strong>quel</strong> médecin peut te dire ça.</em></td></tr>
              <tr><td class="hl-au">n'importe quelle</td><td><em>n'importe <strong>quelle</strong> solution serait mieux.</em></td></tr>
              <tr><td class="hl-au">n'importe quels</td><td><em>n'importe <strong>quels</strong> documents suffisent.</em></td></tr>
              <tr><td class="hl-au">n'importe quelles</td><td><em>n'importe <strong>quelles</strong> chaussures feront l'affaire.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">N'importe quel</span> étudiant peut participer à ce concours.</div>
            <div class="ex-es">Cualquier estudiante puede participar en este concurso.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Tu peux utiliser <span class="eau">n'importe quelle</span> couleur pour ce dessin.</div>
            <div class="ex-es">Puedes usar cualquier color para este dibujo.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il accepte <span class="eau">n'importe quelles</span> conditions pour obtenir ce poste.</div>
            <div class="ex-es">Acepta cualquier condición para conseguir ese puesto.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Dans <span class="eau">n'importe quel</span> pays, il faut respecter les lois locales.</div>
            <div class="ex-es">En cualquier país, hay que respetar las leyes locales.</div>
          </div>
        </div>

        <div class="chip-panel" id="nim-p-3">
          <div class="def-box">La diferencia entre <em>n'importe qui/quoi</em> y <em>quelqu'un/quelque chose</em> es de <strong>grado de restricción</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-qu">Quelqu'un / quelque chose</th><th class="hl-au">N'importe qui / quoi</th></tr></thead>
            <tbody>
              <tr><td><strong>Sentido</strong></td><td>una persona/cosa indeterminada</td><td>cualquier persona/cosa, sin restricción</td></tr>
              <tr><td><strong>Restricción</strong></td><td>puede implicar criterios</td><td>ninguna restricción ni criterio</td></tr>
              <tr><td><strong>Ejemplo</strong></td><td><em>Quelqu'un d'expérimenté peut le faire.</em> (alguien con experiencia)</td><td><em>N'importe qui peut le faire.</em> (cualquiera)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block qu">
            <div class="ex-fr">J'ai besoin de <span class="equ">quelqu'un de</span> fiable pour ce projet.</div>
            <div class="ex-es">Necesito a alguien de confianza para este proyecto. <em>(con criterios)</em></div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">N'importe qui</span> peut s'inscrire — il n'y a pas de critères.</div>
            <div class="ex-es">Cualquiera puede inscribirse — no hay criterios.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Tu peux acheter <span class="equ">quelque chose de</span> joli pour elle.</div>
            <div class="ex-es">Puedes comprarle algo bonito. <em>(indeterminado pero con cualidad)</em></div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Il mange <span class="eau">n'importe quoi</span> — il n'est vraiment pas difficile.</div>
            <div class="ex-es">Come cualquier cosa — no es nada exigente.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>
</div>
<div class="panel" id="panel-ex">
  <div class="exercise-controls">
    <h3>Generar ejercicios</h3>
    <span class="ctrl-label">Tipo</span>
    <div class="ex-options">
      <button class="ex-opt-btn active" data-type="fill">Completar huecos</button>
      <button class="ex-opt-btn" data-type="choice">Elección múltiple</button>
      <button class="ex-opt-btn" data-type="transform">Transformación</button>
      <button class="ex-opt-btn" data-type="mix">Mixto</button>
    </div>
    <span class="ctrl-label">Foco</span>
    <div class="ex-options" id="foco-btns">
      <button class="ex-opt-btn foco active" data-foco="mix">General (todo)</button>
      <button class="ex-opt-btn foco" data-foco="quantite">Quantité (plusieurs/certains/la plupart…)</button>
      <button class="ex-opt-btn foco" data-foco="tout">Tout / toute / tous / toutes</button>
      <button class="ex-opt-btn foco" data-foco="negatifs">Négatifs (aucun / personne / rien)</button>
      <button class="ex-opt-btn foco" data-foco="autres">Chacun / quelqu'un / quelque chose / même</button>
      <button class="ex-opt-btn foco" data-foco="nimporte">N'importe qui / quoi / où / quand / comment</button>
    </div>
    <span class="ctrl-label">Nivel</span>
    <div class="row-btns" id="diff-btns">
      <button class="pill-btn diff A2" onclick="setDiff('A2')">A2</button>
      <button class="pill-btn diff B1 active" onclick="setDiff('B1')">B1</button>
      <button class="pill-btn diff B2" onclick="setDiff('B2')">B2</button>
    </div>
    <span class="ctrl-label">Cantidad</span>
    <div class="row-btns" id="qty-btns">
      <button class="pill-btn qty" onclick="setQty(3)">3</button>
      <button class="pill-btn qty active" onclick="setQty(5)">5</button>
      <button class="pill-btn qty" onclick="setQty(8)">8</button>
    </div>
    <button class="btn-generate" id="btn-gen" onclick="generateExercises()">
      <span class="btn-icon">✨</span>
      <span class="spinner">⟳</span>
      Generar ejercicios
    </button>
  </div>
  <div class="progress-wrap" id="progress-wrap">
    <div class="progress-top">
      <span class="progress-label">Progreso</span>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="progress-frac" id="progress-frac">0 / 0</span>
        <button class="btn-retry" onclick="resetExercises()">↺ Nuevo</button>
      </div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="progress-score">
      <div class="score-item"><div class="score-dot g"></div><span id="score-correct">0 correctas</span></div>
      <div class="score-item"><div class="score-dot r"></div><span id="score-wrong">0 errores</span></div>
    </div>
  </div>
  <div class="final-score-bar" id="final-score-bar">
    <div><div class="final-num" id="final-num">—</div><div class="final-label">resultado final</div></div>
    <div class="final-track"><div class="final-fill" id="final-fill" style="width:0%"></div></div>
    <div class="final-msg" id="final-msg"></div>
  </div>
  <div class="exercise-area" id="exercise-area">
    <div class="state-msg">
      <div class="state-icon">✏️</div>
      <p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p>
    </div>
  </div>
</div>
</div>
<script>
const TRAPS = [
  {name:"La plupart de: acuerdo del verbo en plural",
   wrong:"La plupart des étudiants est satisfait. / La plupart a répondu correctement.",
   right:"La plupart des étudiants sont satisfaits. / La plupart ont répondu correctement.",
   expl:"<strong>La plupart</strong> rige siempre el verbo en <strong>plural</strong>, aunque parezca singular. <em>La plupart des gens pensent</em> ✓ — <em>pense</em> ✗. Lo mismo para <em>la majorité de, une partie de, un grand nombre de</em> cuando el sustantivo que sigue es plural."},
  {name:"Tout vs. tous: pronunciación y función",
   wrong:"Tout les jours (sin s audible). / Il a mangé tout les gâteaux.",
   right:"Tous les jours (s pronunciada). / Il a mangé tous les gâteaux.",
   expl:"<strong>Tout</strong> (adverbe) = completamente, totalmente — invariable. <strong>Tous</strong> (déterminant/pronom masc. pl.) — la s se pronuncia cuando es pronom: <em>Ils sont tous venus</em> (/tus/). Como determinante: <em>tous les jours</em> (/tu/). La confusión ortográfica tout/tous es muy frecuente."},
  {name:"Chacun / chacune: acuerdo de género",
   wrong:"Chacun des élèves a rendu son devoir. (correcto si élèves masc.) / Chacun des étudiantes…",
   right:"Chacune des étudiantes a rendu son devoir.",
   expl:"<strong>Chacun</strong> (masc.) / <strong>chacune</strong> (fém.) concuerda con el sustantivo al que se refiere. El error más frecuente es usar siempre <em>chacun</em> sin respetar el género femenino."},
  {name:"Quelqu'un / quelque chose + adjectif: de obligatorio",
   wrong:"J'ai rencontré quelqu'un intéressant. / Il y a quelque chose important à dire.",
   right:"J'ai rencontré quelqu'un d'intéressant. / Il y a quelque chose d'important à dire.",
   expl:"Tras <strong>quelqu'un, quelque chose, personne, rien</strong>, el adjetivo va siempre precedido de <strong>de</strong>: <em>quelqu'un <strong>de</strong> sympa, rien <strong>d'</strong>intéressant, personne <strong>d'</strong>autre</em>. Sin el <em>de</em> es un error sistemático de hispanohablantes."},
  {name:"Plusieurs vs. quelques: matiz de cantidad",
   wrong:"Il y a quelques dizaines de personnes. (si hay exactamente varias decenas, es correcto, pero…) / J'ai plusieurs ami.",
   right:"J'ai plusieurs amis. / Il a quelques livres (pocos). / Il a plusieurs livres (varios, más de dos).",
   expl:"<strong>Quelques</strong> = unos pocos (cantidad pequeña, subjetiva). <strong>Plusieurs</strong> = varios (más de dos, cantidad más notable). <em>Plusieurs</em> es invariable y no lleva artículo. <em>Quelques</em> tampoco lleva artículo pero el sustantivo va siempre en plural."},
  {name:"N'importe qui vs. quelqu'un",
   wrong:"N'importe qui peut entrer — il faut un badge. (contradictorio) / Quelqu'un peut le faire, mais c'est difficile.",
   right:"N'importe qui peut entrer sans badge. (sin restricción) / Quelqu'un d'expérimenté peut le faire.",
   expl:"<strong>N'importe qui</strong> = cualquier persona, sin restricción ni condición. <strong>Quelqu'un</strong> = una persona indeterminada pero no necesariamente cualquiera. Confundirlos cambia el sentido: <em>n'importe qui peut conduire</em> (cualquiera) vs. <em>quelqu'un peut conduire</em> (alguien puede)."},
  {name:"Certains vs. certaines: acuerdo con el sustantivo",
   wrong:"Certains personnes pensent que… / Certains idées sont intéressantes.",
   right:"Certaines personnes pensent que… / Certaines idées sont intéressantes.",
   expl:"<strong>Certains</strong> (masc. pl.) / <strong>certaines</strong> (fém. pl.) concuerda con el sustantivo. <em>Personnes</em> y <em>idées</em> son femeninos → <em>certaines</em>. Error muy frecuente: usar siempre <em>certains</em> como forma genérica."},
  {name:"Aucun + sustantivo en plural",
   wrong:"Aucuns problèmes n'ont été signalés. / Il n'a aucunes idées.",
   right:"Aucun problème n'a été signalé. / Il n'a aucune idée.",
   expl:"<strong>Aucun / aucune</strong> va siempre con el sustantivo en <strong>singular</strong>. La negación es total, por tanto no se necesita el plural. <em>Aucun problème</em> ✓ — <em>aucuns problèmes</em> ✗. Solo con pluralia tantum (sustantivos que solo existen en plural): <em>aucuns frais</em>."},
];

function renderTraps(){
  document.getElementById("trap-cards").innerHTML=TRAPS.map(t=>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

function selectChip(ns,idx){
  document.querySelectorAll(".chip-bar").forEach(bar=>{
    const first=bar.querySelector(".chip");
    if(first&&first.getAttribute("onclick")&&first.getAttribute("onclick").includes("'"+ns+"'"))
      bar.querySelectorAll(".chip").forEach((c,i)=>c.classList.toggle("active",i===idx));
  });
  const el=document.getElementById(ns+"-panels");
  if(el) el.querySelectorAll(":scope > .chip-panel").forEach((p,i)=>p.classList.toggle("active",i===idx));
}
function showSection(id,btn){
  document.querySelectorAll(".sec-block").forEach(s=>s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode,btn){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById("panel-"+mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display=mode==="ref"?"":"none";
}
function setFontSize(v){document.documentElement.style.setProperty("--fs",v+"px");}

let exType="fill",exDiff="B1",exQty=5,exFoco="mix";
let exTotal=0,exAnswered=0,exCorrect=0,exWrong=0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b=>b.addEventListener("click",function(){
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x=>x.classList.remove("active"));
  this.classList.add("active");exType=this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b=>b.addEventListener("click",function(){
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x=>x.classList.remove("active"));
  this.classList.add("active");exFoco=this.dataset.foco;
}));
function setDiff(d){
  exDiff=d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b=>{
    b.classList.remove("active","A2","B1","B2");
    if(b.textContent.trim()===d) b.classList.add("active",d);
  });
}
function setQty(q){
  exQty=q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b=>
    b.classList.toggle("active",parseInt(b.textContent.trim())===q));
}

const FOCO_DESC={
  mix:       "todos los indéfinis: quantité partielle (plusieurs/certains/la plupart de/beaucoup de/peu de/quelques), totalité (tout/toute/tous/toutes con acuerdo), négatifs (aucun/personne/rien con ne), chacun/chacune, quelqu'un/quelque chose/personne/rien + de + adjectif, même, n'importe qui/quoi/où/quand/comment/quel",
  quantite:  "indéfinis de quantité partielle: quelques (unos pocos), plusieurs (varios), certains/certaines (algunos, acuerdo fém.), beaucoup de/peu de/assez de/trop de (sin artículo), la plupart de (verbo en plural), la majorité de, un grand nombre de; acuerdo del verbo y del adjetivo",
  tout:      "tout/toute/tous/toutes: como déterminant (tout le monde, tous les jours, toute la nuit), como pronom (ils sont tous venus, toutes sont arrivées), como adverbe (elle est tout étonnée, invariable excepto devant adj. fém. commençant par consonne: toute petite), acuerdo y pronunciación",
  negatifs:  "indéfinis négatifs: aucun/aucune + nom singulier + ne, personne ne / ne… personne, rien ne / ne… rien; posición en temps composés (rien avant p.p., personne après); como sujeto (Rien ne se passe. Personne n'est venu. Aucun élève n'a répondu.)",
  autres:    "chacun/chacune (acuerdo fém.), quelqu'un / quelque chose / personne / rien + de + adjectif (de obligatorio), même (même chose, le même, moi-même), autre/d'autres/l'un l'autre, tel/telle (acuerdo)",
  nimporte:  "n'importe qui (cualquier persona), n'importe quoi (cualquier cosa), n'importe où (en cualquier sitio), n'importe quand (en cualquier momento), n'importe comment (de cualquier manera), n'importe quel/quelle + nom (acuerdo); matiz indiscriminado / sin elección",
};
const TYPE_DESC={
  fill:      "completar huecos: el alumno escribe el indéfini correcto o la forma acordada según género/número y contexto",
  choice:    "elección múltiple: 4 indéfinis o formas, solo una correcta según el sentido, el acuerdo y la construcción gramatical",
  transform: "transformación: reformular usando el indéfini indicado con los cambios de acuerdo y construcción necesarios",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS={
  "s-intro":"Panorama","s-quantite":"Quantité partielle","s-tout":"Tout / tous / toutes",
  "s-negatifs":"Indéfinis négatifs","s-autres":"Autres indéfinis","s-nimporte":"N'importe qui/quoi/où","s-trampas":"Trampas"
};

function renderExercises(exs){
  const area=document.getElementById("exercise-area");
  const labels={fill:"Completar",choice:"Elección múltiple",transform:"Transformación"};
  area.innerHTML=exs.map((ex,i)=>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex,i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex,i)=>{
    const chk=document.getElementById("chk-"+i);
    if(chk) chk.addEventListener("click",()=>checkAnswer(ex,i));
    const inp=document.getElementById("inp-"+i);
    if(inp) inp.addEventListener("keydown",e=>{if(e.key==="Enter") checkAnswer(ex,i);});
  });
}

function buildBody(ex,i){
  if(ex.type==="fill"){
    const parts=ex.prompt_parts||["",""];
    return `<div class="exercise-prompt">${parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||"…"}" autocomplete="off" spellcheck="false">${parts.slice(1).join("")}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  }
  if(ex.type==="choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if(ex.type==="transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase con indéfini…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex,i){
  const inp=document.getElementById("inp-"+i);
  if(!inp||inp.disabled) return;
  const ok=inp.value.trim().toLowerCase()===ex.answer.trim().toLowerCase();
  inp.classList.add(ok?"ok":"err");inp.disabled=true;
  const chk=document.getElementById("chk-"+i);if(chk) chk.disabled=true;
  showFeedback(i,ok,ex.answer,ex.explanation,ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx,chosen,correct){
  const c0=document.getElementById(`ch-${idx}-0`);
  if(!c0||c0.disabled) return;
  for(let j=0;j<4;j++){
    const b=document.getElementById(`ch-${idx}-${j}`);
    if(!b) continue;b.disabled=true;
    if(j===correct) b.classList.add("ok");else if(j===chosen) b.classList.add("err");
  }
  const card=document.getElementById("ex-card-"+idx);
  showFeedback(idx,chosen===correct,null,card.dataset.expl,card.dataset.rule);
  recordAnswer(chosen===correct);
}

function showFeedback(i,ok,ans,expl,ruleRef){
  document.getElementById("ex-st-"+i).textContent=ok?"✅":"❌";
  const fb=document.getElementById("ex-fb-"+i);
  fb.className="ex-feedback visible "+(ok?"ok":"err");
  const link=RULE_LABELS[ruleRef]?`<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>`:"";
  let html=ok?`<strong>✓ Correcto</strong>`:`<strong>✗ Incorrecto</strong>${ans?` — Respuesta: <strong>${ans}</strong>`:""}`;
  if(expl) html+=`<br><span style="font-size:.88em;opacity:.92;margin-top:3px;display:block">${expl}</span>`;
  html+=link;fb.innerHTML=html;
}

function goToRule(ref){
  switchMode("ref",document.querySelector(".mode-btn"));
  setTimeout(()=>{
    showSection(ref,document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:"smooth",block:"start"});
  },80);
}

function recordAnswer(ok){exAnswered++;if(ok)exCorrect++;else exWrong++;updateProgress();}

function updateProgress(){
  const pct=exTotal>0?(exAnswered/exTotal)*100:0;
  document.getElementById("progress-frac").textContent=`${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width=pct+"%";
  document.getElementById("score-correct").textContent=`${exCorrect} correcta${exCorrect!==1?"s":""}`;
  document.getElementById("score-wrong").textContent=`${exWrong} error${exWrong!==1?"es":""}`;
  if(exAnswered>=exTotal&&exTotal>0) showFinalScore();
}

function showFinalScore(){
  const pct=Math.round((exCorrect/exTotal)*100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent=`${exCorrect} / ${exTotal}`;
  const fill=document.getElementById("final-fill");
  fill.style.width=pct+"%";
  fill.style.background=pct>=80?"var(--green)":pct>=50?"var(--accent)":"var(--red)";
  const msgs={100:"Parfait ! Dominas los indéfinis. 🎉",80:"Très bien ! Repasa los errores.",50:"Bien, refuerza los bloques señalados.",0:"Vuelve a Referencia antes de repetir."};
  document.getElementById("final-msg").textContent=msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById("score-pill").style.display="";
  document.getElementById("score-pill-val").textContent=`${exCorrect}/${exTotal}`;
}

function resetExercises(){
  document.getElementById("exercise-area").innerHTML=`<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display="none";
  exAnswered=0;exCorrect=0;exWrong=0;
}

function esc(s){return(s||"").replace(/"/g,"&quot;").replace(/</g,"&lt;");}

renderTraps();
</script>
</body>
</html>
