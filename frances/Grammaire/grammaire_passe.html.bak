<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Temps du Passé</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ede9df;
  --card: #faf7f1;
  --border: #c4bead;
  --text: #1a1814;
  --text2: #44413a;
  --text3: #706c64;
  --accent: #7a5a0a;
  --accent-light: #f0e0c0;
  --accent-mid: #b89050;
  --warn-bg: #fdf0cc;
  --shadow: 0 2px 14px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.08);
  --radius: 14px;
  --radius-sm: 8px;
  --green: #1a6028;
  --green-bg: #e4f2e8;
  --red: #a81e2e;
  --red-bg: #fce6e8;
  --blue: #163494;
  --blue-bg: #e6ebf8;
  --purple: #6a1a8a;
  --purple-bg: #f2e6f8;
  --pc-color: #163494;
  --pc-bg: #e6ebf8;
  --imp-color: #1a6028;
  --imp-bg: #e4f2e8;
  --pqp-color: #6a1a8a;
  --pqp-bg: #f2e6f8;
  --fs: 15px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; font-size: var(--fs); }

/* ── HEADER ── */
.site-header { background: var(--card); border-bottom: 2px solid var(--border); padding: 20px 20px 14px; }
.header-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 3px; flex-wrap: wrap; }
.site-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.3rem, 5vw, 2rem); font-weight: 700; color: var(--text); }
.header-tag { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); background: var(--accent-light); border: 1px solid var(--accent-mid); border-radius: 20px; padding: 3px 10px; }
.subtitle { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; }
.stats-row { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; }
.stat-pill { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 4px 11px; font-size: 0.76rem; font-weight: 500; color: var(--text2); }
.stat-pill span { font-weight: 700; color: var(--text); }
.stat-pill.pc  { border-color: var(--pc-color);  color: var(--pc-color);  background: var(--pc-bg); }
.stat-pill.imp { border-color: var(--imp-color); color: var(--imp-color); background: var(--imp-bg); }
.stat-pill.pqp { border-color: var(--pqp-color); color: var(--pqp-color); background: var(--pqp-bg); }
.fs-wrap { display: flex; align-items: center; gap: 7px; margin-left: auto; }
.fs-slider { width: 76px; accent-color: var(--accent); cursor: pointer; }
.fs-sz { color: var(--text3); font-weight: 700; }

/* ── NAV ── */
.mode-toggle { display: flex; border-bottom: 2px solid var(--border); background: var(--card); }
.mode-btn { flex: 1; padding: 12px 8px; font-family: 'DM Sans', sans-serif; font-size: 0.84rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; margin-bottom: -2px; }
.mode-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.section-nav { position: sticky; top: 0; z-index: 200; background: var(--card); border-bottom: 2px solid var(--border); box-shadow: var(--shadow-sm); }
.section-nav-inner { display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.section-nav-inner::-webkit-scrollbar { display: none; }
.snav-btn { flex-shrink: 0; padding: 11px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.snav-btn:hover { color: var(--text2); }
.snav-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

/* ── LAYOUT ── */
.main-layout { max-width: 860px; margin: 0 auto; padding: 16px 16px 40px; }
.panel { display: none; } .panel.active { display: block; }
.sec-block { display: none; } .sec-block.active { display: block; }

/* ── CARDS ── */
.gram-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 14px; overflow: hidden; }
.gram-card-body { padding: 18px; }

/* ── BOXES ── */
.def-box { background: var(--warn-bg); border-left: 4px solid var(--accent); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 12px 15px; margin-bottom: 14px; line-height: 1.65; color: var(--text); }
.def-box strong { color: var(--accent); font-weight: 700; }
.warn-box { background: #fff4e0; border: 1px solid #c8900a; border-radius: var(--radius-sm); padding: 10px 13px; margin: 10px 0; font-size: 0.9em; display: flex; gap: 8px; align-items: flex-start; }
.warn-icon { flex-shrink: 0; margin-top: 1px; }
.warn-text { color: var(--text2); line-height: 1.55; }
.warn-text strong { color: #7a4400; font-weight: 700; }
.note-box { background: var(--purple-bg); border-left: 4px solid var(--purple); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.note-box strong { color: var(--purple); font-weight: 700; }

/* ── EXAMPLE BLOCKS — coloured by tense ── */
.example-block { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 8px 0; }
.example-block.pc  { background: var(--pc-bg);  border-left: 4px solid var(--pc-color); }
.example-block.imp { background: var(--imp-bg); border-left: 4px solid var(--imp-color); }
.example-block.pqp { background: var(--pqp-bg); border-left: 4px solid var(--pqp-color); }
.example-block.mix { background: var(--blue-bg); border-left: 4px solid #444; }
.example-block.neu { background: var(--blue-bg); border-left: 4px solid var(--blue); }
.ex-fr { font-weight: 600; margin-bottom: 3px; color: var(--text); }
.ex-fr .epc  { color: var(--pc-color);  font-weight: 700; font-style: normal; }
.ex-fr .eimp { color: var(--imp-color); font-weight: 700; font-style: normal; }
.ex-fr .epqp { color: var(--pqp-color); font-weight: 700; font-style: normal; }
.ex-fr em { color: var(--blue); font-style: normal; font-weight: 700; }
.ex-es { color: var(--text2); font-size: 0.88em; font-style: italic; }
.ex-note { font-size: 0.78em; color: var(--text3); margin-top: 3px; font-weight: 500; }

/* ── TENSE LEGEND PILLS ── */
.legend-row { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 14px; }
.legend-pill { font-size: 0.74em; font-weight: 700; border-radius: 20px; padding: 3px 10px; border: 1.5px solid; }
.legend-pill.pc  { background: var(--pc-bg);  color: var(--pc-color);  border-color: var(--pc-color); }
.legend-pill.imp { background: var(--imp-bg); color: var(--imp-color); border-color: var(--imp-color); }
.legend-pill.pqp { background: var(--pqp-bg); color: var(--pqp-color); border-color: var(--pqp-color); }

/* ── TABLES ── */
.table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 14px; border-radius: var(--radius-sm); border: 1px solid var(--border); }
.gram-table { width: 100%; border-collapse: collapse; min-width: 300px; }
.gram-table th { background: var(--bg); border-bottom: 2px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; text-align: left; font-size: 0.72em; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text3); }
.gram-table td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; vertical-align: top; color: var(--text); }
.gram-table tr:last-child td { border-bottom: none; }
.gram-table tr:nth-child(even) td { background: #f4f0e6; }
.gram-table td:last-child, .gram-table th:last-child { border-right: none; }
.hl-pc  { color: var(--pc-color);  font-weight: 700; }
.hl-imp { color: var(--imp-color); font-weight: 700; }
.hl-pqp { color: var(--pqp-color); font-weight: 700; }
.hl { color: var(--accent); font-weight: 700; }
.dim { color: var(--text3); }
.ok-cell { color: var(--green); font-weight: 700; }
.err-cell { color: var(--red); font-weight: 600; }

/* ── CHIPS ── */
.chip-bar { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.chip { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; white-space: nowrap; }
.chip:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); }
.chip.active { background: var(--accent); color: #fff; border-color: var(--accent); }
.chip.pc.active  { background: var(--pc-color);  border-color: var(--pc-color); }
.chip.imp.active { background: var(--imp-color); border-color: var(--imp-color); }
.chip.pqp.active { background: var(--pqp-color); border-color: var(--pqp-color); }
.chip-panel { display: none; } .chip-panel.active { display: block; }

/* ── CONJUGATION MINI TABLE ── */
.conj-table { width: 100%; border-collapse: collapse; }
.conj-table td { padding: 6px 12px; border-bottom: 1px solid var(--border); font-size: 0.9em; }
.conj-table tr:last-child td { border-bottom: none; }
.conj-pron { color: var(--text3); font-weight: 500; width: 38%; }
.conj-form-pc  { color: var(--pc-color);  font-weight: 700; }
.conj-form-imp { color: var(--imp-color); font-weight: 700; }
.conj-form-pqp { color: var(--pqp-color); font-weight: 700; }
.conj-note { font-size: 0.72em; background: var(--accent-light); color: var(--accent); border: 1px solid var(--accent-mid); border-radius: 12px; padding: 2px 10px; font-weight: 700; display: inline-block; margin-top: 8px; }

/* ── TRAP CARDS ── */
.trap-cards { display: flex; flex-direction: column; gap: 10px; }
.trap-card { border: 1.5px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
.trap-card-header { padding: 11px 14px; background: var(--bg); }
.trap-name { font-weight: 700; font-size: 0.9em; color: var(--text); margin-bottom: 7px; }
.trap-vs { display: flex; gap: 8px; flex-wrap: wrap; }
.trap-wrong { background: var(--red-bg); border: 1.5px solid #d09098; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--red); font-weight: 500; }
.trap-right { background: var(--green-bg); border: 1.5px solid #80b890; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--green); font-weight: 500; }
.trap-expl { padding: 10px 14px 12px; font-size: 0.86em; color: var(--text2); line-height: 1.6; border-top: 1px solid var(--border); background: var(--card); }
.trap-expl strong { color: var(--text); font-weight: 700; }

/* ── TIMELINE ── */
.timeline { position: relative; padding: 8px 0 8px 20px; margin: 14px 0; }
.timeline::before { content:''; position:absolute; left:6px; top:0; bottom:0; width:2px; background:var(--border); border-radius:2px; }
.tl-item { position: relative; margin-bottom: 10px; padding-left: 14px; }
.tl-item:last-child { margin-bottom: 0; }
.tl-item::before { content:''; position:absolute; left:-14px; top:6px; width:10px; height:10px; border-radius:50%; border:2px solid var(--card); }
.tl-item.pqp::before { background: var(--pqp-color); }
.tl-item.pc::before  { background: var(--pc-color); }
.tl-item.now::before { background: var(--text3); }
.tl-label { font-size: 0.78em; font-weight: 700; margin-bottom: 2px; }
.tl-item.pqp .tl-label { color: var(--pqp-color); }
.tl-item.pc .tl-label  { color: var(--pc-color); }
.tl-item.now .tl-label { color: var(--text3); }
.tl-text { font-size: 0.84em; color: var(--text2); line-height: 1.5; }

/* ── SECTION LABEL ── */
.sec-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); margin: 14px 0 7px; }

/* ── EXERCISES ── */
.exercise-controls { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 14px; box-shadow: var(--shadow-sm); }
.exercise-controls h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 14px; color: var(--text); }
.ctrl-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 7px; display: block; }
.ex-options { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.ex-opt-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.ex-opt-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
.row-btns { display: flex; gap: 7px; margin-bottom: 14px; flex-wrap: wrap; }
.pill-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.pill-btn:hover:not(.active) { background: var(--border); }
.pill-btn.active { background: var(--text); color: var(--bg); border-color: var(--text); }
.pill-btn.diff.active.A2 { background: var(--green); border-color: var(--green); color:#fff; }
.pill-btn.diff.active.B1 { background: var(--blue); border-color: var(--blue); color:#fff; }
.pill-btn.diff.active.B2 { background: var(--accent); border-color: var(--accent); color:#fff; }
.btn-generate { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: none; border-radius: 10px; padding: 13px; font-family: 'DM Sans', sans-serif; font-size: 0.92em; font-weight: 700; cursor: pointer; background: var(--accent); color: white; transition: all 0.18s; margin-top: 4px; }
.btn-generate:hover:not(:disabled) { filter: brightness(1.1); box-shadow: 0 4px 14px rgba(122,90,10,0.32); }
.btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
.spinner { display: none; animation: spin 0.8s linear infinite; }
.btn-generate.loading .spinner { display: inline; }
.btn-generate.loading .btn-icon { display: none; }
@keyframes spin { to { transform: rotate(360deg); } }

.progress-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; margin-bottom: 14px; display: none; }
.progress-wrap.visible { display: block; }
.progress-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.progress-label { font-size: 0.78em; color: var(--text3); font-weight: 600; }
.progress-frac { font-size: 0.92em; font-weight: 700; color: var(--accent); }
.progress-track { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.35s ease; }
.progress-score { display: flex; gap: 14px; margin-top: 9px; font-size: 0.8em; flex-wrap: wrap; align-items: center; }
.score-item { display: flex; align-items: center; gap: 5px; font-weight: 500; color: var(--text2); }
.score-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.score-dot.g { background: var(--green); } .score-dot.r { background: var(--red); }
.btn-retry { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 13px; font-family: 'DM Sans', sans-serif; font-size: 0.78em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; margin-left: auto; }
.btn-retry:hover { background: var(--border); }

.final-score-bar { display: none; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 14px; }
.final-score-bar.visible { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.final-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
.final-label { font-size: 0.74em; color: var(--text3); }
.final-track { flex: 1; min-width: 80px; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.final-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
.final-msg { font-size: 0.84em; color: var(--text2); width: 100%; font-weight: 500; }

.exercise-area { display: none; } .exercise-area.visible { display: block; }
.exercise-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 12px; overflow: hidden; }
.exercise-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--bg); border-bottom: 1px solid var(--border); }
.ex-num { font-weight: 700; color: var(--accent); font-size: 0.88em; }
.ex-type-badge { font-size: 0.68em; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; background: var(--accent-light); color: var(--accent); border: 1px solid var(--accent-mid); border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge { font-size: 0.68em; font-weight: 700; border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge.A2 { background: var(--green-bg); color: var(--green); border: 1px solid #80b890; }
.ex-diff-badge.B1 { background: var(--blue-bg); color: var(--blue); border: 1px solid #90a8e0; }
.ex-diff-badge.B2 { background: var(--warn-bg); color: var(--accent); border: 1px solid var(--accent-mid); }
.ex-status { margin-left: auto; }
.exercise-body { padding: 16px 18px; }
.exercise-prompt { line-height: 1.7; margin-bottom: 12px; color: var(--text); }
.exercise-prompt em { color: var(--accent); font-style: italic; font-weight: 600; }
.fill-input { border: none; border-bottom: 2px solid var(--accent-mid); background: var(--accent-light); padding: 2px 8px; border-radius: 4px 4px 0 0; font-family: 'DM Sans', sans-serif; font-size: 1em; color: var(--text); min-width: 110px; outline: none; transition: border-color 0.15s; }
.fill-input:focus { border-bottom-color: var(--accent); }
.fill-input.ok { background: var(--green-bg); border-bottom-color: var(--green); }
.fill-input.err { background: var(--red-bg); border-bottom-color: var(--red); }
.choices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; margin-bottom: 10px; }
.choice-btn { border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.88em; font-weight: 500; cursor: pointer; text-align: left; background: var(--bg); color: var(--text); transition: all 0.15s; }
.choice-btn:hover:not(:disabled) { border-color: var(--accent); background: var(--accent-light); }
.choice-btn.ok { background: var(--green-bg); border-color: var(--green); color: var(--green); font-weight: 700; }
.choice-btn.err { background: var(--red-bg); border-color: var(--red); color: var(--red); }
.choice-btn:disabled { cursor: default; }
.transform-input { width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.9em; background: var(--bg); color: var(--text); outline: none; margin-bottom: 8px; transition: border-color 0.15s; }
.transform-input:focus { border-color: var(--accent); }
.transform-input.ok { background: var(--green-bg); border-color: var(--green); }
.transform-input.err { background: var(--red-bg); border-color: var(--red); }
.btn-check { border: 1.5px solid var(--accent); border-radius: 20px; padding: 7px 18px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 700; cursor: pointer; background: transparent; color: var(--accent); transition: all 0.15s; }
.btn-check:hover:not(:disabled) { background: var(--accent); color: white; }
.btn-check:disabled { opacity: 0.35; cursor: default; }
.ex-feedback { display: none; border-radius: var(--radius-sm); padding: 11px 14px; line-height: 1.55; margin-top: 10px; font-size: 0.9em; }
.ex-feedback.visible { display: block; }
.ex-feedback.ok  { background: var(--green-bg); border: 1.5px solid #80b890; color: #0e4818; }
.ex-feedback.err { background: var(--red-bg);   border: 1.5px solid #c08090; color: #700018; }
.fb-rule-link { display: inline-flex; align-items: center; gap: 4px; margin-top: 8px; font-size: 0.84em; font-weight: 700; color: var(--accent); cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }

.skeleton-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 12px; }
.skel { background: linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%); background-size: 200% 100%; animation: skel 1.4s infinite; border-radius: 4px; height: 13px; margin-bottom: 9px; }
@keyframes skel { to { background-position: -200% 0; } }
.state-msg { text-align: center; padding: 40px 20px; color: var(--text3); }
.state-icon { font-size: 2rem; margin-bottom: 10px; }
.state-msg p { max-width: 260px; margin: 0 auto; line-height: 1.6; font-weight: 500; }
</style>
</head>
<body>

<!-- HEADER -->
<header class="site-header">
  <div class="header-top">
    <h1>Les Temps du Passé</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill pc">Passé composé</div>
    <div class="stat-pill imp">Imparfait</div>
    <div class="stat-pill pqp">Plus-que-parfait</div>
    <div class="stat-pill" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:0.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>

<!-- MODE TOGGLE -->
<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>

<!-- SECTION NAV -->
<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Visión general</button>
    <button class="snav-btn" onclick="showSection('s-pc',this)">2. Passé composé</button>
    <button class="snav-btn" onclick="showSection('s-imp',this)">3. Imparfait</button>
    <button class="snav-btn" onclick="showSection('s-pqp',this)">4. Plus-que-parfait</button>
    <button class="snav-btn" onclick="showSection('s-contraste',this)">5. PC vs. Imparfait</button>
    <button class="snav-btn" onclick="showSection('s-pqp2',this)">6. PQP en contexto</button>
    <button class="snav-btn" onclick="showSection('s-trampas',this)">7. Trampas</button>
  </div>
</div>

<div class="main-layout">

  <!-- ══════════ REFERENCIA ══════════ -->
  <div class="panel active" id="panel-ref">

    <!-- 1. VISIÓN GENERAL -->
    <div class="sec-block active" id="s-intro">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            Los tres tiempos del pasado en francés B1–B2 sirven para <strong>situar acciones en el tiempo de formas distintas</strong>. Ninguno es equivalente directo del español: hay diferencias sistemáticas que son fuente de errores frecuentes.
          </div>
          <div class="legend-row">
            <span class="legend-pill pc">Passé composé — acción puntual / resultado</span>
            <span class="legend-pill imp">Imparfait — descripción / hábito / marco</span>
            <span class="legend-pill pqp">Plus-que-parfait — anterioridad al pasado</span>
          </div>

          <div class="sec-label">Cronología relativa</div>
          <div class="timeline">
            <div class="tl-item pqp">
              <div class="tl-label">Plus-que-parfait</div>
              <div class="tl-text">Acción anterior a otra acción pasada. <em>Il avait déjà mangé quand elle est arrivée.</em></div>
            </div>
            <div class="tl-item pc">
              <div class="tl-label">Passé composé</div>
              <div class="tl-text">Acción puntual, completada, con resultado en el presente. <em>Il est arrivé à 8h.</em></div>
            </div>
            <div class="tl-item now">
              <div class="tl-label">Présent (ahora)</div>
              <div class="tl-text">Punto de referencia del hablante.</div>
            </div>
          </div>

          <div class="warn-box">
            <span class="warn-icon">💡</span>
            <div class="warn-text">El <strong>imparfait</strong> no ocupa un punto en la línea temporal: es el <strong>fondo o marco</strong> sobre el que ocurren las acciones del passé composé.</div>
          </div>

          <div class="sec-label">Comparativa rápida</div>
          <div class="table-wrap">
            <table class="gram-table">
              <thead><tr><th>Tiempo</th><th>Pregunta clave</th><th>Típico en...</th></tr></thead>
              <tbody>
                <tr><td><strong class="hl-pc">Passé composé</strong></td><td>¿Qué pasó? ¿Qué hizo?</td><td>Narración, hechos, cambios</td></tr>
                <tr><td><strong class="hl-imp">Imparfait</strong></td><td>¿Cómo era? ¿Qué hacía (habitualmente)?</td><td>Descripción, hábito, estado</td></tr>
                <tr><td><strong class="hl-pqp">Plus-que-parfait</strong></td><td>¿Qué había pasado antes?</td><td>Anterioridad, explicación de causa</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>

    <!-- 2. PASSÉ COMPOSÉ -->
    <div class="sec-block" id="s-pc">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            El <strong>passé composé</strong> expresa acciones <strong>puntuales, completadas</strong> en el pasado, con relevancia o resultado en el presente. Se forma con <strong>avoir o être en présent + participio pasado</strong>.
          </div>

          <div class="sec-label">Formación — elige el auxiliar</div>
          <div class="chip-bar" id="pc-aux-chips">
            <button class="chip pc active" onclick="selectChip('pcaux',0)">avoir + p.p.</button>
            <button class="chip pc" onclick="selectChip('pcaux',1)">être + p.p.</button>
            <button class="chip pc" onclick="selectChip('pcaux',2)">Verbos pronominales</button>
          </div>
          <div id="pcaux-panels">
            <div class="chip-panel active" id="pcaux-p-0">
              <div class="def-box" style="margin-bottom:10px">La mayoría de verbos usan <strong>avoir</strong>. El participio <strong>no concuerda</strong> con el sujeto (salvo con COD antepuesto).</div>
              <div class="table-wrap">
                <table class="gram-table">
                  <thead><tr><th>Pronombre</th><th>PARLER</th><th>FINIR</th><th>PRENDRE</th></tr></thead>
                  <tbody>
                    <tr><td><strong>j'</strong></td><td class="hl-pc">ai parlé</td><td class="hl-pc">ai fini</td><td class="hl-pc">ai pris</td></tr>
                    <tr><td><strong>tu</strong></td><td class="hl-pc">as parlé</td><td class="hl-pc">as fini</td><td class="hl-pc">as pris</td></tr>
                    <tr><td><strong>il/elle</strong></td><td class="hl-pc">a parlé</td><td class="hl-pc">a fini</td><td class="hl-pc">a pris</td></tr>
                    <tr><td><strong>nous</strong></td><td class="hl-pc">avons parlé</td><td class="hl-pc">avons fini</td><td class="hl-pc">avons pris</td></tr>
                    <tr><td><strong>vous</strong></td><td class="hl-pc">avez parlé</td><td class="hl-pc">avez fini</td><td class="hl-pc">avez pris</td></tr>
                    <tr><td><strong>ils/elles</strong></td><td class="hl-pc">ont parlé</td><td class="hl-pc">ont fini</td><td class="hl-pc">ont pris</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
            <div class="chip-panel" id="pcaux-p-1">
              <div class="def-box" style="margin-bottom:10px">Los verbos de <strong>movimiento y cambio de estado</strong> usan <strong>être</strong>. El participio <strong>concuerda en género y número</strong> con el sujeto.</div>
              <div class="table-wrap">
                <table class="gram-table">
                  <thead><tr><th>Pronombre</th><th>ALLER</th><th>PARTIR</th><th>VENIR</th></tr></thead>
                  <tbody>
                    <tr><td><strong>je (m.)</strong></td><td class="hl-pc">suis allé</td><td class="hl-pc">suis parti</td><td class="hl-pc">suis venu</td></tr>
                    <tr><td><strong>je (f.)</strong></td><td class="hl-pc">suis allée</td><td class="hl-pc">suis partie</td><td class="hl-pc">suis venue</td></tr>
                    <tr><td><strong>il</strong></td><td class="hl-pc">est allé</td><td class="hl-pc">est parti</td><td class="hl-pc">est venu</td></tr>
                    <tr><td><strong>elle</strong></td><td class="hl-pc">est allée</td><td class="hl-pc">est partie</td><td class="hl-pc">est venue</td></tr>
                    <tr><td><strong>nous (m.)</strong></td><td class="hl-pc">sommes allés</td><td class="hl-pc">sommes partis</td><td class="hl-pc">sommes venus</td></tr>
                    <tr><td><strong>ils</strong></td><td class="hl-pc">sont allés</td><td class="hl-pc">sont partis</td><td class="hl-pc">sont venus</td></tr>
                  </tbody>
                </table>
              </div>
              <div class="note-box"><strong>Los 17 verbos DR MRS VANDERTRAMP</strong> usan être: Devenir, Revenir, Monter, Rester, Sortir, Venir, Aller, Naître, Descendre, Entrer, Rentrer, Tomber, Retourner, Arriver, Mourir, Partir + todos sus derivados.</div>
            </div>
            <div class="chip-panel" id="pcaux-p-2">
              <div class="def-box" style="margin-bottom:10px">Todos los verbos pronominales usan <strong>être</strong>. El participio concuerda con el sujeto <strong>si el pronombre es COD</strong>.</div>
              <div class="table-wrap">
                <table class="gram-table">
                  <thead><tr><th>Pronombre</th><th>SE LEVER</th><th>S'HABILLER</th></tr></thead>
                  <tbody>
                    <tr><td><strong>je (m.)</strong></td><td class="hl-pc">me suis levé</td><td class="hl-pc">me suis habillé</td></tr>
                    <tr><td><strong>je (f.)</strong></td><td class="hl-pc">me suis levée</td><td class="hl-pc">me suis habillée</td></tr>
                    <tr><td><strong>il</strong></td><td class="hl-pc">s'est levé</td><td class="hl-pc">s'est habillé</td></tr>
                    <tr><td><strong>elle</strong></td><td class="hl-pc">s'est levée</td><td class="hl-pc">s'est habillée</td></tr>
                    <tr><td><strong>nous</strong></td><td class="hl-pc">nous sommes levé(e)s</td><td class="hl-pc">nous sommes habillé(e)s</td></tr>
                    <tr><td><strong>ils/elles</strong></td><td class="hl-pc">se sont levé(e)s</td><td class="hl-pc">se sont habillé(e)s</td></tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div class="sec-label" style="margin-top:16px">Participios irregulares frecuentes</div>
          <div class="chip-bar" id="pp-chips">
            <button class="chip pc active" onclick="selectChip('pp',0)">-is / -it</button>
            <button class="chip pc" onclick="selectChip('pp',1)">-u</button>
            <button class="chip pc" onclick="selectChip('pp',2)">-ert / -ert</button>
            <button class="chip pc" onclick="selectChip('pp',3)">Otros</button>
          </div>
          <div id="pp-panels">
            <div class="chip-panel active" id="pp-p-0">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Infinitivo</th><th>Participio</th><th>Infinitivo</th><th>Participio</th></tr></thead>
                <tbody>
                  <tr><td>prendre</td><td class="hl-pc">pris</td><td>mettre</td><td class="hl-pc">mis</td></tr>
                  <tr><td>apprendre</td><td class="hl-pc">appris</td><td>promettre</td><td class="hl-pc">promis</td></tr>
                  <tr><td>comprendre</td><td class="hl-pc">compris</td><td>dire</td><td class="hl-pc">dit</td></tr>
                  <tr><td>écrire</td><td class="hl-pc">écrit</td><td>faire</td><td class="hl-pc">fait</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="pp-p-1">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Infinitivo</th><th>Participio</th><th>Infinitivo</th><th>Participio</th></tr></thead>
                <tbody>
                  <tr><td>avoir</td><td class="hl-pc">eu</td><td>savoir</td><td class="hl-pc">su</td></tr>
                  <tr><td>boire</td><td class="hl-pc">bu</td><td>vouloir</td><td class="hl-pc">voulu</td></tr>
                  <tr><td>croire</td><td class="hl-pc">cru</td><td>pouvoir</td><td class="hl-pc">pu</td></tr>
                  <tr><td>lire</td><td class="hl-pc">lu</td><td>voir</td><td class="hl-pc">vu</td></tr>
                  <tr><td>recevoir</td><td class="hl-pc">reçu</td><td>pleuvoir</td><td class="hl-pc">plu</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="pp-p-2">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Infinitivo</th><th>Participio</th></tr></thead>
                <tbody>
                  <tr><td>ouvrir</td><td class="hl-pc">ouvert</td></tr>
                  <tr><td>offrir</td><td class="hl-pc">offert</td></tr>
                  <tr><td>couvrir</td><td class="hl-pc">couvert</td></tr>
                  <tr><td>souffrir</td><td class="hl-pc">souffert</td></tr>
                  <tr><td>découvrir</td><td class="hl-pc">découvert</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="pp-p-3">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Infinitivo</th><th>Participio</th><th>Infinitivo</th><th>Participio</th></tr></thead>
                <tbody>
                  <tr><td>être</td><td class="hl-pc">été</td><td>naître</td><td class="hl-pc">né</td></tr>
                  <tr><td>venir</td><td class="hl-pc">venu</td><td>mourir</td><td class="hl-pc">mort</td></tr>
                  <tr><td>tenir</td><td class="hl-pc">tenu</td><td>vivre</td><td class="hl-pc">vécu</td></tr>
                  <tr><td>suivre</td><td class="hl-pc">suivi</td><td>conduire</td><td class="hl-pc">conduit</td></tr>
                </tbody>
              </table></div>
            </div>
          </div>

          <div class="sec-label" style="margin-top:16px">Ejemplos</div>
          <div class="example-block pc"><div class="ex-fr">Hier, elle <span class="epc">est allée</span> au marché.</div><div class="ex-es">Ayer, fue al mercado.</div></div>
          <div class="example-block pc"><div class="ex-fr">Il <span class="epc">a pris</span> son manteau et <span class="epc">est parti</span>.</div><div class="ex-es">Cogió su abrigo y se fue.</div></div>
          <div class="example-block pc"><div class="ex-fr">Nous <span class="epc">avons fini</span> le projet la semaine dernière.</div><div class="ex-es">Terminamos el proyecto la semana pasada.</div></div>
          <div class="example-block pc"><div class="ex-fr">Elle <span class="epc">s'est levée</span> tard ce matin.</div><div class="ex-es">Se levantó tarde esta mañana.</div></div>
          <div class="example-block pc"><div class="ex-fr">Tu <span class="epc">as compris</span> la leçon ?</div><div class="ex-es">¿Entendiste la lección?</div></div>
        </div>
      </div>
    </div>

    <!-- 3. IMPARFAIT -->
    <div class="sec-block" id="s-imp">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            El <strong>imparfait</strong> describe <strong>estados, situaciones, hábitos o acciones en desarrollo</strong> en el pasado. No indica cuándo empezó ni cuándo terminó la acción. Se forma con la <strong>raíz de nous (présent) + terminaciones</strong>.
          </div>

          <div class="sec-label">Formación</div>
          <div class="def-box" style="margin-bottom:10px">
            <strong>Base:</strong> raíz de <em>nous</em> (présent) + <strong>-ais · -ais · -ait · -ions · -iez · -aient</strong><br>
            <span style="color:var(--text2);font-size:0.9em">Única excepción: être → raíz <strong>ét-</strong> (j'étais, tu étais…)</span>
          </div>
          <div class="chip-bar" id="imp-conj-chips">
            <button class="chip imp active" onclick="selectChip('impconj',0)">PARLER</button>
            <button class="chip imp" onclick="selectChip('impconj',1)">FINIR</button>
            <button class="chip imp" onclick="selectChip('impconj',2)">FAIRE</button>
            <button class="chip imp" onclick="selectChip('impconj',3)">ÊTRE</button>
            <button class="chip imp" onclick="selectChip('impconj',4)">AVOIR</button>
            <button class="chip imp" onclick="selectChip('impconj',5)">ALLER</button>
          </div>
          <div id="impconj-panels">
            <div class="chip-panel active" id="impconj-p-0">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>nous (présent) → parl-</th><th>Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="dim">parl-</td><td class="hl-imp">parlais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="dim">parl-</td><td class="hl-imp">parlais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="dim">parl-</td><td class="hl-imp">parlait</td></tr>
                  <tr><td><strong>nous</strong></td><td class="dim">parl-</td><td class="hl-imp">parlions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="dim">parl-</td><td class="hl-imp">parliez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="dim">parl-</td><td class="hl-imp">parlaient</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="impconj-p-1">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>nous finissons → finiss-</th><th>Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissait</td></tr>
                  <tr><td><strong>nous</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissiez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="dim">finiss-</td><td class="hl-imp">finissaient</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="impconj-p-2">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>nous faisons → fais-</th><th>Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="dim">fais-</td><td class="hl-imp">faisais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="dim">fais-</td><td class="hl-imp">faisais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="dim">fais-</td><td class="hl-imp">faisait</td></tr>
                  <tr><td><strong>nous</strong></td><td class="dim">fais-</td><td class="hl-imp">faisions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="dim">fais-</td><td class="hl-imp">faisiez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="dim">fais-</td><td class="hl-imp">faisaient</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="impconj-p-3">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>ÊTRE — raíz irregular: ét-</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="hl-imp">étais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="hl-imp">étais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="hl-imp">était</td></tr>
                  <tr><td><strong>nous</strong></td><td class="hl-imp">étions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="hl-imp">étiez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="hl-imp">étaient</td></tr>
                </tbody>
              </table></div>
              <div class="note-box"><strong>Único irregular del imparfait.</strong> Todos los demás verbos siguen la regla de la raíz de <em>nous</em>.</div>
            </div>
            <div class="chip-panel" id="impconj-p-4">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>nous avons → av-</th><th>Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="dim">av-</td><td class="hl-imp">avais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="dim">av-</td><td class="hl-imp">avais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="dim">av-</td><td class="hl-imp">avait</td></tr>
                  <tr><td><strong>nous</strong></td><td class="dim">av-</td><td class="hl-imp">avions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="dim">av-</td><td class="hl-imp">aviez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="dim">av-</td><td class="hl-imp">avaient</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="impconj-p-5">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>nous allons → all-</th><th>Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>je</strong></td><td class="dim">all-</td><td class="hl-imp">allais</td></tr>
                  <tr><td><strong>tu</strong></td><td class="dim">all-</td><td class="hl-imp">allais</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="dim">all-</td><td class="hl-imp">allait</td></tr>
                  <tr><td><strong>nous</strong></td><td class="dim">all-</td><td class="hl-imp">allions</td></tr>
                  <tr><td><strong>vous</strong></td><td class="dim">all-</td><td class="hl-imp">alliez</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="dim">all-</td><td class="hl-imp">allaient</td></tr>
                </tbody>
              </table></div>
            </div>
          </div>

          <div class="sec-label" style="margin-top:16px">Usos — elige la función</div>
          <div class="chip-bar" id="imp-uso-chips">
            <button class="chip imp active" onclick="selectChip('impuso',0)">Descripción / estado</button>
            <button class="chip imp" onclick="selectChip('impuso',1)">Hábito / repetición</button>
            <button class="chip imp" onclick="selectChip('impuso',2)">Acción en desarrollo</button>
            <button class="chip imp" onclick="selectChip('impuso',3)">Cortesía</button>
          </div>
          <div id="impuso-panels">
            <div class="chip-panel active" id="impuso-p-0">
              <div class="def-box">Estado, situación o características que existían en el pasado sin inicio ni fin marcados.</div>
              <div class="example-block imp"><div class="ex-fr">La maison <span class="eimp">était</span> grande et lumineuse.</div><div class="ex-es">La casa era grande y luminosa.</div></div>
              <div class="example-block imp"><div class="ex-fr">Il <span class="eimp">avait</span> les yeux bleus et <span class="eimp">portait</span> une veste rouge.</div><div class="ex-es">Tenía los ojos azules y llevaba una chaqueta roja.</div></div>
              <div class="example-block imp"><div class="ex-fr">Quand j'<span class="eimp">étais</span> enfant, je <span class="eimp">voulais</span> être médecin.</div><div class="ex-es">Cuando era niño, quería ser médico.</div></div>
              <div class="example-block imp"><div class="ex-fr">Il <span class="eimp">faisait</span> beau et tout le monde <span class="eimp">semblait</span> heureux.</div><div class="ex-es">Hacía buen tiempo y todo el mundo parecía feliz.</div></div>
              <div class="example-block imp"><div class="ex-fr">Elle ne <span class="eimp">savait</span> pas quoi faire.</div><div class="ex-es">No sabía qué hacer.</div></div>
            </div>
            <div class="chip-panel" id="impuso-p-1">
              <div class="def-box">Acción que se repetía regularmente en el pasado. Señales típicas: <strong>tous les jours, souvent, chaque semaine, autrefois, d'habitude</strong>.</div>
              <div class="example-block imp"><div class="ex-fr">Quand j'<span class="eimp">habitais</span> à Paris, je <span class="eimp">prenais</span> le métro tous les matins.</div><div class="ex-es">Cuando vivía en París, cogía el metro cada mañana.</div></div>
              <div class="example-block imp"><div class="ex-fr">Il <span class="eimp">lisait</span> toujours avant de s'endormir.</div><div class="ex-es">Siempre leía antes de dormirse.</div></div>
              <div class="example-block imp"><div class="ex-fr">Nous <span class="eimp">allions</span> à la plage chaque été.</div><div class="ex-es">Íbamos a la playa cada verano.</div></div>
              <div class="example-block imp"><div class="ex-fr">Elle <span class="eimp">appelait</span> sa mère chaque dimanche.</div><div class="ex-es">Llamaba a su madre cada domingo.</div></div>
              <div class="example-block imp"><div class="ex-fr">Autrefois, les gens <span class="eimp">écrivaient</span> beaucoup de lettres.</div><div class="ex-es">Antiguamente, la gente escribía muchas cartas.</div></div>
            </div>
            <div class="chip-panel" id="impuso-p-2">
              <div class="def-box">Acción en curso cuando ocurrió otro evento (passé composé). El imparfait es el <strong>fondo</strong>; el PC es la acción que lo interrumpe.</div>
              <div class="example-block mix"><div class="ex-fr">Il <span class="eimp">dormait</span> quand le téléphone <span class="epc">a sonné</span>.</div><div class="ex-es">Dormía cuando sonó el teléfono.</div><div class="ex-note">Imparfait = fondo · Passé composé = evento</div></div>
              <div class="example-block mix"><div class="ex-fr">Nous <span class="eimp">regardions</span> la télé quand elle <span class="epc">est entrée</span>.</div><div class="ex-es">Veíamos la tele cuando ella entró.</div></div>
              <div class="example-block mix"><div class="ex-fr">Je <span class="eimp">traversais</span> la rue quand j'<span class="epc">ai vu</span> l'accident.</div><div class="ex-es">Cruzaba la calle cuando vi el accidente.</div></div>
              <div class="example-block mix"><div class="ex-fr">Elle <span class="eimp">préparait</span> le dîner quand les invités <span class="epc">sont arrivés</span>.</div><div class="ex-es">Preparaba la cena cuando llegaron los invitados.</div></div>
              <div class="example-block mix"><div class="ex-fr">Il <span class="eimp">pleuvait</span> quand nous <span class="epc">sommes sortis</span>.</div><div class="ex-es">Llovía cuando salimos.</div></div>
            </div>
            <div class="chip-panel" id="impuso-p-3">
              <div class="def-box">Imparfait de cortesía o de atenuación. Suaviza peticiones o expresa deseos con menos brusquedad que el présent.</div>
              <div class="example-block imp"><div class="ex-fr">Je <span class="eimp">voulais</span> vous demander quelque chose.</div><div class="ex-es">Quería preguntarle algo. (más cortés que: <em>je veux</em>)</div></div>
              <div class="example-block imp"><div class="ex-fr">Je <span class="eimp">venais</span> pour le poste d'assistant.</div><div class="ex-es">Venía por el puesto de asistente.</div></div>
              <div class="example-block imp"><div class="ex-fr">Tu n'<span class="eimp">avais</span> pas un stylo, par hasard ?</div><div class="ex-es">¿No tendrías un bolígrafo, por casualidad?</div></div>
              <div class="example-block imp"><div class="ex-fr">J'<span class="eimp">espérais</span> vous voir aujourd'hui.</div><div class="ex-es">Esperaba verle hoy.</div></div>
              <div class="example-block imp"><div class="ex-fr">Je <span class="eimp">souhaitais</span> vous parler en privé.</div><div class="ex-es">Deseaba hablarle en privado.</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 4. PLUS-QUE-PARFAIT -->
    <div class="sec-block" id="s-pqp">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            El <strong>plus-que-parfait</strong> expresa una acción <strong>anterior a otra acción pasada</strong>. Es el "pasado del pasado". Se forma con <strong>avoir o être en imparfait + participio pasado</strong>.
          </div>

          <div class="sec-label">Formación — elige el auxiliar</div>
          <div class="chip-bar" id="pqp-aux-chips">
            <button class="chip pqp active" onclick="selectChip('pqpaux',0)">avoir (imparfait) + p.p.</button>
            <button class="chip pqp" onclick="selectChip('pqpaux',1)">être (imparfait) + p.p.</button>
            <button class="chip pqp" onclick="selectChip('pqpaux',2)">Pronominales</button>
          </div>
          <div id="pqpaux-panels">
            <div class="chip-panel active" id="pqpaux-p-0">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>PARLER</th><th>FAIRE</th><th>PRENDRE</th></tr></thead>
                <tbody>
                  <tr><td><strong>j'</strong></td><td class="hl-pqp">avais parlé</td><td class="hl-pqp">avais fait</td><td class="hl-pqp">avais pris</td></tr>
                  <tr><td><strong>tu</strong></td><td class="hl-pqp">avais parlé</td><td class="hl-pqp">avais fait</td><td class="hl-pqp">avais pris</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="hl-pqp">avait parlé</td><td class="hl-pqp">avait fait</td><td class="hl-pqp">avait pris</td></tr>
                  <tr><td><strong>nous</strong></td><td class="hl-pqp">avions parlé</td><td class="hl-pqp">avions fait</td><td class="hl-pqp">avions pris</td></tr>
                  <tr><td><strong>vous</strong></td><td class="hl-pqp">aviez parlé</td><td class="hl-pqp">aviez fait</td><td class="hl-pqp">aviez pris</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="hl-pqp">avaient parlé</td><td class="hl-pqp">avaient fait</td><td class="hl-pqp">avaient pris</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="pqpaux-p-1">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>ALLER</th><th>VENIR</th></tr></thead>
                <tbody>
                  <tr><td><strong>j'</strong></td><td class="hl-pqp">étais allé(e)</td><td class="hl-pqp">étais venu(e)</td></tr>
                  <tr><td><strong>tu</strong></td><td class="hl-pqp">étais allé(e)</td><td class="hl-pqp">étais venu(e)</td></tr>
                  <tr><td><strong>il/elle</strong></td><td class="hl-pqp">était allé/allée</td><td class="hl-pqp">était venu/venue</td></tr>
                  <tr><td><strong>nous</strong></td><td class="hl-pqp">étions allé(e)s</td><td class="hl-pqp">étions venu(e)s</td></tr>
                  <tr><td><strong>vous</strong></td><td class="hl-pqp">étiez allé(e)(s)</td><td class="hl-pqp">étiez venu(e)(s)</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="hl-pqp">étaient allés/allées</td><td class="hl-pqp">étaient venus/venues</td></tr>
                </tbody>
              </table></div>
            </div>
            <div class="chip-panel" id="pqpaux-p-2">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Pronombre</th><th>SE LEVER</th></tr></thead>
                <tbody>
                  <tr><td><strong>je (m.)</strong></td><td class="hl-pqp">m'étais levé</td></tr>
                  <tr><td><strong>je (f.)</strong></td><td class="hl-pqp">m'étais levée</td></tr>
                  <tr><td><strong>il</strong></td><td class="hl-pqp">s'était levé</td></tr>
                  <tr><td><strong>elle</strong></td><td class="hl-pqp">s'était levée</td></tr>
                  <tr><td><strong>nous</strong></td><td class="hl-pqp">nous étions levé(e)s</td></tr>
                  <tr><td><strong>ils/elles</strong></td><td class="hl-pqp">s'étaient levé(e)s</td></tr>
                </tbody>
              </table></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 5. PC vs. IMPARFAIT -->
    <div class="sec-block" id="s-contraste">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            La distinción PC / Imparfait es el <strong>núcleo del DELF B1–B2</strong> y el error más frecuente de hispanohablantes. La clave es la <strong>perspectiva del hablante</strong>, no la duración de la acción.
          </div>

          <div class="sec-label">Criterios de elección — elige el criterio</div>
          <div class="chip-bar" id="contraste-chips">
            <button class="chip active" onclick="selectChip('contraste',0)">Puntual vs. Marco</button>
            <button class="chip" onclick="selectChip('contraste',1)">Señales léxicas</button>
            <button class="chip" onclick="selectChip('contraste',2)">Verbos que cambian de significado</button>
            <button class="chip" onclick="selectChip('contraste',3)">Textos narrativos</button>
          </div>
          <div id="contraste-panels">
            <div class="chip-panel active" id="contraste-p-0">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th></th><th class="hl-pc">Passé composé</th><th class="hl-imp">Imparfait</th></tr></thead>
                <tbody>
                  <tr><td><strong>Naturaleza</strong></td><td>Acción puntual, evento</td><td>Estado, fondo, marco</td></tr>
                  <tr><td><strong>Límites</strong></td><td>Inicio y fin marcados</td><td>Sin límites temporales</td></tr>
                  <tr><td><strong>Pregunta</strong></td><td>¿Qué pasó?</td><td>¿Cómo era / qué hacía?</td></tr>
                  <tr><td><strong>Repetición</strong></td><td>N.º de veces especificado</td><td>Hábito sin número</td></tr>
                  <tr><td><strong>Función narrativa</strong></td><td>Avanza la historia</td><td>Describe, ralentiza</td></tr>
                </tbody>
              </table></div>
              <div class="example-block mix">
                <div class="ex-fr">Il <span class="eimp">faisait</span> beau. Les enfants <span class="eimp">jouaient</span> dans le jardin quand soudain il <span class="epc">a commencé</span> à pleuvoir.</div>
                <div class="ex-es">Hacía buen tiempo. Los niños jugaban en el jardín cuando de repente empezó a llover.</div>
                <div class="ex-note">Imparfait = contexto · PC = evento que rompe el marco</div>
              </div>
            </div>
            <div class="chip-panel" id="contraste-p-1">
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Señal → PC</th><th>Señal → Imparfait</th></tr></thead>
                <tbody>
                  <tr><td>soudain, tout à coup</td><td>toujours, souvent, d'habitude</td></tr>
                  <tr><td>un jour, une fois</td><td>autrefois, jadis, à cette époque</td></tr>
                  <tr><td>hier, la semaine dernière</td><td>chaque jour / semaine / année</td></tr>
                  <tr><td>enfin, alors, puis, ensuite</td><td>normalement, en général</td></tr>
                  <tr><td>à ce moment-là (evento)</td><td>pendant que, tandis que</td></tr>
                  <tr><td>X fois (número concreto)</td><td>quand + estado simultáneo</td></tr>
                </tbody>
              </table></div>
              <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>quand</strong> puede introducir tanto PC como imparfait según el contexto: <em>quand il est arrivé</em> (evento puntual) vs. <em>quand j'étais jeune</em> (estado).</div></div>
            </div>
            <div class="chip-panel" id="contraste-p-2">
              <div class="def-box">Algunos verbos cambian de significado según el tiempo que usan.</div>
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Verbo</th><th class="hl-imp">Imparfait</th><th class="hl-pc">Passé composé</th></tr></thead>
                <tbody>
                  <tr><td><strong>savoir</strong></td><td>sabía (estado)</td><td>se enteró, supo (momento)</td></tr>
                  <tr><td><strong>connaître</strong></td><td>conocía (ya)</td><td>conoció (por primera vez)</td></tr>
                  <tr><td><strong>pouvoir</strong></td><td>podía (capacidad)</td><td>pudo (lo consiguió)</td></tr>
                  <tr><td><strong>vouloir</strong></td><td>quería (deseo)</td><td>quiso / intentó</td></tr>
                  <tr><td><strong>devoir</strong></td><td>debía (obligación)</td><td>tuvo que (lo hizo)</td></tr>
                </tbody>
              </table></div>
              <div class="example-block imp"><div class="ex-fr">Je <span class="eimp">savais</span> qu'il mentait.</div><div class="ex-es">Sabía que mentía. (estado mental)</div></div>
              <div class="example-block pc"><div class="ex-fr">J'<span class="epc">ai su</span> la vérité hier.</div><div class="ex-es">Me enteré de la verdad ayer. (momento de descubrimiento)</div></div>
            </div>
            <div class="chip-panel" id="contraste-p-3">
              <div class="def-box">En un texto narrativo, PC e imparfait trabajan juntos: el <strong>imparfait pinta el escenario</strong>, el <strong>PC cuenta los hechos</strong>.</div>
              <div class="example-block mix">
                <div class="ex-fr">Ce soir-là, la ville <span class="eimp">était</span> calme. Les rues <span class="eimp">étaient</span> désertes et il <span class="eimp">pleuvait</span> doucement. Tout à coup, une voiture <span class="epc">s'est arrêtée</span> devant la banque. Deux hommes <span class="epc">sont sortis</span> et <span class="epc">ont couru</span> vers l'entrée.</div>
                <div class="ex-es">Esa noche, la ciudad estaba tranquila. Las calles estaban desiertas y llovía suavemente. De repente, un coche se detuvo ante el banco. Dos hombres salieron y corrieron hacia la entrada.</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 6. PQP EN CONTEXTO -->
    <div class="sec-block" id="s-pqp2">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">
            El <strong>plus-que-parfait</strong> sitúa una acción <strong>antes de otro momento pasado</strong>. Aparece combinado con PC o imparfait y es especialmente frecuente con <em>déjà, encore, jamais, parce que, quand, lorsque</em>.
          </div>

          <div class="sec-label">Usos del PQP — elige el contexto</div>
          <div class="chip-bar" id="pqp2-chips">
            <button class="chip pqp active" onclick="selectChip('pqp2',0)">Anterioridad pura</button>
            <button class="chip pqp" onclick="selectChip('pqp2',1)">Causa en el pasado</button>
            <button class="chip pqp" onclick="selectChip('pqp2',2)">déjà / encore / jamais</button>
            <button class="chip pqp" onclick="selectChip('pqp2',3)">Estilo indirecto</button>
          </div>
          <div id="pqp2-panels">
            <div class="chip-panel active" id="pqp2-p-0">
              <div class="def-box">Una acción pasada (PQP) ocurrió antes de otra acción pasada (PC o imparfait).</div>
              <div class="example-block pqp"><div class="ex-fr">Quand je <span class="epc">suis arrivé</span>, elle <span class="epqp">était déjà partie</span>.</div><div class="ex-es">Cuando llegué, ella ya se había ido.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="epc">a mangé</span> le gâteau que j'<span class="epqp">avais préparé</span>.</div><div class="ex-es">Se comió el pastel que yo había preparado.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Nous <span class="eimp">savions</span> qu'il <span class="epqp">avait menti</span>.</div><div class="ex-es">Sabíamos que había mentido.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Le film <span class="eimp">était</span> déjà commencé quand nous <span class="epc">sommes entrés</span>.</div><div class="ex-es">La película ya había empezado cuando entramos.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Elle <span class="epc">a reconnu</span> l'homme qu'elle <span class="epqp">avait rencontré</span> la veille.</div><div class="ex-es">Reconoció al hombre que había conocido el día anterior.</div></div>
            </div>
            <div class="chip-panel" id="pqp2-p-1">
              <div class="def-box">El PQP explica la causa de una situación o acción pasada.</div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="eimp">était</span> fatigué parce qu'il <span class="epqp">avait travaillé</span> toute la nuit.</div><div class="ex-es">Estaba cansado porque había trabajado toda la noche.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Elle <span class="epc">a raté</span> le train parce qu'elle <span class="epqp">s'était levée</span> trop tard.</div><div class="ex-es">Perdió el tren porque se había levantado demasiado tarde.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="eimp">connaissait</span> la réponse car il <span class="epqp">avait déjà lu</span> le livre.</div><div class="ex-es">Sabía la respuesta porque ya había leído el libro.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Nous <span class="epc">n'avons pas pu</span> entrer : ils <span class="epqp">avaient fermé</span> la porte.</div><div class="ex-es">No pudimos entrar: habían cerrado la puerta.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Elle <span class="eimp">avait</span> l'air heureux parce qu'il <span class="epqp">lui avait offert</span> des fleurs.</div><div class="ex-es">Parecía feliz porque él le había regalado flores.</div></div>
            </div>
            <div class="chip-panel" id="pqp2-p-2">
              <div class="def-box"><strong>Déjà</strong> (ya), <strong>encore / toujours</strong> (todavía), <strong>jamais</strong> (nunca) se combinan frecuentemente con PQP.</div>
              <div class="example-block pqp"><div class="ex-fr">Elle <span class="epqp">n'avait jamais vu</span> la mer avant ce jour.</div><div class="ex-es">Nunca había visto el mar antes de ese día.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="epqp">avait déjà fini</span> quand le professeur <span class="epc">a demandé</span> les copies.</div><div class="ex-es">Ya había terminado cuando el profesor pidió los trabajos.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Nous <span class="epqp">n'avions encore jamais mangé</span> de cuisine japonaise.</div><div class="ex-es">Nunca habíamos comido cocina japonesa.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="eimp">pensait</span> qu'elle <span class="epqp">était déjà partie</span>.</div><div class="ex-es">Pensaba que ella ya se había ido.</div></div>
              <div class="example-block pqp"><div class="ex-fr">La réunion <span class="epqp">avait déjà commencé</span> quand il <span class="epc">est arrivé</span>.</div><div class="ex-es">La reunión ya había empezado cuando llegó.</div></div>
            </div>
            <div class="chip-panel" id="pqp2-p-3">
              <div class="def-box">En estilo indirecto pasado, el passé composé de la frase original se convierte en PQP.</div>
              <div class="table-wrap"><table class="gram-table">
                <thead><tr><th>Estilo directo</th><th>Estilo indirecto (pasado)</th></tr></thead>
                <tbody>
                  <tr><td>"J'<span class="epc">ai vu</span> le film."</td><td>Il a dit qu'il <span class="epqp">avait vu</span> le film.</td></tr>
                  <tr><td>"Elle <span class="epc">est partie</span>."</td><td>Il a dit qu'elle <span class="epqp">était partie</span>.</td></tr>
                  <tr><td>"Nous <span class="epc">avons fini</span>."</td><td>Ils ont dit qu'ils <span class="epqp">avaient fini</span>.</td></tr>
                </tbody>
              </table></div>
              <div class="example-block pqp"><div class="ex-fr">Elle <span class="epc">a dit</span> : "Je <span class="epc">suis arrivée</span> tôt." → Elle <span class="epc">a dit</span> qu'elle <span class="epqp">était arrivée</span> tôt.</div><div class="ex-es">Dijo: "Llegué pronto." → Dijo que había llegado pronto.</div></div>
              <div class="example-block pqp"><div class="ex-fr">Il <span class="epc">a expliqué</span> qu'il <span class="epqp">avait oublié</span> ses clés.</div><div class="ex-es">Explicó que había olvidado sus llaves.</div></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- 7. TRAMPAS -->
    <div class="sec-block" id="s-trampas">
      <div class="gram-card">
        <div class="gram-card-body">
          <div class="def-box">Los 7 errores más frecuentes de hispanohablantes en el DELF B1–B2.</div>
          <div class="trap-cards" id="trap-cards"></div>
        </div>
      </div>
    </div>

  </div><!-- /panel-ref -->
</div><!-- /main-layout -->

<script>
/* ══════════ DATA ══════════ */
const TRAPS = [
  {name:'Duración ≠ Imparfait',
   wrong:'Il a travaillé pendant 3 heures → imparfait',
   right:'Il a travaillé pendant 3 heures → PC',
   expl:'La <strong>duración especificada</strong> no implica imparfait. Si la acción está delimitada y terminada → PC. <em>Il a dormi pendant 8 heures.</em> ✓'},
  {name:'Ser / estar en el pasado',
   wrong:"C'était un accident qui a duré (imparfait para el evento)",
   right:"C'était calme (estado) + l'accident a eu lieu (evento)",
   expl:'<em>Être</em> describe <strong>estados</strong> → imparfait casi siempre. Pero <em>c\'était</em> puede ser PC en estilo hablado cuando introduce un hecho puntual.'},
  {name:'Hábito con número específico',
   wrong:'Je visitais Paris trois fois.',
   right:'J\'ai visité Paris trois fois.',
   expl:'Cuando el hábito incluye un <strong>número concreto de veces</strong>, se usa PC: <em>trois fois, une fois par semaine pendant un mois</em>…'},
  {name:'Concordancia del participio con être',
   wrong:'Elle est parti / Ils est allé',
   right:'Elle est partie / Ils sont allés',
   expl:'Con auxiliar <strong>être</strong>, el participio concuerda en género y número con el sujeto. <em>Elle est partie, elles sont parties, ils sont partis.</em>'},
  {name:'PQP vs. PC en secuencias',
   wrong:'Quand il est arrivé, elle est déjà partie.',
   right:'Quand il est arrivé, elle était déjà partie.',
   expl:'Si una acción pasada ocurrió <strong>antes que otra</strong>, la anterior debe ir en PQP, no en PC. El marcador <em>déjà</em> es una señal frecuente.'},
  {name:'Imparfait de cortesía confundido con présent',
   wrong:'Je veux vous demander quelque chose. (brusco)',
   right:'Je voulais vous demander quelque chose.',
   expl:'En francés formal, el <strong>imparfait de cortesía o atenuación</strong> suaviza peticiones. Equivale a un condicional suavizado: <em>je voulais, je venais pour…</em>'},
  {name:'Passé récent confundido con PC',
   wrong:'J\'ai vu le film (cuando fue hace muy poco)',
   right:'Je viens de voir le film.',
   expl:'Para acciones <strong>muy recientes</strong> ("acabar de"), el francés usa <em>venir de + infinitif</em>, no el PC. <em>Je viens de manger, il vient d\'arriver.</em>'},
];

/* ══════════ RENDER TRAPS ══════════ */
function renderTraps() {
  document.getElementById('trap-cards').innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join('');
}

/* ══════════ GENERIC CHIP SELECT ══════════ */
function selectChip(ns, idx) {
  // Find chip-bar by scanning all chip-bars for a button whose onclick contains this namespace
  document.querySelectorAll('.chip-bar').forEach(bar => {
    const first = bar.querySelector('.chip');
    if (first && first.getAttribute('onclick') && first.getAttribute('onclick').includes("'" + ns + "'")) {
      bar.querySelectorAll('.chip').forEach((c,i) => c.classList.toggle('active', i===idx));
    }
  });
  // Find panels div: try ns+'-panels' first, then scan by contained panel ids
  const panelsEl = document.getElementById(ns + '-panels');
  if (panelsEl) {
    panelsEl.querySelectorAll(':scope > .chip-panel').forEach((p,i) => p.classList.toggle('active', i===idx));
  }
}

/* ══════════ SECTION NAV ══════════ */
function showSection(id, btn) {
  document.querySelectorAll('.sec-block').forEach(s => s.classList.remove('active'));
  document.querySelectorAll('.snav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  btn.classList.add('active');
}

function switchMode(mode, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('panel-'+mode).classList.add('active');
  btn.classList.add('active');
  document.getElementById('section-nav').style.display = mode==='ref' ? '' : 'none';
}

/* ══════════ FONT SIZE ══════════ */
function setFontSize(v) { document.documentElement.style.setProperty('--fs', v+'px'); }

/* ══════════ EXERCISE STATE ══════════ */
let exType='fill', exDiff='B1', exQty=5, exFoco='mix';
let exTotal=0, exAnswered=0, exCorrect=0, exWrong=0;

document.querySelectorAll('.ex-opt-btn:not(.foco)').forEach(b => b.addEventListener('click', function(){
  document.querySelectorAll('.ex-opt-btn:not(.foco)').forEach(x => x.classList.remove('active'));
  this.classList.add('active'); exType = this.dataset.type;
}));
document.querySelectorAll('.ex-opt-btn.foco').forEach(b => b.addEventListener('click', function(){
  document.querySelectorAll('.ex-opt-btn.foco').forEach(x => x.classList.remove('active'));
  this.classList.add('active'); exFoco = this.dataset.foco;
}));

function setDiff(d) {
  exDiff = d;
  document.querySelectorAll('#diff-btns .pill-btn').forEach(b => {
    b.classList.remove('active','A2','B1','B2');
    if (b.textContent.trim()===d) b.classList.add('active',d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll('#qty-btns .pill-btn').forEach(b =>
    b.classList.toggle('active', parseInt(b.textContent.trim())===q)
  );
}

/* ══════════ GENERATE ══════════ */
const FOCO_DESC = {
  mix: 'los tres tiempos (passé composé, imparfait y plus-que-parfait), mezclando libremente',
  pc: 'exclusivamente el passé composé: auxiliar correcto (avoir/être), participio correcto, concordancia',
  imp: 'exclusivamente el imparfait: formación correcta a partir de la raíz de nous',
  pqp: 'exclusivamente el plus-que-parfait: auxiliar en imparfait + participio',
  pc_imp: 'la distinción passé composé vs. imparfait: el alumno debe elegir el tiempo correcto según el contexto',
};
const TYPE_DESC = {
  fill: 'completar huecos: el alumno escribe la forma correcta del verbo en el hueco',
  choice: 'elección múltiple: 4 opciones (formas verbales), solo una correcta',
  transform: 'transformación: reformular la frase poniendo el verbo en el tiempo pedido',
  mix: 'mixto: combina fill, choice y transform de forma variada',
};

const RULE_LABELS = {
  's-intro':'Visión general','s-pc':'Passé composé','s-imp':'Imparfait',
  's-pqp':'Plus-que-parfait','s-contraste':'PC vs. Imparfait',
  's-pqp2':'PQP en contexto','s-trampas':'Trampas'
};

function renderExercises(exs) {
  const area = document.getElementById('exercise-area');
  const labels = {fill:'Completar', choice:'Elección múltiple', transform:'Transformación'};
  area.innerHTML = exs.map((ex,i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||''}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex,i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join('');

  exs.forEach((ex,i) => {
    const chk = document.getElementById('chk-'+i);
    if (chk) chk.addEventListener('click', ()=>checkAnswer(ex,i));
    const inp = document.getElementById('inp-'+i);
    if (inp) inp.addEventListener('keydown', e => { if(e.key==='Enter') checkAnswer(ex,i); });
  });
}

function buildBody(ex,i) {
  if (ex.type==='fill')
    return `<div class="exercise-prompt">${ex.prompt_parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||'…'}" autocomplete="off" spellcheck="false">${ex.prompt_parts[1]||''}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  if (ex.type==='choice')
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join('')}</div>`;
  if (ex.type==='transform')
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Tu respuesta…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return '';
}

function checkAnswer(ex,i) {
  const inp = document.getElementById('inp-'+i);
  if (!inp||inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok?'ok':'err'); inp.disabled=true;
  const chk = document.getElementById('chk-'+i); if(chk) chk.disabled=true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0||c0.disabled) return;
  for(let j=0;j<4;j++){
    const b=document.getElementById(`ch-${idx}-${j}`);
    if(!b) continue; b.disabled=true;
    if(j===correct)b.classList.add('ok'); else if(j===chosen)b.classList.add('err');
  }
  const card=document.getElementById('ex-card-'+idx);
  showFeedback(idx, chosen===correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen===correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById('ex-st-'+i).textContent = ok?'✅':'❌';
  const fb=document.getElementById('ex-fb-'+i);
  fb.className='ex-feedback visible '+(ok?'ok':'err');
  const link = RULE_LABELS[ruleRef]
    ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : '';
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans?` — Respuesta: <strong>${ans}</strong>`:''}`;
  if(expl) html += `<br><span style="font-size:0.88em;opacity:0.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML=html;
}

function goToRule(ref) {
  switchMode('ref', document.querySelector('.mode-btn'));
  setTimeout(()=>{
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:'smooth',block:'start'});
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if(ok)exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal>0 ? (exAnswered/exTotal)*100 : 0;
  document.getElementById('progress-frac').textContent=`${exAnswered} / ${exTotal}`;
  document.getElementById('progress-fill').style.width=pct+'%';
  document.getElementById('score-correct').textContent=`${exCorrect} correcta${exCorrect!==1?'s':''}`;
  document.getElementById('score-wrong').textContent=`${exWrong} error${exWrong!==1?'es':''}`;
  if(exAnswered>=exTotal&&exTotal>0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect/exTotal)*100);
  document.getElementById('final-score-bar').classList.add('visible');
  document.getElementById('final-num').textContent=`${exCorrect} / ${exTotal}`;
  const fill=document.getElementById('final-fill');
  fill.style.width=pct+'%';
  fill.style.background = pct>=80?'var(--green)':pct>=50?'var(--accent)':'var(--red)';
  const msgs={100:'¡Parfait! Dominas los tiempos del pasado. 🎉',80:'Très bien! Repasa los errores marcados.',50:'Bien, pero refuerza los bloques señalados.',0:'Vuelve a Referencia antes de repetir.'};
  document.getElementById('final-msg').textContent=msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById('score-pill').style.display='';
  document.getElementById('score-pill-val').textContent=`${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById('exercise-area').innerHTML=`<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById('progress-wrap').classList.remove('visible');
  document.getElementById('final-score-bar').classList.remove('visible');
  document.getElementById('score-pill').style.display='none';
  exAnswered=0; exCorrect=0; exWrong=0;
}

function esc(s) { return (s||'').replace(/"/g,'&quot;').replace(/</g,'&lt;'); }

/* ══════════ INIT ══════════ */
renderTraps();
</script>
</body>
</html>
