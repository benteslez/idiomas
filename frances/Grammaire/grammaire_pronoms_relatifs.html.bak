<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Pronoms Relatifs</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ede9df;
  --card: #faf7f1;
  --border: #c4bead;
  --text: #1a1814;
  --text2: #44413a;
  --text3: #706c64;
  --accent: #7a5a0a;
  --accent-light: #f0e0c0;
  --accent-mid: #b89050;
  --warn-bg: #fdf0cc;
  --shadow: 0 2px 14px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.08);
  --radius: 14px;
  --radius-sm: 8px;
  --green: #1a6028;  --green-bg: #e4f2e8;
  --red: #a81e2e;    --red-bg: #fce6e8;
  --blue: #163494;   --blue-bg: #e6ebf8;
  --purple: #6a1a8a; --purple-bg: #f2e6f8;
  --qui-color: #163494;  --qui-bg: #e6ebf8;
  --que-color: #1a6028;  --que-bg: #e4f2e8;
  --ou-color:  #7a5a0a;  --ou-bg:  #f0e0c0;
  --dont-color:#6a1a8a;  --dont-bg:#f2e6f8;
  --leq-color: #8b1a4a;  --leq-bg: #f8e6ee;
  --fs: 15px;
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; font-size: var(--fs); }

/* ── HEADER ── */
.site-header { background: var(--card); border-bottom: 2px solid var(--border); padding: 20px 20px 14px; }
.header-top { display: flex; align-items: baseline; gap: 10px; margin-bottom: 3px; flex-wrap: wrap; }
.site-header h1 { font-family: 'Playfair Display', serif; font-size: clamp(1.2rem,5vw,1.9rem); font-weight: 700; color: var(--text); }
.header-tag { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); background: var(--accent-light); border: 1px solid var(--accent-mid); border-radius: 20px; padding: 3px 10px; }
.subtitle { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text3); margin-bottom: 12px; }
.stats-row { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; }
.stat-pill { background: var(--bg); border: 1px solid var(--border); border-radius: 20px; padding: 4px 11px; font-size: 0.76rem; font-weight: 600; }
.stat-pill.qui  { border-color: var(--qui-color);  color: var(--qui-color);  background: var(--qui-bg); }
.stat-pill.que  { border-color: var(--que-color);  color: var(--que-color);  background: var(--que-bg); }
.stat-pill.ou   { border-color: var(--ou-color);   color: var(--ou-color);   background: var(--ou-bg); }
.stat-pill.dont { border-color: var(--dont-color); color: var(--dont-color); background: var(--dont-bg); }
.stat-pill.leq  { border-color: var(--leq-color);  color: var(--leq-color);  background: var(--leq-bg); }
.fs-wrap { display: flex; align-items: center; gap: 7px; margin-left: auto; }
.fs-slider { width: 76px; accent-color: var(--accent); cursor: pointer; }
.fs-sz { color: var(--text3); font-weight: 700; }

/* ── NAV ── */
.mode-toggle { display: flex; border-bottom: 2px solid var(--border); background: var(--card); }
.mode-btn { flex: 1; padding: 12px 8px; font-family: 'DM Sans', sans-serif; font-size: 0.84rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; margin-bottom: -2px; }
.mode-btn.active { color: var(--accent); border-bottom-color: var(--accent); }
.section-nav { position: sticky; top: 0; z-index: 200; background: var(--card); border-bottom: 2px solid var(--border); box-shadow: var(--shadow-sm); }
.section-nav-inner { display: flex; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
.section-nav-inner::-webkit-scrollbar { display: none; }
.snav-btn { flex-shrink: 0; padding: 11px 16px; font-family: 'DM Sans', sans-serif; font-size: 0.8rem; font-weight: 600; color: var(--text3); background: transparent; border: none; border-bottom: 3px solid transparent; cursor: pointer; transition: all 0.15s; white-space: nowrap; }
.snav-btn:hover { color: var(--text2); }
.snav-btn.active { color: var(--accent); border-bottom-color: var(--accent); }

/* ── LAYOUT ── */
.main-layout { max-width: 860px; margin: 0 auto; padding: 16px 16px 40px; }
.panel { display: none; } .panel.active { display: block; }
.sec-block { display: none; } .sec-block.active { display: block; }
.gram-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 14px; overflow: hidden; }
.gram-card-body { padding: 18px; }

/* ── BOXES ── */
.def-box { background: var(--warn-bg); border-left: 4px solid var(--accent); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 12px 15px; margin-bottom: 14px; line-height: 1.65; color: var(--text); }
.def-box strong { color: var(--accent); font-weight: 700; }
.warn-box { background: #fff4e0; border: 1px solid #c8900a; border-radius: var(--radius-sm); padding: 10px 13px; margin: 10px 0; font-size: 0.9em; display: flex; gap: 8px; align-items: flex-start; }
.warn-icon { flex-shrink: 0; margin-top: 1px; }
.warn-text { color: var(--text2); line-height: 1.55; }
.warn-text strong { color: #7a4400; font-weight: 700; }
.note-box { background: var(--purple-bg); border-left: 4px solid var(--purple); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.note-box strong { color: var(--purple); font-weight: 700; }
.green-box { background: var(--green-bg); border-left: 4px solid var(--green); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 10px 0; font-size: 0.9em; color: var(--text2); line-height: 1.55; }
.green-box strong { color: var(--green); font-weight: 700; }

/* ── EXAMPLE BLOCKS ── */
.example-block { border-radius: 0 var(--radius-sm) var(--radius-sm) 0; padding: 10px 14px; margin: 8px 0; }
.example-block.qui  { background: var(--qui-bg);  border-left: 4px solid var(--qui-color); }
.example-block.que  { background: var(--que-bg);  border-left: 4px solid var(--que-color); }
.example-block.ou   { background: var(--ou-bg);   border-left: 4px solid var(--ou-color); }
.example-block.dont { background: var(--dont-bg); border-left: 4px solid var(--dont-color); }
.example-block.leq  { background: var(--leq-bg);  border-left: 4px solid var(--leq-color); }
.example-block.neu  { background: var(--blue-bg); border-left: 4px solid var(--blue); }
.ex-fr { font-weight: 600; margin-bottom: 3px; color: var(--text); }
.equi  { color: var(--qui-color);  font-weight: 700; }
.eque  { color: var(--que-color);  font-weight: 700; }
.eou   { color: var(--ou-color);   font-weight: 700; }
.edont { color: var(--dont-color); font-weight: 700; }
.eleq  { color: var(--leq-color);  font-weight: 700; }
.ex-fr em { color: var(--blue); font-style: normal; font-weight: 700; }
.ex-es { color: var(--text2); font-size: 0.88em; font-style: italic; }
.ex-note { font-size: 0.78em; color: var(--text3); margin-top: 3px; font-weight: 500; }

/* ── TABLES ── */
.table-wrap { overflow-x: auto; -webkit-overflow-scrolling: touch; margin-bottom: 14px; border-radius: var(--radius-sm); border: 1px solid var(--border); }
.gram-table { width: 100%; border-collapse: collapse; min-width: 280px; }
.gram-table th { background: var(--bg); border-bottom: 2px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; text-align: left; font-size: 0.72em; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--text3); }
.gram-table td { border-bottom: 1px solid var(--border); border-right: 1px solid var(--border); padding: 8px 11px; vertical-align: top; color: var(--text); }
.gram-table tr:last-child td { border-bottom: none; }
.gram-table tr:nth-child(even) td { background: #f4f0e6; }
.gram-table td:last-child, .gram-table th:last-child { border-right: none; }
.hl-qui  { color: var(--qui-color);  font-weight: 700; }
.hl-que  { color: var(--que-color);  font-weight: 700; }
.hl-ou   { color: var(--ou-color);   font-weight: 700; }
.hl-dont { color: var(--dont-color); font-weight: 700; }
.hl-leq  { color: var(--leq-color);  font-weight: 700; }
.hl      { color: var(--accent);     font-weight: 700; }
.dim     { color: var(--text3); }
.ok-cell   { color: var(--green); font-weight: 700; }
.err-cell  { color: var(--red);   font-weight: 600; font-style: italic; }

/* ── CHIPS ── */
.chip-bar { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.chip { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; white-space: nowrap; }
.chip:hover { border-color: var(--accent); background: var(--accent-light); color: var(--accent); }
.chip.active      { background: var(--accent);     color:#fff; border-color: var(--accent); }
.chip.qui.active  { background: var(--qui-color);  border-color: var(--qui-color); }
.chip.que.active  { background: var(--que-color);  border-color: var(--que-color); }
.chip.ou.active   { background: var(--ou-color);   border-color: var(--ou-color); }
.chip.dont.active { background: var(--dont-color); border-color: var(--dont-color); }
.chip.leq.active  { background: var(--leq-color);  border-color: var(--leq-color); }
.chip-panel { display: none; } .chip-panel.active { display: block; }

.sec-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--text3); margin: 14px 0 7px; }

/* ── PROPOSITION ANATOMY ── */
.prop-box { background: var(--bg); border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 14px 16px; margin: 12px 0; font-size: 0.9em; line-height: 2; }
.prop-ant { background: #fff3cd; border-bottom: 2px solid var(--ou-color); padding: 0 4px; border-radius: 3px; font-weight: 700; }
.prop-rel { display: inline-block; background: #e8f0ff; border: 1.5px solid var(--qui-color); border-radius: 4px; padding: 1px 6px; font-weight: 600; color: var(--qui-color); }
.prop-pr  { font-weight: 700; color: var(--accent); }

/* ── LEQUEL TABLE ── */
.leq-table { width: 100%; border-collapse: collapse; font-size: 0.88em; }
.leq-table th { background: var(--leq-bg); color: var(--leq-color); border: 1px solid var(--border); padding: 7px 10px; font-weight: 700; text-align: center; }
.leq-table td { border: 1px solid var(--border); padding: 7px 10px; text-align: center; }
.leq-table .hl-leq { color: var(--leq-color); font-weight: 700; }

/* ── TRAP CARDS ── */
.trap-cards { display: flex; flex-direction: column; gap: 10px; }
.trap-card { border: 1.5px solid var(--border); border-radius: var(--radius-sm); overflow: hidden; }
.trap-card-header { padding: 11px 14px; background: var(--bg); }
.trap-name { font-weight: 700; font-size: 0.9em; color: var(--text); margin-bottom: 7px; }
.trap-vs { display: flex; gap: 8px; flex-wrap: wrap; }
.trap-wrong { background: var(--red-bg);  border: 1.5px solid #d09098; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--red);   font-weight: 500; }
.trap-right { background: var(--green-bg); border: 1.5px solid #80b890; border-radius: 6px; padding: 4px 10px; font-size: 0.82em; color: var(--green); font-weight: 500; }
.trap-expl { padding: 10px 14px 12px; font-size: 0.86em; color: var(--text2); line-height: 1.6; border-top: 1px solid var(--border); background: var(--card); }
.trap-expl strong { color: var(--text); font-weight: 700; }

/* ── EXERCISES ── */
.exercise-controls { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 14px; box-shadow: var(--shadow-sm); }
.exercise-controls h3 { font-family: 'Playfair Display', serif; font-size: 1.05rem; font-weight: 700; margin-bottom: 14px; color: var(--text); }
.ctrl-label { font-size: 0.7em; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text3); margin-bottom: 7px; display: block; }
.ex-options { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 14px; }
.ex-opt-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 6px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.ex-opt-btn.active { background: var(--accent); color: white; border-color: var(--accent); }
.row-btns { display: flex; gap: 7px; margin-bottom: 14px; flex-wrap: wrap; }
.pill-btn { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 14px; font-family: 'DM Sans', sans-serif; font-size: 0.82em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; }
.pill-btn:hover:not(.active) { background: var(--border); }
.pill-btn.active { background: var(--text); color: var(--bg); border-color: var(--text); }
.pill-btn.diff.active.A2 { background: var(--green); border-color: var(--green); color: #fff; }
.pill-btn.diff.active.B1 { background: var(--blue);  border-color: var(--blue);  color: #fff; }
.pill-btn.diff.active.B2 { background: var(--accent); border-color: var(--accent); color: #fff; }
.btn-generate { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; border: none; border-radius: 10px; padding: 13px; font-family: 'DM Sans', sans-serif; font-size: 0.92em; font-weight: 700; cursor: pointer; background: var(--accent); color: white; transition: all 0.18s; margin-top: 4px; }
.btn-generate:hover:not(:disabled) { filter: brightness(1.1); box-shadow: 0 4px 14px rgba(122,90,10,0.32); }
.btn-generate:disabled { opacity: 0.5; cursor: not-allowed; }
.spinner { display: none; animation: spin 0.8s linear infinite; }
.btn-generate.loading .spinner { display: inline; }
.btn-generate.loading .btn-icon { display: none; }
@keyframes spin { to { transform: rotate(360deg); } }
.progress-wrap { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; margin-bottom: 14px; display: none; }
.progress-wrap.visible { display: block; }
.progress-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.progress-label { font-size: 0.78em; color: var(--text3); font-weight: 600; }
.progress-frac  { font-size: 0.92em; font-weight: 700; color: var(--accent); }
.progress-track { height: 7px; background: var(--border); border-radius: 4px; overflow: hidden; }
.progress-fill  { height: 100%; background: var(--accent); border-radius: 4px; transition: width 0.35s ease; }
.progress-score { display: flex; gap: 14px; margin-top: 9px; font-size: 0.8em; flex-wrap: wrap; align-items: center; }
.score-item { display: flex; align-items: center; gap: 5px; font-weight: 500; color: var(--text2); }
.score-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.score-dot.g { background: var(--green); } .score-dot.r { background: var(--red); }
.btn-retry { border: 1.5px solid var(--border); border-radius: 20px; padding: 5px 13px; font-family: 'DM Sans', sans-serif; font-size: 0.78em; font-weight: 600; cursor: pointer; background: var(--bg); color: var(--text2); transition: all 0.15s; margin-left: auto; }
.btn-retry:hover { background: var(--border); }
.final-score-bar { display: none; background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px 18px; margin-bottom: 14px; }
.final-score-bar.visible { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
.final-num { font-size: 1.5rem; font-weight: 700; color: var(--accent); }
.final-label { font-size: 0.74em; color: var(--text3); }
.final-track { flex: 1; min-width: 80px; height: 8px; background: var(--border); border-radius: 4px; overflow: hidden; }
.final-fill { height: 100%; border-radius: 4px; transition: width 0.5s ease; }
.final-msg { font-size: 0.84em; color: var(--text2); width: 100%; font-weight: 500; }
.exercise-area { display: none; } .exercise-area.visible { display: block; }
.exercise-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); box-shadow: var(--shadow); margin-bottom: 12px; overflow: hidden; }
.exercise-card-header { display: flex; align-items: center; gap: 8px; padding: 10px 16px; background: var(--bg); border-bottom: 1px solid var(--border); }
.ex-num { font-weight: 700; color: var(--accent); font-size: 0.88em; }
.ex-type-badge { font-size: 0.68em; font-weight: 700; letter-spacing: 0.07em; text-transform: uppercase; background: var(--accent-light); color: var(--accent); border: 1px solid var(--accent-mid); border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge { font-size: 0.68em; font-weight: 700; border-radius: 12px; padding: 2px 8px; }
.ex-diff-badge.A2 { background: var(--green-bg); color: var(--green); border: 1px solid #80b890; }
.ex-diff-badge.B1 { background: var(--blue-bg);  color: var(--blue);  border: 1px solid #90a8e0; }
.ex-diff-badge.B2 { background: var(--warn-bg);  color: var(--accent); border: 1px solid var(--accent-mid); }
.ex-status { margin-left: auto; }
.exercise-body { padding: 16px 18px; }
.exercise-prompt { line-height: 1.7; margin-bottom: 12px; color: var(--text); }
.exercise-prompt em { color: var(--accent); font-style: italic; font-weight: 600; }
.fill-input { border: none; border-bottom: 2px solid var(--accent-mid); background: var(--accent-light); padding: 2px 8px; border-radius: 4px 4px 0 0; font-family: 'DM Sans', sans-serif; font-size: 1em; color: var(--text); min-width: 110px; outline: none; transition: border-color 0.15s; }
.fill-input:focus { border-bottom-color: var(--accent); }
.fill-input.ok  { background: var(--green-bg); border-bottom-color: var(--green); }
.fill-input.err { background: var(--red-bg);   border-bottom-color: var(--red); }
.choices-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 7px; margin-bottom: 10px; }
.choice-btn { border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.88em; font-weight: 500; cursor: pointer; text-align: left; background: var(--bg); color: var(--text); transition: all 0.15s; }
.choice-btn:hover:not(:disabled) { border-color: var(--accent); background: var(--accent-light); }
.choice-btn.ok  { background: var(--green-bg); border-color: var(--green); color: var(--green); font-weight: 700; }
.choice-btn.err { background: var(--red-bg);   border-color: var(--red);   color: var(--red); }
.choice-btn:disabled { cursor: default; }
.transform-input { width: 100%; border: 1.5px solid var(--border); border-radius: var(--radius-sm); padding: 10px 12px; font-family: 'DM Sans', sans-serif; font-size: 0.9em; background: var(--bg); color: var(--text); outline: none; margin-bottom: 8px; transition: border-color 0.15s; }
.transform-input:focus { border-color: var(--accent); }
.transform-input.ok  { background: var(--green-bg); border-color: var(--green); }
.transform-input.err { background: var(--red-bg);   border-color: var(--red); }
.btn-check { border: 1.5px solid var(--accent); border-radius: 20px; padding: 7px 18px; font-family: 'DM Sans', sans-serif; font-size: 0.84em; font-weight: 700; cursor: pointer; background: transparent; color: var(--accent); transition: all 0.15s; }
.btn-check:hover:not(:disabled) { background: var(--accent); color: white; }
.btn-check:disabled { opacity: 0.35; cursor: default; }
.ex-feedback { display: none; border-radius: var(--radius-sm); padding: 11px 14px; line-height: 1.55; margin-top: 10px; font-size: 0.9em; }
.ex-feedback.visible { display: block; }
.ex-feedback.ok  { background: var(--green-bg); border: 1.5px solid #80b890; color: #0e4818; }
.ex-feedback.err { background: var(--red-bg);   border: 1.5px solid #c08090; color: #700018; }
.fb-rule-link { display: inline-flex; align-items: center; gap: 4px; margin-top: 8px; font-size: 0.84em; font-weight: 700; color: var(--accent); cursor: pointer; text-decoration: underline; text-underline-offset: 2px; }
.skeleton-card { background: var(--card); border: 1px solid var(--border); border-radius: var(--radius); padding: 18px; margin-bottom: 12px; }
.skel { background: linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%); background-size: 200% 100%; animation: skel 1.4s infinite; border-radius: 4px; height: 13px; margin-bottom: 9px; }
@keyframes skel { to { background-position: -200% 0; } }
.state-msg { text-align: center; padding: 40px 20px; color: var(--text3); }
.state-icon { font-size: 2rem; margin-bottom: 10px; }
.state-msg p { max-width: 260px; margin: 0 auto; line-height: 1.6; font-weight: 500; }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <h1>Les Pronoms Relatifs</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill qui">qui</div>
    <div class="stat-pill que">que</div>
    <div class="stat-pill ou">où</div>
    <div class="stat-pill dont">dont</div>
    <div class="stat-pill leq">lequel</div>
    <div class="stat-pill" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:0.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>

<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>

<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Qué son</button>
    <button class="snav-btn"        onclick="showSection('s-qui',this)">2. QUI</button>
    <button class="snav-btn"        onclick="showSection('s-que',this)">3. QUE</button>
    <button class="snav-btn"        onclick="showSection('s-ou',this)">4. OÙ</button>
    <button class="snav-btn"        onclick="showSection('s-dont',this)">5. DONT</button>
    <button class="snav-btn"        onclick="showSection('s-lequel',this)">6. LEQUEL</button>
    <button class="snav-btn"        onclick="showSection('s-contraste',this)">7. Elección</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">8. Trampas</button>
  </div>
</div>

<div class="main-layout">
<div class="panel active" id="panel-ref">

  <!-- 1. QUÉ SON -->
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Un <strong>pronom relatif</strong> une deux phrases en una sola, introduciendo una <strong>proposición subordinada relativa</strong> que aporta información sobre un sustantivo ya mencionado (el <strong>antécédent</strong>). La elección del pronombre depende de la <strong>función gramatical</strong> que ocupa en la subordinada, no de si el antecedente es persona o cosa.
      </div>

      <div class="sec-label">Anatomía de la proposición relativa</div>
      <div class="prop-box">
        Le livre <span class="prop-ant">que</span> <span class="prop-rel">[tu m'as prêté]</span> est passionnant.
        <br><span class="dim" style="font-size:0.82em">antécédent: <em>le livre</em> · pronom: <em>que</em> (COD dans la subordonnée) · prop. principale: <em>Le livre est passionnant</em></span>
      </div>

      <div class="sec-label">Tabla de referencia: función → pronombre</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Función en la subordinada</th><th>Pronombre</th><th>Antecedente</th><th>Ejemplo rápido</th></tr></thead>
        <tbody>
          <tr><td>Sujeto</td><td class="hl-qui">qui</td><td>persona o cosa</td><td>le livre <span class="hl-qui">qui</span> est sur la table</td></tr>
          <tr><td>COD</td><td class="hl-que">que / qu'</td><td>persona o cosa</td><td>le livre <span class="hl-que">que</span> je lis</td></tr>
          <tr><td>Lugar / tiempo</td><td class="hl-ou">où</td><td>lugar o tiempo</td><td>la ville <span class="hl-ou">où</span> j'habite</td></tr>
          <tr><td>Complemento con <em>de</em></td><td class="hl-dont">dont</td><td>persona o cosa</td><td>le film <span class="hl-dont">dont</span> je parle</td></tr>
          <tr><td>Compl. con preposición (≠ de)</td><td class="hl-leq">lequel / laquelle…</td><td>persona o cosa</td><td>la table <span class="hl-leq">sur laquelle</span> je travaille</td></tr>
        </tbody>
      </table></div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Clave de elección:</strong> pregúntate qué función tiene el pronombre <em>dentro</em> de la subordinada. ¿Es el sujeto? → <strong>qui</strong>. ¿Es el COD? → <strong>que</strong>. ¿Tiene preposición? → <strong>dont</strong> (de) o <strong>lequel</strong> (otras prep.).</div>
      </div>
    </div></div>
  </div>

  <!-- 2. QUI -->
  <div class="sec-block" id="s-qui">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong class="hl-qui">Qui</strong> es el pronombre relativo <strong>sujeto</strong>. El verbo de la subordinada concuerda con el antecedente. Puede referirse tanto a personas como a cosas.
      </div>

      <div class="sec-label">Estructura</div>
      <div class="prop-box">
        antécédent + <span class="prop-pr">qui</span> + [verbe de la subordonnée…]
        <br><span class="dim" style="font-size:0.82em">qui = sujeto de la subordinada → verbo concuerda con el antecedente</span>
      </div>

      <div class="chip-bar">
        <button class="chip qui active" onclick="selectChip('qui',0)">Antecedente: persona</button>
        <button class="chip qui"        onclick="selectChip('qui',1)">Antecedente: cosa</button>
        <button class="chip qui"        onclick="selectChip('qui',2)">Qui tras preposición (= a quien)</button>
      </div>
      <div id="qui-panels">
        <div class="chip-panel active" id="qui-p-0">
          <div class="example-block qui"><div class="ex-fr">C'est un ami <span class="equi">qui</span> parle plusieurs langues.</div><div class="ex-es">Es un amigo que habla varios idiomas.</div><div class="ex-note">qui = sujeto de "parle" → concuerda con "un ami" (sing.)</div></div>
          <div class="example-block qui"><div class="ex-fr">Les étudiants <span class="equi">qui</span> ont réussi l'examen sont contents.</div><div class="ex-es">Los estudiantes que aprobaron el examen están contentos.</div></div>
          <div class="example-block qui"><div class="ex-fr">Je connais quelqu'un <span class="equi">qui</span> peut t'aider.</div><div class="ex-es">Conozco a alguien que puede ayudarte.</div></div>
          <div class="example-block qui"><div class="ex-fr">C'est elle <span class="equi">qui</span> a pris la décision.</div><div class="ex-es">Es ella quien tomó la decisión.</div><div class="ex-note">Estructura de énfasis: c'est… qui</div></div>
          <div class="example-block qui"><div class="ex-fr">La femme <span class="equi">qui</span> vous a appelé hier s'appelle Marie.</div><div class="ex-es">La mujer que os llamó ayer se llama Marie.</div></div>
        </div>
        <div class="chip-panel" id="qui-p-1">
          <div class="example-block qui"><div class="ex-fr">Le livre <span class="equi">qui</span> est sur la table est à moi.</div><div class="ex-es">El libro que está sobre la mesa es mío.</div></div>
          <div class="example-block qui"><div class="ex-fr">J'ai acheté un ordinateur <span class="equi">qui</span> fonctionne très bien.</div><div class="ex-es">He comprado un ordenador que funciona muy bien.</div></div>
          <div class="example-block qui"><div class="ex-fr">Il y a une réunion <span class="equi">qui</span> commence à 14h.</div><div class="ex-es">Hay una reunión que empieza a las 14h.</div></div>
          <div class="example-block qui"><div class="ex-fr">C'est le problème <span class="equi">qui</span> m'inquiète le plus.</div><div class="ex-es">Es el problema que más me preocupa.</div></div>
          <div class="example-block qui"><div class="ex-fr">Voilà les documents <span class="equi">qui</span> manquaient.</div><div class="ex-es">Aquí están los documentos que faltaban.</div></div>
        </div>
        <div class="chip-panel" id="qui-p-2">
          <div class="def-box">Después de preposición, <em>qui</em> solo se usa para <strong>personas</strong>: <em>à qui, pour qui, avec qui, chez qui…</em> Para cosas, se usa <em>lequel</em>.</div>
          <div class="example-block qui"><div class="ex-fr">La personne à <span class="equi">qui</span> j'ai parlé était très aimable.</div><div class="ex-es">La persona con quien hablé era muy amable.</div></div>
          <div class="example-block qui"><div class="ex-fr">L'ami chez <span class="equi">qui</span> je séjourne habite à Lyon.</div><div class="ex-es">El amigo en cuya casa me alojo vive en Lyon.</div></div>
          <div class="example-block qui"><div class="ex-fr">C'est la collègue pour <span class="equi">qui</span> j'ai écrit ce rapport.</div><div class="ex-es">Es la compañera para quien escribí ese informe.</div></div>
          <div class="example-block qui"><div class="ex-fr">Le médecin avec <span class="equi">qui</span> elle travaille est très compétent.</div><div class="ex-es">El médico con quien trabaja es muy competente.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Prep. + <strong>qui</strong> solo para personas. Prep. + <strong>lequel/laquelle…</strong> para cosas: <em>la table sur <strong>laquelle</strong></em> (no: <em>sur qui</em>).</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 3. QUE -->
  <div class="sec-block" id="s-que">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong class="hl-que">Que / qu'</strong> es el pronombre relativo <strong>COD</strong> (objeto directo) de la subordinada. El antecedente puede ser persona o cosa. Nunca es sujeto. Se elide en <em>qu'</em> ante vocal.
      </div>

      <div class="sec-label">Estructura</div>
      <div class="prop-box">
        antécédent + <span class="prop-pr">que</span> + [sujeto + verbo de la subordonnée…]
        <br><span class="dim" style="font-size:0.82em">que ≠ sujeto: siempre tiene su propio sujeto detrás (diferencia clave con qui)</span>
      </div>

      <div class="chip-bar">
        <button class="chip que active" onclick="selectChip('que',0)">Que como COD (persona/cosa)</button>
        <button class="chip que"        onclick="selectChip('que',1)">Accord du participe avec que</button>
        <button class="chip que"        onclick="selectChip('que',2)">Que en passé composé</button>
      </div>
      <div id="que-panels">
        <div class="chip-panel active" id="que-p-0">
          <div class="example-block que"><div class="ex-fr">Le film <span class="eque">que</span> j'ai vu hier était excellent.</div><div class="ex-es">La película que vi ayer era excelente.</div><div class="ex-note">que = COD de "j'ai vu" → j'ai vue (accord)</div></div>
          <div class="example-block que"><div class="ex-fr">La personne <span class="eque">que</span> tu cherches est partie.</div><div class="ex-es">La persona que buscas se ha ido.</div></div>
          <div class="example-block que"><div class="ex-fr">C'est le livre <span class="eque">qu'</span>elle m'a offert.</div><div class="ex-es">Es el libro que me regaló. (elision)</div></div>
          <div class="example-block que"><div class="ex-fr">Les documents <span class="eque">que</span> nous avons préparés sont prêts.</div><div class="ex-es">Los documentos que hemos preparado están listos.</div></div>
          <div class="example-block que"><div class="ex-fr">C'est lui <span class="eque">que</span> j'aime. (énfasis)</div><div class="ex-es">Es a él a quien quiero. (estructura c'est… que)</div></div>
        </div>
        <div class="chip-panel" id="que-p-1">
          <div class="def-box">Cuando <em>que</em> es COD y el verbo de la subordinada está en passé composé con <em>avoir</em>, el participio <strong>concuerda en género y número con el antecedente</strong> (= con que).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Antecedente</th><th>Accord</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>masc. sing.</td><td class="dim">— (sin acuerdo)</td><td>le livre <span class="hl-que">que</span> j'ai lu</td></tr>
              <tr><td>fém. sing.</td><td class="hl-que">-e</td><td>la lettre <span class="hl-que">que</span> j'ai écrit<span class="hl-que">e</span></td></tr>
              <tr><td>masc. pl.</td><td class="hl-que">-s</td><td>les films <span class="hl-que">que</span> j'ai vu<span class="hl-que">s</span></td></tr>
              <tr><td>fém. pl.</td><td class="hl-que">-es</td><td>les photos <span class="hl-que">que</span> j'ai pris<span class="hl-que">es</span></td></tr>
            </tbody>
          </table></div>
          <div class="example-block que"><div class="ex-fr">Les lettres <span class="eque">que</span> tu as écrit<span class="eque">es</span> sont magnifiques.</div><div class="ex-es">Las cartas que escribiste son magníficas. (fém. pl. → -es)</div></div>
          <div class="example-block que"><div class="ex-fr">Voilà la décision <span class="eque">que</span> nous avons pris<span class="eque">e</span>.</div><div class="ex-es">Esta es la decisión que tomamos. (fém. sing. → -e)</div></div>
        </div>
        <div class="chip-panel" id="que-p-2">
          <div class="def-box">En passé composé, el participio concuerda con el antecedente de <em>que</em>. Esto es una trampa frecuente porque requiere conocer el género del antecedente.</div>
          <div class="example-block que"><div class="ex-fr">Les chansons <span class="eque">qu'</span>il a chant<span class="eque">ées</span> étaient magnifiques.</div><div class="ex-es">Las canciones que cantó eran magníficas. (chansons = fém. pl.)</div></div>
          <div class="example-block que"><div class="ex-fr">La voiture <span class="eque">que</span> j'ai achet<span class="eque">ée</span> est rouge.</div><div class="ex-es">El coche que compré es rojo. (voiture = fém. sing.)</div></div>
          <div class="example-block que"><div class="ex-fr">Les erreurs <span class="eque">que</span> vous avez commis<span class="eque">es</span> sont graves.</div><div class="ex-es">Los errores que cometisteis son graves. (erreurs = fém. pl.)</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Este acuerdo es <strong>obligatorio en la escritura</strong> y muy examinado en el DELF B2. En oral apenas se percibe, lo que aumenta el riesgo de olvidarlo al escribir.</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 4. OÙ -->
  <div class="sec-block" id="s-ou">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong class="hl-ou">Où</strong> es el pronombre relativo de <strong>lugar y tiempo</strong>. Sustituye a un complemento de lugar (<em>dans lequel, sur lequel…</em>) o de tiempo (<em>pendant lequel, au moment où…</em>). El antecedente puede ser un lugar o un momento temporal.
      </div>

      <div class="chip-bar">
        <button class="chip ou active" onclick="selectChip('ou',0)">Lugar</button>
        <button class="chip ou"        onclick="selectChip('ou',1)">Tiempo</button>
        <button class="chip ou"        onclick="selectChip('ou',2)">D'où (procedencia)</button>
      </div>
      <div id="ou-panels">
        <div class="chip-panel active" id="ou-p-0">
          <div class="example-block ou"><div class="ex-fr">La ville <span class="eou">où</span> j'habite s'appelle Bordeaux.</div><div class="ex-es">La ciudad donde vivo se llama Burdeos.</div></div>
          <div class="example-block ou"><div class="ex-fr">C'est le restaurant <span class="eou">où</span> nous avons dîné la semaine dernière.</div><div class="ex-es">Es el restaurante donde cenamos la semana pasada.</div></div>
          <div class="example-block ou"><div class="ex-fr">Le pays <span class="eou">où</span> il est né est très loin d'ici.</div><div class="ex-es">El país donde nació está muy lejos de aquí.</div></div>
          <div class="example-block ou"><div class="ex-fr">Voilà la pièce <span class="eou">où</span> les enfants jouent.</div><div class="ex-es">Esta es la habitación donde juegan los niños.</div></div>
          <div class="example-block ou"><div class="ex-fr">C'est la maison <span class="eou">où</span> Proust est né.</div><div class="ex-es">Es la casa donde nació Proust.</div></div>
        </div>
        <div class="chip-panel" id="ou-p-1">
          <div class="def-box"><em>Où</em> puede referirse a un <strong>momento temporal</strong> como antecedente: <em>le jour, le moment, l'époque, l'année, la fois…</em></div>
          <div class="example-block ou"><div class="ex-fr">Je me souviens du jour <span class="eou">où</span> on s'est rencontrés.</div><div class="ex-es">Me acuerdo del día en que nos conocimos.</div></div>
          <div class="example-block ou"><div class="ex-fr">Il y a des moments <span class="eou">où</span> je ne comprends plus rien.</div><div class="ex-es">Hay momentos en que ya no entiendo nada.</div></div>
          <div class="example-block ou"><div class="ex-fr">C'était l'époque <span class="eou">où</span> tout semblait possible.</div><div class="ex-es">Era la época en que todo parecía posible.</div></div>
          <div class="example-block ou"><div class="ex-fr">La nuit <span class="eou">où</span> il est parti, il pleuvait.</div><div class="ex-es">La noche en que se fue, llovía.</div></div>
          <div class="example-block ou"><div class="ex-fr">L'année <span class="eou">où</span> j'ai fini mes études, j'avais 23 ans.</div><div class="ex-es">El año en que terminé mis estudios, tenía 23 años.</div></div>
        </div>
        <div class="chip-panel" id="ou-p-2">
          <div class="def-box"><em>D'où</em> expresa procedencia o consecuencia lógica. Es más formal y muy frecuente en escritura argumentativa.</div>
          <div class="example-block ou"><div class="ex-fr">C'est la ville <span class="eou">d'où</span> vient ma famille.</div><div class="ex-es">Es la ciudad de donde proviene mi familia.</div></div>
          <div class="example-block ou"><div class="ex-fr">Il est parti sans laisser d'adresse, <span class="eou">d'où</span> notre inquiétude.</div><div class="ex-es">Se fue sin dejar dirección, de ahí nuestra preocupación. (consecuencia)</div></div>
          <div class="example-block ou"><div class="ex-fr">La région <span class="eou">d'où</span> il est originaire est magnifique.</div><div class="ex-es">La región de la que es originario es preciosa.</div></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 5. DONT -->
  <div class="sec-block" id="s-dont">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong class="hl-dont">Dont</strong> sustituye a un complemento introducido por <strong>de</strong>. Cubre cuatro casos principales: complemento de verbo con <em>de</em>, complemento de nombre (posesión), complemento de adjetivo con <em>de</em>, y <em>dont</em> de manera. Es el pronombre relativo más complejo y más examinado.
      </div>

      <div class="sec-label">Estructura clave</div>
      <div class="prop-box">
        antécédent + <span class="prop-pr">dont</span> + [sujeto + verbo + (resto sin <em>de</em>)]
        <br><span class="dim" style="font-size:0.82em">La preposición <em>de</em> desaparece: se integra en <em>dont</em></span>
      </div>

      <div class="chip-bar">
        <button class="chip dont active" onclick="selectChip('dont',0)">Verbe + de (parler de, avoir besoin de…)</button>
        <button class="chip dont"        onclick="selectChip('dont',1)">Possessif (dont = de qui / duquel)</button>
        <button class="chip dont"        onclick="selectChip('dont',2)">Adjectif + de (fier de, content de…)</button>
        <button class="chip dont"        onclick="selectChip('dont',3)">Dont de manière / façon</button>
      </div>
      <div id="dont-panels">
        <div class="chip-panel active" id="dont-p-0">
          <div class="def-box">El verbo de la subordinada se construye con <em>de + complément</em>: <em>parler de, se souvenir de, avoir besoin de, rêver de, s'occuper de, profiter de…</em></div>
          <div class="example-block dont"><div class="ex-fr">C'est le film <span class="edont">dont</span> je t'ai parlé.</div><div class="ex-es">Es la película de la que te hablé.</div><div class="ex-note">parler de + le film → dont</div></div>
          <div class="example-block dont"><div class="ex-fr">Voilà l'outil <span class="edont">dont</span> j'ai besoin.</div><div class="ex-es">Esta es la herramienta que necesito.</div><div class="ex-note">avoir besoin de + outil → dont</div></div>
          <div class="example-block dont"><div class="ex-fr">C'est une maladie <span class="edont">dont</span> on ne guérit pas facilement.</div><div class="ex-es">Es una enfermedad de la que no se cura fácilmente.</div></div>
          <div class="example-block dont"><div class="ex-fr">Le projet <span class="edont">dont</span> elle s'occupe est très ambitieux.</div><div class="ex-es">El proyecto del que se ocupa es muy ambicioso.</div></div>
          <div class="example-block dont"><div class="ex-fr">C'est une expérience <span class="edont">dont</span> je me souviendrai toujours.</div><div class="ex-es">Es una experiencia que recordaré siempre.</div></div>
        </div>
        <div class="chip-panel" id="dont-p-1">
          <div class="def-box"><em>Dont</em> expresa posesión cuando equivale a <em>de qui / duquel / de laquelle</em>. El orden dentro de la subordinada es: <strong>sujeto + verbo + objeto (sin artículo poseedor)</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Dos frases</th><th>Con dont (posesión)</th></tr></thead>
            <tbody>
              <tr><td>J'ai un ami. Son père est médecin.</td><td>J'ai un ami <span class="hl-dont">dont</span> le père est médecin.</td></tr>
              <tr><td>C'est une femme. Sa voix est magnifique.</td><td>C'est une femme <span class="hl-dont">dont</span> la voix est magnifique.</td></tr>
              <tr><td>Il a un chien. Ses yeux sont bleus.</td><td>Il a un chien <span class="hl-dont">dont</span> les yeux sont bleus.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block dont"><div class="ex-fr">C'est un auteur <span class="edont">dont</span> j'admire le style.</div><div class="ex-es">Es un autor cuyo estilo admiro.</div></div>
          <div class="example-block dont"><div class="ex-fr">Voilà la maison <span class="edont">dont</span> les fenêtres sont toujours ouvertes.</div><div class="ex-es">Esta es la casa cuyas ventanas están siempre abiertas.</div></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Orden obligatorio tras <em>dont</em> posesivo: <strong>dont + sujeto + verbo + (artículo + nom)</strong>. <em>Un ami dont le père est médecin</em> ✓ — <em>un ami dont est médecin le père</em> ✗</div></div>
        </div>
        <div class="chip-panel" id="dont-p-2">
          <div class="def-box">Adjetivos construidos con <em>de</em>: <em>fier de, content de, satisfait de, conscient de, sûr de, responsable de…</em></div>
          <div class="example-block dont"><div class="ex-fr">C'est une réussite <span class="edont">dont</span> je suis très fier.</div><div class="ex-es">Es un logro del que estoy muy orgulloso.</div><div class="ex-note">être fier de → dont</div></div>
          <div class="example-block dont"><div class="ex-fr">Voilà les résultats <span class="edont">dont</span> nous sommes satisfaits.</div><div class="ex-es">Estos son los resultados con los que estamos satisfechos.</div></div>
          <div class="example-block dont"><div class="ex-fr">C'est un problème <span class="edont">dont</span> tout le monde est conscient.</div><div class="ex-es">Es un problema del que todo el mundo es consciente.</div></div>
          <div class="example-block dont"><div class="ex-fr">Il y a des risques <span class="edont">dont</span> il faut être conscient.</div><div class="ex-es">Hay riesgos de los que hay que ser consciente.</div></div>
          <div class="example-block dont"><div class="ex-fr">C'est une décision <span class="edont">dont</span> je suis responsable.</div><div class="ex-es">Es una decisión de la que soy responsable.</div></div>
        </div>
        <div class="chip-panel" id="dont-p-3">
          <div class="def-box"><em>Dont</em> también puede expresar la manera o el modo, equivaliendo a <em>de cette façon</em> o <em>de cette manière</em>.</div>
          <div class="example-block dont"><div class="ex-fr">J'aime la façon <span class="edont">dont</span> elle parle.</div><div class="ex-es">Me gusta la manera en que habla.</div></div>
          <div class="example-block dont"><div class="ex-fr">La manière <span class="edont">dont</span> il a géré la crise est admirable.</div><div class="ex-es">La manera en que gestionó la crisis es admirable.</div></div>
          <div class="example-block dont"><div class="ex-fr">Je n'aime pas la façon <span class="edont">dont</span> il me regarde.</div><div class="ex-es">No me gusta la manera en que me mira.</div></div>
          <div class="example-block dont"><div class="ex-fr">La vitesse <span class="edont">dont</span> elle travaille m'impressionne.</div><div class="ex-es">La velocidad a la que trabaja me impresiona.</div></div>
          <div class="note-box"><strong>Patrón fijo:</strong> <em>la façon / la manière dont + sujeto + verbo</em> — sin preposición adicional.</div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 6. LEQUEL -->
  <div class="sec-block" id="s-lequel">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong class="hl-leq">Lequel / laquelle / lesquels / lesquelles</strong> se usa cuando el pronombre relativo va precedido de una <strong>preposición distinta de <em>de</em></strong> (pour, avec, sur, dans, par, à, en…). Concuerda en género y número con el antecedente. Con <em>à</em> y <em>de</em> se contrae.
      </div>

      <div class="sec-label">Tabla de formas</div>
      <div class="table-wrap">
        <table class="leq-table">
          <thead><tr><th></th><th>Masc. sing.</th><th>Fém. sing.</th><th>Masc. pl.</th><th>Fém. pl.</th></tr></thead>
          <tbody>
            <tr><td><strong>Base</strong></td><td class="hl-leq">lequel</td><td class="hl-leq">laquelle</td><td class="hl-leq">lesquels</td><td class="hl-leq">lesquelles</td></tr>
            <tr><td><strong>à +</strong></td><td class="hl-leq">auquel</td><td class="hl-leq">à laquelle</td><td class="hl-leq">auxquels</td><td class="hl-leq">auxquelles</td></tr>
            <tr><td><strong>de +</strong></td><td class="hl-leq">duquel</td><td class="hl-leq">de laquelle</td><td class="hl-leq">desquels</td><td class="hl-leq">desquelles</td></tr>
          </tbody>
        </table>
      </div>

      <div class="chip-bar">
        <button class="chip leq active" onclick="selectChip('leq',0)">Preposiciones simples (sur, dans, pour, avec…)</button>
        <button class="chip leq"        onclick="selectChip('leq',1)">Auquel / auxquels (à + lequel)</button>
        <button class="chip leq"        onclick="selectChip('leq',2)">Duquel / desquels (de + lequel)</button>
        <button class="chip leq"        onclick="selectChip('leq',3)">Lequel pour personnes (vs. qui)</button>
      </div>
      <div id="leq-panels">
        <div class="chip-panel active" id="leq-p-0">
          <div class="def-box">Con preposiciones como <em>sur, dans, pour, avec, par, sans, en face de, à côté de…</em> → <em>lequel</em> con concordancia.</div>
          <div class="example-block leq"><div class="ex-fr">C'est la table <span class="eleq">sur laquelle</span> je travaille.</div><div class="ex-es">Es la mesa sobre la que trabajo.</div></div>
          <div class="example-block leq"><div class="ex-fr">Le projet <span class="eleq">pour lequel</span> il travaille est ambitieux.</div><div class="ex-es">El proyecto por el que trabaja es ambicioso.</div></div>
          <div class="example-block leq"><div class="ex-fr">C'est l'outil <span class="eleq">avec lequel</span> on peut tout faire.</div><div class="ex-es">Es la herramienta con la que se puede hacer todo.</div></div>
          <div class="example-block leq"><div class="ex-fr">Les raisons <span class="eleq">pour lesquelles</span> il a démissionné restent inconnues.</div><div class="ex-es">Las razones por las que dimitió siguen desconocidas.</div></div>
          <div class="example-block leq"><div class="ex-fr">La fenêtre <span class="eleq">par laquelle</span> il est entré était ouverte.</div><div class="ex-es">La ventana por la que entró estaba abierta.</div></div>
        </div>
        <div class="chip-panel" id="leq-p-1">
          <div class="def-box"><em>À + lequel → auquel</em>. Se usa cuando el verbo de la subordinada se construye con <em>à</em> y el antecedente es una <strong>cosa</strong> (para personas se prefiere <em>à qui</em>).</div>
          <div class="example-block leq"><div class="ex-fr">Le cours <span class="eleq">auquel</span> je participe est très intéressant.</div><div class="ex-es">El curso al que asisto es muy interesante.</div><div class="ex-note">participer à + le cours → auquel</div></div>
          <div class="example-block leq"><div class="ex-fr">Le problème <span class="eleq">auquel</span> nous faisons face est complexe.</div><div class="ex-es">El problema al que nos enfrentamos es complejo.</div></div>
          <div class="example-block leq"><div class="ex-fr">Les questions <span class="eleq">auxquelles</span> il a répondu étaient difficiles.</div><div class="ex-es">Las preguntas a las que respondió eran difíciles.</div></div>
          <div class="example-block leq"><div class="ex-fr">L'événement <span class="eleq">auquel</span> j'ai assisté était exceptionnel.</div><div class="ex-es">El evento al que asistí era excepcional.</div></div>
          <div class="warn-box"><span class="warn-icon">💡</span><div class="warn-text">Para personas con <em>à</em>: se prefiere <em>à qui</em>: <em>la personne <strong>à qui</strong> j'ai parlé</em>. Para cosas: <strong>auquel / à laquelle / auxquels / auxquelles</strong>.</div></div>
        </div>
        <div class="chip-panel" id="leq-p-2">
          <div class="def-box"><em>De + lequel → duquel / de laquelle / desquels / desquelles</em>. Alternativa formal a <em>dont</em>, especialmente con locuciones prepositivas (<em>à côté de, en face de, près de, au cours de…</em>).</div>
          <div class="example-block leq"><div class="ex-fr">L'immeuble à côté <span class="eleq">duquel</span> j'habite est très ancien.</div><div class="ex-es">El edificio al lado del cual vivo es muy antiguo.</div></div>
          <div class="example-block leq"><div class="ex-fr">La période au cours <span class="eleq">de laquelle</span> il a vécu était troublée.</div><div class="ex-es">El período durante el cual vivió era turbulento.</div></div>
          <div class="example-block leq"><div class="ex-fr">Les pays en face <span class="eleq">desquels</span> nous nous trouvons sont arabes.</div><div class="ex-es">Los países frente a los cuales nos encontramos son árabes.</div></div>
          <div class="note-box"><strong>Nota:</strong> con locuciones prepositivas + <em>de</em> (à côté de, près de, à l'intérieur de…), no se puede usar <em>dont</em> — hay que usar <em>duquel / de laquelle…</em></div>
        </div>
        <div class="chip-panel" id="leq-p-3">
          <div class="def-box">Después de preposición, <em>lequel</em> puede usarse para personas cuando se quiere precisar el género o en registros muy formales. Pero <em>qui</em> es más natural.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Con qui (más usual)</th><th>Con lequel (más formal)</th></tr></thead>
            <tbody>
              <tr><td>la personne avec <span class="hl-qui">qui</span> je travaille</td><td>la personne avec <span class="hl-leq">laquelle</span> je travaille</td></tr>
              <tr><td>l'ami chez <span class="hl-qui">qui</span> je loge</td><td>l'ami chez <span class="hl-leq">lequel</span> je loge</td></tr>
              <tr><td>les collègues pour <span class="hl-qui">qui</span> je travaille</td><td>les collègues pour <span class="hl-leq">lesquels</span> je travaille</td></tr>
            </tbody>
          </table></div>
          <div class="green-box"><strong>Regla práctica:</strong> preposición + persona → preferir <em>qui</em>. Preposición + cosa → usar <em>lequel</em> con concordancia.</div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 7. ELECCIÓN -->
  <div class="sec-block" id="s-contraste">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La elección del pronombre relativo correcto depende de un <strong>análisis de la función</strong> dentro de la subordinada. Estos chips presentan los pares más confundidos.
      </div>

      <div class="chip-bar">
        <button class="chip active" onclick="selectChip('contr',0)">qui vs. que</button>
        <button class="chip"        onclick="selectChip('contr',1)">que vs. dont</button>
        <button class="chip"        onclick="selectChip('contr',2)">dont vs. lequel</button>
        <button class="chip"        onclick="selectChip('contr',3)">où vs. quand / lequel</button>
        <button class="chip"        onclick="selectChip('contr',4)">Ejercicio de diagnóstico</button>
      </div>
      <div id="contr-panels">
        <div class="chip-panel active" id="contr-p-0">
          <div class="def-box"><strong>qui</strong> = sujeto de la subordinada · <strong>que</strong> = COD de la subordinada. La prueba: ¿el verbo de la subordinada ya tiene sujeto explícito?</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Prueba</th><th>Pronombre</th></tr></thead>
            <tbody>
              <tr><td>verbo sin sujeto explícito → el pronombre ES el sujeto</td><td class="hl-qui">qui</td></tr>
              <tr><td>verbo con sujeto explícito → el pronombre es COD</td><td class="hl-que">que</td></tr>
            </tbody>
          </table></div>
          <div class="example-block qui"><div class="ex-fr">C'est l'homme <span class="equi">qui</span> a appelé. (qui = sujeto de "a appelé")</div><div class="ex-es">Es el hombre que llamó.</div></div>
          <div class="example-block que"><div class="ex-fr">C'est l'homme <span class="eque">que</span> j'ai appelé. (je = sujeto; que = COD)</div><div class="ex-es">Es el hombre al que llamé.</div></div>
          <div class="example-block qui"><div class="ex-fr">Le film <span class="equi">qui</span> passe ce soir est excellent. (qui = sujeto de "passe")</div><div class="ex-es">La película que dan esta noche es excelente.</div></div>
          <div class="example-block que"><div class="ex-fr">Le film <span class="eque">que</span> tu m'as recommandé est excellent. (tu = sujeto; que = COD)</div><div class="ex-es">La película que me recomendaste es excelente.</div></div>
        </div>
        <div class="chip-panel" id="contr-p-1">
          <div class="def-box"><strong>que</strong> = COD (sin preposición) · <strong>dont</strong> = complemento de verbo/adjetivo con <em>de</em>. La prueba: ¿el verbo/adjetivo se construye con <em>de</em>?</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo/Adjetivo</th><th>Construcción</th><th>Pronombre</th></tr></thead>
            <tbody>
              <tr><td>lire, voir, acheter, aimer…</td><td>directo (sin prep.)</td><td class="hl-que">que</td></tr>
              <tr><td>parler de, rêver de, avoir besoin de, être fier de…</td><td>avec <em>de</em></td><td class="hl-dont">dont</td></tr>
            </tbody>
          </table></div>
          <div class="example-block que"><div class="ex-fr">Le livre <span class="eque">que</span> je lis est passionnant. (lire qqch → direct)</div><div class="ex-es">El libro que leo es apasionante.</div></div>
          <div class="example-block dont"><div class="ex-fr">Le livre <span class="edont">dont</span> je parle est épuisé. (parler de qqch → dont)</div><div class="ex-es">El libro del que hablo está agotado.</div></div>
          <div class="example-block que"><div class="ex-fr">La personne <span class="eque">que</span> j'attends est en retard. (attendre qqn → direct)</div><div class="ex-es">La persona que espero llega tarde.</div></div>
          <div class="example-block dont"><div class="ex-fr">La personne <span class="edont">dont</span> je me souviens était très gentille. (se souvenir de → dont)</div><div class="ex-es">La persona que recuerdo era muy amable.</div></div>
        </div>
        <div class="chip-panel" id="contr-p-2">
          <div class="def-box"><strong>dont</strong> = sust. de <em>de</em> solo · <strong>duquel / de laquelle…</strong> = cuando hay locución prepositiva (<em>à côté de, près de, au cours de…</em>). <em>Dont</em> no puede ir después de una preposición compuesta.</div>
          <div class="example-block dont"><div class="ex-fr">Le problème <span class="edont">dont</span> je parle est grave. (parler de → dont)</div><div class="ex-es">El problema del que hablo es grave.</div></div>
          <div class="example-block leq"><div class="ex-fr">L'immeuble à côté <span class="eleq">duquel</span> j'habite est bruyant. (à côté de → duquel, no dont)</div><div class="ex-es">El edificio al lado del cual vivo es ruidoso.</div></div>
          <div class="example-block dont"><div class="ex-fr">La raison <span class="edont">dont</span> il est conscient est évidente. (être conscient de → dont)</div><div class="ex-es">La razón de la que es consciente es evidente.</div></div>
          <div class="example-block leq"><div class="ex-fr">La chaise sur <span class="eleq">laquelle</span> tu es assis est fragile. (sur → laquelle, no dont)</div><div class="ex-es">La silla sobre la que estás sentado es frágil.</div></div>
        </div>
        <div class="chip-panel" id="contr-p-3">
          <div class="def-box"><strong>où</strong> = lugar o momento (antecedente temporal o espacial) · <strong>lequel</strong> = cuando hay preposición de lugar explícita (<em>dans lequel, sur lequel</em>). <em>Où</em> no va precedido de preposición.</div>
          <div class="example-block ou"><div class="ex-fr">La ville <span class="eou">où</span> je vis est belle. (où = lugar, sin preposición)</div><div class="ex-es">La ciudad donde vivo es bonita.</div></div>
          <div class="example-block leq"><div class="ex-fr">Le quartier <span class="eleq">dans lequel</span> je vis est calme. (dans = preposición explícita → lequel)</div><div class="ex-es">El barrio en el que vivo es tranquilo.</div></div>
          <div class="note-box"><strong>Nota:</strong> ambas formas son aceptables para lugares. <em>Où</em> es más natural y frecuente; <em>dans lequel</em> es más formal o preciso cuando importa la preposición exacta.</div>
          <div class="example-block ou"><div class="ex-fr">Le moment <span class="eou">où</span> elle est arrivée, tout a changé.</div><div class="ex-es">El momento en que llegó, todo cambió.</div></div>
        </div>
        <div class="chip-panel" id="contr-p-4">
          <div class="def-box">Aplica el método: 1) identifica el antecedente · 2) encuentra la función del pronombre en la subordinada · 3) elige.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Frase</th><th>Análisis</th><th>Pronombre</th></tr></thead>
            <tbody>
              <tr><td>C'est le projet ___ nous travaillons.</td><td>travailler sur → sur lequel</td><td class="hl-leq">sur lequel</td></tr>
              <tr><td>La chanson ___ il chante est connue.</td><td>chanter = intransitif → sujeto</td><td class="hl-qui">qui</td></tr>
              <tr><td>La chanson ___ il chante est connue.</td><td>chanter qqch → COD</td><td class="hl-que">que</td></tr>
              <tr><td>Le médecin ___ je suis fier est mon père.</td><td>être fier de → dont</td><td class="hl-dont">dont</td></tr>
              <tr><td>L'année ___ j'ai eu mon bac.</td><td>antecedente temporal</td><td class="hl-ou">où</td></tr>
              <tr><td>La raison ___ il est parti reste floue.</td><td>pour laquelle (raison = chose)</td><td class="hl-leq">pour laquelle</td></tr>
            </tbody>
          </table></div>
        </div>
      </div>
    </div></div>
  </div>

  <!-- 8. TRAMPAS -->
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">Los 8 errores más frecuentes con los pronombres relativos en el DELF B1–B2.</div>
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>

</div><!-- /panel-ref -->
</div><!-- /main-layout -->

<script>
/* DATA */
const TRAPS = [
  {name:"qui vs. que: confundir sujeto y COD",
   wrong:"Le film que passe ce soir. / L'acteur qui j'admire.",
   right:"Le film qui passe ce soir. / L'acteur que j'admire.",
   expl:"<strong>Qui</strong> = sujeto (el verbo de la subordinada no tiene otro sujeto). <strong>Que</strong> = COD (el verbo ya tiene sujeto explícito). Prueba: si puedes poner 'il/elle' en lugar del pronombre, usa <strong>qui</strong>."},
  {name:"dont: olvidar que la preposición de desaparece",
   wrong:"Le film dont je parle de lui. / Le sujet dont il a besoin de.",
   right:"Le film dont je parle. / Le sujet dont il a besoin.",
   expl:"<em>Dont</em> ya incluye la preposición <em>de</em>. No se repite: <em>dont je parle</em> (no: <em>dont je parle de</em>). La <em>de</em> del verbo/adjetivo queda absorbida por <em>dont</em>."},
  {name:"dont posesivo: orden de los elementos",
   wrong:"Un ami dont son père est médecin. / Une femme dont sa voix est belle.",
   right:"Un ami dont le père est médecin. / Une femme dont la voix est belle.",
   expl:"En <em>dont</em> posesivo, el artículo posesivo (<em>son, sa, ses</em>) se sustituye por el artículo definido (<em>le, la, les</em>). Orden obligatorio: <strong>dont + sujeto + verbo + le/la/les + nom</strong>."},
  {name:"dont vs. duquel con locuciones prepositivas",
   wrong:"L'immeuble à côté dont j'habite. / La période au cours dont il a vécu.",
   right:"L'immeuble à côté duquel j'habite. / La période au cours de laquelle il a vécu.",
   expl:"Después de locuciones prepositivas con <em>de</em> (<em>à côté de, près de, au cours de…</em>), <strong>no se puede usar dont</strong>. Se usa <em>duquel / de laquelle / desquels / desquelles</em>."},
  {name:"accord du participe avec que",
   wrong:"Les lettres que tu as écrit. / La chanson qu'il a chanté.",
   right:"Les lettres que tu as écrites. / La chanson qu'il a chantée.",
   expl:"Cuando <em>que</em> es COD y el verbo está en passé composé avec <em>avoir</em>, el participio <strong>concuerda en género y número con el antecedente</strong> de <em>que</em>: <em>lettres</em> (fém. pl.) → écrites; <em>chanson</em> (fém. sing.) → chantée."},
  {name:"lequel: falta de concordancia de género/número",
   wrong:"La table sur lequel je travaille. / Les raisons pour lequel il est parti.",
   right:"La table sur laquelle je travaille. / Les raisons pour lesquelles il est parti.",
   expl:"<em>Lequel</em> concuerda en <strong>género y número</strong> con su antecedente: tabla (fém. sing.) → <em>laquelle</em>; raisons (fém. pl.) → <em>lesquelles</em>. Error frecuente: usar <em>lequel</em> para todos los géneros y números."},
  {name:"que vs. dont: verbo con de",
   wrong:"Le sujet que j'ai besoin. / La personne que je me souviens.",
   right:"Le sujet dont j'ai besoin. / La personne dont je me souviens.",
   expl:"Si el verbo se construye con <em>de</em> (<em>avoir besoin de, se souvenir de, parler de…</em>), hay que usar <strong>dont</strong>, no <em>que</em>. <em>Que</em> solo se usa para complementos directos (sin preposición)."},
  {name:"où temporal: olvidarlo como opción",
   wrong:"L'année pendant laquelle j'ai eu mon bac, j'avais 18 ans.",
   right:"L'année où j'ai eu mon bac, j'avais 18 ans.",
   expl:"Cuando el antecedente es un <strong>momento temporal</strong> (jour, moment, époque, année, soir, nuit…), se usa <strong>où</strong>, no <em>pendant laquelle / au cours de laquelle</em>. La forma con <em>lequel</em> es posible pero mucho más pesada."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

/* CHIP SELECT */
function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c, i) => c.classList.toggle("active", i === idx));
    }
  });
  const el = document.getElementById(ns + "-panels");
  if (el) el.querySelectorAll(":scope > .chip-panel").forEach((p, i) => p.classList.toggle("active", i === idx));
}

/* NAV */
function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

/* EXERCISE STATE */
let exType = "fill", exDiff = "B1", exQty = 5, exFoco = "mix";
let exTotal = 0, exAnswered = 0, exCorrect = 0, exWrong = 0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function () {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));

function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active", "A2", "B1", "B2");
    if (b.textContent.trim() === d) b.classList.add("active", d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim()) === q));
}

/* GENERATE */
const FOCO_DESC = {
  mix:      "todos los pronombres relativos: qui (sujeto), que (COD), où (lugar/tiempo), dont (complemento con de), lequel/laquelle/lesquels/lesquelles (preposición + cosa); incluye elección entre ellos",
  qui_que:  "distinción qui (sujeto) vs. que (COD): el alumno debe identificar la función del pronombre en la subordinada para elegir el correcto",
  dont:     "pronombre dont: complemento de verbos con de (parler de, avoir besoin de, se souvenir de, rêver de, être fier de, être content de...), dont posesivo (dont le père est...), dont de manière (la façon dont)",
  ou:       "pronombre où: complemento de lugar (ville où, pays où) y de tiempo (jour où, moment où, époque où, année où); también d'où de procedencia",
  lequel:   "lequel / laquelle / lesquels / lesquelles y sus contracciones auquel / auxquels / auxquelles / duquel / desquels; preposiciones simples (sur, dans, pour, avec, par) y locuciones (à côté de, au cours de, en face de)",
  accord:   "acuerdo del participio pasado con el antecedente de que: género y número del participio cuando el verbo de la subordinada está en passé composé con avoir",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe el pronombre relativo correcto (puede ser qui, que, où, dont, lequel, laquelle, lesquels, lesquelles, auquel, auxquelles, duquel, etc.)",
  choice:    "elección múltiple: 4 pronombres relativos posibles, solo uno correcto según la función en la subordinada",
  transform: "combinación de dos frases simples en una sola usando el pronombre relativo adecuado",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS = {
  "s-intro": "Qué son",
  "s-qui": "QUI",
  "s-que": "QUE",
  "s-ou": "OÙ",
  "s-dont": "DONT",
  "s-lequel": "LEQUEL",
  "s-contraste": "Elección del pronombre",
  "s-trampas": "Trampas"
};

function renderExercises(exs) {
  const area = document.getElementById("exercise-area");
  const labels = { fill: "Completar", choice: "Elección múltiple", transform: "Combinar frases" };
  area.innerHTML = exs.map((ex, i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref || ""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i + 1}</span>
        <span class="ex-type-badge">${labels[ex.type] || ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex, i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex, i) => {
    const chk = document.getElementById("chk-" + i);
    if (chk) chk.addEventListener("click", () => checkAnswer(ex, i));
    const inp = document.getElementById("inp-" + i);
    if (inp) inp.addEventListener("keydown", e => { if (e.key === "Enter") checkAnswer(ex, i); });
  });
}

function buildBody(ex, i) {
  if (ex.type === "fill")
    return `<div class="exercise-prompt">${ex.prompt_parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint || "…"}" autocomplete="off" spellcheck="false">${ex.prompt_parts[1] || ""}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  if (ex.type === "choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o, j) => `<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if (ex.type === "transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Tu respuesta completa…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex, i) {
  const inp = document.getElementById("inp-" + i);
  if (!inp || inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok ? "ok" : "err"); inp.disabled = true;
  const chk = document.getElementById("chk-" + i); if (chk) chk.disabled = true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0 || c0.disabled) return;
  for (let j = 0; j < 4; j++) {
    const b = document.getElementById(`ch-${idx}-${j}`);
    if (!b) continue; b.disabled = true;
    if (j === correct) b.classList.add("ok"); else if (j === chosen) b.classList.add("err");
  }
  const card = document.getElementById("ex-card-" + idx);
  showFeedback(idx, chosen === correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen === correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById("ex-st-" + i).textContent = ok ? "✅" : "❌";
  const fb = document.getElementById("ex-fb-" + i);
  fb.className = "ex-feedback visible " + (ok ? "ok" : "err");
  const link = RULE_LABELS[ruleRef]
    ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : "";
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans ? ` — Respuesta: <strong>${ans}</strong>` : ""}`;
  if (expl) html += `<br><span style="font-size:0.88em;opacity:0.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML = html;
}

function goToRule(ref) {
  switchMode("ref", document.querySelector(".mode-btn"));
  setTimeout(() => {
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({ behavior: "smooth", block: "start" });
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if (ok) exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal > 0 ? (exAnswered / exTotal) * 100 : 0;
  document.getElementById("progress-frac").textContent = `${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width = pct + "%";
  document.getElementById("score-correct").textContent = `${exCorrect} correcta${exCorrect !== 1 ? "s" : ""}`;
  document.getElementById("score-wrong").textContent = `${exWrong} error${exWrong !== 1 ? "es" : ""}`;
  if (exAnswered >= exTotal && exTotal > 0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect / exTotal) * 100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent = `${exCorrect} / ${exTotal}`;
  const fill = document.getElementById("final-fill");
  fill.style.width = pct + "%";
  fill.style.background = pct >= 80 ? "var(--green)" : pct >= 50 ? "var(--accent)" : "var(--red)";
  const msgs = { 100: "Parfait ! Dominas los pronombres relativos. 🎉", 80: "Très bien ! Repasa los errores marcados.", 50: "Bien, pero refuerza los bloques señalados.", 0: "Vuelve a Referencia antes de repetir." };
  document.getElementById("final-msg").textContent = msgs[pct === 100 ? 100 : pct >= 80 ? 80 : pct >= 50 ? 50 : 0];
  document.getElementById("score-pill").style.display = "";
  document.getElementById("score-pill-val").textContent = `${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById("exercise-area").innerHTML = `<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display = "none";
  exAnswered = 0; exCorrect = 0; exWrong = 0;
}

function esc(s) { return (s || "").replace(/"/g, "&quot;").replace(/</g, "&lt;"); }

/* INIT */
renderTraps();
</script>
</body>
</html>
