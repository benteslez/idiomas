<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Les Articles et Déterminants — Gramática francesa A2–B2+</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;600;700;800&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #ede9df;
  --card: #faf7f1;
  --border: #c4bead;
  --text: #1a1814;
  --text2: #44413a;
  --text3: #706c64;
  --accent: #7a5a0a;
  --accent-light: #f0e0c0;
  --accent-mid: #b89050;
  --warn-bg: #fdf0cc;
  --shadow: 0 2px 14px rgba(0,0,0,0.11), 0 1px 4px rgba(0,0,0,0.06);
  --shadow-sm: 0 1px 6px rgba(0,0,0,0.08);
  --radius: 14px;
  --radius-sm: 8px;
  --green: #1a6028;   --green-bg: #e4f2e8;
  --red: #a81e2e;     --red-bg: #fce6e8;
  --blue: #163494;    --blue-bg: #e6ebf8;
  --purple: #6a1a8a;  --purple-bg: #f2e6f8;
  --def-color: #0a5a6a;
  --def-bg: #e2f2f4;
  --part-color: #8a3a1a;
  --part-bg: #f4e8e2;
  --contr-color: #6a1a8a;
  --contr-bg: #f2e6f8;
  --fs: 15px;
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--text);
  font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
  font-size: var(--fs);
  line-height: 1.55;
}

h1, h2, h3, h4 {
  font-family: 'Playfair Display', Georgia, serif;
  color: var(--text);
  margin: 0 0 0.4em 0;
  line-height: 1.2;
}

p { margin: 0.6em 0; }

a { color: var(--accent); }

/* ----------- HEADER ----------- */
.site-header {
  background: var(--card);
  border-bottom: 1px solid var(--border);
  padding: 28px 24px 22px;
  box-shadow: var(--shadow-sm);
}
.header-top {
  max-width: 860px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 14px;
}
.header-top h1 {
  font-size: 2.4em;
  font-weight: 700;
  font-style: italic;
  letter-spacing: -0.5px;
  margin: 0;
  color: var(--text);
}
.header-tag {
  display: inline-block;
  padding: 4px 12px;
  background: var(--accent-light);
  color: var(--accent);
  border-radius: 999px;
  font-size: 0.78em;
  font-weight: 600;
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.subtitle {
  max-width: 860px;
  margin: 6px auto 0;
  color: var(--text2);
  font-size: 1.05em;
  font-style: italic;
}
.stats-row {
  max-width: 860px;
  margin: 18px auto 0;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  align-items: center;
}
.stat-pill {
  display: inline-flex;
  align-items: center;
  padding: 5px 12px;
  background: var(--accent-light);
  color: var(--accent);
  border-radius: 999px;
  font-size: 0.85em;
  font-weight: 600;
}
.stat-pill.def {
  background: var(--def-bg);
  color: var(--def-color);
}
.stat-pill.part {
  background: var(--part-bg);
  color: var(--part-color);
}
.stat-pill.contr {
  background: var(--contr-bg);
  color: var(--contr-color);
}
.fs-wrap {
  margin-left: auto;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.85em;
  color: var(--text3);
}
.fs-wrap input[type=range] {
  width: 100px;
  accent-color: var(--accent);
}

/* ----------- SECTION NAV ----------- */
.section-nav {
  position: sticky;
  top: 0;
  background: var(--bg);
  border-bottom: 1px solid var(--border);
  z-index: 200;
  box-shadow: var(--shadow-sm);
}
.section-nav-inner {
  max-width: 860px;
  margin: 0 auto;
  display: flex;
  gap: 4px;
  overflow-x: auto;
  padding: 8px 12px;
  scrollbar-width: none;
}
.section-nav-inner::-webkit-scrollbar { display: none; }
.snav-btn {
  flex-shrink: 0;
  background: transparent;
  border: none;
  padding: 8px 12px;
  font-family: inherit;
  font-size: 0.86em;
  font-weight: 500;
  color: var(--text3);
  cursor: pointer;
  border-radius: var(--radius-sm);
  white-space: nowrap;
  border-bottom: 2px solid transparent;
  transition: all 0.15s ease;
}
.snav-btn:hover { color: var(--text2); background: var(--card); }
.snav-btn.active {
  color: var(--accent);
  border-bottom: 2px solid var(--accent);
  font-weight: 600;
}

/* ----------- MAIN LAYOUT ----------- */
.main-layout {
  max-width: 860px;
  margin: 0 auto;
  padding: 16px 16px 40px;
}

.sec-block { display: none; }
.sec-block.active { display: block; }

.sec-block > h2 {
  font-size: 1.9em;
  font-weight: 700;
  font-style: italic;
  margin: 0 0 22px 0;
  color: var(--text);
  letter-spacing: -0.3px;
}

.sec-label {
  text-transform: uppercase;
  font-size: 0.7em;
  letter-spacing: 1.2px;
  font-weight: 700;
  color: var(--text3);
  margin: 26px 0 10px;
  font-family: 'DM Sans', sans-serif;
}

/* ----------- CARDS ----------- */
.gram-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 22px;
  overflow: hidden;
}
.gram-card-body {
  padding: 18px;
}

.def-box {
  background: var(--warn-bg);
  border-left: 4px solid var(--accent);
  padding: 14px 18px;
  border-radius: var(--radius-sm);
  margin: 12px 0 18px;
  color: var(--text2);
  font-size: 0.98em;
  line-height: 1.6;
}
.def-box strong { color: var(--text); }

.warn-box {
  background: var(--red-bg);
  border-left: 4px solid var(--red);
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  margin: 14px 0;
  color: var(--text2);
  display: flex;
  gap: 10px;
  align-items: flex-start;
  font-size: 0.95em;
}
.warn-box::before {
  content: "⚠️";
  flex-shrink: 0;
  font-size: 1.05em;
  line-height: 1.4;
}
.warn-text { flex: 1; }

.note-box {
  background: var(--purple-bg);
  border-left: 4px solid var(--purple);
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  margin: 14px 0;
  color: var(--text2);
  font-size: 0.94em;
}
.note-box strong { color: var(--text); }

/* ----------- EXAMPLES ----------- */
.example-block {
  background: var(--blue-bg);
  border-left: 4px solid var(--blue);
  padding: 12px 16px;
  border-radius: var(--radius-sm);
  margin: 10px 0;
}
.example-block.def {
  background: var(--def-bg);
  border-left: 4px solid var(--def-color);
}
.example-block.part {
  background: var(--part-bg);
  border-left: 4px solid var(--part-color);
}
.example-block.contr {
  background: var(--contr-bg);
  border-left: 4px solid var(--contr-color);
}
.example-block.neu {
  background: var(--blue-bg);
  border-left: 4px solid var(--blue);
}
.example-block.mix {
  background: var(--blue-bg);
  border-left: 4px solid var(--text);
}
.ex-fr {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  color: var(--text);
  font-size: 1.04em;
}
.ex-fr .edef   { color: var(--def-color);   font-weight: 700; }
.ex-fr .epart  { color: var(--part-color);  font-weight: 700; }
.ex-fr .econtr { color: var(--contr-color); font-weight: 700; }
.ex-es {
  color: var(--text2);
  font-size: 0.88em;
  font-style: italic;
  margin-top: 4px;
}
.ex-note {
  color: var(--text3);
  font-size: 0.78em;
  margin-top: 4px;
  font-style: italic;
}

/* ----------- CHIPS ----------- */
.chip-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin: 14px 0 14px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--border);
}
.chip {
  background: var(--bg);
  border: 1px solid var(--border);
  color: var(--text2);
  font-family: inherit;
  font-size: 0.86em;
  font-weight: 500;
  padding: 6px 13px;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.15s ease;
}
.chip:hover { background: var(--accent-light); color: var(--accent); }
.chip.active {
  background: var(--accent);
  color: #fff;
  border-color: var(--accent);
  font-weight: 600;
}
.chip.def.active {
  background: var(--def-color);
  border-color: var(--def-color);
  color: #fff;
}
.chip.part.active {
  background: var(--part-color);
  border-color: var(--part-color);
  color: #fff;
}
.chip.contr.active {
  background: var(--contr-color);
  border-color: var(--contr-color);
  color: #fff;
}
.chip-panel { display: none; }
.chip-panel.active { display: block; animation: fadeIn 0.2s ease; }

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(2px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ----------- TABLES ----------- */
.table-wrap {
  overflow-x: auto;
  margin: 14px 0;
  border-radius: var(--radius-sm);
  border: 1px solid var(--border);
}
.gram-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.93em;
  background: var(--card);
}
.gram-table th, .gram-table td {
  padding: 9px 12px;
  text-align: left;
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}
.gram-table th {
  background: var(--accent-light);
  color: var(--accent);
  font-weight: 700;
  font-size: 0.82em;
  text-transform: uppercase;
  letter-spacing: 0.4px;
}
.gram-table tr:last-child td { border-bottom: none; }
.gram-table .hl-def   { color: var(--def-color);   font-weight: 700; }
.gram-table .hl-part  { color: var(--part-color);  font-weight: 700; }
.gram-table .hl-contr { color: var(--contr-color); font-weight: 700; }
.gram-table .hl       { color: var(--accent);      font-weight: 700; }
.gram-table .dim      { color: var(--text3); }
.gram-table .ok-cell  { background: var(--green-bg); color: var(--green); font-weight: 600; }
.gram-table .err-cell { background: var(--red-bg);   color: var(--red);   font-weight: 600; text-decoration: line-through; }
.gram-table em { font-style: italic; color: var(--text); }

/* ----------- FORMULA BOX ----------- */
.formula-box {
  background: var(--bg);
  border: 2px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 14px 18px;
  font-family: 'DM Sans', sans-serif;
  font-weight: 700;
  font-size: 1.05em;
  text-align: center;
  margin: 12px 0;
  letter-spacing: 0.01em;
  color: var(--text);
  line-height: 1.7;
}
.formula-box .f-def   { color: var(--def-color); }
.formula-box .f-part  { color: var(--part-color); }
.formula-box .f-contr { color: var(--contr-color); }
.formula-box .f-dim   { color: var(--text3); font-weight: 400; }
.formula-box .f-opt   { color: var(--text3); font-style: italic; font-weight: 400; }

/* ----------- TRAPS ----------- */
.trap-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: var(--shadow-sm);
  padding: 16px 18px;
  margin-bottom: 14px;
}
.trap-card-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.trap-name {
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-weight: 600;
  color: var(--text);
  font-size: 1.08em;
}
.trap-vs {
  display: flex;
  flex-direction: column;
  gap: 6px;
  margin: 8px 0 8px;
}
.trap-wrong, .trap-right {
  padding: 7px 12px;
  border-radius: var(--radius-sm);
  font-family: 'Playfair Display', serif;
  font-style: italic;
  font-size: 0.96em;
}
.trap-wrong {
  background: var(--red-bg);
  border-left: 3px solid var(--red);
  color: var(--red);
}
.trap-wrong::before { content: "✗ "; font-weight: 700; font-style: normal; }
.trap-right {
  background: var(--green-bg);
  border-left: 3px solid var(--green);
  color: var(--green);
}
.trap-right::before { content: "✓ "; font-weight: 700; font-style: normal; }
.trap-expl {
  margin-top: 8px;
  color: var(--text2);
  font-size: 0.92em;
  line-height: 1.55;
}

/* ----------- LEGEND ----------- */
.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 12px 0 14px;
}
.legend-pill {
  display: inline-flex;
  align-items: center;
  padding: 4px 12px;
  border-radius: 999px;
  font-size: 0.83em;
  font-weight: 600;
  background: var(--accent-light);
  color: var(--accent);
}
.legend-pill.def   { background: var(--def-bg);   color: var(--def-color);   }
.legend-pill.part  { background: var(--part-bg);  color: var(--part-color);  }
.legend-pill.contr { background: var(--contr-bg); color: var(--contr-color); }

/* ----------- RESPONSIVE ----------- */
@media (max-width: 640px) {
  .site-header { padding: 22px 16px 18px; }
  .header-top h1 { font-size: 1.8em; }
  .main-layout { padding: 16px 12px 60px; }
  .gram-card-body { padding: 16px 14px; }
  .sec-block > h2 { font-size: 1.5em; }
  .fs-wrap { width: 100%; margin-left: 0; margin-top: 8px; }
  .formula-box { font-size: 0.95em; padding: 12px 14px; }
}
</style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <h1>Les Articles et Déterminants</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · A2–B2</div>
  <div class="stats-row">
    <span class="stat-pill def">Défini / Indéfini</span>
    <span class="stat-pill part">Partitif</span>
    <span class="stat-pill contr">Contracté</span>
    <div class="fs-wrap">
      <span>A</span>
      <input type="range" min="13" max="20" value="15" oninput="setFontSize(this.value)">
      <span style="font-size:1.15em">A</span>
    </div>
  </div>
</header>

<nav class="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('sec1', this)">1. Visión general</button>
    <button class="snav-btn" onclick="showSection('sec2', this)">2. Article défini</button>
    <button class="snav-btn" onclick="showSection('sec3', this)">3. Article indéfini</button>
    <button class="snav-btn" onclick="showSection('sec4', this)">4. Article partitif</button>
    <button class="snav-btn" onclick="showSection('sec5', this)">5. Formes contractées</button>
    <button class="snav-btn" onclick="showSection('sec6', this)">6. Omisión del artículo</button>
    <button class="snav-btn" onclick="showSection('sec7', this)">7. Cas particuliers</button>
    <button class="snav-btn" onclick="showSection('sec8', this)">8. Trampas</button>
  </div>
</nav>

<main class="main-layout">

<!-- =================== SECTION 1 =================== -->
<section id="sec1" class="sec-block active">
  <h2>1. Visión general</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        El francés usa <strong>determinantes obligatorios</strong> delante de casi todos los sustantivos comunes. La elección entre défini, indéfini y partitif no es arbitraria: depende de si el objeto es <strong>identificado, contable o incontable</strong>, y del contexto discursivo. Además, las preposiciones <em>à</em> y <em>de</em> se contraen con el artículo masculino y plural, generando formas propias. Conocer las reglas de <strong>omisión</strong> (profesiones, negación, cantidades) es igualmente obligatorio.
      </div>

      <div class="legend-row">
        <span class="legend-pill def">Article défini — le / la / l' / les</span>
        <span class="legend-pill part">Article partitif — du / de la / de l' / des</span>
        <span class="legend-pill contr">Formes contractées — au / du / aux / des</span>
      </div>

      <div class="sec-label">Panorama de los artículos del francés</div>
      <div class="table-wrap">
        <table class="gram-table">
          <thead>
            <tr>
              <th>Tipo</th>
              <th>Masculino sg.</th>
              <th>Femenino sg.</th>
              <th>Ante vocal/h mudo</th>
              <th>Plural</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><strong>Défini</strong></td>
              <td class="hl-def">le</td>
              <td class="hl-def">la</td>
              <td class="hl-def">l'</td>
              <td class="hl-def">les</td>
            </tr>
            <tr>
              <td><strong>Indéfini</strong></td>
              <td class="hl">un</td>
              <td class="hl">une</td>
              <td class="hl">un / une</td>
              <td class="hl">des</td>
            </tr>
            <tr>
              <td><strong>Partitif</strong></td>
              <td class="hl-part">du</td>
              <td class="hl-part">de la</td>
              <td class="hl-part">de l'</td>
              <td class="hl-part">des</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="warn-box">
        <div class="warn-text">
          El artículo <strong>des</strong> es ambiguo: puede ser indéfini plural (<em>des livres</em> = unos libros) o partitif plural (<em>des épinards</em> = espinacas, incontable en plural). La diferencia la determina la naturaleza del sustantivo (contable vs. incontable), no la forma.
        </div>
      </div>

      <div class="sec-label">Criterio de selección — esquema lógico</div>
      <div class="table-wrap">
        <table class="gram-table">
          <thead>
            <tr>
              <th>Pregunta clave</th>
              <th>Artículo</th>
              <th>Ejemplo</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>¿Es identificado / único en contexto?</td>
              <td><strong class="hl-def">défini</strong></td>
              <td><em>Passe-moi <span class="hl-def">le</span> sel.</em></td>
            </tr>
            <tr>
              <td>¿Es contable, no identificado, primer uso?</td>
              <td><strong class="hl">indéfini</strong></td>
              <td><em>J'ai acheté <span class="hl">un</span> livre.</em></td>
            </tr>
            <tr>
              <td>¿Es incontable (sustancia, actividad, abstracción)?</td>
              <td><strong class="hl-part">partitif</strong></td>
              <td><em>Tu veux <span class="hl-part">du</span> café ?</em></td>
            </tr>
            <tr>
              <td>¿Es genérico / toda la especie / abstracción total?</td>
              <td><strong class="hl-def">défini</strong></td>
              <td><em><span class="hl-def">Les</span> chats sont indépendants.</em></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="note-box">
        Una trampa clásica: tanto el <strong>défini</strong> como el <strong>partitif</strong> pueden aparecer con sustantivos incontables, pero con significado diferente. <em>J'aime <strong>le</strong> café</em> = me gusta el café (en general, genérico). <em>Je bois <strong>du</strong> café</em> = bebo café (una cantidad indeterminada, partitivo). Esta distinción genérico/partitivo no existe igual en español y es fuente de errores sistemáticos.
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 2 =================== -->
<section id="sec2" class="sec-block">
  <h2>2. Article défini</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        El artículo défini (<strong>le, la, l', les</strong>) señala que el referente es <strong>identificable</strong> por el oyente o hablante: bien porque ya se mencionó, bien porque es único en el contexto, bien porque se habla de la <strong>categoría entera</strong> (uso genérico). Es el artículo más frecuente del francés.
      </div>

      <div class="formula-box">
        <span class="f-def">le</span> <span class="f-dim">(m. sg.)</span> / <span class="f-def">la</span> <span class="f-dim">(f. sg.)</span> / <span class="f-def">l'</span> <span class="f-dim">(ante vocal o h mudo)</span> / <span class="f-def">les</span> <span class="f-dim">(pl.)</span> + <span class="f-dim">NOM</span>
      </div>

      <div class="sec-label">Formas — elección según fonética y género</div>

      <div class="table-wrap">
        <table class="gram-table">
          <thead>
            <tr>
              <th>Contexto</th>
              <th>Forma</th>
              <th>Ejemplo</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Masculino singular, consonante</td>
              <td class="hl-def">le</td>
              <td><em>le livre, le chat, le train</em></td>
            </tr>
            <tr>
              <td>Femenino singular, consonante</td>
              <td class="hl-def">la</td>
              <td><em>la table, la voiture, la rue</em></td>
            </tr>
            <tr>
              <td>Cualquier género, ante vocal</td>
              <td class="hl-def">l'</td>
              <td><em>l'ami, l'école, l'hôpital</em></td>
            </tr>
            <tr>
              <td>Cualquier género, ante h mudo</td>
              <td class="hl-def">l'</td>
              <td><em>l'heure, l'homme, l'habitude</em></td>
            </tr>
            <tr>
              <td>Cualquier género, ante h aspirado</td>
              <td class="hl-def">le/la</td>
              <td><em>le hibou, la honte</em> (no elisión)</td>
            </tr>
            <tr>
              <td>Plural (todo género)</td>
              <td class="hl-def">les</td>
              <td><em>les livres, les tables, les amis</em></td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="warn-box">
        <div class="warn-text">
          La <strong>h aspirée</strong> (h aspirada) bloquea la elisión y la liaison: <em>le hibou</em> [lə ibu] (no <em>l'hibou</em>), <em>les hiboux</em> [le ibu] (no [lez ibu]). La h aspirée no es una cuestión de pronunciación sino de convención léxica. Las palabras con h aspirée deben aprenderse individualmente: <em>le hibou, la honte, le haricot, la hauteur, le héros</em> (pero <em>l'héroïne</em> — h muda).
        </div>
      </div>

      <div class="chip-bar">
        <button class="chip def active" onclick="selectChip('def', 0, this)">Emploi spécifique</button>
        <button class="chip def" onclick="selectChip('def', 1, this)">Emploi générique</button>
        <button class="chip def" onclick="selectChip('def', 2, this)">Noms géographiques</button>
        <button class="chip def" onclick="selectChip('def', 3, this)">Parties du corps</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="def" data-idx="0">
        <p>El artículo défini aparece cuando el sustantivo ya está identificado en el discurso o en la situación:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Situación</th>
                <th>Ejemplo</th>
                <th>Traducción</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Segunda mención</td>
                <td><em>J'ai acheté un livre. <span class="hl-def">Le</span> livre est passionnant.</em></td>
                <td>Compré un libro. El libro es apasionante.</td>
              </tr>
              <tr>
                <td>Único en el contexto</td>
                <td><em>Ferme <span class="hl-def">la</span> porte, s'il te plaît.</em></td>
                <td>Cierra la puerta, por favor.</td>
              </tr>
              <tr>
                <td>Superlativo</td>
                <td><em>C'est <span class="hl-def">le</span> meilleur film de l'année.</em></td>
                <td>Es la mejor peli del año.</td>
              </tr>
              <tr>
                <td>Défini por una relativa</td>
                <td><em>C'est <span class="hl-def">l'</span>étudiant dont je t'ai parlé.</em></td>
                <td>Es el estudiante del que te hablé.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="def" data-idx="1">
        <p>Cuando se habla de <strong>toda la especie, categoría o abstracción</strong>, el francés usa el défini (≠ español, que a veces omite el artículo).</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Francés</th>
                <th>Español equivalente</th>
                <th>Nota</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>J'aime <span class="hl-def">les</span> chats.</em></td>
                <td>Me gustan los gatos.</td>
                <td>Toda la especie</td>
              </tr>
              <tr>
                <td><em><span class="hl-def">La</span> liberté est précieuse.</em></td>
                <td>La libertad es preciosa.</td>
                <td>Abstracción total</td>
              </tr>
              <tr>
                <td><em><span class="hl-def">Le</span> vin français est réputé.</em></td>
                <td>El vino francés es reputado.</td>
                <td>Categoría genérica</td>
              </tr>
              <tr>
                <td><em><span class="hl-def">Les</span> enfants apprennent vite.</em></td>
                <td>Los niños aprenden rápido.</td>
                <td>Generalización</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="warn-box">
          <div class="warn-text">
            En español, el uso genérico es opcional: «me gustan los gatos» y «me gustan gatos» se usan; en francés el défini genérico es <strong>obligatorio</strong>: <em>J'aime les chats</em> ✓ / <em>J'aime chats</em> ✗ (agramatical).
          </div>
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="def" data-idx="2">
        <p>El francés usa artículo con la mayoría de topónimos, pero su combinación con preposiciones genera formas contractas (ver Sección 5).</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Tipo</th>
                <th>Artículo</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Países femeninos (terminados en -e)</td>
                <td class="hl-def">la</td>
                <td><em>la France, la Chine, la Colombie</em></td>
              </tr>
              <tr>
                <td>Países masculinos</td>
                <td class="hl-def">le</td>
                <td><em>le Japon, le Brésil, le Canada</em></td>
              </tr>
              <tr>
                <td>Países plurales</td>
                <td class="hl-def">les</td>
                <td><em>les États-Unis, les Pays-Bas</em></td>
              </tr>
              <tr>
                <td>Continentes</td>
                <td class="hl-def">l' / le / la</td>
                <td><em>l'Europe, l'Asie, l'Afrique</em></td>
              </tr>
              <tr>
                <td>Ciudades</td>
                <td class="dim">sin artículo (normalmente)</td>
                <td><em>Paris, Lyon, Madrid, Bogotá</em></td>
              </tr>
              <tr>
                <td>Ciudades con artículo lexicalizado</td>
                <td class="hl-def">défini</td>
                <td><em>La Havane, Le Caire, La Paz</em></td>
              </tr>
              <tr>
                <td>Montes, ríos, mares</td>
                <td class="hl-def">le/la/les</td>
                <td><em>la Seine, les Alpes, le Pacifique</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Las ciudades que llevan artículo como parte del nombre no lo pierden: <em>Je vais <strong>au</strong> Caire</em> (à + le = au). Las islas se comportan de forma variable: <em>à Cuba</em> (sin artículo), <em>à la Réunion</em> (con artículo).
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="def" data-idx="3">
        <p>El francés prefiere el artículo <strong>défini</strong> (no el posesivo) con partes del cuerpo cuando el poseedor es claro:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Construcción francesa</th>
                <th>Traducción española</th>
                <th>Nota</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>Il a levé <span class="hl-def">la</span> main.</em></td>
                <td>Levantó la mano.</td>
                <td>défini, no <em>sa main</em></td>
              </tr>
              <tr>
                <td><em>Elle a mal à <span class="hl-def">la</span> tête.</em></td>
                <td>Le duele la cabeza.</td>
                <td>défini tras <em>avoir mal à</em></td>
              </tr>
              <tr>
                <td><em>Il s'est cassé <span class="hl-def">le</span> bras.</em></td>
                <td>Se rompió el brazo.</td>
                <td>défini + verbe pronominal</td>
              </tr>
              <tr>
                <td><em>Ferme <span class="hl-def">les</span> yeux.</em></td>
                <td>Cierra los ojos.</td>
                <td>défini</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="warn-box">
          <div class="warn-text">
            Con los verbos pronominales de higiene/cuidado corporal, el francés siempre usa défini, nunca posesivo: <em>se laver <strong>les</strong> mains</em> (no <em>ses mains</em>), <em>se brosser <strong>les</strong> dents</em> (no <em>ses dents</em>). En español se dice «lavarse las manos» — la estructura es paralela, pero hay que recordar aplicarla sistemáticamente.
          </div>
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block def">
        <div class="ex-fr"><span class="edef">Le</span> soleil se lève à l'est.</div>
        <div class="ex-es">El sol sale por el este.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">J'ai rendez-vous chez <span class="edef">le</span> médecin à 15h.</div>
        <div class="ex-es">Tengo cita en el médico a las 15h.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr"><span class="edef">L'</span>eau bout à 100 degrés.</div>
        <div class="ex-es">El agua hierve a 100 grados.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr"><span class="edef">Les</span> enfants ont besoin de stabilité.</div>
        <div class="ex-es">Los niños necesitan estabilidad.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Elle s'est lavé <span class="edef">les</span> mains avant de manger.</div>
        <div class="ex-es">Se lavó las manos antes de comer.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Tu as vu <span class="edef">le</span> film dont je t'ai parlé ?</div>
        <div class="ex-es">¿Has visto la película de la que te hablé?</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 3 =================== -->
<section id="sec3" class="sec-block">
  <h2>3. Article indéfini</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        El artículo indéfini (<strong>un, une, des</strong>) introduce un sustantivo <strong>contable, no específicamente identificado</strong>: un referente que el interlocutor no puede identificar unívocamente, bien porque es la primera mención, bien porque es uno cualquiera de una clase. El plural <strong>des</strong> equivale a «unos/unas» o simplemente al plural no identificado del español.
      </div>

      <div class="formula-box">
        <span class="f-def">un</span> <span class="f-dim">(m. sg.)</span> / <span class="f-def">une</span> <span class="f-dim">(f. sg.)</span> / <span class="f-def">des</span> <span class="f-dim">(pl.)</span> + <span class="f-dim">NOM contable non-identifié</span>
      </div>

      <div class="chip-bar">
        <button class="chip def active" onclick="selectChip('indef', 0, this)">Formes et emplois</button>
        <button class="chip def" onclick="selectChip('indef', 1, this)">Des → de (règle clé)</button>
        <button class="chip def" onclick="selectChip('indef', 2, this)">Indéfini vs. Défini</button>
        <button class="chip def" onclick="selectChip('indef', 3, this)">Un / Une de valeur numérique</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="indef" data-idx="0">
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Forma</th>
                <th>Género/Número</th>
                <th>Ejemplo</th>
                <th>Traducción</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="hl">un</td>
                <td>m. sg.</td>
                <td><em>J'ai vu <span class="hl">un</span> film excellent.</em></td>
                <td>Vi una película excelente.</td>
              </tr>
              <tr>
                <td class="hl">une</td>
                <td>f. sg.</td>
                <td><em>Il cherche <span class="hl">une</span> solution.</em></td>
                <td>Busca una solución.</td>
              </tr>
              <tr>
                <td class="hl">des</td>
                <td>pl.</td>
                <td><em>Il y a <span class="hl">des</span> étudiants dans la cour.</em></td>
                <td>Hay (unos) estudiantes en el patio.</td>
              </tr>
              <tr>
                <td class="hl">des</td>
                <td>pl. ante adj. → <strong>de</strong></td>
                <td><em>Il a <span class="hl">de</span> bonnes idées.</em></td>
                <td>Tiene buenas ideas.</td>
              </tr>
            </tbody>
          </table>
        </div>
        <p><strong>Cuándo usar indéfini:</strong></p>
        <ul>
          <li>Primera mención de un objeto no identificado: <em>J'ai rencontré <strong>une</strong> collègue très sympa.</em></li>
          <li>Un representante cualquiera de una clase: <em>Passe-moi <strong>un</strong> stylo.</em> (cualquier bolígrafo)</li>
          <li>Descripción con <em>c'est</em>: <em>C'est <strong>un</strong> médecin.</em> (cuando hay modificador) ≠ <em>Il est médecin.</em> (→ Sección 6)</li>
        </ul>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="indef" data-idx="1">
        <p>Cuando el artículo indéfini plural <strong>des</strong> precede a un <strong>adjetivo antepuesto</strong> (antes del nombre), se convierte en <strong>de</strong> (o <strong>d'</strong> ante vocal):</p>

        <div class="formula-box">
          <span class="f-dim">des + [nom]</span> → <span class="f-def">des livres</span> &nbsp;·&nbsp; <span class="f-dim">des + [ADJ antéposé + nom]</span> → <span class="f-def">de beaux livres</span>
        </div>

        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Estructura</th>
                <th>Ejemplo correcto</th>
                <th>Ejemplo incorrecto</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>des + sustantivo solo</td>
                <td class="ok-cell">des livres</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td>des + adj. antepuesto + sust.</td>
                <td class="ok-cell">de beaux livres</td>
                <td class="err-cell">des beaux livres</td>
              </tr>
              <tr>
                <td>des + adj. antepuesto + sust.</td>
                <td class="ok-cell">de jeunes étudiants</td>
                <td class="err-cell">des jeunes étudiants</td>
              </tr>
              <tr>
                <td>des + adj. ante vocal</td>
                <td class="ok-cell">d'autres solutions</td>
                <td class="err-cell">des autres solutions</td>
              </tr>
              <tr>
                <td>des + adj. postpuesto + sust.</td>
                <td class="ok-cell">des livres intéressants</td>
                <td class="dim">— (no cambia)</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            Esta regla (<em>des → de</em> ante adjetivo antepuesto) es <strong>prescriptiva en escrito formal</strong> pero en registro oral/familiar muchos hablantes mantienen <em>des</em>: <em>des beaux livres</em> (oral tolerado). Sin embargo, en el DELF/DALF y en escrito culto, <strong>de</strong> es obligatorio. Adjetivos postpuestos no activan esta regla: <em>des résultats <strong>excellents</strong></em> → sigue siendo <em>des</em>.
          </div>
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="indef" data-idx="2">
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Indéfini</th>
                <th>Défini</th>
                <th>Principio</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>J'ai acheté <span class="hl">un</span> livre.</em></td>
                <td><em>Passe-moi <span class="hl-def">le</span> livre.</em></td>
                <td>Nuevo vs. conocido</td>
              </tr>
              <tr>
                <td><em>Il cherche <span class="hl">une</span> secrétaire.</em></td>
                <td><em>Appelle <span class="hl-def">la</span> secrétaire.</em></td>
                <td>Inespecífico vs. específico</td>
              </tr>
              <tr>
                <td><em>C'est <span class="hl">un</span> problème.</em></td>
                <td><em>C'est <span class="hl-def">le</span> problème.</em></td>
                <td>«hay un problema» vs. «ese es EL problema»</td>
              </tr>
              <tr>
                <td><em><span class="hl">Des</span> chiens ont aboyé.</em></td>
                <td><em><span class="hl-def">Les</span> chiens ont aboyé.</em></td>
                <td>Algunos perros vs. todos (genérico)</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          La alternancia indéfini/défini es uno de los ejes del análisis del discurso en francés. La progresión textual clásica es: primera mención → <strong>indéfini</strong> (<em>un livre</em>), reanudación → <strong>défini</strong> (<em>le livre</em>). Aprender a gestionar esta progresión es clave para la coherencia textual en B2+.
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="indef" data-idx="3">
        <p><em>Un/une</em> puede funcionar como <strong>numeral</strong> (el número 1) y no como artículo indéfini. La distinción importa porque en negación el comportamiento cambia:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Valor</th>
                <th>Ejemplo</th>
                <th>Negación</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Artículo indéfini</td>
                <td><em>J'ai <span class="hl">un</span> chien.</em></td>
                <td><em>Je n'ai pas <span class="hl">de</span> chien.</em></td>
              </tr>
              <tr>
                <td>Numeral (valor uno)</td>
                <td><em>J'ai <span class="hl">un</span> seul chien.</em></td>
                <td><em>Je n'ai pas <span class="hl">un</span> chien — j'en ai deux.</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          <em>Je n'ai pas <strong>un</strong> euro</em> (no tengo ni un euro — valor numérico enfático, énfasis en la cantidad) ≠ <em>Je n'ai pas <strong>d'</strong>argent</em> (no tengo dinero — negación con artículo cero). La primera usa <em>un</em> como numeral y por eso no se convierte en <em>de</em> tras la negación.
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block def">
        <div class="ex-fr">J'ai rencontré <span class="edef">une</span> personne formidable hier soir.</div>
        <div class="ex-es">Conocí anoche a una persona estupenda.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Tu as <span class="edef">des</span> nouvelles de lui ?</div>
        <div class="ex-es">¿Tienes noticias de él?</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">C'est <span class="edef">un</span> problème difficile à résoudre.</div>
        <div class="ex-es">Es un problema difícil de resolver.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Il a <span class="edef">de</span> bonnes raisons de refuser.</div>
        <div class="ex-es">Tiene buenas razones para negarse.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr"><span class="edef">D'</span>autres solutions existent peut-être.</div>
        <div class="ex-es">Quizás existan otras soluciones.</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 4 =================== -->
<section id="sec4" class="sec-block">
  <h2>4. Article partitif</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        El artículo partitif (<strong>du, de la, de l', des</strong>) se usa con sustantivos <strong>incontables</strong> para indicar una <strong>cantidad indeterminada</strong> de algo: una sustancia, un material, una actividad, una cualidad abstracta. Equivale vagamente a «algo de», «un poco de» en español, pero en francés su uso es <strong>obligatorio</strong> donde el español a menudo omite el artículo.
      </div>

      <div class="formula-box">
        <span class="f-part">du</span> <span class="f-dim">(m. sg.)</span> / <span class="f-part">de la</span> <span class="f-dim">(f. sg.)</span> / <span class="f-part">de l'</span> <span class="f-dim">(ante vocal o h mudo)</span> / <span class="f-part">des</span> <span class="f-dim">(pl. incontable)</span> + <span class="f-dim">NOM incontable</span>
      </div>

      <div class="chip-bar">
        <button class="chip part active" onclick="selectChip('part', 0, this)">Substances et aliments</button>
        <button class="chip part" onclick="selectChip('part', 1, this)">Activités et sports</button>
        <button class="chip part" onclick="selectChip('part', 2, this)">Qualités abstraites</button>
        <button class="chip part" onclick="selectChip('part', 3, this)">Après négation</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="part" data-idx="0">
        <p>El uso más concreto y frecuente del partitif es con sustancias, alimentos y líquidos:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Sustantivo</th>
                <th>Masculino</th>
                <th>Femenino</th>
                <th>Ante vocal</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>pain</em></td>
                <td class="hl-part">du pain</td>
                <td class="dim">—</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td><em>eau</em></td>
                <td class="dim">—</td>
                <td class="dim">—</td>
                <td class="hl-part">de l'eau</td>
              </tr>
              <tr>
                <td><em>lait</em></td>
                <td class="hl-part">du lait</td>
                <td class="dim">—</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td><em>beurre</em></td>
                <td class="hl-part">du beurre</td>
                <td class="dim">—</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td><em>farine</em></td>
                <td class="dim">—</td>
                <td class="hl-part">de la farine</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td><em>huile</em></td>
                <td class="dim">—</td>
                <td class="dim">—</td>
                <td class="hl-part">de l'huile</td>
              </tr>
              <tr>
                <td><em>sucre</em></td>
                <td class="hl-part">du sucre</td>
                <td class="dim">—</td>
                <td class="dim">—</td>
              </tr>
              <tr>
                <td><em>viande</em></td>
                <td class="dim">—</td>
                <td class="hl-part">de la viande</td>
                <td class="dim">—</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="example-block part">
          <div class="ex-fr">Tu veux <span class="epart">du</span> café ou <span class="epart">du</span> thé ?</div>
          <div class="ex-es">¿Quieres café o té?</div>
        </div>
        <div class="example-block part">
          <div class="ex-fr">Il mange <span class="epart">de la</span> viande tous les jours.</div>
          <div class="ex-es">Come carne todos los días.</div>
        </div>
        <div class="example-block part">
          <div class="ex-fr">Elle boit <span class="epart">de l'</span>eau minérale.</div>
          <div class="ex-es">Bebe agua mineral.</div>
        </div>
        <div class="example-block part">
          <div class="ex-fr">Mets <span class="epart">du</span> beurre sur le pain.</div>
          <div class="ex-es">Pon mantequilla en el pan.</div>
        </div>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="part" data-idx="1">
        <p>El partitif se usa obligatoriamente con actividades físicas, artísticas y deportes cuando se conjugan con <strong>faire</strong>:</p>

        <div class="formula-box">
          <span class="f-dim">faire +</span> <span class="f-part">du</span> / <span class="f-part">de la</span> / <span class="f-part">de l'</span> <span class="f-dim">+ activité</span>
        </div>

        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Actividad</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>sport (m.)</td>
                <td><em>faire <span class="hl-part">du</span> sport / <span class="hl-part">du</span> football / <span class="hl-part">du</span> vélo</em></td>
              </tr>
              <tr>
                <td>natation (f.)</td>
                <td><em>faire <span class="hl-part">de la</span> natation / <span class="hl-part">de la</span> danse / <span class="hl-part">de la</span> gym</em></td>
              </tr>
              <tr>
                <td>escalade (f.)</td>
                <td><em>faire <span class="hl-part">de l'</span>escalade / <span class="hl-part">de l'</span>équitation</em></td>
              </tr>
              <tr>
                <td>ski (m.)</td>
                <td><em>faire <span class="hl-part">du</span> ski / <span class="hl-part">du</span> jardinage / <span class="hl-part">du</span> bénévolat</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            <strong>Faire de + article contracté</strong> (pas faire à). <em>Faire <strong>du</strong> sport</em> ✓ / <em>Faire <strong>au</strong> sport</em> ✗. En cambio, para instrumentos musicales se usa <strong>jouer de</strong>: <em>jouer <strong>du</strong> piano, jouer <strong>de la</strong> guitare, jouer <strong>de l'</strong>accordéon</em>. Y para deportes con balón: <strong>jouer à</strong>: <em>jouer <strong>au</strong> football, jouer <strong>aux</strong> échecs</em> (ver Sección 5).
          </div>
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="part" data-idx="2">
        <p>Con sustantivos abstractos incontables, el partitif indica «algo de esa cualidad»:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Ejemplo</th>
                <th>Traducción</th>
                <th>Nota</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>Il faut <span class="hl-part">du</span> courage pour faire ça.</em></td>
                <td>Hace falta valor para hacer eso.</td>
                <td>incontable abstracto</td>
              </tr>
              <tr>
                <td><em>Elle a <span class="hl-part">de la</span> patience.</em></td>
                <td>Tiene paciencia.</td>
                <td>cualidad</td>
              </tr>
              <tr>
                <td><em>Ça prend <span class="hl-part">du</span> temps.</em></td>
                <td>Lleva tiempo.</td>
                <td>incontable</td>
              </tr>
              <tr>
                <td><em>Il manque <span class="hl-part">de l'</span>enthousiasme.</em></td>
                <td>Le falta entusiasmo.</td>
                <td>ante vocal</td>
              </tr>
              <tr>
                <td><em>Avoir <span class="hl-part">du</span> mal à faire qch</em></td>
                <td>Tener dificultades para hacer algo.</td>
                <td>expresión fija</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Contraste clave con el uso genérico del défini: <em>J'admire <strong>le</strong> courage</em> = admiro el valor (como virtud universal, genérico) ≠ <em>Il a <strong>du</strong> courage</em> = tiene valor (una cantidad de esa cualidad, partitivo). La diferencia es la misma que entre <em>J'aime <strong>le</strong> café</em> (genérico) y <em>Je bois <strong>du</strong> café</em> (partitivo de cantidad).
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="part" data-idx="3">
        <p>Tras la negación <strong>ne…pas</strong> (y otras negaciones), los artículos <strong>indéfini y partitif</strong> se transforman en <strong>de</strong> (o <strong>d'</strong> ante vocal). El <strong>défini no cambia</strong>.</p>

        <div class="formula-box">
          <span class="f-dim">ne … pas +</span> <span class="f-part">de / d'</span> <span class="f-dim">+ NOM &nbsp; (indéfini et partitif → de)</span><br>
          <span class="f-dim">ne … pas +</span> <span class="f-def">le / la / l' / les</span> &nbsp; <span class="f-dim">(défini → inchangé)</span>
        </div>

        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Afirmativo</th>
                <th>Negativo</th>
                <th>Tipo de artículo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>J'ai <span class="hl">un</span> chien.</em></td>
                <td><em>Je n'ai pas <span class="hl-part">de</span> chien.</em></td>
                <td>indéfini → de</td>
              </tr>
              <tr>
                <td><em>Il boit <span class="hl-part">du</span> café.</em></td>
                <td><em>Il ne boit pas <span class="hl-part">de</span> café.</em></td>
                <td>partitif → de</td>
              </tr>
              <tr>
                <td><em>Elle mange <span class="hl-part">de la</span> viande.</em></td>
                <td><em>Elle ne mange pas <span class="hl-part">de</span> viande.</em></td>
                <td>partitif → de</td>
              </tr>
              <tr>
                <td><em>J'ai <span class="hl">des</span> amis.</em></td>
                <td><em>Je n'ai pas <span class="hl-part">d'</span>amis.</em></td>
                <td>indéfini → de/d'</td>
              </tr>
              <tr>
                <td><em>Il aime <span class="hl-def">le</span> chocolat.</em></td>
                <td><em>Il n'aime pas <span class="hl-def">le</span> chocolat.</em></td>
                <td>défini → inchangé ✓</td>
              </tr>
              <tr>
                <td><em>Elle prend <span class="hl-def">la</span> voiture.</em></td>
                <td><em>Elle ne prend pas <span class="hl-def">la</span> voiture.</em></td>
                <td>défini → inchangé ✓</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            <strong>CRÍTICO:</strong> El artículo <strong>défini no cambia</strong> tras la negación porque ya es específico/identificado. <em>Je n'aime pas <strong>le</strong> café</em> (no me gusta el café — genérico) mantiene <em>le</em>. Pero <em>Je ne bois pas <strong>de</strong> café</em> (no bebo café — partitivo) convierte <em>du</em> → <em>de</em>. Confundir estos dos contextos es un error muy frecuente a nivel A2–B1.
          </div>
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block part">
        <div class="ex-fr">Il fait <span class="epart">du</span> yoga tous les matins.</div>
        <div class="ex-es">Hace yoga todas las mañanas.</div>
      </div>
      <div class="example-block part">
        <div class="ex-fr">Tu as <span class="epart">de la</span> monnaie ?</div>
        <div class="ex-es">¿Tienes cambio/monedas?</div>
      </div>
      <div class="example-block part">
        <div class="ex-fr">Il faut <span class="epart">de la</span> concentration pour réussir.</div>
        <div class="ex-es">Hace falta concentración para tener éxito.</div>
      </div>
      <div class="example-block part">
        <div class="ex-fr">Je ne mange pas <span class="epart">de</span> viande.</div>
        <div class="ex-es">No como carne.</div>
        <div class="ex-note">de la → de tras négation</div>
      </div>
      <div class="example-block part">
        <div class="ex-fr">Il ne boit jamais <span class="epart">d'</span>alcool.</div>
        <div class="ex-es">Nunca bebe alcohol.</div>
        <div class="ex-note">d' ante vocal</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 5 =================== -->
<section id="sec5" class="sec-block">
  <h2>5. Formes contractées</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        Las preposiciones <strong>à</strong> y <strong>de</strong> se contraen obligatoriamente con los artículos définis masculino singular (<strong>le</strong>) y plural (<strong>les</strong>). Esta contracción es <strong>obligatoria</strong> en francés: las formas <em>à le</em>, <em>à les</em>, <em>de le</em>, <em>de les</em> son <strong>agramaticales</strong> y nunca se usan. Con <strong>la</strong> y <strong>l'</strong> no hay contracción.
      </div>

      <div class="formula-box">
        <span class="f-dim">à + le</span> = <span class="f-contr">au</span> &nbsp;·&nbsp; <span class="f-dim">à + les</span> = <span class="f-contr">aux</span><br>
        <span class="f-dim">de + le</span> = <span class="f-contr">du</span> &nbsp;·&nbsp; <span class="f-dim">de + les</span> = <span class="f-contr">des</span><br>
        <span class="f-dim">à + la / l'</span> = <span class="f-contr">à la / à l'</span> <span class="f-opt">(sin contracción)</span><br>
        <span class="f-dim">de + la / l'</span> = <span class="f-contr">de la / de l'</span> <span class="f-opt">(sin contracción)</span>
      </div>

      <div class="chip-bar">
        <button class="chip contr active" onclick="selectChip('contr', 0, this)">À + article (au / aux)</button>
        <button class="chip contr" onclick="selectChip('contr', 1, this)">De + article (du / des)</button>
        <button class="chip contr" onclick="selectChip('contr', 2, this)">Pas de contraction</button>
        <button class="chip contr" onclick="selectChip('contr', 3, this)">Emplois et contextes</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="contr" data-idx="0">
        <div class="sec-label">Tabla de contracción</div>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Preposición + artículo</th>
                <th>Forma contracta</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>à + <strong>le</strong></td>
                <td class="hl-contr">au</td>
                <td><em>Je vais <span class="hl-contr">au</span> marché.</em></td>
              </tr>
              <tr>
                <td>à + <strong>les</strong></td>
                <td class="hl-contr">aux</td>
                <td><em>Je parle <span class="hl-contr">aux</span> étudiants.</em></td>
              </tr>
              <tr>
                <td>à + <strong>la</strong></td>
                <td class="dim">à la (sin cambio)</td>
                <td><em>Je vais <span class="hl-contr">à la</span> gare.</em></td>
              </tr>
              <tr>
                <td>à + <strong>l'</strong></td>
                <td class="dim">à l' (sin cambio)</td>
                <td><em>Je vais <span class="hl-contr">à l'</span>hôpital.</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="sec-label">Casos de uso frecuentes de <em>au / aux</em></div>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Contexto</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Dirección/lugar (ir a)</td>
                <td><em>aller <span class="hl-contr">au</span> cinéma, <span class="hl-contr">au</span> bureau, <span class="hl-contr">aux</span> toilettes</em></td>
              </tr>
              <tr>
                <td>Tiempo</td>
                <td><em><span class="hl-contr">au</span> printemps, <span class="hl-contr">au</span> mois de mai</em></td>
              </tr>
              <tr>
                <td>Dativo (objeto indirecto)</td>
                <td><em>parler <span class="hl-contr">au</span> directeur, écrire <span class="hl-contr">aux</span> parents</em></td>
              </tr>
              <tr>
                <td>Jouer à (deportes/juegos)</td>
                <td><em>jouer <span class="hl-contr">au</span> tennis, <span class="hl-contr">aux</span> cartes, <span class="hl-contr">au</span> foot</em></td>
              </tr>
              <tr>
                <td>Países masculinos</td>
                <td><em>aller <span class="hl-contr">au</span> Brésil, <span class="hl-contr">au</span> Japon</em></td>
              </tr>
              <tr>
                <td>Países plurales</td>
                <td><em>aller <span class="hl-contr">aux</span> États-Unis, <span class="hl-contr">aux</span> Pays-Bas</em></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="contr" data-idx="1">
        <div class="sec-label">Tabla de contracción</div>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Preposición + artículo</th>
                <th>Forma contracta</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>de + <strong>le</strong></td>
                <td class="hl-contr">du</td>
                <td><em>Je reviens <span class="hl-contr">du</span> marché.</em></td>
              </tr>
              <tr>
                <td>de + <strong>les</strong></td>
                <td class="hl-contr">des</td>
                <td><em>Je parle <span class="hl-contr">des</span> étudiants.</em></td>
              </tr>
              <tr>
                <td>de + <strong>la</strong></td>
                <td class="dim">de la (sin cambio)</td>
                <td><em>Je reviens <span class="hl-contr">de la</span> gare.</em></td>
              </tr>
              <tr>
                <td>de + <strong>l'</strong></td>
                <td class="dim">de l' (sin cambio)</td>
                <td><em>Je reviens <span class="hl-contr">de l'</span>hôpital.</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            El <strong>du</strong> como forma contracta (<em>de + le</em>) es <strong>distinto</strong> del <strong>du</strong> partitif (<em>du café</em>). Son homófonos pero de naturaleza diferente: <em>Je reviens <strong>du</strong> marché</em> = de + le marché (contracción preposicional). <em>Je bois <strong>du</strong> café</em> = article partitif. El contexto sintáctico los distingue.
          </div>
        </div>

        <div class="sec-label">Casos de uso frecuentes de <em>du / des</em></div>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Contexto</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Procedencia (venir de)</td>
                <td><em>venir <span class="hl-contr">du</span> bureau, <span class="hl-contr">des</span> États-Unis</em></td>
              </tr>
              <tr>
                <td>Genitivo / pertenencia</td>
                <td><em>la porte <span class="hl-contr">du</span> jardin, les noms <span class="hl-contr">des</span> élèves</em></td>
              </tr>
              <tr>
                <td>Jouer de (instrumentos)</td>
                <td><em>jouer <span class="hl-contr">du</span> piano, <span class="hl-contr">des</span> percussions</em></td>
              </tr>
              <tr>
                <td>Pays masculins (de)</td>
                <td><em>revenir <span class="hl-contr">du</span> Mexique, <span class="hl-contr">du</span> Maroc</em></td>
              </tr>
              <tr>
                <td>Pays pluriels (de)</td>
                <td><em>revenir <span class="hl-contr">des</span> Antilles, <span class="hl-contr">des</span> Pays-Bas</em></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="contr" data-idx="2">
        <p>La contracción no se produce con:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Caso</th>
                <th>Razón</th>
                <th>Ejemplo correcto</th>
                <th>Error frecuente</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>à + <strong>la</strong></td>
                <td>femenino, sin contracción</td>
                <td class="ok-cell">à la maison</td>
                <td class="err-cell">au maison</td>
              </tr>
              <tr>
                <td>à + <strong>l'</strong></td>
                <td>vocal, sin contracción</td>
                <td class="ok-cell">à l'école</td>
                <td class="err-cell">au école</td>
              </tr>
              <tr>
                <td>de + <strong>la</strong></td>
                <td>femenino, sin contracción</td>
                <td class="ok-cell">de la salle</td>
                <td class="err-cell">du salle</td>
              </tr>
              <tr>
                <td>de + <strong>l'</strong></td>
                <td>vocal, sin contracción</td>
                <td class="ok-cell">de l'aéroport</td>
                <td class="err-cell">du aéroport</td>
              </tr>
              <tr>
                <td>Nombre propre avec article</td>
                <td>el artículo es parte del nombre propio</td>
                <td class="ok-cell">à Le Havre</td>
                <td class="err-cell">au Havre</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Los topónimos cuyo nombre propio incluye el artículo como parte fija (<em>Le Havre, La Rochelle, Le Caire, Les Sables-d'Olonne</em>) <strong>no se contraen</strong> cuando el artículo es nombre propio: <em>Je vais à <strong>Le</strong> Havre</em> ✓ / <em>Je vais <strong>au</strong> Havre</em> ✗. Esta regla es frecuentemente ignorada incluso por hablantes nativos en registro oral, pero es prescriptiva en escrito formal.
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="contr" data-idx="3">
        <p>Tabla comparativa <em>à</em> vs. <em>de</em> + contracción:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Estructura</th>
                <th>au / à la</th>
                <th>du / de la</th>
                <th>Ejemplo completo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>aller à + lieu</td>
                <td class="hl-contr">aller au bureau</td>
                <td class="dim">—</td>
                <td><em>Je vais <span class="hl-contr">au</span> bureau le matin.</em></td>
              </tr>
              <tr>
                <td>revenir de + lieu</td>
                <td class="dim">—</td>
                <td class="hl-contr">revenir du bureau</td>
                <td><em>Je reviens <span class="hl-contr">du</span> bureau à 18h.</em></td>
              </tr>
              <tr>
                <td>parler à + personne</td>
                <td class="hl-contr">parler au patron</td>
                <td class="dim">—</td>
                <td><em>J'ai parlé <span class="hl-contr">au</span> directeur.</em></td>
              </tr>
              <tr>
                <td>parler de + sujet</td>
                <td class="dim">—</td>
                <td class="hl-contr">parler du problème</td>
                <td><em>On a parlé <span class="hl-contr">du</span> projet hier.</em></td>
              </tr>
              <tr>
                <td>jouer à + sport</td>
                <td class="hl-contr">jouer au foot</td>
                <td class="dim">—</td>
                <td><em>Ils jouent <span class="hl-contr">aux</span> échecs.</em></td>
              </tr>
              <tr>
                <td>jouer de + instrument</td>
                <td class="dim">—</td>
                <td class="hl-contr">jouer du piano</td>
                <td><em>Elle joue <span class="hl-contr">de la</span> guitare.</em></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block contr">
        <div class="ex-fr">Il va <span class="econtr">au</span> travail en vélo.</div>
        <div class="ex-es">Va al trabajo en bici.</div>
      </div>
      <div class="example-block contr">
        <div class="ex-fr">Nous parlons <span class="econtr">du</span> projet depuis ce matin.</div>
        <div class="ex-es">Llevamos desde esta mañana hablando del proyecto.</div>
      </div>
      <div class="example-block contr">
        <div class="ex-fr">Elle joue <span class="econtr">du</span> violon et <span class="econtr">de la</span> flûte.</div>
        <div class="ex-es">Toca el violín y la flauta.</div>
      </div>
      <div class="example-block contr">
        <div class="ex-fr">Vous avez pensé <span class="econtr">aux</span> conséquences ?</div>
        <div class="ex-es">¿Habéis pensado en las consecuencias?</div>
      </div>
      <div class="example-block contr">
        <div class="ex-fr">Le chat sort <span class="econtr">du</span> jardin.</div>
        <div class="ex-es">El gato sale del jardín.</div>
      </div>
      <div class="example-block contr">
        <div class="ex-fr">Il revient <span class="econtr">des</span> États-Unis demain.</div>
        <div class="ex-es">Vuelve de Estados Unidos mañana.</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 6 =================== -->
<section id="sec6" class="sec-block">
  <h2>6. Omisión del artículo</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        El francés, pese a ser una lengua de uso casi obligatorio del artículo, tiene contextos precisos donde el artículo <strong>se omite completamente</strong> (artículo cero). Los más importantes son: tras <strong>être + profesión/nacionalidad/religión</strong> sin modificador, tras <strong>ne…pas de</strong>, tras <strong>expresiones de cantidad</strong>, y en ciertos contextos fijos como títulos, listas o locuciones preposicionales.
      </div>

      <div class="chip-bar">
        <button class="chip def active" onclick="selectChip('omis', 0, this)">Profession / Nationalité</button>
        <button class="chip def" onclick="selectChip('omis', 1, this)">Après négation (→ de)</button>
        <button class="chip def" onclick="selectChip('omis', 2, this)">Expressions de quantité</button>
        <button class="chip def" onclick="selectChip('omis', 3, this)">Autres cas d'omission</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="omis" data-idx="0">
        <p>Tras <strong>être, devenir, rester, travailler comme</strong> + profesión/nacionalidad/religión <strong>sin modificador</strong> → artículo cero:</p>

        <div class="formula-box">
          <span class="f-dim">être / devenir / rester +</span> <span class="f-def">∅</span> <span class="f-dim">+ profession / nationalité / religion</span> <span class="f-opt">(sans modificateur)</span>
        </div>

        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Sin modificador (artículo cero)</th>
                <th>Con modificador (artículo indéfini)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>Il est <strong>médecin</strong>.</em></td>
                <td><em>C'est <span class="hl">un</span> médecin <strong>réputé</strong>.</em></td>
              </tr>
              <tr>
                <td><em>Elle est <strong>professeure</strong>.</em></td>
                <td><em>C'est <span class="hl">une</span> professeure <strong>excellente</strong>.</em></td>
              </tr>
              <tr>
                <td><em>Il est devenu <strong>directeur</strong>.</em></td>
                <td><em>C'est <span class="hl">un</span> directeur <strong>sévère</strong>.</em></td>
              </tr>
              <tr>
                <td><em>Elle est <strong>française</strong>.</em></td>
                <td><em>C'est <span class="hl">une</span> Française <strong>passionnante</strong>.</em></td>
              </tr>
              <tr>
                <td><em>Il est <strong>catholique</strong>.</em></td>
                <td><em>C'est <span class="hl">un</span> catholique <strong>pratiquant</strong>.</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            La regla es simple: <strong>sin adjetivo ni modificador → artículo cero</strong> después de <em>être</em>. En cuanto aparece un modificador (adjetivo, relativa, complemento), el artículo indéfini es obligatorio. Diferencia estructural: <em>Il est médecin</em> (atributo del sujeto) → artículo cero. <em>C'est un médecin</em> (presentación con <em>c'est</em>) → indéfini. En español ambas estructuras se dicen con artículo en muchos dialectos, de ahí la transferencia errónea.
          </div>
        </div>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="omis" data-idx="1">
        <p>Ver también Sección 4 (partitif). Aquí se consolida la regla completa:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Artículo en afirmativo</th>
                <th>Tras negación</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><span class="hl">un / une</span> (indéfini)</td>
                <td class="hl-part">de / d'</td>
                <td><em>J'ai <span class="hl">une</span> voiture.</em> → <em>Je n'ai pas <span class="hl-part">de</span> voiture.</em></td>
              </tr>
              <tr>
                <td><span class="hl-part">du / de la / de l'</span> (partitif)</td>
                <td class="hl-part">de / d'</td>
                <td><em>Je bois <span class="hl-part">du</span> vin.</em> → <em>Je ne bois pas <span class="hl-part">de</span> vin.</em></td>
              </tr>
              <tr>
                <td><span class="hl">des</span> (indéfini pl.)</td>
                <td class="hl-part">de / d'</td>
                <td><em>J'ai <span class="hl">des</span> amis.</em> → <em>Je n'ai pas <span class="hl-part">d'</span>amis.</em></td>
              </tr>
              <tr>
                <td><span class="hl-def">le / la / l' / les</span> (défini)</td>
                <td class="hl-def">le / la / l' / les (inchangé)</td>
                <td><em>J'aime <span class="hl-def">le</span> vin.</em> → <em>Je n'aime pas <span class="hl-def">le</span> vin.</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Esta regla no se aplica solo a <em>ne…pas</em>: otras expresiones negativas también la activan: <em>ne…plus de</em> (<em>Il n'a plus <strong>de</strong> travail</em>), <em>ne…jamais de</em> (<em>Elle ne mange jamais <strong>de</strong> viande</em>), <em>sans + de</em> (<em>partir sans <strong>bagages</strong></em>), <em>ne…guère de</em> (registro formal). En cambio, tras <em>ne…que</em> (restrictivo) el artículo no cambia: <em>Il ne mange que <strong>du</strong> riz</em> (solo come arroz — défini/partitif se mantiene).
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="omis" data-idx="2">
        <p>Tras expresiones de cantidad, el complemento nominal va siempre con <strong>de/d'</strong> y <strong>sin artículo</strong>:</p>

        <div class="formula-box">
          <span class="f-dim">expression de quantité +</span> <span class="f-part">de / d'</span> <span class="f-dim">+ NOM</span> <span class="f-opt">(sans article)</span>
        </div>

        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Expresión de cantidad</th>
                <th>Ejemplo</th>
                <th>Incorrecto</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>beaucoup de</td>
                <td class="ok-cell">beaucoup de travail</td>
                <td class="err-cell">beaucoup du travail</td>
              </tr>
              <tr>
                <td>assez de</td>
                <td class="ok-cell">assez d'argent</td>
                <td class="err-cell">assez de l'argent</td>
              </tr>
              <tr>
                <td>trop de</td>
                <td class="ok-cell">trop de bruit</td>
                <td class="err-cell">trop du bruit</td>
              </tr>
              <tr>
                <td>peu de</td>
                <td class="ok-cell">peu de temps</td>
                <td class="err-cell">peu du temps</td>
              </tr>
              <tr>
                <td>un peu de</td>
                <td class="ok-cell">un peu de patience</td>
                <td class="err-cell">un peu de la patience</td>
              </tr>
              <tr>
                <td>plus de / moins de</td>
                <td class="ok-cell">plus de liberté</td>
                <td class="err-cell">plus de la liberté</td>
              </tr>
              <tr>
                <td>autant de</td>
                <td class="ok-cell">autant d'efforts</td>
                <td class="err-cell">autant des efforts</td>
              </tr>
              <tr>
                <td>une bouteille de</td>
                <td class="ok-cell">une bouteille de vin</td>
                <td class="err-cell">une bouteille du vin</td>
              </tr>
              <tr>
                <td>un kilo de</td>
                <td class="ok-cell">un kilo de farine</td>
                <td class="err-cell">un kilo de la farine</td>
              </tr>
              <tr>
                <td>la plupart de</td>
                <td class="ok-cell">la plupart des étudiants <span class="dim">(excepción: défini)</span></td>
                <td class="dim">—</td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            <strong>La plupart</strong> es una excepción: <em>la plupart <strong>des</strong> étudiants</em> (no <em>de étudiants</em>). Con <em>la plupart</em>, el artículo défini se mantiene porque el grupo de referencia es específico e identificado. Comparar: <em>beaucoup <strong>d'</strong>étudiants</em> (incontable general) ≠ <em>la plupart <strong>des</strong> étudiants</em> (la mayoría de LOS estudiantes — referencia específica).
          </div>
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="omis" data-idx="3">
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Contexto</th>
                <th>Regla</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Países femeninos con <em>en</em></td>
                <td><em>en + pays féminin</em> → sin artículo</td>
                <td><em>en France, en Colombie, en Chine</em></td>
              </tr>
              <tr>
                <td>Ciudades (normalmente)</td>
                <td>sin artículo</td>
                <td><em>à Paris, à Lyon, à Madrid</em></td>
              </tr>
              <tr>
                <td>Aposiciones y títulos</td>
                <td>sin artículo</td>
                <td><em>Louis XIV, roi de France</em></td>
              </tr>
              <tr>
                <td>Listas, enumeraciones</td>
                <td>sin artículo posible</td>
                <td><em>Apporter : stylo, cahier, règle.</em></td>
              </tr>
              <tr>
                <td>Locuciones preposicionales fijas</td>
                <td>artículo cero lexicalizado</td>
                <td><em>avec plaisir, sans doute, en voiture, à pied</em></td>
              </tr>
              <tr>
                <td>Après <em>de</em> en GN (modificador)</td>
                <td>sin artículo</td>
                <td><em>une tasse <strong>de</strong> café, une salle <strong>de</strong> bain</em></td>
              </tr>
              <tr>
                <td>Complemento de matière</td>
                <td>sin artículo</td>
                <td><em>une table <strong>en</strong> bois, un pull <strong>en</strong> laine</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Los países femeninos (terminados en <em>-e</em> salvo excepciones) usan <em>en</em> sin artículo para la ubicación y el destino: <em>en France, en Espagne, en Italie</em>. Los países masculinos usan <em>au</em>: <em>au Japon, au Brésil</em>. Los países plurales usan <em>aux</em>: <em>aux États-Unis</em>. Las islas y algunos países pequeños usan <em>à</em> sin artículo: <em>à Cuba, à Chypre, à Malte, à Haïti</em>.
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block def">
        <div class="ex-fr">Mon frère est <span class="edef">ingénieur</span>.</div>
        <div class="ex-es">Mi hermano es ingeniero.</div>
        <div class="ex-note">artículo cero tras être + profesión</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">C'est <span class="edef">un</span> ingénieur <strong>brillant</strong>.</div>
        <div class="ex-es">Es un ingeniero brillante.</div>
        <div class="ex-note">modificador → indéfini</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Elle vit <span class="edef">en</span> Colombie depuis dix ans.</div>
        <div class="ex-es">Vive en Colombia desde hace diez años.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Il n'y a plus <span class="edef">de</span> pain.</div>
        <div class="ex-es">Ya no hay pan.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">J'ai trop <span class="edef">de</span> travail cette semaine.</div>
        <div class="ex-es">Tengo demasiado trabajo esta semana.</div>
      </div>
      <div class="example-block def">
        <div class="ex-fr">Nous voyageons <span class="edef">en</span> voiture.</div>
        <div class="ex-es">Viajamos en coche.</div>
        <div class="ex-note">locución fija</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 7 =================== -->
<section id="sec7" class="sec-block">
  <h2>7. Cas particuliers</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        Más allá de las reglas centrales, el sistema de artículos del francés presenta varios <strong>casos especiales</strong> de alta frecuencia que generan errores sistemáticos: el comportamiento del artículo con la <strong>negación restrictiva <em>ne…que</em></strong>, la distinción <strong>défini/partitif con abstractos</strong>, el uso del artículo con <strong>adjectifs substantivés</strong>, y los <strong>noms propres</strong> con artículo.
      </div>

      <div class="chip-bar">
        <button class="chip def active" onclick="selectChip('part2', 0, this)">Ne…que — exception</button>
        <button class="chip def" onclick="selectChip('part2', 1, this)">Défini générique vs. partitif</button>
        <button class="chip def" onclick="selectChip('part2', 2, this)">Adjectifs substantivés</button>
        <button class="chip def" onclick="selectChip('part2', 3, this)">Noms propres avec article</button>
      </div>

      <!-- chip 0 -->
      <div class="chip-panel active" data-group="part2" data-idx="0">
        <p><em>Ne…que</em> es una negación <strong>restrictiva</strong> (= seulement), no una negación total. Por eso <strong>no aplica</strong> la regla <em>de</em> tras negación: el artículo se mantiene.</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Estructura</th>
                <th>Artículo</th>
                <th>Ejemplo</th>
                <th>Nota</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>ne…pas + partitif</td>
                <td class="hl-part">de</td>
                <td><em>Il ne boit pas <span class="hl-part">de</span> vin.</em></td>
                <td>negación total → de</td>
              </tr>
              <tr>
                <td>ne…que + partitif</td>
                <td class="hl-part">du/de la</td>
                <td><em>Il ne boit que <span class="hl-part">du</span> vin.</em></td>
                <td>restrictivo → artículo normal</td>
              </tr>
              <tr>
                <td>ne…plus + indéfini</td>
                <td class="hl-part">de</td>
                <td><em>Je n'ai plus <span class="hl-part">d'</span>argent.</em></td>
                <td>negación total → de</td>
              </tr>
              <tr>
                <td>ne…que + indéfini</td>
                <td class="hl">un/une</td>
                <td><em>Je n'ai qu'<span class="hl">une</span> chance.</em></td>
                <td>restrictivo → artículo normal</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          <em>Ne…que</em> = <em>seulement</em>. No es una negación de existencia sino de exclusividad. <em>Il ne boit que <strong>du</strong> vin</em> = boit seulement du vin = solo bebe vino. El artículo se comporta como en una frase afirmativa.
        </div>
      </div>

      <!-- chip 1 -->
      <div class="chip-panel" data-group="part2" data-idx="1">
        <p>Esta distinción es la más conceptualmente difícil para hispanohablantes:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Construcción</th>
                <th>Artículo</th>
                <th>Significado</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Verbe de goût + abstrait/substance</td>
                <td class="hl-def">défini</td>
                <td>gusto por la categoría entera</td>
                <td><em>J'aime <span class="hl-def">le</span> café.</em></td>
              </tr>
              <tr>
                <td>Verbe de consommation/possession + substance</td>
                <td class="hl-part">partitif</td>
                <td>cantidad indeterminada en contexto concreto</td>
                <td><em>Je bois <span class="hl-part">du</span> café.</em></td>
              </tr>
              <tr>
                <td>Abstraction totale</td>
                <td class="hl-def">défini</td>
                <td>La virtud como concepto</td>
                <td><em><span class="hl-def">La</span> patience est une vertu.</em></td>
              </tr>
              <tr>
                <td>Possession d'une qualité</td>
                <td class="hl-part">partitif</td>
                <td>Alguien tiene algo de esa cualidad</td>
                <td><em>Elle a <span class="hl-part">de la</span> patience.</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="sec-label">Exemples contrastifs</div>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Défini (générique)</th>
                <th>Partitif (quantité)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>J'adore <span class="hl-def">la</span> musique classique.</em></td>
                <td><em>J'écoute <span class="hl-part">de la</span> musique classique.</em></td>
              </tr>
              <tr>
                <td><em><span class="hl-def">Le</span> silence est précieux.</em></td>
                <td><em>Il y a <span class="hl-part">du</span> silence dans la maison.</em></td>
              </tr>
              <tr>
                <td><em>Il respecte <span class="hl-def">la</span> liberté.</em></td>
                <td><em>Donnez-leur <span class="hl-part">de la</span> liberté.</em></td>
              </tr>
            </tbody>
          </table>
        </div>

        <div class="warn-box">
          <div class="warn-text">
            Los verbos de <strong>gusto, opinión y sentimiento</strong> (<em>aimer, adorer, détester, apprécier, préférer, respecter</em>) van típicamente con artículo <strong>défini</strong> porque expresan una relación genérica con la categoría. Los verbos de <strong>acción concreta</strong> (<em>manger, boire, acheter, vendre, avoir, prendre, faire</em>) van típicamente con <strong>partitif o indéfini</strong> porque se refieren a una cantidad o instancia concreta.
          </div>
        </div>
      </div>

      <!-- chip 2 -->
      <div class="chip-panel" data-group="part2" data-idx="2">
        <p>Cuando un adjetivo funciona como sustantivo (sustantivación), sigue las mismas reglas de artículo:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Adjetivo sustantivado</th>
                <th>Artículo</th>
                <th>Ejemplo</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><em>le beau / la belle</em></td>
                <td class="hl-def">défini</td>
                <td><em><span class="hl-def">Le</span> beau est subjectif.</em></td>
              </tr>
              <tr>
                <td><em>un beau / une belle</em></td>
                <td class="hl">indéfini</td>
                <td><em>C'est <span class="hl">une</span> belle.</em> (una belleza)</td>
              </tr>
              <tr>
                <td><em>les anciens</em></td>
                <td class="hl-def">défini pl.</td>
                <td><em><span class="hl-def">Les</span> anciens avaient raison.</em></td>
              </tr>
              <tr>
                <td><em>du nouveau</em></td>
                <td class="hl-part">partitif</td>
                <td><em>Il y a <span class="hl-part">du</span> nouveau dans ce dossier.</em></td>
              </tr>
              <tr>
                <td><em>rien de + adj.</em></td>
                <td class="dim">artículo cero</td>
                <td><em>Rien <strong>d'</strong>intéressant ici.</em></td>
              </tr>
              <tr>
                <td><em>quelque chose de + adj.</em></td>
                <td class="dim">artículo cero</td>
                <td><em>Quelque chose <strong>d'</strong>étrange.</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Las construcciones <strong>rien de + adjectif</strong> y <strong>quelque chose de + adjectif</strong> usan artículo cero: <em>rien <strong>d'</strong>important, quelque chose <strong>d'</strong>inhabituel</em>. El <em>de</em> aquí no es artículo sino preposición introductora del adjetivo. No confundir con <em>rien <strong>du</strong> tout</em> (nada en absoluto) donde <em>tout</em> es un sustantivo y <em>du</em> es la contracción.
        </div>
      </div>

      <!-- chip 3 -->
      <div class="chip-panel" data-group="part2" data-idx="3">
        <p>Algunos nombres propios llevan artículo de forma lexicalizada:</p>
        <div class="table-wrap">
          <table class="gram-table">
            <thead>
              <tr>
                <th>Tipo</th>
                <th>Artículo</th>
                <th>Ejemplos</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Países masculinos</td>
                <td class="hl-def">le</td>
                <td><em>le Brésil, le Japon, le Canada, le Maroc</em></td>
              </tr>
              <tr>
                <td>Países plurales</td>
                <td class="hl-def">les</td>
                <td><em>les États-Unis, les Pays-Bas</em></td>
              </tr>
              <tr>
                <td>Cordilleras, ríos, mares</td>
                <td class="hl-def">le/la/les</td>
                <td><em>les Alpes, la Seine, le Pacifique</em></td>
              </tr>
              <tr>
                <td>Certaines villes</td>
                <td class="hl-def">le/la</td>
                <td><em>La Havane, Le Caire, La Paz</em></td>
              </tr>
              <tr>
                <td>Œuvres d'art (titres)</td>
                <td class="hl-def">variable</td>
                <td><em><span class="hl-def">La</span> Joconde, <span class="hl-def">Le</span> Penseur</em></td>
              </tr>
              <tr>
                <td>Noms de famille (pl.)</td>
                <td class="hl-def">les (familiar)</td>
                <td><em><span class="hl-def">Les</span> Dupont arrivent ce soir.</em></td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="note-box">
          Avec les noms de personnes, le défini familier (<em>les Dupont</em>) s'utilise pour désigner une famille ou un groupe. À l'écrit formel, on évite cet usage et on préfère <em>la famille Dupont</em> ou <em>M. et Mme Dupont</em>.
        </div>
      </div>

      <div class="sec-label">Ejemplos integrados</div>

      <div class="example-block mix">
        <div class="ex-fr">Il ne mange que <span class="edef">des</span> légumes.</div>
        <div class="ex-es">Solo come verduras.</div>
        <div class="ex-note">ne…que → artículo normal</div>
      </div>
      <div class="example-block mix">
        <div class="ex-fr">J'adore <span class="edef">le</span> chocolat, mais je ne mange pas <span class="epart">de</span> chocolat en semaine.</div>
        <div class="ex-es">Me encanta el chocolate, pero no como chocolate entre semana.</div>
        <div class="ex-note">genérico → défini / negación → de</div>
      </div>
      <div class="example-block mix">
        <div class="ex-fr">Il y a <span class="epart">du</span> nouveau dans cette affaire.</div>
        <div class="ex-es">Hay novedades en este asunto.</div>
        <div class="ex-note">adjectif substantivé + partitif</div>
      </div>
      <div class="example-block mix">
        <div class="ex-fr">Il est revenu <span class="econtr">du</span> Japon la semaine dernière.</div>
        <div class="ex-es">Volvió de Japón la semana pasada.</div>
        <div class="ex-note">contracción de + le</div>
      </div>
    </div>
  </div>
</section>

<!-- =================== SECTION 8 =================== -->
<section id="sec8" class="sec-block">
  <h2>8. Trampas</h2>

  <div class="gram-card">
    <div class="gram-card-body">
      <div class="def-box">
        Errores típicos a nivel A2–B2+ con artículos y determinantes: confusiones entre partitif y contracté, entre défini genérico y partitif tras negación, omisiones que deberían ser obligatorias, y aplicaciones equivocadas de las reglas de contracción. Reconocer estas trampas es esencial para escribir y hablar francés sin tropiezos.
      </div>

      <div id="traps-container"></div>
    </div>
  </div>
</section>

</main>

<script>
function setFontSize(v) {
  document.documentElement.style.setProperty('--fs', v + 'px');
}

function showSection(id, btn) {
  document.querySelectorAll('.sec-block').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  document.querySelectorAll('.snav-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function selectChip(group, idx, btn) {
  const bar = btn.parentElement;
  bar.querySelectorAll('.chip').forEach(c => c.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.chip-panel[data-group="' + group + '"]').forEach(p => {
    p.classList.toggle('active', parseInt(p.dataset.idx) === idx);
  });
}

const TRAPS = [
  {
    name: "beaucoup du / trop du — artículo tras expresión de cantidad",
    wrong: "Il a beaucoup du travail. / Elle mange trop de la viande.",
    right: "Il a beaucoup de travail. / Elle mange trop de viande.",
    explanation: "Tras TODAS las expresiones de cantidad (<em>beaucoup de, trop de, assez de, peu de, plus de, moins de, autant de, un kilo de…</em>), el nombre va SIEMPRE con <em>de/d'</em> y sin artículo. Nunca <em>du/de la/des</em> después de estas expresiones. Es uno de los errores más frecuentes en todos los niveles."
  },
  {
    name: "Il est un médecin — artículo con profesiones tras être",
    wrong: "Il est un médecin. / Elle est une professeure.",
    right: "Il est médecin. / Elle est professeure. — PERO: C'est un médecin réputé.",
    explanation: "Tras <em>être/devenir</em> + profesión/nacionalidad/religión SIN modificador → artículo cero. La trampa es que <em>c'est</em> sí requiere artículo indéfini: <em>c'est un médecin</em>. La prueba: ¿hay adjetivo o complemento? Si sí → artículo indéfini obligatorio (<em>c'est un médecin brillant</em>). Si no → artículo cero (<em>il est médecin</em>)."
  },
  {
    name: "Je n'aime pas du café — défini tras negación",
    wrong: "Je n'aime pas du café. / Il ne veut pas de la viande.",
    right: "Je n'aime pas le café. (défini → inchangé) / Il ne veut pas de viande. (partitif → de)",
    explanation: "El artículo DÉFINI no cambia tras la negación. <em>Je n'aime pas LE café</em> (no me gusta el café — genérico) mantiene <em>le</em>. Solo los artículos INDÉFINI y PARTITIF se convierten en <em>de</em>. La clave: ¿es un gusto general sobre la categoría (défini)? → sin cambio. ¿Es una cantidad concreta (partitif) o un objeto no identificado (indéfini)? → <em>de</em>."
  },
  {
    name: "aussi de — igualdad con nombres",
    wrong: "Elle a aussi de travail que moi.",
    right: "Elle a autant de travail que moi.",
    explanation: "Con NOMBRES, la igualdad en la comparación usa SIEMPRE <em>autant de</em>, nunca <em>aussi de</em>. <em>Aussi</em> es exclusivo de adjetivos y adverbios. <em>Autant de</em> funciona exactamente como <em>also de</em> debería, pero solo existe <em>autant</em>. Ver también el documento sobre le Comparatif."
  },
  {
    name: "à le / de le — formas no contractas",
    wrong: "Je vais à le marché. / Je reviens de le bureau.",
    right: "Je vais au marché. / Je reviens du bureau.",
    explanation: "<em>À le</em> y <em>de le</em> son AGRAMATICALES en francés. La contracción con <em>le</em> es OBLIGATORIA: à + le = au, de + le = du, à + les = aux, de + les = des. En cambio, con <em>la</em> y <em>l'</em> no hay contracción: <em>à la gare, de l'aéroport</em> (correctos sin contracción)."
  },
  {
    name: "des beaux livres — des ante adjectivo antepuesto",
    wrong: "J'ai vu des beaux tableaux. / Il a des petits enfants.",
    right: "J'ai vu de beaux tableaux. / Il a de petits enfants.",
    explanation: "Ante un adjetivo ANTEPUESTO (que va antes del nombre), el artículo indéfini plural <em>des</em> se convierte en <em>de/d'</em>. Esta regla se aplica en registro formal y escrito: <em>de beaux tableaux, de jeunes étudiants, d'autres solutions</em>. Si el adjetivo va DESPUÉS del nombre, <em>des</em> no cambia: <em>des résultats excellents</em> ✓."
  },
  {
    name: "jouer au guitare — confusión au/de la con instruments/sports",
    wrong: "Il joue au guitare. / Elle joue de la football.",
    right: "Il joue de la guitare. / Elle joue au football.",
    explanation: "DEPORTES y JUEGOS → <em>jouer À</em> (+ contraction): <em>jouer AU foot, jouer AUX cartes, jouer AU tennis</em>. INSTRUMENTOS musicales → <em>jouer DE</em> (+ contraction): <em>jouer DU piano, jouer DE LA guitare, jouer DE L'accordéon</em>. No hay excepción: la preposición cambia según el tipo de actividad."
  },
  {
    name: "en la France / en le Japon — preposición + pays",
    wrong: "Je vis en la France. / Il va en le Japon.",
    right: "Je vis en France. / Il va au Japon.",
    explanation: "Países femeninos (terminados en <em>-e</em>): EN + país sin artículo (<em>en France, en Espagne, en Colombie</em>). Países masculinos: AU + pays (<em>au Japon, au Brésil, au Canada</em>). Países plurales: AUX + pays (<em>aux États-Unis, aux Pays-Bas</em>). <em>En la France</em> es agramatical: con <em>en</em>, el artículo desaparece para los países femeninos."
  },
  {
    name: "Il ne boit que de vin — ne…que y el artículo",
    wrong: "Il ne boit que de vin. / Je n'ai qu'une idée.",
    right: "Il ne boit que du vin. / Je n'ai qu'une idée. ✓",
    explanation: "<em>Ne…que</em> es restrictivo (= seulement), no es una negación de existencia. Por eso NO activa la regla <em>indéfini/partitif → de</em>. El artículo se mantiene igual que en una frase afirmativa: <em>il boit DU vin</em> → <em>il ne boit que DU vin</em>. Contrastar con <em>ne…pas</em>: <em>il ne boit pas DE vin</em> (negación total → de)."
  },
  {
    name: "du vs. de l' — partitif ante vocal",
    wrong: "Je bois du eau. / Il mange du huile d'olive.",
    right: "Je bois de l'eau. / Il mange de l'huile d'olive.",
    explanation: "El artículo partitif (y défini) se elide ante vocal o h muda: <em>du → DE L', de la → DE L'</em>. <em>Du eau</em> es agramatical porque <em>du = de + le</em> y <em>eau</em> es femenino además de empezar por vocal. Siempre: <em>de l'eau</em> (f.), <em>de l'huile</em> (f.), <em>de l'enthousiasme</em> (m.), <em>de l'air</em> (m.)."
  }
];

function renderTraps() {
  const container = document.getElementById('traps-container');
  if (!container) return;
  container.innerHTML = TRAPS.map((t, i) => `
    <div class="trap-card">
      <div class="trap-card-header">
        <span class="trap-name">${i + 1}. ${t.name}</span>
      </div>
      <div class="trap-vs">
        <div class="trap-wrong">${t.wrong}</div>
        <div class="trap-right">${t.right}</div>
      </div>
      <div class="trap-expl">${t.explanation}</div>
    </div>
  `).join('');
}

document.addEventListener('DOMContentLoaded', () => {
  renderTraps();
});
</script>

</body>
</html>
