<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · La Voix Passive</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ede9df;--card:#faf7f1;--border:#c4bead;
  --text:#1a1814;--text2:#44413a;--text3:#706c64;
  --accent:#7a5a0a;--accent-light:#f0e0c0;--accent-mid:#b89050;
  --warn-bg:#fdf0cc;
  --shadow:0 2px 14px rgba(0,0,0,.11),0 1px 4px rgba(0,0,0,.06);
  --shadow-sm:0 1px 6px rgba(0,0,0,.08);
  --radius:14px;--radius-sm:8px;
  --green:#1a6028;--green-bg:#e4f2e8;
  --red:#a81e2e;--red-bg:#fce6e8;
  --blue:#163494;--blue-bg:#e6ebf8;
  --purple:#6a1a8a;--purple-bg:#f2e6f8;
  --ac-color:#163494;--ac-bg:#e6ebf8;
  --pa-color:#1a6028;--pa-bg:#e4f2e8;
  --ag-color:#6a1a8a;--ag-bg:#f2e6f8;
  --al-color:#8b1a4a;--al-bg:#f8e6ee;
  --fs:15px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:var(--fs);}
.site-header{background:var(--card);border-bottom:2px solid var(--border);padding:20px 20px 14px;}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px;flex-wrap:wrap;}
.site-header h1{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,5vw,1.9rem);font-weight:700;}
.header-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-mid);border-radius:20px;padding:3px 10px;}
.subtitle{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.stats-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;}
.stat-pill{border-radius:20px;padding:4px 11px;font-size:.76rem;font-weight:600;border:1px solid;}
.stat-pill.ac{background:var(--ac-bg);color:var(--ac-color);border-color:var(--ac-color);}
.stat-pill.pa{background:var(--pa-bg);color:var(--pa-color);border-color:var(--pa-color);}
.stat-pill.ag{background:var(--ag-bg);color:var(--ag-color);border-color:var(--ag-color);}
.stat-pill.al{background:var(--al-bg);color:var(--al-color);border-color:var(--al-color);}
.stat-pill.neu{background:var(--bg);color:var(--text2);border-color:var(--border);font-weight:500;}
.fs-wrap{display:flex;align-items:center;gap:7px;margin-left:auto;}
.fs-slider{width:76px;accent-color:var(--accent);cursor:pointer;}
.fs-sz{color:var(--text3);font-weight:700;}
.mode-toggle{display:flex;border-bottom:2px solid var(--border);background:var(--card);}
.mode-btn{flex:1;padding:12px 8px;font-family:'DM Sans',sans-serif;font-size:.84rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.mode-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.section-nav{position:sticky;top:0;z-index:200;background:var(--card);border-bottom:2px solid var(--border);box-shadow:var(--shadow-sm);}
.section-nav-inner{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.section-nav-inner::-webkit-scrollbar{display:none;}
.snav-btn{flex-shrink:0;padding:11px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;}
.snav-btn:hover{color:var(--text2);}
.snav-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.main-layout{max-width:860px;margin:0 auto;padding:16px 16px 40px;}
.panel{display:none;}.panel.active{display:block;}
.sec-block{display:none;}.sec-block.active{display:block;}
.gram-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:14px;overflow:hidden;}
.gram-card-body{padding:18px;}
.def-box{background:var(--warn-bg);border-left:4px solid var(--accent);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:12px 15px;margin-bottom:14px;line-height:1.65;}
.def-box strong{color:var(--accent);font-weight:700;}
.warn-box{background:#fff4e0;border:1px solid #c8900a;border-radius:var(--radius-sm);padding:10px 13px;margin:10px 0;font-size:.9em;display:flex;gap:8px;align-items:flex-start;}
.warn-icon{flex-shrink:0;margin-top:1px;}
.warn-text{color:var(--text2);line-height:1.55;}
.warn-text strong{color:#7a4400;font-weight:700;}
.note-box{background:var(--purple-bg);border-left:4px solid var(--purple);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.note-box strong{color:var(--purple);font-weight:700;}
.green-box{background:var(--green-bg);border-left:4px solid var(--green);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.green-box strong{color:var(--green);font-weight:700;}
.example-block{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:8px 0;}
.example-block.ac{background:var(--ac-bg);border-left:4px solid var(--ac-color);}
.example-block.pa{background:var(--pa-bg);border-left:4px solid var(--pa-color);}
.example-block.ag{background:var(--ag-bg);border-left:4px solid var(--ag-color);}
.example-block.al{background:var(--al-bg);border-left:4px solid var(--al-color);}
.example-block.neu{background:var(--blue-bg);border-left:4px solid var(--blue);}
.ex-fr{font-weight:600;margin-bottom:3px;color:var(--text);}
.eac{color:var(--ac-color);font-weight:700;}
.epa{color:var(--pa-color);font-weight:700;}
.eag{color:var(--ag-color);font-weight:700;}
.eal{color:var(--al-color);font-weight:700;}
.ex-es{color:var(--text2);font-size:.88em;font-style:italic;}
.ex-note{font-size:.78em;color:var(--text3);margin-top:3px;font-weight:500;}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:14px;border-radius:var(--radius-sm);border:1px solid var(--border);}
.gram-table{width:100%;border-collapse:collapse;min-width:280px;}
.gram-table th{background:var(--bg);border-bottom:2px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;text-align:left;font-size:.72em;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.gram-table td{border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;vertical-align:top;}
.gram-table tr:last-child td{border-bottom:none;}
.gram-table tr:nth-child(even) td{background:#f4f0e6;}
.gram-table td:last-child,.gram-table th:last-child{border-right:none;}
.hl-ac{color:var(--ac-color);font-weight:700;}
.hl-pa{color:var(--pa-color);font-weight:700;}
.hl-ag{color:var(--ag-color);font-weight:700;}
.hl-al{color:var(--al-color);font-weight:700;}
.hl{color:var(--accent);font-weight:700;}
.dim{color:var(--text3);font-size:.88em;}
.ok-cell{color:var(--green);font-weight:700;}
.err-cell{color:var(--red);font-weight:600;font-style:italic;}
.chip-bar{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.chip{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;white-space:nowrap;}
.chip:hover{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.chip.ac.active{background:var(--ac-color);border-color:var(--ac-color);}
.chip.pa.active{background:var(--pa-color);border-color:var(--pa-color);}
.chip.ag.active{background:var(--ag-color);border-color:var(--ag-color);}
.chip.al.active{background:var(--al-color);border-color:var(--al-color);}
.chip-panel{display:none;}.chip-panel.active{display:block;}
.sec-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px;}
.trap-cards{display:flex;flex-direction:column;gap:10px;}
.trap-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.trap-card-header{padding:11px 14px;background:var(--bg);}
.trap-name{font-weight:700;font-size:.9em;color:var(--text);margin-bottom:7px;}
.trap-vs{display:flex;gap:8px;flex-wrap:wrap;}
.trap-wrong{background:var(--red-bg);border:1.5px solid #d09098;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--red);font-weight:500;}
.trap-right{background:var(--green-bg);border:1.5px solid #80b890;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--green);font-weight:500;}
.trap-expl{padding:10px 14px 12px;font-size:.86em;color:var(--text2);line-height:1.6;border-top:1px solid var(--border);background:var(--card);}
.trap-expl strong{color:var(--text);font-weight:700;}
.exercise-controls{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:var(--shadow-sm);}
.exercise-controls h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:14px;}
.ctrl-label{font-size:.7em;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:7px;display:block;}
.ex-options{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ex-opt-btn{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.ex-opt-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.row-btns{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.pill-btn{border:1.5px solid var(--border);border-radius:20px;padding:5px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.pill-btn:hover:not(.active){background:var(--border);}
.pill-btn.active{background:var(--text);color:var(--bg);border-color:var(--text);}
.pill-btn.diff.active.A2{background:var(--green);border-color:var(--green);color:#fff;}
.pill-btn.diff.active.B1{background:var(--blue);border-color:var(--blue);color:#fff;}
.pill-btn.diff.active.B2{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-generate{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:.92em;font-weight:700;cursor:pointer;background:var(--accent);color:white;transition:all .18s;margin-top:4px;}
.btn-generate:hover:not(:disabled){filter:brightness(1.1);box-shadow:0 4px 14px rgba(122,90,10,.32);}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;}
.spinner{display:none;animation:spin .8s linear infinite;}
.btn-generate.loading .spinner{display:inline;}
.btn-generate.loading .btn-icon{display:none;}
@keyframes spin{to{transform:rotate(360deg);}}
.progress-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:14px;display:none;}
.progress-wrap.visible{display:block;}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-size:.78em;color:var(--text3);font-weight:600;}
.progress-frac{font-size:.92em;font-weight:700;color:var(--accent);}
.progress-track{height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .35s ease;}
.progress-score{display:flex;gap:14px;margin-top:9px;font-size:.8em;flex-wrap:wrap;align-items:center;}
.score-item{display:flex;align-items:center;gap:5px;font-weight:500;color:var(--text2);}
.score-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.score-dot.g{background:var(--green);}.score-dot.r{background:var(--red);}
.btn-retry{border:1.5px solid var(--border);border-radius:20px;padding:5px 13px;font-family:'DM Sans',sans-serif;font-size:.78em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;margin-left:auto;}
.btn-retry:hover{background:var(--border);}
.final-score-bar{display:none;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;}
.final-score-bar.visible{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.final-num{font-size:1.5rem;font-weight:700;color:var(--accent);}
.final-label{font-size:.74em;color:var(--text3);}
.final-track{flex:1;min-width:80px;height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.final-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.final-msg{font-size:.84em;color:var(--text2);width:100%;font-weight:500;}
.exercise-area{display:none;}.exercise-area.visible{display:block;}
.exercise-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;}
.exercise-card-header{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg);border-bottom:1px solid var(--border);}
.ex-num{font-weight:700;color:var(--accent);font-size:.88em;}
.ex-type-badge{font-size:.68em;font-weight:700;letter-spacing:.07em;text-transform:uppercase;background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-mid);border-radius:12px;padding:2px 8px;}
.ex-diff-badge{font-size:.68em;font-weight:700;border-radius:12px;padding:2px 8px;}
.ex-diff-badge.A2{background:var(--green-bg);color:var(--green);border:1px solid #80b890;}
.ex-diff-badge.B1{background:var(--blue-bg);color:var(--blue);border:1px solid #90a8e0;}
.ex-diff-badge.B2{background:var(--warn-bg);color:var(--accent);border:1px solid var(--accent-mid);}
.ex-status{margin-left:auto;}
.exercise-body{padding:16px 18px;}
.exercise-prompt{line-height:1.7;margin-bottom:12px;color:var(--text);}
.exercise-prompt em{color:var(--accent);font-style:italic;font-weight:600;}
.fill-input{border:none;border-bottom:2px solid var(--accent-mid);background:var(--accent-light);padding:2px 8px;border-radius:4px 4px 0 0;font-family:'DM Sans',sans-serif;font-size:1em;color:var(--text);min-width:160px;outline:none;transition:border-color .15s;}
.fill-input:focus{border-bottom-color:var(--accent);}
.fill-input.ok{background:var(--green-bg);border-bottom-color:var(--green);}
.fill-input.err{background:var(--red-bg);border-bottom-color:var(--red);}
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.choice-btn{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.88em;font-weight:500;cursor:pointer;text-align:left;background:var(--bg);color:var(--text);transition:all .15s;}
.choice-btn:hover:not(:disabled){border-color:var(--accent);background:var(--accent-light);}
.choice-btn.ok{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:700;}
.choice-btn.err{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.choice-btn:disabled{cursor:default;}
.transform-input{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.9em;background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;transition:border-color .15s;}
.transform-input:focus{border-color:var(--accent);}
.transform-input.ok{background:var(--green-bg);border-color:var(--green);}
.transform-input.err{background:var(--red-bg);border-color:var(--red);}
.btn-check{border:1.5px solid var(--accent);border-radius:20px;padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:700;cursor:pointer;background:transparent;color:var(--accent);transition:all .15s;}
.btn-check:hover:not(:disabled){background:var(--accent);color:white;}
.btn-check:disabled{opacity:.35;cursor:default;}
.ex-feedback{display:none;border-radius:var(--radius-sm);padding:11px 14px;line-height:1.55;margin-top:10px;font-size:.9em;}
.ex-feedback.visible{display:block;}
.ex-feedback.ok{background:var(--green-bg);border:1.5px solid #80b890;color:#0e4818;}
.ex-feedback.err{background:var(--red-bg);border:1.5px solid #c08090;color:#700018;}
.fb-rule-link{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:.84em;font-weight:700;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;}
.skeleton-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:12px;}
.skel{background:linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.4s infinite;border-radius:4px;height:13px;margin-bottom:9px;}
@keyframes skel{to{background-position:-200% 0;}}
.state-msg{text-align:center;padding:40px 20px;color:var(--text3);}
.state-icon{font-size:2rem;margin-bottom:10px;}
.state-msg p{max-width:260px;margin:0 auto;line-height:1.6;font-weight:500;}
</style>
</head>
<body>
<header class="site-header">
  <div class="header-top">
    <h1>La Voix Passive</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1</div>
  <div class="stats-row">
    <div class="stat-pill ac">Voix active</div>
    <div class="stat-pill pa">Voix passive</div>
    <div class="stat-pill ag">Complément d'agent</div>
    <div class="stat-pill al">Alternatives</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>
<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>
<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-formation',this)">2. Formation</button>
    <button class="snav-btn"        onclick="showSection('s-temps',this)">3. Tous les temps</button>
    <button class="snav-btn"        onclick="showSection('s-agent',this)">4. Complément d'agent</button>
    <button class="snav-btn"        onclick="showSection('s-alternatives',this)">5. Alternatives</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">7. Trampas</button>
  </div>
</div>
<div class="main-layout">
<div class="panel active" id="panel-ref">
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La <strong>voix passive</strong> permite presentar una frase haciendo del objeto de la acción el sujeto gramatical. El sujeto activo puede desaparecer o pasar a ser <em>complément d'agent</em>. Es muy frecuente en textos periodísticos, científicos y administrativos — clave para la comprensión lectora del DELF B1.
      </div>

      <div class="sec-label">Transformación actif → passif</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Voix active</th><th>Voix passive</th></tr></thead>
        <tbody>
          <tr>
            <td><span class="hl-ac">Le gouvernement</span> a adopté <span class="hl-ag">cette loi</span>.</td>
            <td><span class="hl-ag">Cette loi</span> a été adoptée <span class="hl-ac">par le gouvernement</span>.</td>
          </tr>
          <tr>
            <td><span class="hl-ac">Sujet actif</span> → agente</td>
            <td><span class="hl-ag">COD actif</span> → nuevo sujeto</td>
          </tr>
        </tbody>
      </table></div>

      <div class="sec-label">Tres reglas fundamentales</div>
      <div class="green-box">
        <strong>1. Estructura:</strong> être (conjugado) + participio pasado<br>
        <strong>2. Acuerdo:</strong> el participio concuerda con el <em>nuevo sujeto</em> (= el COD de la frase activa)<br>
        <strong>3. Solo transitifs directs:</strong> únicamente los verbos con COD pueden pasivizarse
      </div>

      <div class="sec-label">¿Cuándo se usa el pasivo en francés?</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Motivo</th><th>Ejemplo</th></tr></thead>
        <tbody>
          <tr><td>El agente es desconocido</td><td><em>La voiture <strong>a été volée</strong>.</em></td></tr>
          <tr><td>El agente es evidente o sin importancia</td><td><em>Le président <strong>a été élu</strong>.</em></td></tr>
          <tr><td>Se quiere enfatizar el objeto</td><td><em>Ce tableau <strong>a été peint</strong> par Picasso.</em></td></tr>
          <tr><td>Estilo formal / periodístico</td><td><em>Un accord <strong>a été signé</strong> hier.</em></td></tr>
        </tbody>
      </table></div>

      <div class="warn-box"><span class="warn-icon">⚠️</span>
        <div class="warn-text"><strong>El pasivo es mucho más frecuente en comprensión que en producción.</strong> En producción escrita B1, el pasivo aparece pero no es obligatorio. En comprensión lectora, es imprescindible reconocerlo en todos los tiempos.</div>
      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-formation">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La voz pasiva se forma con <strong>être + participio pasado</strong>. El participio concuerda siempre con el sujeto gramatical de la frase pasiva (= el COD de la frase activa). Solo los verbos transitivos directos pueden pasivizarse.
      </div>

      <div class="chip-bar">
        <button class="chip pa active" onclick="selectChip('form',0)">Estructura y acuerdo</button>
        <button class="chip pa"        onclick="selectChip('form',1)">Actif → Passif paso a paso</button>
        <button class="chip pa"        onclick="selectChip('form',2)">Passif → Actif</button>
        <button class="chip pa"        onclick="selectChip('form',3)">Verbos que NO se pasivan</button>
      </div>
      <div id="form-panels">

        <div class="chip-panel active" id="form-p-0">
          <div class="green-box">
            <strong>Fórmula:</strong> SUJETO + être (tiempo) + p.p. (acordado) [+ par/de + agente]
          </div>
          <div class="sec-label">Acuerdo del participio — tabla completa</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Sujeto pasivo</th><th>Terminación p.p.</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Masc. sing.</td><td>base</td><td>Le projet est <span class="hl-pa">approuvé</span>.</td></tr>
              <tr><td>Fém. sing.</td><td>+ e</td><td>La loi est <span class="hl-pa">approuvée</span>.</td></tr>
              <tr><td>Masc. pl.</td><td>+ s</td><td>Les projets sont <span class="hl-pa">approuvés</span>.</td></tr>
              <tr><td>Fém. pl.</td><td>+ es</td><td>Les lois sont <span class="hl-pa">approuvées</span>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block pa">
            <div class="ex-fr">Ce document <span class="epa">est signé</span> par le directeur.</div>
            <div class="ex-es">Este documento está firmado por el director.</div>
            <div class="ex-note">document = masc. sing. → signé (base)</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Cette lettre <span class="epa">est signée</span> par le directeur.</div>
            <div class="ex-es">Esta carta está firmada por el director.</div>
            <div class="ex-note">lettre = fém. sing. → signée (+e)</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Ces mesures <span class="epa">sont prises</span> par le gouvernement.</div>
            <div class="ex-es">Estas medidas son tomadas por el gobierno.</div>
            <div class="ex-note">mesures = fém. pl. → prises (+es)</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Les suspects <span class="epa">sont arrêtés</span> par la police.</div>
            <div class="ex-es">Los sospechosos son detenidos por la policía.</div>
            <div class="ex-note">suspects = masc. pl. → arrêtés (+s)</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-1">
          <div class="def-box">Tres pasos para transformar una frase activa en pasiva.</div>
          <div class="green-box">
            <strong>Paso 1:</strong> El COD activo → nuevo sujeto pasivo<br>
            <strong>Paso 2:</strong> El verbo → être (mismo tiempo) + p.p. acordado con el nuevo sujeto<br>
            <strong>Paso 3:</strong> El sujeto activo → <em>par</em> + agente (o desaparece)
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">Le chef</span> prépare <span class="eag">le repas</span>.</div>
            <div class="ex-es">El jefe prepara la comida. <em>(actif)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="eag">Le repas</span> <span class="epa">est préparé</span> par <span class="eac">le chef</span>.</div>
            <div class="ex-es">La comida es preparada por el jefe. <em>(passif)</em></div>
            <div class="ex-note">repas = masc. sing. → préparé (base) ✓</div>
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">Les journalistes</span> ont publié <span class="eag">cet article</span>.</div>
            <div class="ex-es">Los periodistas publicaron este artículo. <em>(actif, passé composé)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="eag">Cet article</span> <span class="epa">a été publié</span> par <span class="eac">les journalistes</span>.</div>
            <div class="ex-es">Este artículo fue publicado por los periodistas. <em>(passif)</em></div>
            <div class="ex-note">article = masc. sing. → publié (base) ✓</div>
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">Un médecin</span> examinera <span class="eag">les patients</span>.</div>
            <div class="ex-es">Un médico examinará a los pacientes. <em>(actif, futur)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="eag">Les patients</span> <span class="epa">seront examinés</span> par <span class="eac">un médecin</span>.</div>
            <div class="ex-es">Los pacientes serán examinados por un médico. <em>(passif)</em></div>
            <div class="ex-note">patients = masc. pl. → examinés (+s) ✓</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-2">
          <div class="def-box">Para pasar de pasiva a activa: el agente (si existe) → nuevo sujeto; el sujeto pasivo → COD; être + p.p. → verbo activo conjugado.</div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="epa">Cette décision a été prise</span> par <span class="eac">le conseil</span>.</div>
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">Le conseil</span> a pris <span class="eag">cette décision</span>.</div>
            <div class="ex-es">El consejo tomó esta decisión. <em>(actif)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="epa">Le voleur a été arrêté</span>.</div>
            <div class="ex-note">(sin agente → sujeto activo = on)</div>
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">On</span> a arrêté le voleur.</div>
            <div class="ex-es">Detuvieron al ladrón. <em>(actif con on)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr"><span class="epa">Ces règles sont respectées</span> par <span class="eac">tout le monde</span>.</div>
          </div>
          <div class="example-block ac">
            <div class="ex-fr"><span class="eac">Tout le monde</span> respecte ces règles.</div>
            <div class="ex-es">Todo el mundo respeta estas normas.</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-3">
          <div class="def-box">Solo los verbos <strong>transitifs directs</strong> (con COD) pueden pasivizarse. Los transitifs indirects (COI con à, de…) no pueden.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo</th><th>Construcción</th><th>¿Pasivizable?</th></tr></thead>
            <tbody>
              <tr><td><strong>aimer</strong></td><td>aimer + COD</td><td class="ok-cell">✓ être aimé</td></tr>
              <tr><td><strong>construire</strong></td><td>construire + COD</td><td class="ok-cell">✓ être construit</td></tr>
              <tr><td><strong>obéir</strong></td><td>obéir <strong>à</strong> + COI</td><td class="err-cell">✗ no pasivo</td></tr>
              <tr><td><strong>téléphoner</strong></td><td>téléphoner <strong>à</strong> + COI</td><td class="err-cell">✗ no pasivo</td></tr>
              <tr><td><strong>appartenir</strong></td><td>appartenir <strong>à</strong> + COI</td><td class="err-cell">✗ no pasivo</td></tr>
              <tr><td><strong>ressembler</strong></td><td>ressembler <strong>à</strong> + COI</td><td class="err-cell">✗ no pasivo</td></tr>
              <tr><td><strong>manquer</strong></td><td>manquer <strong>à / de</strong></td><td class="err-cell">✗ no pasivo</td></tr>
            </tbody>
          </table></div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Il est obéi par ses enfants</em> ✗ — <em>obéir à</em> es COI. <em>Il est téléphoné par son ami</em> ✗ — <em>téléphoner à</em> es COI. Para expresar estas ideas: <em>Ses enfants lui obéissent</em> / <em>Son ami lui téléphone</em>.</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-temps">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El pasivo puede formarse en <strong>todos los tiempos verbales</strong>. La clave es conjugar <em>être</em> en el tiempo correspondiente y mantener el acuerdo del participio con el sujeto. Reconocer el pasivo en todos los tiempos es esencial para la comprensión lectora B1.
      </div>

      <div class="sec-label">Tabla de referencia completa</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Temps</th><th>Être conjugado</th><th>Ejemplo (fém. sing.)</th></tr></thead>
        <tbody>
          <tr><td><strong>Présent</strong></td><td>est</td><td>La lettre <span class="hl-pa">est signée</span>.</td></tr>
          <tr><td><strong>Imparfait</strong></td><td>était</td><td>La lettre <span class="hl-pa">était signée</span>.</td></tr>
          <tr><td><strong>Passé composé</strong></td><td>a été</td><td>La lettre <span class="hl-pa">a été signée</span>.</td></tr>
          <tr><td><strong>Plus-que-parfait</strong></td><td>avait été</td><td>La lettre <span class="hl-pa">avait été signée</span>.</td></tr>
          <tr><td><strong>Futur simple</strong></td><td>sera</td><td>La lettre <span class="hl-pa">sera signée</span>.</td></tr>
          <tr><td><strong>Conditionnel présent</strong></td><td>serait</td><td>La lettre <span class="hl-pa">serait signée</span>.</td></tr>
          <tr><td><strong>Subjonctif présent</strong></td><td>soit</td><td>…que la lettre <span class="hl-pa">soit signée</span>.</td></tr>
        </tbody>
      </table></div>

      <div class="chip-bar">
        <button class="chip pa active" onclick="selectChip('temps',0)">Présent et imparfait</button>
        <button class="chip pa"        onclick="selectChip('temps',1)">Passé composé et PQP</button>
        <button class="chip pa"        onclick="selectChip('temps',2)">Futur et conditionnel</button>
        <button class="chip pa"        onclick="selectChip('temps',3)">Présent vs. état résultant</button>
      </div>
      <div id="temps-panels">

        <div class="chip-panel active" id="temps-p-0">
          <div class="example-block pa">
            <div class="ex-fr">Ce musée <span class="epa">est visité</span> par des milliers de touristes chaque année.</div>
            <div class="ex-es">Este museo es visitado por miles de turistas cada año. <em>(présent)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Les résultats <span class="epa">sont publiés</span> tous les mois.</div>
            <div class="ex-es">Los resultados se publican cada mes. <em>(présent — hábito)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Avant, les lettres <span class="epa">étaient écrites</span> à la main.</div>
            <div class="ex-es">Antes, las cartas se escribían a mano. <em>(imparfait — hábito pasado)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">À l'époque, ces décisions <span class="epa">étaient prises</span> par un comité restreint.</div>
            <div class="ex-es">En aquella época, estas decisiones las tomaba un comité reducido. <em>(imparfait)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Les données <span class="epa">étaient analysées</span> chaque semaine par l'équipe de recherche.</div>
            <div class="ex-es">Los datos eran analizados cada semana por el equipo de investigación.</div>
          </div>
        </div>

        <div class="chip-panel" id="temps-p-1">
          <div class="def-box">Passé composé = acción puntual en el pasado. Plus-que-parfait = acción anterior a otra acción pasada.</div>
          <div class="example-block pa">
            <div class="ex-fr">Le suspect <span class="epa">a été arrêté</span> hier soir par la police.</div>
            <div class="ex-es">El sospechoso fue detenido anoche por la policía. <em>(passé composé)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Un accord <span class="epa">a été signé</span> entre les deux pays.</div>
            <div class="ex-es">Se firmó un acuerdo entre los dos países.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Les victimes <span class="epa">ont été transportées</span> à l'hôpital immédiatement.</div>
            <div class="ex-es">Las víctimas fueron trasladadas al hospital de inmediato.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">La décision <span class="epa">avait déjà été prise</span> avant notre arrivée.</div>
            <div class="ex-es">La decisión ya había sido tomada antes de nuestra llegada. <em>(plus-que-parfait)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Il a découvert que son bureau <span class="epa">avait été cambriolé</span> pendant la nuit.</div>
            <div class="ex-es">Descubrió que su oficina había sido robada durante la noche.</div>
          </div>
          <div class="note-box"><strong>Passé composé passif:</strong> avoir + été + p.p. — son tres elementos. <em>A été signée</em> (fém.) ✓. Error frecuente: <em>a été signé</em> con sujeto femenino ✗.</div>
        </div>

        <div class="chip-panel" id="temps-p-2">
          <div class="example-block pa">
            <div class="ex-fr">Les résultats <span class="epa">seront annoncés</span> la semaine prochaine.</div>
            <div class="ex-es">Los resultados serán anunciados la semana que viene. <em>(futur simple)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">La nouvelle loi <span class="epa">sera votée</span> par l'Assemblée nationale.</div>
            <div class="ex-es">La nueva ley será votada por la Asamblea Nacional.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Ce projet <span class="epa">serait financé</span> par des fonds européens.</div>
            <div class="ex-es">Este proyecto sería financiado por fondos europeos. <em>(conditionnel)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Il faut que cette décision <span class="epa">soit prise</span> rapidement.</div>
            <div class="ex-es">Es necesario que esta decisión sea tomada rápidamente. <em>(subjonctif)</em></div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Je voudrais que ces problèmes <span class="epa">soient résolus</span> avant la fin du mois.</div>
            <div class="ex-es">Quisiera que estos problemas fueran resueltos antes de fin de mes.</div>
          </div>
        </div>

        <div class="chip-panel" id="temps-p-3">
          <div class="def-box">Una distinción clave: el passif d'action expresa una acción realizada; el passif d'état describe el resultado de una acción anterior.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Passif d'action</th><th>État résultant</th></tr></thead>
            <tbody>
              <tr><td>La porte <span class="hl-pa">est fermée</span> par le gardien. <span class="dim">(acción: el guardia la cierra ahora)</span></td><td>La porte <span class="hl-pa">est fermée</span>. <span class="dim">(estado: está cerrada, sin agente)</span></td></tr>
              <tr><td>Le magasin <span class="hl-pa">est fermé</span> par le propriétaire à 19h.</td><td>Le magasin <span class="hl-pa">est fermé</span> le dimanche.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block pa">
            <div class="ex-fr">La fenêtre <span class="epa">est ouverte</span> par Marie chaque matin. <span class="ex-note">(action — Marie l'ouvre)</span></div>
            <div class="ex-es">Marie abre la ventana cada mañana.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">La fenêtre <span class="epa">est ouverte</span>. <span class="ex-note">(état — la ventana está abierta)</span></div>
            <div class="ex-es">La ventana está abierta.</div>
          </div>
          <div class="note-box"><strong>Clave:</strong> si hay complemento de agente (<em>par + nom</em>) o la acción es reciente y puntual → passif d'action. Si describe simplemente el estado actual sin agente → état résultant.</div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-agent">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El <strong>complément d'agent</strong> indica quién realiza la acción en la voz pasiva. Se introduce con <strong>par</strong> o <strong>de</strong> según el tipo de verbo. Puede también omitirse cuando el agente es desconocido o sin importancia.
      </div>

      <div class="chip-bar">
        <button class="chip ag active" onclick="selectChip('agent',0)">Par — acción concreta</button>
        <button class="chip ag"        onclick="selectChip('agent',1)">De — estado / sentimiento / situation</button>
        <button class="chip ag"        onclick="selectChip('agent',2)">Sin agente — agente omitido</button>
        <button class="chip ag"        onclick="selectChip('agent',3)">Par vs. De — tabla comparativa</button>
      </div>
      <div id="agent-panels">

        <div class="chip-panel active" id="agent-p-0">
          <div class="def-box"><strong>Par</strong> introduce el agente de una <strong>acción concreta y puntual</strong>. Es la preposición más frecuente.</div>
          <div class="example-block ag">
            <div class="ex-fr">Ce livre a été écrit <span class="eag">par</span> un auteur inconnu.</div>
            <div class="ex-es">Este libro fue escrito por un autor desconocido.</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Le voleur a été arrêté <span class="eag">par</span> deux policiers.</div>
            <div class="ex-es">El ladrón fue detenido por dos policías.</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">La décision a été prise <span class="eag">par</span> le conseil d'administration.</div>
            <div class="ex-es">La decisión fue tomada por el consejo de administración.</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Ce pont a été construit <span class="eag">par</span> des ingénieurs français.</div>
            <div class="ex-es">Este puente fue construido por ingenieros franceses.</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">La nouvelle a été annoncée <span class="eag">par</span> le président lui-même.</div>
            <div class="ex-es">La noticia fue anunciada por el propio presidente.</div>
          </div>
        </div>

        <div class="chip-panel" id="agent-p-1">
          <div class="def-box"><strong>De</strong> introduce el agente cuando el verbo expresa un <strong>estado, sentimiento, situación permanente o descripción</strong>. Los verbos más frecuentes con <em>de</em>: <em>entourer, couvrir, remplir, orner, accompagner, aimer, respecter, admirer, apprécier, connaître, suivre</em>.</div>
          <div class="example-block ag">
            <div class="ex-fr">La ville est entourée <span class="eag">de</span> montagnes.</div>
            <div class="ex-es">La ciudad está rodeada de montañas.</div>
            <div class="ex-note">état permanent → de</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Il est aimé <span class="eag">de</span> tout le monde.</div>
            <div class="ex-es">Es querido por todo el mundo.</div>
            <div class="ex-note">sentiment → de</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Elle est respectée <span class="eag">de</span> ses collègues.</div>
            <div class="ex-es">Es respetada por sus colegas.</div>
            <div class="ex-note">état durable → de</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">La table était couverte <span class="eag">de</span> fleurs.</div>
            <div class="ex-es">La mesa estaba cubierta de flores.</div>
            <div class="ex-note">état résultant → de</div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Le musée est fréquenté <span class="eag">de</span> nombreux touristes.</div>
            <div class="ex-es">El museo es frecuentado por numerosos turistas.</div>
            <div class="ex-note">situation habituelle → de (también aceptable: par)</div>
          </div>
          <div class="warn-box"><span class="warn-icon">💡</span><div class="warn-text">La distinción par/de puede ser sutil. En caso de duda, <strong>par</strong> siempre es correcto con verbos de acción. <strong>De</strong> es obligatorio con los verbos de estado y sentimiento listados.</div></div>
        </div>

        <div class="chip-panel" id="agent-p-2">
          <div class="def-box">El agente puede omitirse cuando es desconocido, evidente, indeterminado o sin importancia para el mensaje.</div>
          <div class="example-block pa">
            <div class="ex-fr">Ma voiture <span class="epa">a été volée</span>. <span class="ex-note">(agente desconocido)</span></div>
            <div class="ex-es">Me robaron el coche.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Le président <span class="epa">a été élu</span> pour cinq ans. <span class="ex-note">(agente evidente = los ciudadanos)</span></div>
            <div class="ex-es">El presidente fue elegido por cinco años.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Ces chiffres <span class="epa">sont publiés</span> chaque trimestre. <span class="ex-note">(agente sin importancia)</span></div>
            <div class="ex-es">Estas cifras se publican cada trimestre.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">L'accusé <span class="epa">a été condamné</span> à deux ans de prison.</div>
            <div class="ex-es">El acusado fue condenado a dos años de prisión.</div>
          </div>
          <div class="example-block pa">
            <div class="ex-fr">Des milliers d'emplois <span class="epa">ont été supprimés</span> l'an dernier.</div>
            <div class="ex-es">Miles de empleos fueron suprimidos el año pasado.</div>
          </div>
          <div class="note-box"><strong>El pasivo sin agente</strong> es el más frecuente en textos periodísticos y científicos — permite presentar el hecho sin mencionar al responsable.</div>
        </div>

        <div class="chip-panel" id="agent-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-ag">Par</th><th class="hl-ag">De</th></tr></thead>
            <tbody>
              <tr><td><strong>Tipo de acción</strong></td><td>Acción concreta, puntual, dinámica</td><td>Estado, sentimiento, descripción, hábito</td></tr>
              <tr><td><strong>Verbos típicos</strong></td><td>arrêter, construire, écrire, signer, publier, annoncer, prendre, envoyer</td><td>entourer, couvrir, remplir, aimer, respecter, admirer, accompagner, orner</td></tr>
              <tr><td><strong>Ejemplo</strong></td><td>arrêté <em>par</em> la police</td><td>aimé <em>de</em> tous</td></tr>
              <tr><td><strong>¿Intercambiable?</strong></td><td colspan="2">Con algunos verbos (fréquenter, connaître, suivre), ambos son aceptables. En examen, <em>par</em> siempre es seguro con verbos de acción.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ag">
            <div class="ex-fr">Ce roman est connu <span class="eag">de</span> / <span class="eag">par</span> tous les lycéens. <span class="ex-note">(ambos aceptables)</span></div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">La ville est entourée <span class="eag">de</span> forêts. <span class="ex-note">(solo de — estado permanente)</span></div>
          </div>
          <div class="example-block ag">
            <div class="ex-fr">Le suspect a été interpellé <span class="eag">par</span> les forces de l'ordre. <span class="ex-note">(solo par — acción concreta)</span></div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-alternatives">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El francés dispone de varias alternativas al pasivo que son más naturales en ciertos contextos. Reconocerlas en comprensión es esencial; usarlas en producción demuestra dominio del idioma.
      </div>

      <div class="chip-bar">
        <button class="chip al active" onclick="selectChip('alt',0)">On + verbe actif</button>
        <button class="chip al"        onclick="selectChip('alt',1)">Pronominal de valor pasivo</button>
        <button class="chip al"        onclick="selectChip('alt',2)">Se faire + infinitif</button>
        <button class="chip al"        onclick="selectChip('alt',3)">Tableau comparatif</button>
      </div>
      <div id="alt-panels">

        <div class="chip-panel active" id="alt-p-0">
          <div class="def-box"><strong>On + verbe actif</strong> es la alternativa más frecuente al pasivo cuando el agente es indeterminado. Equivale exactamente al pasivo sin agente y es más natural en oral y en producción escrita.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Voix passive (sans agent)</th><th>On + actif</th></tr></thead>
            <tbody>
              <tr><td>Un pont <span class="hl-pa">a été construit</span> ici.</td><td><span class="hl-al">On</span> a construit un pont ici.</td></tr>
              <tr><td>Le français <span class="hl-pa">est parlé</span> dans 29 pays.</td><td><span class="hl-al">On</span> parle français dans 29 pays.</td></tr>
              <tr><td>La réunion <span class="hl-pa">a été annulée</span>.</td><td><span class="hl-al">On</span> a annulé la réunion.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block al">
            <div class="ex-fr"><span class="eal">On</span> a découvert un nouveau traitement contre cette maladie.</div>
            <div class="ex-es">Se ha descubierto un nuevo tratamiento para esta enfermedad.</div>
            <div class="ex-note">= Un nouveau traitement a été découvert…</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr"><span class="eal">On</span> parle beaucoup de ce sujet en ce moment.</div>
            <div class="ex-es">Se habla mucho de este tema en este momento.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr"><span class="eal">On</span> m'a dit que la réunion était annulée.</div>
            <div class="ex-es">Me dijeron que la reunión estaba cancelada.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">En France, <span class="eal">on</span> mange beaucoup de fromage.</div>
            <div class="ex-es">En Francia, se come mucho queso.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr"><span class="eal">On</span> a finalement trouvé une solution à ce problème.</div>
            <div class="ex-es">Por fin se encontró una solución a este problema.</div>
          </div>
        </div>

        <div class="chip-panel" id="alt-p-1">
          <div class="def-box">El <strong>pronominal de valor pasivo</strong> (se + verbe transitif) expresa que algo "se hace" sin mencionar el agente. Solo con objetos inanimados. El verbo concuerda con el sujeto gramatical.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Pasivo</th><th>Pronominal pasivo</th></tr></thead>
            <tbody>
              <tr><td>Ce vin est bu frais.</td><td>Ce vin <span class="hl-al">se boit</span> frais.</td></tr>
              <tr><td>Ces livres sont vendus partout.</td><td>Ces livres <span class="hl-al">se vendent</span> partout.</td></tr>
              <tr><td>Cette expression est utilisée à l'écrit.</td><td>Cette expression <span class="hl-al">s'utilise</span> à l'écrit.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block al">
            <div class="ex-fr">Ce mot <span class="eal">ne s'emploie</span> plus de nos jours.</div>
            <div class="ex-es">Esta palabra ya no se usa hoy en día.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Les billets <span class="eal">se réservent</span> en ligne.</div>
            <div class="ex-es">Los billetes se reservan en línea.</div>
            <div class="ex-note">billets = pl. → se réservent (concuerda)</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Ça <span class="eal">se voit</span> facilement.</div>
            <div class="ex-es">Eso se nota fácilmente.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Ce plat <span class="eal">se mange</span> chaud.</div>
            <div class="ex-es">Este plato se come caliente.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Ces expressions <span class="eal">s'utilisent</span> surtout à l'oral.</div>
            <div class="ex-es">Estas expresiones se usan sobre todo en oral.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Solo con objetos <strong>inanimados</strong>. No: <em>Les enfants se grondent par leurs parents</em> ✗. El verbo concuerda con el sujeto: <em>Ces livres se <strong>vendent</strong></em> (pl.) ✓ — <em>se vend</em> ✗.</div></div>
        </div>

        <div class="chip-panel" id="alt-p-2">
          <div class="def-box"><strong>Se faire + infinitif</strong> expresa que el sujeto es el receptor de una acción realizada por otro. El participio de <em>faire</em> es siempre <strong>invariable</strong>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Pasivo</th><th>Se faire + inf.</th></tr></thead>
            <tbody>
              <tr><td>Elle a été opérée.</td><td>Elle <span class="hl-al">s'est fait opérer</span>.</td></tr>
              <tr><td>Il a été licencié.</td><td>Il <span class="hl-al">s'est fait licencier</span>.</td></tr>
              <tr><td>Ils ont été punis.</td><td>Ils <span class="hl-al">se sont fait punir</span>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block al">
            <div class="ex-fr">Elle <span class="eal">s'est fait</span> couper les cheveux.</div>
            <div class="ex-es">Se cortó el pelo (se lo cortaron).</div>
            <div class="ex-note">fait invariable ✓ — pas faite</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Il <span class="eal">s'est fait</span> voler son portefeuille dans le métro.</div>
            <div class="ex-es">Le robaron la cartera en el metro.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Ils <span class="eal">se sont fait</span> renvoyer à cause de leur comportement.</div>
            <div class="ex-es">Los despidieron por su comportamiento.</div>
            <div class="ex-note">fait invariable ✓ — pas faits</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Je <span class="eal">me suis fait</span> attendre une heure à la banque.</div>
            <div class="ex-es">Me hicieron esperar una hora en el banco.</div>
          </div>
          <div class="example-block al">
            <div class="ex-fr">Elle <span class="eal">s'est fait</span> remarquer par son discours brillant.</div>
            <div class="ex-es">Se hizo notar con su brillante discurso.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Fait</em> causatif/passif est toujours <strong>invariable</strong>: <em>Elle s'est <strong>fait</strong> opérer</em> ✓ — <em>faite opérer</em> ✗. <em>Ils se sont <strong>fait</strong> renvoyer</em> ✓ — <em>faits renvoyer</em> ✗.</div></div>
        </div>

        <div class="chip-panel" id="alt-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Structure</th><th>Agente</th><th>Contexto</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-pa">Être + p.p.</strong></td><td>Conocido (par/de) u omitido</td><td>Formal, periodístico, escrito</td><td><em>La loi a été votée.</em></td></tr>
              <tr><td><strong class="hl-al">On + actif</strong></td><td>Indeterminado</td><td>Neutro, oral y escrito</td><td><em>On a voté la loi.</em></td></tr>
              <tr><td><strong class="hl-al">Se + verbe</strong></td><td>Indeterminado</td><td>Hábito, uso general, inanimado</td><td><em>Ça se dit / ça se fait.</em></td></tr>
              <tr><td><strong class="hl-al">Se faire + inf.</strong></td><td>Otro (implícito)</td><td>Neutro — sujeto recibe la acción</td><td><em>Il s'est fait renvoyer.</em></td></tr>
            </tbody>
          </table></div>
          <div class="green-box"><strong>Para el DELF B1:</strong> reconocer el pasivo en comprensión lectora es la prioridad. En producción, usar <em>on</em> cuando el pasivo sin agente resulta más natural, y el pasivo formal cuando el texto lo requiera (carta de reclamación, narración de hechos).</div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>
</div>
<div class="panel" id="panel-ex">
  <div class="exercise-controls">
    <h3>Generar ejercicios</h3>
    <span class="ctrl-label">Tipo</span>
    <div class="ex-options">
      <button class="ex-opt-btn active" data-type="fill">Completar huecos</button>
      <button class="ex-opt-btn" data-type="choice">Elección múltiple</button>
      <button class="ex-opt-btn" data-type="transform">Transformación</button>
      <button class="ex-opt-btn" data-type="mix">Mixto</button>
    </div>
    <span class="ctrl-label">Foco</span>
    <div class="ex-options" id="foco-btns">
      <button class="ex-opt-btn foco active" data-foco="mix">General (todo)</button>
      <button class="ex-opt-btn foco" data-foco="formation">Formation (être + p.p. + accord)</button>
      <button class="ex-opt-btn foco" data-foco="temps">Todos los tiempos en pasivo</button>
      <button class="ex-opt-btn foco" data-foco="agent">Complément d'agent (par / de)</button>
      <button class="ex-opt-btn foco" data-foco="actif_passif">Actif → Passif / Passif → Actif</button>
      <button class="ex-opt-btn foco" data-foco="alternatives">Alternatives au passif (on / se / se faire)</button>
    </div>
    <span class="ctrl-label">Nivel</span>
    <div class="row-btns" id="diff-btns">
      <button class="pill-btn diff A2" onclick="setDiff('A2')">A2</button>
      <button class="pill-btn diff B1 active" onclick="setDiff('B1')">B1</button>
      <button class="pill-btn diff B2" onclick="setDiff('B2')">B2</button>
    </div>
    <span class="ctrl-label">Cantidad</span>
    <div class="row-btns" id="qty-btns">
      <button class="pill-btn qty" onclick="setQty(3)">3</button>
      <button class="pill-btn qty active" onclick="setQty(5)">5</button>
      <button class="pill-btn qty" onclick="setQty(8)">8</button>
    </div>
    <button class="btn-generate" id="btn-gen" onclick="generateExercises()">
      <span class="btn-icon">✨</span>
      <span class="spinner">⟳</span>
      Generar ejercicios
    </button>
  </div>
  <div class="progress-wrap" id="progress-wrap">
    <div class="progress-top">
      <span class="progress-label">Progreso</span>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="progress-frac" id="progress-frac">0 / 0</span>
        <button class="btn-retry" onclick="resetExercises()">↺ Nuevo</button>
      </div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="progress-score">
      <div class="score-item"><div class="score-dot g"></div><span id="score-correct">0 correctas</span></div>
      <div class="score-item"><div class="score-dot r"></div><span id="score-wrong">0 errores</span></div>
    </div>
  </div>
  <div class="final-score-bar" id="final-score-bar">
    <div><div class="final-num" id="final-num">—</div><div class="final-label">resultado final</div></div>
    <div class="final-track"><div class="final-fill" id="final-fill" style="width:0%"></div></div>
    <div class="final-msg" id="final-msg"></div>
  </div>
  <div class="exercise-area" id="exercise-area">
    <div class="state-msg">
      <div class="state-icon">✏️</div>
      <p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p>
    </div>
  </div>
</div>
</div>
<script>
const TRAPS = [
  {name:"Accord du participe passé avec être au passif",
   wrong:"La loi a été voté. / Les décisions ont été pris.",
   right:"La loi a été votée. / Les décisions ont été prises.",
   expl:"Al pasivo, el participio concuerda siempre con el <strong>sujeto gramatical</strong> (que era el COD en la voz activa). <em>La loi</em> (fém. sing.) → <em>votée</em>. <em>Les décisions</em> (fém. pl.) → <em>prises</em>. Es el mismo principio que el acuerdo con être en los tiempos compuestos."},
  {name:"Confundir être + p.p. pasivo con être + p.p. de estado",
   wrong:"La porte est fermée par le vent. (ambiguo — acción o estado?)",
   right:"La porte est fermée par le vent. (acción pasiva) / La porte est fermée. (état résultant — sin agente)",
   expl:"<em>La porte est fermée</em> puede ser (1) pasivo de acción si hay complemento de agente (<em>par quelqu'un</em>), o (2) un estado resultante sin agente. En el pasivo de acción, alguien realizó la acción. En el estado, describe simplemente la situación actual. Distinguir por contexto y presencia del agente."},
  {name:"Par vs. de con el complemento de agente",
   wrong:"La ville est entourée par des montagnes. / Il est aimé par tout le monde.",
   right:"La ville est entourée de montagnes. / Il est aimé de tout le monde.",
   expl:"Con verbos que expresan <strong>estado, sentimiento o situación permanente</strong> (entourer, aimer, couvrir, remplir, orner, respecter…), se usa <strong>de</strong>. Con verbos de acción concreta → <strong>par</strong>. La distinción acción/estado determina la preposición."},
  {name:"Solo los verbos transitivos directos forman el pasivo",
   wrong:"Il est obéi par ses enfants. / Elle est téléphoné par son ami.",
   right:"Ses enfants lui obéissent. / Son ami lui téléphone.",
   expl:"Solo los verbos <strong>transitifs directs</strong> (con COD) pueden formar el pasivo. <em>Obéir à</em> y <em>téléphoner à</em> son transitifs indirects (COI) → no pueden pasivizarse. El COI no puede convertirse en sujeto del pasivo."},
  {name:"On como alternativa: confundir con il y a",
   wrong:"Il y a construit un pont ici. / Il y a vendu beaucoup de produits.",
   right:"On a construit un pont ici. / On a vendu beaucoup de produits.",
   expl:"Para evitar el pasivo cuando el agente es indeterminado, se usa <strong>on</strong> + verbo activo, no <em>il y a</em>. <em>On a construit un pont</em> = <em>Un pont a été construit</em>. <em>Il y a</em> es une locution existencielle, no una alternativa al pasivo."},
  {name:"Se faire + infinitif: orden de los elementos",
   wrong:"Elle s'est fait opérée. / Ils se sont faits renvoyer.",
   right:"Elle s'est fait opérer. / Ils se sont fait renvoyer.",
   expl:"En la estructura <strong>se faire + infinitif</strong>, el participio de <em>faire</em> es <strong>invariable</strong> (fait, jamás faite/faits/faites). <em>Elle s'est <strong>fait</strong> opérer</em> ✓. El infinitivo que sigue tampoco concuerda. Es la misma regla que <em>faire</em> causatif."},
  {name:"Pasivo en temps composés: doble auxiliaire",
   wrong:"La lettre a été envoyée par lui hier. (correcto, pero confusión con) La lettre était envoyée hier.",
   right:"La lettre a été envoyée hier. (passé composé passif — acción) / La lettre était envoyée. (imparfait — état)",
   expl:"En temps composés, el pasivo requiere <strong>avoir + été + p.p.</strong>: <em>La lettre <strong>a été</strong> envoyée</em>. No confundir con el imparfait pasivo (<em>était envoyée</em>) que describe un estado. El error es usar <em>était</em> cuando se quiere expresar una acción puntual pasada."},
  {name:"Pronominal de valor pasivo: olvidar el acuerdo",
   wrong:"Les livres se vend bien. / Cette expression s'utilise beaucoup.",
   right:"Les livres se vendent bien. / Cette expression s'utilise beaucoup.",
   expl:"Con el pronominal de valor pasivo (<em>se vendre, s'utiliser, se dire…</em>), el verbo concuerda con el <strong>sujeto gramatical</strong>: <em>Les livres se <strong>vendent</strong></em> (pl.) ✓. El sujeto no es <em>on</em> sino el sustantivo, y el verbo concuerda normalmente con él."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c, i) => c.classList.toggle("active", i === idx));
    }
  });
  const el = document.getElementById(ns + "-panels");
  if (el) el.querySelectorAll(":scope > .chip-panel").forEach((p, i) => p.classList.toggle("active", i === idx));
}
function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

let exType="fill", exDiff="B1", exQty=5, exFoco="mix";
let exTotal=0, exAnswered=0, exCorrect=0, exWrong=0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));
function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active","A2","B1","B2");
    if (b.textContent.trim()===d) b.classList.add("active",d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim())===q));
}

const FOCO_DESC = {
  mix:          "todos los aspectos de la voix passive: formación (être + p.p. con acuerdo), todos los tiempos verbales, complément d'agent (par vs. de), transformación actif→passif y passif→actif, alternativas (on, pronominal de valor pasivo, se faire + inf.)",
  formation:    "formación del pasivo: être conjugado + participio pasado que concuerda con el sujeto; el alumno escribe la forma correcta del participio con el acuerdo de género y número",
  temps:        "pasivo en todos los tiempos: présent (est fait), passé composé (a été fait), imparfait (était fait), futur simple (sera fait), conditionnel présent (serait fait), subjonctif présent (soit fait); el alumno conjuga être en el tiempo indicado",
  agent:        "complément d'agent: par (acción concreta) vs. de (estado, sentimiento, situation permanente); ejemplos: être entouré de / être aimé de / être respecté de vs. être arrêté par / être construit par",
  actif_passif: "transformación actif→passif y passif→actif: cambio de sujeto/COD, conjugación de être, acuerdo del p.p., presencia o ausencia del agente; incluir todos los tiempos",
  alternatives: "alternativas al pasivo: on + actif (indéfini), pronominal de valor pasivo (se vendre, s'utiliser, se dire — acuerdo con sujeto), se faire + infinitif (invariable), se laisser + inf.",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe la forma correcta del passif (être conjugado + p.p. acordado), la preposición del agente, o la forma alternativa",
  choice:    "elección múltiple: 4 opciones de formas del passif o preposiciones, solo una correcta según el tiempo, el sujeto y el tipo de verbo",
  transform: "transformación: pasar de actif a passif o viceversa, con la forma correcta del p.p. y el agente si procede",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS={
  "s-intro":"Panorama","s-formation":"Formation","s-temps":"Tous les temps",
  "s-agent":"Complément d'agent","s-alternatives":"Alternatives au passif","s-trampas":"Trampas"
};

function renderExercises(exs) {
  const area=document.getElementById("exercise-area");
  const labels={fill:"Completar",choice:"Elección múltiple",transform:"Transformación"};
  area.innerHTML=exs.map((ex,i)=>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex,i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex,i)=>{
    const chk=document.getElementById("chk-"+i);
    if(chk) chk.addEventListener("click",()=>checkAnswer(ex,i));
    const inp=document.getElementById("inp-"+i);
    if(inp) inp.addEventListener("keydown",e=>{if(e.key==="Enter") checkAnswer(ex,i);});
  });
}

function buildBody(ex,i) {
  if(ex.type==="fill"){
    const parts=ex.prompt_parts||["",""];
    return `<div class="exercise-prompt">${parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||"…"}" autocomplete="off" spellcheck="false">${parts.slice(1).join("")}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  }
  if(ex.type==="choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if(ex.type==="transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase en voz pasiva…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex,i) {
  const inp=document.getElementById("inp-"+i);
  if(!inp||inp.disabled) return;
  const ok=inp.value.trim().toLowerCase()===ex.answer.trim().toLowerCase();
  inp.classList.add(ok?"ok":"err"); inp.disabled=true;
  const chk=document.getElementById("chk-"+i); if(chk) chk.disabled=true;
  showFeedback(i,ok,ex.answer,ex.explanation,ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx,chosen,correct) {
  const c0=document.getElementById(`ch-${idx}-0`);
  if(!c0||c0.disabled) return;
  for(let j=0;j<4;j++){
    const b=document.getElementById(`ch-${idx}-${j}`);
    if(!b) continue; b.disabled=true;
    if(j===correct) b.classList.add("ok"); else if(j===chosen) b.classList.add("err");
  }
  const card=document.getElementById("ex-card-"+idx);
  showFeedback(idx,chosen===correct,null,card.dataset.expl,card.dataset.rule);
  recordAnswer(chosen===correct);
}

function showFeedback(i,ok,ans,expl,ruleRef) {
  document.getElementById("ex-st-"+i).textContent=ok?"✅":"❌";
  const fb=document.getElementById("ex-fb-"+i);
  fb.className="ex-feedback visible "+(ok?"ok":"err");
  const link=RULE_LABELS[ruleRef]?`<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>`:"";
  let html=ok?`<strong>✓ Correcto</strong>`:`<strong>✗ Incorrecto</strong>${ans?` — Respuesta: <strong>${ans}</strong>`:""}`;
  if(expl) html+=`<br><span style="font-size:.88em;opacity:.92;margin-top:3px;display:block">${expl}</span>`;
  html+=link; fb.innerHTML=html;
}

function goToRule(ref) {
  switchMode("ref",document.querySelector(".mode-btn"));
  setTimeout(()=>{
    showSection(ref,document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:"smooth",block:"start"});
  },80);
}

function recordAnswer(ok){exAnswered++;if(ok)exCorrect++;else exWrong++;updateProgress();}

function updateProgress(){
  const pct=exTotal>0?(exAnswered/exTotal)*100:0;
  document.getElementById("progress-frac").textContent=`${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width=pct+"%";
  document.getElementById("score-correct").textContent=`${exCorrect} correcta${exCorrect!==1?"s":""}`;
  document.getElementById("score-wrong").textContent=`${exWrong} error${exWrong!==1?"es":""}`;
  if(exAnswered>=exTotal&&exTotal>0) showFinalScore();
}

function showFinalScore(){
  const pct=Math.round((exCorrect/exTotal)*100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent=`${exCorrect} / ${exTotal}`;
  const fill=document.getElementById("final-fill");
  fill.style.width=pct+"%";
  fill.style.background=pct>=80?"var(--green)":pct>=50?"var(--accent)":"var(--red)";
  const msgs={100:"Parfait ! Dominas la voz pasiva. 🎉",80:"Très bien ! Repasa los errores.",50:"Bien, refuerza los bloques señalados.",0:"Vuelve a Referencia antes de repetir."};
  document.getElementById("final-msg").textContent=msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById("score-pill").style.display="";
  document.getElementById("score-pill-val").textContent=`${exCorrect}/${exTotal}`;
}

function resetExercises(){
  document.getElementById("exercise-area").innerHTML=`<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display="none";
  exAnswered=0;exCorrect=0;exWrong=0;
}

function esc(s){return(s||"").replace(/"/g,"&quot;").replace(/</g,"&lt;");}

renderTraps();
</script>
</body>
</html>
