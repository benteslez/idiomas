<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · La Mise en Relief</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ede9df; --card:#faf7f1; --border:#c4bead;
  --text:#1a1814; --text2:#44413a; --text3:#706c64;
  --accent:#7a5a0a; --accent-light:#f0e0c0; --accent-mid:#b89050;
  --warn-bg:#fdf0cc;
  --shadow:0 2px 14px rgba(0,0,0,.11),0 1px 4px rgba(0,0,0,.06);
  --shadow-sm:0 1px 6px rgba(0,0,0,.08);
  --radius:14px; --radius-sm:8px;
  --green:#1a6028; --green-bg:#e4f2e8;
  --red:#a81e2e;   --red-bg:#fce6e8;
  --blue:#163494;  --blue-bg:#e6ebf8;
  --purple:#6a1a8a; --purple-bg:#f2e6f8;
  /* mise en relief colours */
  --ce-color:#163494; --ce-bg:#e6ebf8;   /* c'est…qui/que — blue   */
  --qu-color:#1a6028; --qu-bg:#e4f2e8;   /* quant à / pour — green */
  --pr-color:#6a1a8a; --pr-bg:#f2e6f8;   /* pronoms disjoints — purple */
  --au-color:#8b1a4a; --au-bg:#f8e6ee;   /* autres structures — wine */
  --fs:15px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:var(--fs);}

.site-header{background:var(--card);border-bottom:2px solid var(--border);padding:20px 20px 14px;}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px;flex-wrap:wrap;}
.site-header h1{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,5vw,1.9rem);font-weight:700;}
.header-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-mid);border-radius:20px;padding:3px 10px;}
.subtitle{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.stats-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;}
.stat-pill{border-radius:20px;padding:4px 11px;font-size:.76rem;font-weight:600;border:1px solid;}
.stat-pill.ce{background:var(--ce-bg);color:var(--ce-color);border-color:var(--ce-color);}
.stat-pill.qu{background:var(--qu-bg);color:var(--qu-color);border-color:var(--qu-color);}
.stat-pill.pr{background:var(--pr-bg);color:var(--pr-color);border-color:var(--pr-color);}
.stat-pill.au{background:var(--au-bg);color:var(--au-color);border-color:var(--au-color);}
.stat-pill.neu{background:var(--bg);color:var(--text2);border-color:var(--border);font-weight:500;}
.fs-wrap{display:flex;align-items:center;gap:7px;margin-left:auto;}
.fs-slider{width:76px;accent-color:var(--accent);cursor:pointer;}
.fs-sz{color:var(--text3);font-weight:700;}

.mode-toggle{display:flex;border-bottom:2px solid var(--border);background:var(--card);}
.mode-btn{flex:1;padding:12px 8px;font-family:'DM Sans',sans-serif;font-size:.84rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.mode-btn.active{color:var(--accent);border-bottom-color:var(--accent);}

.section-nav{position:sticky;top:0;z-index:200;background:var(--card);border-bottom:2px solid var(--border);box-shadow:var(--shadow-sm);}
.section-nav-inner{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.section-nav-inner::-webkit-scrollbar{display:none;}
.snav-btn{flex-shrink:0;padding:11px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;}
.snav-btn:hover{color:var(--text2);}
.snav-btn.active{color:var(--accent);border-bottom-color:var(--accent);}

.main-layout{max-width:860px;margin:0 auto;padding:16px 16px 40px;}
.panel{display:none;} .panel.active{display:block;}
.sec-block{display:none;} .sec-block.active{display:block;}
.gram-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:14px;overflow:hidden;}
.gram-card-body{padding:18px;}

.def-box{background:var(--warn-bg);border-left:4px solid var(--accent);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:12px 15px;margin-bottom:14px;line-height:1.65;}
.def-box strong{color:var(--accent);font-weight:700;}
.warn-box{background:#fff4e0;border:1px solid #c8900a;border-radius:var(--radius-sm);padding:10px 13px;margin:10px 0;font-size:.9em;display:flex;gap:8px;align-items:flex-start;}
.warn-icon{flex-shrink:0;margin-top:1px;}
.warn-text{color:var(--text2);line-height:1.55;}
.warn-text strong{color:#7a4400;font-weight:700;}
.note-box{background:var(--purple-bg);border-left:4px solid var(--purple);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.note-box strong{color:var(--purple);font-weight:700;}
.green-box{background:var(--green-bg);border-left:4px solid var(--green);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.green-box strong{color:var(--green);font-weight:700;}

.example-block{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:8px 0;}
.example-block.ce{background:var(--ce-bg);border-left:4px solid var(--ce-color);}
.example-block.qu{background:var(--qu-bg);border-left:4px solid var(--qu-color);}
.example-block.pr{background:var(--pr-bg);border-left:4px solid var(--pr-color);}
.example-block.au{background:var(--au-bg);border-left:4px solid var(--au-color);}
.example-block.neu{background:var(--blue-bg);border-left:4px solid var(--blue);}
.ex-fr{font-weight:600;margin-bottom:3px;color:var(--text);}
.ece{color:var(--ce-color);font-weight:700;}
.equ{color:var(--qu-color);font-weight:700;}
.epr{color:var(--pr-color);font-weight:700;}
.eau{color:var(--au-color);font-weight:700;}
.ex-es{color:var(--text2);font-size:.88em;font-style:italic;}
.ex-note{font-size:.78em;color:var(--text3);margin-top:3px;font-weight:500;}

.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:14px;border-radius:var(--radius-sm);border:1px solid var(--border);}
.gram-table{width:100%;border-collapse:collapse;min-width:280px;}
.gram-table th{background:var(--bg);border-bottom:2px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;text-align:left;font-size:.72em;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.gram-table td{border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;vertical-align:top;}
.gram-table tr:last-child td{border-bottom:none;}
.gram-table tr:nth-child(even) td{background:#f4f0e6;}
.gram-table td:last-child,.gram-table th:last-child{border-right:none;}
.hl-ce{color:var(--ce-color);font-weight:700;}
.hl-qu{color:var(--qu-color);font-weight:700;}
.hl-pr{color:var(--pr-color);font-weight:700;}
.hl-au{color:var(--au-color);font-weight:700;}
.hl{color:var(--accent);font-weight:700;}
.dim{color:var(--text3);font-size:.88em;}
.ok-cell{color:var(--green);font-weight:700;}
.err-cell{color:var(--red);font-weight:600;font-style:italic;}

.chip-bar{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.chip{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;white-space:nowrap;}
.chip:hover{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.chip.ce.active{background:var(--ce-color);border-color:var(--ce-color);}
.chip.qu.active{background:var(--qu-color);border-color:var(--qu-color);}
.chip.pr.active{background:var(--pr-color);border-color:var(--pr-color);}
.chip.au.active{background:var(--au-color);border-color:var(--au-color);}
.chip-panel{display:none;} .chip-panel.active{display:block;}
.sec-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px;}

.trap-cards{display:flex;flex-direction:column;gap:10px;}
.trap-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.trap-card-header{padding:11px 14px;background:var(--bg);}
.trap-name{font-weight:700;font-size:.9em;color:var(--text);margin-bottom:7px;}
.trap-vs{display:flex;gap:8px;flex-wrap:wrap;}
.trap-wrong{background:var(--red-bg);border:1.5px solid #d09098;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--red);font-weight:500;}
.trap-right{background:var(--green-bg);border:1.5px solid #80b890;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--green);font-weight:500;}
.trap-expl{padding:10px 14px 12px;font-size:.86em;color:var(--text2);line-height:1.6;border-top:1px solid var(--border);background:var(--card);}
.trap-expl strong{color:var(--text);font-weight:700;}

.exercise-controls{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:var(--shadow-sm);}
.exercise-controls h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:14px;}
.ctrl-label{font-size:.7em;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:7px;display:block;}
.ex-options{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ex-opt-btn{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.ex-opt-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.row-btns{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.pill-btn{border:1.5px solid var(--border);border-radius:20px;padding:5px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.pill-btn:hover:not(.active){background:var(--border);}
.pill-btn.active{background:var(--text);color:var(--bg);border-color:var(--text);}
.pill-btn.diff.active.A2{background:var(--green);border-color:var(--green);color:#fff;}
.pill-btn.diff.active.B1{background:var(--blue);border-color:var(--blue);color:#fff;}
.pill-btn.diff.active.B2{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-generate{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:.92em;font-weight:700;cursor:pointer;background:var(--accent);color:white;transition:all .18s;margin-top:4px;}
.btn-generate:hover:not(:disabled){filter:brightness(1.1);box-shadow:0 4px 14px rgba(122,90,10,.32);}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;}
.spinner{display:none;animation:spin .8s linear infinite;}
.btn-generate.loading .spinner{display:inline;}
.btn-generate.loading .btn-icon{display:none;}
@keyframes spin{to{transform:rotate(360deg);}}
.progress-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:14px;display:none;}
.progress-wrap.visible{display:block;}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-size:.78em;color:var(--text3);font-weight:600;}
.progress-frac{font-size:.92em;font-weight:700;color:var(--accent);}
.progress-track{height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .35s ease;}
.progress-score{display:flex;gap:14px;margin-top:9px;font-size:.8em;flex-wrap:wrap;align-items:center;}
.score-item{display:flex;align-items:center;gap:5px;font-weight:500;color:var(--text2);}
.score-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.score-dot.g{background:var(--green);} .score-dot.r{background:var(--red);}
.btn-retry{border:1.5px solid var(--border);border-radius:20px;padding:5px 13px;font-family:'DM Sans',sans-serif;font-size:.78em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;margin-left:auto;}
.btn-retry:hover{background:var(--border);}
.final-score-bar{display:none;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;}
.final-score-bar.visible{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.final-num{font-size:1.5rem;font-weight:700;color:var(--accent);}
.final-label{font-size:.74em;color:var(--text3);}
.final-track{flex:1;min-width:80px;height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.final-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.final-msg{font-size:.84em;color:var(--text2);width:100%;font-weight:500;}
.exercise-area{display:none;} .exercise-area.visible{display:block;}
.exercise-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;}
.exercise-card-header{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg);border-bottom:1px solid var(--border);}
.ex-num{font-weight:700;color:var(--accent);font-size:.88em;}
.ex-type-badge{font-size:.68em;font-weight:700;letter-spacing:.07em;text-transform:uppercase;background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-mid);border-radius:12px;padding:2px 8px;}
.ex-diff-badge{font-size:.68em;font-weight:700;border-radius:12px;padding:2px 8px;}
.ex-diff-badge.A2{background:var(--green-bg);color:var(--green);border:1px solid #80b890;}
.ex-diff-badge.B1{background:var(--blue-bg);color:var(--blue);border:1px solid #90a8e0;}
.ex-diff-badge.B2{background:var(--warn-bg);color:var(--accent);border:1px solid var(--accent-mid);}
.ex-status{margin-left:auto;}
.exercise-body{padding:16px 18px;}
.exercise-prompt{line-height:1.7;margin-bottom:12px;color:var(--text);}
.exercise-prompt em{color:var(--accent);font-style:italic;font-weight:600;}
.fill-input{border:none;border-bottom:2px solid var(--accent-mid);background:var(--accent-light);padding:2px 8px;border-radius:4px 4px 0 0;font-family:'DM Sans',sans-serif;font-size:1em;color:var(--text);min-width:150px;outline:none;transition:border-color .15s;}
.fill-input:focus{border-bottom-color:var(--accent);}
.fill-input.ok{background:var(--green-bg);border-bottom-color:var(--green);}
.fill-input.err{background:var(--red-bg);border-bottom-color:var(--red);}
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.choice-btn{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.88em;font-weight:500;cursor:pointer;text-align:left;background:var(--bg);color:var(--text);transition:all .15s;}
.choice-btn:hover:not(:disabled){border-color:var(--accent);background:var(--accent-light);}
.choice-btn.ok{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:700;}
.choice-btn.err{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.choice-btn:disabled{cursor:default;}
.transform-input{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.9em;background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;transition:border-color .15s;}
.transform-input:focus{border-color:var(--accent);}
.transform-input.ok{background:var(--green-bg);border-color:var(--green);}
.transform-input.err{background:var(--red-bg);border-color:var(--red);}
.btn-check{border:1.5px solid var(--accent);border-radius:20px;padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:700;cursor:pointer;background:transparent;color:var(--accent);transition:all .15s;}
.btn-check:hover:not(:disabled){background:var(--accent);color:white;}
.btn-check:disabled{opacity:.35;cursor:default;}
.ex-feedback{display:none;border-radius:var(--radius-sm);padding:11px 14px;line-height:1.55;margin-top:10px;font-size:.9em;}
.ex-feedback.visible{display:block;}
.ex-feedback.ok{background:var(--green-bg);border:1.5px solid #80b890;color:#0e4818;}
.ex-feedback.err{background:var(--red-bg);border:1.5px solid #c08090;color:#700018;}
.fb-rule-link{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:.84em;font-weight:700;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;}
.skeleton-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:12px;}
.skel{background:linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.4s infinite;border-radius:4px;height:13px;margin-bottom:9px;}
@keyframes skel{to{background-position:-200% 0;}}
.state-msg{text-align:center;padding:40px 20px;color:var(--text3);}
.state-icon{font-size:2rem;margin-bottom:10px;}
.state-msg p{max-width:260px;margin:0 auto;line-height:1.6;font-weight:500;}
</style>
</head>
<body>

<header class="site-header">
  <div class="header-top">
    <h1>La Mise en Relief</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill ce">C'est… qui / que</div>
    <div class="stat-pill qu">Quant à / Pour</div>
    <div class="stat-pill pr">Pronoms disjoints</div>
    <div class="stat-pill au">Autres structures</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>

<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>

<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-cest',this)">2. C'est… qui / que</button>
    <button class="snav-btn"        onclick="showSection('s-dont',this)">3. C'est… dont / où</button>
    <button class="snav-btn"        onclick="showSection('s-quant',this)">4. Quant à / Pour ce qui est</button>
    <button class="snav-btn"        onclick="showSection('s-disjoints',this)">5. Pronoms disjoints</button>
    <button class="snav-btn"        onclick="showSection('s-autres',this)">6. Autres structures</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">7. Trampas</button>
  </div>
</div>

<div class="main-layout">
<div class="panel active" id="panel-ref">

  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La <strong>mise en relief</strong> permite destacar un elemento de la frase — sujeto, COD, complemento de tiempo, lugar o manera — dándole un énfasis especial. En francés, este énfasis no se expresa solo con entonación sino con <strong>estructuras gramaticales específicas</strong>. Son imprescindibles para la producción escrita B1–B2.
      </div>

      <div class="sec-label">Inventario de estructuras</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Estructura</th><th>Qué destaca</th><th>Ejemplo</th></tr></thead>
        <tbody>
          <tr><td><strong class="hl-ce">C'est… qui</strong></td><td>Sujeto</td><td><em>C'est lui <strong>qui</strong> a décidé.</em></td></tr>
          <tr><td><strong class="hl-ce">C'est… que</strong></td><td>COD, temps, lieu, manière</td><td><em>C'est ce livre <strong>que</strong> j'ai lu.</em></td></tr>
          <tr><td><strong class="hl-ce">C'est… dont</strong></td><td>Complément en <em>de</em></td><td><em>C'est ce dont j'ai besoin.</em></td></tr>
          <tr><td><strong class="hl-ce">C'est… où</strong></td><td>Lieu (avec verbe de mouvement)</td><td><em>C'est là où je suis né.</em></td></tr>
          <tr><td><strong class="hl-qu">Ce qui… c'est</strong></td><td>Sujeto (nominalizado)</td><td><em>Ce qui m'intéresse, c'est la musique.</em></td></tr>
          <tr><td><strong class="hl-qu">Ce que… c'est</strong></td><td>COD (nominalizado)</td><td><em>Ce que je veux, c'est partir.</em></td></tr>
          <tr><td><strong class="hl-qu">Quant à</strong></td><td>Tema nuevo / cambio de perspectiva</td><td><em>Quant à moi, je préfère rester.</em></td></tr>
          <tr><td><strong class="hl-qu">Pour ce qui est de</strong></td><td>Tema específico (formal)</td><td><em>Pour ce qui est du budget, c'est réglé.</em></td></tr>
          <tr><td><strong class="hl-pr">Moi, je…</strong></td><td>Sujeto (pronom disjoint)</td><td><em>Moi, je pense que c'est faux.</em></td></tr>
          <tr><td><strong class="hl-au">Il s'agit de</strong></td><td>Tema / asunto (impersonal)</td><td><em>Il s'agit d'un problème grave.</em></td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Regla fundamental — qui vs. que</div>
      <div class="green-box">
        <strong>Prueba diagnóstica:</strong> sustituye el elemento destacado en la frase original.<br>
        → Si ocupa el lugar del <strong>sujeto</strong> → <strong>c'est… qui</strong><br>
        → Si ocupa el lugar del <strong>COD o complemento</strong> → <strong>c'est… que</strong><br><br>
        <em>Paul a fait ça.</em> → destacar Paul (sujeto) → <em>C'est Paul <strong>qui</strong> a fait ça.</em><br>
        <em>J'ai lu ce livre.</em> → destacar ce livre (COD) → <em>C'est ce livre <strong>que</strong> j'ai lu.</em>
      </div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Para el DELF escrito B2:</strong> usar la mise en relief demuestra dominio del registro. Un texto que varía entre frases neutras y estructuras enfáticas obtiene mejor nota en cohésion et cohérence. Evitar repetir siempre la misma estructura.</div>
      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-cest">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La estructura <strong>c'est… qui / que</strong> es la mise en relief más frecuente y más examinada. <em>Qui</em> cuando el elemento destacado es <strong>sujeto</strong>; <em>que</em> cuando es <strong>COD o complemento</strong>. El verbo tras <em>qui</em> concuerda con el elemento destacado, no con <em>c'est</em>.
      </div>

      <div class="chip-bar">
        <button class="chip ce active" onclick="selectChip('cqq',0)">C'est… qui — sujeto</button>
        <button class="chip ce"        onclick="selectChip('cqq',1)">C'est… que — COD</button>
        <button class="chip ce"        onclick="selectChip('cqq',2)">C'est… que — temps / lieu / manière</button>
        <button class="chip ce"        onclick="selectChip('cqq',3)">Concordancia verbal tras qui</button>
        <button class="chip ce"        onclick="selectChip('cqq',4)">C'est vs. Ce sont (plural)</button>
      </div>
      <div id="cqq-panels">

        <div class="chip-panel active" id="cqq-p-0">
          <div class="def-box">El elemento destacado es el <strong>sujeto</strong> del verbo que sigue a <em>qui</em>. La frase entre <em>c'est</em> y <em>qui</em> contiene el elemento que se quiere enfatizar.</div>
          <div class="example-block ce">
            <div class="ex-fr">Paul a décidé. → <span class="ece">C'est</span> Paul <span class="ece">qui</span> a décidé.</div>
            <div class="ex-es">Es Paul quien decidió.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> elle <span class="ece">qui</span> gère tout dans cette maison.</div>
            <div class="ex-es">Es ella quien lo gestiona todo en esta casa.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> le manque de communication <span class="ece">qui</span> pose problème.</div>
            <div class="ex-es">Es la falta de comunicación lo que plantea el problema.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> toi <span class="ece">qui</span> as eu cette idée en premier.</div>
            <div class="ex-es">Eres tú quien tuvo esa idea primero.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> la confiance <span class="ece">qui</span> manque dans cette équipe.</div>
            <div class="ex-es">Es la confianza lo que falta en este equipo.</div>
          </div>
        </div>

        <div class="chip-panel" id="cqq-p-1">
          <div class="def-box">El elemento destacado es el <strong>COD</strong> del verbo de la frase. Tras <em>que</em>, el sujeto y el verbo aparecen en orden normal.</div>
          <div class="example-block ce">
            <div class="ex-fr">J'ai lu ce livre. → <span class="ece">C'est</span> ce livre <span class="ece">que</span> j'ai lu.</div>
            <div class="ex-es">Es este libro el que he leído.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> la vérité <span class="ece">qu'</span>il faut dire.</div>
            <div class="ex-es">Es la verdad lo que hay que decir.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> ce poste <span class="ece">que</span> je veux obtenir.</div>
            <div class="ex-es">Es este puesto el que quiero conseguir.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> lui <span class="ece">que</span> j'ai vu hier au marché.</div>
            <div class="ex-es">Es a él a quien vi ayer en el mercado.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> cette décision <span class="ece">qu'</span>ils regrettent le plus.</div>
            <div class="ex-es">Es esa decisión la que más lamentan.</div>
          </div>
        </div>

        <div class="chip-panel" id="cqq-p-2">
          <div class="def-box"><em>Que</em> también se usa para destacar complementos de <strong>tiempo</strong>, <strong>lugar</strong> o <strong>manera</strong> — nunca <em>qui</em> en estos casos.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Tipo de complemento</th><th>Ejemplo destacado</th></tr></thead>
            <tbody>
              <tr><td><strong>Temps</strong></td><td>C'est <em>hier</em> <span class="hl-ce">que</span> je l'ai vu.</td></tr>
              <tr><td><strong>Lieu</strong></td><td>C'est <em>ici</em> <span class="hl-ce">que</span> tout a commencé.</td></tr>
              <tr><td><strong>Manière</strong></td><td>C'est <em>ainsi</em> <span class="hl-ce">que</span> les choses fonctionnent.</td></tr>
              <tr><td><strong>Cause</strong></td><td>C'est <em>pour ça</em> <span class="hl-ce">que</span> je suis venu.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> demain <span class="ece">que</span> tout va changer.</div>
            <div class="ex-es">Es mañana cuando todo va a cambiar.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> dans ce quartier <span class="ece">que</span> j'ai grandi.</div>
            <div class="ex-es">Es en este barrio donde crecí.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> pour cette raison <span class="ece">que</span> nous avons refusé.</div>
            <div class="ex-es">Es por esta razón por lo que rechazamos.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> ainsi <span class="ece">que</span> les grandes décisions se prennent.</div>
            <div class="ex-es">Es así como se toman las grandes decisiones.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Con complementos de tiempo, lugar y manera: siempre <strong>que</strong>, nunca <em>qui</em>. <em>C'est hier qui je l'ai vu</em> ✗ — <em>C'est hier <strong>que</strong> je l'ai vu</em> ✓.</div></div>
        </div>

        <div class="chip-panel" id="cqq-p-3">
          <div class="def-box">El verbo después de <em>qui</em> concuerda con el <strong>elemento destacado</strong>, no con <em>c'est</em>. Esta es la regla más incumplida.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Elemento destacado</th><th>Verbo tras qui</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong>moi</strong></td><td>1ª pers. sing.</td><td>C'est moi qui <span class="hl-ce">suis</span> responsable.</td></tr>
              <tr><td><strong>toi</strong></td><td>2ª pers. sing.</td><td>C'est toi qui <span class="hl-ce">as</span> tort.</td></tr>
              <tr><td><strong>lui / elle</strong></td><td>3ª pers. sing.</td><td>C'est lui qui <span class="hl-ce">a</span> décidé.</td></tr>
              <tr><td><strong>nous</strong></td><td>1ª pers. pl.</td><td>C'est nous qui <span class="hl-ce">avons</span> gagné.</td></tr>
              <tr><td><strong>vous</strong></td><td>2ª pers. pl.</td><td>C'est vous qui <span class="hl-ce">avez</span> choisi.</td></tr>
              <tr><td><strong>eux / elles</strong></td><td>3ª pers. pl.</td><td>C'est eux qui <span class="hl-ce">ont</span> organisé.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est moi</span> <span class="ece">qui</span> <span class="ece">suis</span> arrivé le premier.</div>
            <div class="ex-es">Soy yo quien llegó primero.</div>
            <div class="ex-note">moi → suis (1ª persona), no est</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est vous</span> <span class="ece">qui</span> <span class="ece">avez</span> pris cette décision, pas moi.</div>
            <div class="ex-es">Sois vosotros quienes tomasteis esa decisión, no yo.</div>
            <div class="ex-note">vous → avez (2ª pl.), no a</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>C'est moi qui <strong>est</strong> responsable</em> ✗ — <em>C'est moi qui <strong>suis</strong> responsable</em> ✓. El error más frecuente en el DELF: usar siempre <em>est</em> sin respetar la concordancia.</div></div>
        </div>

        <div class="chip-panel" id="cqq-p-4">
          <div class="def-box">Cuando el elemento destacado es <strong>plural</strong>, se usa <em>ce sont</em> en lugar de <em>c'est</em> en el escrito formal.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Singular → C'est</th><th>Plural → Ce sont</th></tr></thead>
            <tbody>
              <tr><td>C'est <em>lui</em> qui a décidé.</td><td><span class="hl-ce">Ce sont</span> <em>eux</em> qui ont décidé.</td></tr>
              <tr><td>C'est <em>mon ami</em> qui m'a aidé.</td><td><span class="hl-ce">Ce sont</span> <em>mes amis</em> qui m'ont aidé.</td></tr>
              <tr><td>C'est <em>cette raison</em> qui compte.</td><td><span class="hl-ce">Ce sont</span> <em>ces raisons</em> qui comptent.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce sont</span> les employés <span class="ece">qui</span> ont organisé la grève.</div>
            <div class="ex-es">Son los empleados quienes organizaron la huelga.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce sont</span> ces petits détails <span class="ece">qui</span> font la différence.</div>
            <div class="ex-es">Son estos pequeños detalles los que marcan la diferencia.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce sont</span> elles <span class="ece">qui</span> ont pris les meilleures décisions.</div>
            <div class="ex-es">Son ellas quienes tomaron las mejores decisiones.</div>
          </div>
          <div class="note-box"><strong>En oral coloquial</strong> se acepta <em>c'est</em> incluso con plural. En el escrito formal del DELF B2, se prefiere <em>ce sont</em>.</div>
        </div>

      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-dont">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Cuando el elemento destacado es un complemento introducido por <strong>de</strong> se usa <em>c'est… dont</em>. Cuando es un complemento de <strong>lugar con verbo de movimiento o ubicación</strong> se usa <em>c'est… où</em>. Ambas son menos frecuentes que <em>qui/que</em> pero aparecen en comprensión lectora B2.
      </div>

      <div class="chip-bar">
        <button class="chip ce active" onclick="selectChip('dou',0)">C'est… dont</button>
        <button class="chip ce"        onclick="selectChip('dou',1)">C'est… où</button>
        <button class="chip ce"        onclick="selectChip('dou',2)">Ce qui / ce que / ce dont / ce à quoi</button>
      </div>
      <div id="dou-panels">

        <div class="chip-panel active" id="dou-p-0">
          <div class="def-box"><em>Dont</em> sustituye a un complemento introducido por <em>de</em>: <em>avoir besoin de, parler de, se souvenir de, avoir peur de, être fier de…</em></div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Frase neutra</th><th>Con mise en relief</th></tr></thead>
            <tbody>
              <tr><td>J'ai besoin <em>de ce livre</em>.</td><td>C'est <em>ce livre</em> <span class="hl-ce">dont</span> j'ai besoin.</td></tr>
              <tr><td>Elle parle <em>de ce sujet</em>.</td><td>C'est <em>ce sujet</em> <span class="hl-ce">dont</span> elle parle.</td></tr>
              <tr><td>Il a peur <em>de l'échec</em>.</td><td>C'est <em>l'échec</em> <span class="hl-ce">dont</span> il a peur.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> exactement <span class="ece">ce dont</span> j'avais besoin.</div>
            <div class="ex-es">Es exactamente lo que necesitaba.</div>
            <div class="ex-note">avoir besoin de → dont</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> la liberté <span class="ece">dont</span> ils rêvaient depuis des années.</div>
            <div class="ex-es">Es la libertad con la que soñaban desde hace años.</div>
            <div class="ex-note">rêver de → dont</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> ce projet <span class="ece">dont</span> tout le monde parle en ce moment.</div>
            <div class="ex-es">Es ese proyecto del que todo el mundo habla ahora mismo.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> la confiance <span class="ece">dont</span> cette équipe a le plus besoin.</div>
            <div class="ex-es">Es la confianza lo que más necesita este equipo.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> de cela <span class="ece">dont</span> il faut se souvenir.</div>
            <div class="ex-es">Es de eso de lo que hay que acordarse.</div>
          </div>
        </div>

        <div class="chip-panel" id="dou-p-1">
          <div class="def-box"><em>Où</em> se usa para destacar un complemento de lugar, especialmente con verbos de movimiento (<em>aller, venir, partir, passer</em>) o de situación (<em>habiter, travailler, naître</em>).</div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> là <span class="ece">où</span> je suis né.</div>
            <div class="ex-es">Es allí donde nací.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> dans cette ville <span class="ece">où</span> tout a commencé pour moi.</div>
            <div class="ex-es">Es en esta ciudad donde todo empezó para mí.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> le quartier <span class="ece">où</span> j'ai grandi et que je ne pourrai jamais oublier.</div>
            <div class="ex-es">Es el barrio donde crecí y que nunca podré olvidar.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">C'est</span> ici <span class="ece">où</span> les grandes décisions se prennent.</div>
            <div class="ex-es">Es aquí donde se toman las grandes decisiones.</div>
          </div>
          <div class="note-box"><strong>Où vs. que con lieu:</strong> <em>c'est ici <strong>que</strong></em> y <em>c'est ici <strong>où</strong></em> son ambas aceptadas para destacar un lugar. <em>Que</em> es más frecuente y neutro; <em>où</em> insiste en el carácter locativo.</div>
        </div>

        <div class="chip-panel" id="dou-p-2">
          <div class="def-box">Las estructuras <strong>ce qui / ce que / ce dont</strong> nominalizan una proposición entera y la destacan como sujeto o complemento. Son muy frecuentes en producción escrita B2.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Estructura</th><th>Función de lo destacado</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-ce">Ce qui</strong>… c'est</td><td>Sujeto de la proposición</td><td><em>Ce qui m'étonne, c'est son silence.</em></td></tr>
              <tr><td><strong class="hl-ce">Ce que</strong>… c'est</td><td>COD de la proposición</td><td><em>Ce que je veux, c'est partir.</em></td></tr>
              <tr><td><strong class="hl-ce">Ce dont</strong>… c'est</td><td>Complemento en <em>de</em></td><td><em>Ce dont j'ai besoin, c'est du temps.</em></td></tr>
              <tr><td><strong class="hl-ce">Ce à quoi</strong>… c'est</td><td>Complemento en <em>à</em></td><td><em>Ce à quoi je pense, c'est l'avenir.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce qui</span> m'intéresse le plus, <span class="ece">c'est</span> la littérature contemporaine.</div>
            <div class="ex-es">Lo que más me interesa es la literatura contemporánea.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce que</span> je trouve remarquable, <span class="ece">c'est</span> sa capacité d'adaptation.</div>
            <div class="ex-es">Lo que encuentro notable es su capacidad de adaptación.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce dont</span> cette société a besoin, <span class="ece">c'est</span> d'un vrai débat démocratique.</div>
            <div class="ex-es">Lo que esta sociedad necesita es un verdadero debate democrático.</div>
          </div>
          <div class="example-block ce">
            <div class="ex-fr"><span class="ece">Ce à quoi</span> je tiens le plus, <span class="ece">c'est</span> l'honnêteté.</div>
            <div class="ex-es">A lo que más le doy importancia es a la honestidad.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Tras <em>ce que… c'est que</em> cuando se expresa un deseo o expectativa → <strong>subjonctif</strong>: <em>Ce que je veux, c'est que tu <strong>viennes</strong></em> ✓ — <em>que tu viens</em> ✗.</div></div>
        </div>

      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-quant">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong>Quant à</strong>, <strong>pour ce qui est de</strong> y <strong>en ce qui concerne</strong> sirven para introducir un tema, cambiar de perspectiva o retomar un elemento ya mencionado. Son estructuras muy valoradas en producción escrita B1–B2 porque organizan el discurso y demuestran dominio del registro formal.
      </div>

      <div class="chip-bar">
        <button class="chip qu active" onclick="selectChip('qua',0)">Quant à</button>
        <button class="chip qu"        onclick="selectChip('qua',1)">Pour ce qui est de</button>
        <button class="chip qu"        onclick="selectChip('qua',2)">En ce qui concerne</button>
        <button class="chip qu"        onclick="selectChip('qua',3)">Comparativa de las tres</button>
      </div>
      <div id="qua-panels">

        <div class="chip-panel active" id="qua-p-0">
          <div class="def-box"><em>Quant à</em> va siempre seguido de un <strong>sustantivo o pronom disjoint</strong>, nunca de un verbo conjugado. Equivale a "en cuanto a, por lo que respecta a".</div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Quant à</span> moi, je préfère rester à la maison.</div>
            <div class="ex-es">En cuanto a mí, prefiero quedarme en casa.</div>
            <div class="ex-note">quant à + pronom disjoint</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Il a accepté la proposition. <span class="equ">Quant à</span> elle, elle hésite encore.</div>
            <div class="ex-es">Él ha aceptado la propuesta. En cuanto a ella, todavía duda.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Quant à</span> l'avenir du projet, il reste incertain.</div>
            <div class="ex-es">En cuanto al futuro del proyecto, sigue siendo incierto.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr">Les résultats sont bons. <span class="equ">Quant au</span> budget, des ajustements sont nécessaires.</div>
            <div class="ex-es">Los resultados son buenos. En cuanto al presupuesto, son necesarios ajustes.</div>
            <div class="ex-note">quant à + le → quant au</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Quant aux</span> autres participants, ils seront informés demain.</div>
            <div class="ex-es">En cuanto a los demás participantes, serán informados mañana.</div>
            <div class="ex-note">quant à + les → quant aux</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Quant à no va seguido de verbo conjugado:</strong> <em>Quant à il viendra</em> ✗ — <em>Quant à lui, il viendra</em> ✓. Si necesitas introducir una proposición completa → usa <em>en ce qui concerne</em> o <em>pour ce qui est de</em>.</div></div>
        </div>

        <div class="chip-panel" id="qua-p-1">
          <div class="def-box"><em>Pour ce qui est de</em> va seguido de un <strong>sustantivo o infinitivo</strong>. Más específico que <em>quant à</em> — introduce un aspecto concreto de un tema.</div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est de</span> l'organisation, tout est réglé.</div>
            <div class="ex-es">Por lo que respecta a la organización, todo está resuelto.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est de</span> trouver une solution, c'est plus compliqué.</div>
            <div class="ex-es">Por lo que respecta a encontrar una solución, es más complicado.</div>
            <div class="ex-note">pour ce qui est de + infinitif</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est du</span> financement, nous attendons la réponse de la mairie.</div>
            <div class="ex-es">Por lo que respecta a la financiación, esperamos la respuesta del ayuntamiento.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est des</span> délais, il faudra négocier.</div>
            <div class="ex-es">Por lo que respecta a los plazos, habrá que negociar.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est de</span> ma décision finale, je vous en informerai demain.</div>
            <div class="ex-es">Por lo que respecta a mi decisión final, os lo comunicaré mañana.</div>
          </div>
        </div>

        <div class="chip-panel" id="qua-p-2">
          <div class="def-box"><em>En ce qui concerne</em> va seguido de un <strong>sustantivo</strong>. Es la más formal de las tres y la más frecuente en textos administrativos y académicos.</div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui concerne</span> le budget, des économies sont indispensables.</div>
            <div class="ex-es">En lo que respecta al presupuesto, los ahorros son indispensables.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui concerne</span> votre candidature, nous vous répondrons sous quinze jours.</div>
            <div class="ex-es">En lo que respecta a su candidatura, le responderemos en quince días.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui concerne</span> les mesures environnementales, des progrès restent à faire.</div>
            <div class="ex-es">En lo que respecta a las medidas medioambientales, aún queda camino por recorrer.</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui me concerne</span>, je suis tout à fait d'accord avec cette analyse.</div>
            <div class="ex-es">Por lo que a mí respecta, estoy completamente de acuerdo con ese análisis.</div>
            <div class="ex-note">en ce qui + pronom COI + concerne → muy frecuente</div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui te concerne</span>, tu devras faire des efforts supplémentaires.</div>
            <div class="ex-es">Por lo que a ti respecta, tendrás que hacer esfuerzos adicionales.</div>
          </div>
        </div>

        <div class="chip-panel" id="qua-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-qu">Quant à</th><th class="hl-qu">Pour ce qui est de</th><th class="hl-qu">En ce qui concerne</th></tr></thead>
            <tbody>
              <tr><td><strong>Registro</strong></td><td>neutro / formal</td><td>formal</td><td>muy formal / admin.</td></tr>
              <tr><td><strong>Sigue de</strong></td><td>nom / pronom disjoint</td><td>nom / infinitif</td><td>nom (/ pronom COI)</td></tr>
              <tr><td><strong>Contracciones</strong></td><td>quant au / quant aux</td><td>pour ce qui est du/des</td><td>en ce qui concerne le/les</td></tr>
              <tr><td><strong>Con infinitivo</strong></td><td class="err-cell">✗</td><td class="ok-cell">✓</td><td class="err-cell">✗</td></tr>
              <tr><td><strong>Posición</strong></td><td>inicio de frase</td><td>inicio de frase</td><td>inicio de frase</td></tr>
            </tbody>
          </table></div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Quant à</span> lui, il ne viendra pas. <span class="ex-note">(pronom disjoint)</span></div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">Pour ce qui est de</span> résoudre ce problème, c'est une autre affaire. <span class="ex-note">(infinitif ✓)</span></div>
          </div>
          <div class="example-block qu">
            <div class="ex-fr"><span class="equ">En ce qui concerne</span> le financement, nous attendons l'accord. <span class="ex-note">(très formel)</span></div>
          </div>
          <div class="green-box"><strong>Consejo para el DELF escrito:</strong> usar las tres en un mismo texto demuestra variedad léxica. Evitar repetir siempre <em>quant à</em>. <em>En ce qui concerne</em> es ideal para cartas formales y ensayos; <em>quant à</em> para cambios de perspectiva personales.</div>
        </div>

      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-disjoints">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los <strong>pronoms disjoints</strong> (también llamados pronoms toniques) refuerzan o destacan el sujeto o complemento. Se usan para el énfasis, tras preposición, en respuestas cortas y en comparaciones. Son distintos de los pronoms sujets (je, tu, il…) y los pronoms COD/COI (me, te, le…).
      </div>

      <div class="sec-label">Tabla de pronoms disjoints</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Persona</th><th>Pronom disjoint</th><th>Ejemplo de refuerzo</th></tr></thead>
        <tbody>
          <tr><td>1ª sing.</td><td><strong class="hl-pr">moi</strong></td><td><em>Moi, je pense que c'est faux.</em></td></tr>
          <tr><td>2ª sing.</td><td><strong class="hl-pr">toi</strong></td><td><em>Toi, tu n'as rien dit.</em></td></tr>
          <tr><td>3ª sing. masc.</td><td><strong class="hl-pr">lui</strong></td><td><em>Lui, il sait toujours quoi faire.</em></td></tr>
          <tr><td>3ª sing. fém.</td><td><strong class="hl-pr">elle</strong></td><td><em>Elle, elle n'est jamais d'accord.</em></td></tr>
          <tr><td>1ª pl.</td><td><strong class="hl-pr">nous</strong></td><td><em>Nous, nous préférons attendre.</em></td></tr>
          <tr><td>2ª pl.</td><td><strong class="hl-pr">vous</strong></td><td><em>Vous, vous avez toujours raison.</em></td></tr>
          <tr><td>3ª pl. masc.</td><td><strong class="hl-pr">eux</strong></td><td><em>Eux, ils ont refusé de participer.</em></td></tr>
          <tr><td>3ª pl. fém.</td><td><strong class="hl-pr">elles</strong></td><td><em>Elles, elles ont tout organisé.</em></td></tr>
        </tbody>
      </table></div>

      <div class="chip-bar">
        <button class="chip pr active" onclick="selectChip('dis',0)">Renforcement du sujet (Moi, je…)</button>
        <button class="chip pr"        onclick="selectChip('dis',1)">Après préposition</button>
        <button class="chip pr"        onclick="selectChip('dis',2)">Réponses courtes et comparaisons</button>
        <button class="chip pr"        onclick="selectChip('dis',3)">Avec même / seul / aussi / non plus</button>
      </div>
      <div id="dis-panels">

        <div class="chip-panel active" id="dis-p-0">
          <div class="def-box">El pronom disjoint se coloca al inicio seguido de coma, y el pronom sujet normal acompaña al verbo. Sirve para contrastar o insistir.</div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Moi,</span> je pense qu'il faut agir maintenant.</div>
            <div class="ex-es">Yo, creo que hay que actuar ahora.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Lui,</span> il n'a jamais compris l'enjeu.</div>
            <div class="ex-es">Él nunca entendió lo que estaba en juego.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Nous,</span> nous avons toujours respecté les règles.</div>
            <div class="ex-es">Nosotros siempre hemos respetado las normas.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Toi,</span> tu aurais pu prévenir avant.</div>
            <div class="ex-es">Tú podrías haber avisado antes.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Eux,</span> ils ont pris la bonne décision au bon moment.</div>
            <div class="ex-es">Ellos tomaron la decisión correcta en el momento adecuado.</div>
          </div>
          <div class="note-box"><strong>Coma obligatoria:</strong> <em>Moi, je…</em> — la coma separa el pronom disjoint del resto de la frase. Sin coma suena incorrecto en el escrito.</div>
        </div>

        <div class="chip-panel" id="dis-p-1">
          <div class="def-box">Tras una preposición (<em>pour, avec, sans, chez, contre, entre, selon, d'après…</em>) se usa siempre el pronom disjoint, nunca el pronom sujet.</div>
          <div class="example-block pr">
            <div class="ex-fr">Ce cadeau est <span class="epr">pour toi</span>.</div>
            <div class="ex-es">Este regalo es para ti.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Il est parti sans <span class="epr">elle</span>.</div>
            <div class="ex-es">Se fue sin ella.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Je suis complètement d'accord avec <span class="epr">vous</span>.</div>
            <div class="ex-es">Estoy completamente de acuerdo con usted.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Entre <span class="epr">toi</span> et <span class="epr">moi</span>, il y a un malentendu.</div>
            <div class="ex-es">Entre tú y yo hay un malentendido.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Selon <span class="epr">eux</span>, la situation s'améliore.</div>
            <div class="ex-es">Según ellos, la situación mejora.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Nunca pronom sujet tras preposición: <em>pour il</em> ✗, <em>avec je</em> ✗, <em>sans tu</em> ✗. Siempre disjoint: <em>pour lui</em> ✓, <em>avec moi</em> ✓, <em>sans toi</em> ✓.</div></div>
        </div>

        <div class="chip-panel" id="dis-p-2">
          <div class="def-box">En respuestas cortas sin verbo y en comparaciones con <em>que</em> se usa el pronom disjoint.</div>
          <div class="sec-label">Réponses courtes</div>
          <div class="example-block pr">
            <div class="ex-fr">— Qui a fait ça ? — <span class="epr">Moi</span>. / <span class="epr">Lui</span>. / Pas <span class="epr">moi</span>.</div>
            <div class="ex-es">— ¿Quién hizo eso? — Yo. / Él. / Yo no.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">— Tu as faim ? — <span class="epr">Moi</span>, oui. <span class="epr">Elle</span>, non.</div>
            <div class="ex-es">— ¿Tienes hambre? — Yo sí. Ella no.</div>
          </div>
          <div class="sec-label">Comparaisons</div>
          <div class="example-block pr">
            <div class="ex-fr">Il travaille autant que <span class="epr">moi</span>.</div>
            <div class="ex-es">Trabaja tanto como yo.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Elle est plus compétente que <span class="epr">lui</span>.</div>
            <div class="ex-es">Ella es más competente que él.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Nous avons les mêmes droits qu'<span class="epr">eux</span>.</div>
            <div class="ex-es">Tenemos los mismos derechos que ellos.</div>
          </div>
        </div>

        <div class="chip-panel" id="dis-p-3">
          <div class="def-box">Los pronoms disjoints se combinan con <em>même, seul, aussi, non plus</em> para añadir énfasis adicional.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Combinación</th><th>Significado</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-pr">moi-même</strong></td><td>yo mismo/a</td><td>Je l'ai fait <em>moi-même</em>.</td></tr>
              <tr><td><strong class="hl-pr">toi seul(e)</strong></td><td>solo tú</td><td><em>Toi seul</em> peux comprendre.</td></tr>
              <tr><td><strong class="hl-pr">lui aussi</strong></td><td>él también</td><td><em>Lui aussi</em> veut partir.</td></tr>
              <tr><td><strong class="hl-pr">elle non plus</strong></td><td>ella tampoco</td><td><em>Elle non plus</em> n'est pas venue.</td></tr>
              <tr><td><strong class="hl-pr">eux-mêmes</strong></td><td>ellos mismos</td><td>Ils l'ont reconnu <em>eux-mêmes</em>.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block pr">
            <div class="ex-fr">J'ai réparé la voiture <span class="epr">moi-même</span> sans l'aide de personne.</div>
            <div class="ex-es">Reparé el coche yo mismo sin ayuda de nadie.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr"><span class="epr">Toi seul</span> sais ce qui s'est vraiment passé ce soir-là.</div>
            <div class="ex-es">Solo tú sabes lo que pasó realmente aquella noche.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Je ne suis pas d'accord — <span class="epr">elle non plus</span>.</div>
            <div class="ex-es">No estoy de acuerdo — ella tampoco.</div>
          </div>
          <div class="example-block pr">
            <div class="ex-fr">Ils ont admis <span class="epr">eux-mêmes</span> que le projet avait échoué.</div>
            <div class="ex-es">Ellos mismos admitieron que el proyecto había fracasado.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-autres">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Otras estructuras de énfasis menos centrales pero muy presentes en textos auténticos y en producción escrita B2: <strong>il s'agit de</strong>, la <strong>dislocation</strong> (reprise par pronom) y estructuras con <em>c'est que</em> causal.
      </div>

      <div class="chip-bar">
        <button class="chip au active" onclick="selectChip('aut',0)">Il s'agit de</button>
        <button class="chip au"        onclick="selectChip('aut',1)">Dislocation (reprise par pronom)</button>
        <button class="chip au"        onclick="selectChip('aut',2)">C'est que… (valeur causale)</button>
        <button class="chip au"        onclick="selectChip('aut',3)">Tableau récapitulatif</button>
      </div>
      <div id="aut-panels">

        <div class="chip-panel active" id="aut-p-0">
          <div class="def-box"><strong>Il s'agit de</strong> es una construcción impersonal que presenta o define el tema sin destacar un sujeto personal. Equivale a "se trata de". Va seguido de sustantivo o infinitivo — nunca de adjetivo solo ni de pronom personnel.</div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Il s'agit de</span> trouver une solution rapidement.</div>
            <div class="ex-es">Se trata de encontrar una solución rápidamente.</div>
            <div class="ex-note">il s'agit de + infinitif</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Il s'agit d'</span>un problème qui touche toute la société.</div>
            <div class="ex-es">Se trata de un problema que afecta a toda la sociedad.</div>
            <div class="ex-note">il s'agit de + nom</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Dans ce roman, <span class="eau">il s'agit de</span> la quête identitaire d'un jeune immigrant.</div>
            <div class="ex-es">En esta novela, se trata de la búsqueda de identidad de un joven inmigrante.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Il ne s'agit pas de</span> critiquer mais de proposer des alternatives.</div>
            <div class="ex-es">No se trata de criticar sino de proponer alternativas.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Attention : <span class="eau">il s'agit de</span> votre avenir professionnel.</div>
            <div class="ex-es">Atención: se trata de vuestro futuro profesional.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>Il s'agit de</em> nunca va seguido de pronom personnel: <em>il s'agit de lui</em> ✓ (pronom disjoint) pero para destacar una persona se prefiere <em>c'est lui dont il s'agit</em> o simplemente <em>c'est lui</em>. <em>Il s'agit d'elle</em> ✓ (pronom disjoint = ella = la persona mencionada).</div></div>
        </div>

        <div class="chip-panel" id="aut-p-1">
          <div class="def-box">La <strong>dislocation</strong> consiste en extraer un elemento fuera de su posición normal y retomarlo con un pronom. Es muy frecuente en oral y aparece en textos informales o literarios.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Tipo</th><th>Estructura</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td><strong>Dislocation à gauche</strong></td><td>Élément, pronom + verbe</td><td><em>Ce film, je l'ai vu trois fois.</em></td></tr>
              <tr><td><strong>Dislocation à droite</strong></td><td>Pronom + verbe, élément</td><td><em>Je l'adore, ce film.</em></td></tr>
              <tr><td><strong>Sujet disloqué</strong></td><td>Nom, il/elle + verbe</td><td><em>Marie, elle ne vient pas.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Ce projet</span>, nous y avons consacré des années.</div>
            <div class="ex-es">Este proyecto, le hemos dedicado años.</div>
            <div class="ex-note">dislocation à gauche — élément destacado al inicio</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Je la trouve vraiment remarquable, <span class="eau">cette initiative</span>.</div>
            <div class="ex-es">La encuentro realmente notable, esta iniciativa.</div>
            <div class="ex-note">dislocation à droite — élément destacado al final</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Paul</span>, il ne dit jamais ce qu'il pense vraiment.</div>
            <div class="ex-es">Paul, nunca dice lo que realmente piensa.</div>
            <div class="ex-note">sujeto disloqué con reprise par il</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr"><span class="eau">Ses enfants</span>, elle leur a tout sacrifié.</div>
            <div class="ex-es">A sus hijos, les sacrificó todo.</div>
          </div>
          <div class="note-box"><strong>Registro:</strong> la dislocation es natural en oral y en textos informales. En producción escrita formal del DELF, preferir <em>c'est… qui/que</em>. Sin embargo, en producción oral B2 demuestra fluidez.</div>
        </div>

        <div class="chip-panel" id="aut-p-2">
          <div class="def-box"><strong>C'est que…</strong> con valor causal introduce la explicación de algo mencionado antes. Equivale a "es que / lo que pasa es que". Muy frecuente en oral y en textos argumentativos.</div>
          <div class="example-block au">
            <div class="ex-fr">Je ne peux pas venir ce soir. <span class="eau">C'est que</span> j'ai beaucoup de travail.</div>
            <div class="ex-es">No puedo venir esta noche. Es que tengo mucho trabajo.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Elle n'a pas répondu à ton message ? <span class="eau">C'est qu'</span>elle est très occupée en ce moment.</div>
            <div class="ex-es">¿No ha respondido a tu mensaje? Es que está muy ocupada ahora mismo.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">S'il refuse, <span class="eau">c'est qu'</span>il a ses raisons.</div>
            <div class="ex-es">Si rechaza, es porque tiene sus razones.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Ce n'est pas qu'il soit incompétent — <span class="eau">c'est qu'</span>il manque de motivation.</div>
            <div class="ex-es">No es que sea incompetente — es que le falta motivación.</div>
          </div>
          <div class="example-block au">
            <div class="ex-fr">Si ce projet a échoué, <span class="eau">c'est que</span> les bases n'étaient pas solides.</div>
            <div class="ex-es">Si este proyecto fracasó, es porque las bases no eran sólidas.</div>
          </div>
          <div class="note-box"><strong>C'est que causal vs. c'est… que de mise en relief:</strong> en la causal, <em>c'est que</em> introduce directamente la causa (sin elemento entre <em>c'est</em> y <em>que</em>). En la mise en relief, hay siempre un elemento destacado entre ambos: <em>C'est <strong>hier</strong> que je l'ai vu</em>.</div>
        </div>

        <div class="chip-panel" id="aut-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Estructura</th><th>Qué destaca</th><th>Modo / construcción</th><th>Registro</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-ce">C'est… qui</strong></td><td>Sujeto</td><td>verbo concuerda con destacado</td><td>neutro</td></tr>
              <tr><td><strong class="hl-ce">C'est… que</strong></td><td>COD, temps, lieu, manière</td><td>orden normal tras que</td><td>neutro</td></tr>
              <tr><td><strong class="hl-ce">C'est… dont</strong></td><td>Complément en de</td><td>verbo sin de</td><td>neutro</td></tr>
              <tr><td><strong class="hl-ce">Ce qui/que… c'est</strong></td><td>Proposición nominali­zada</td><td>c'est + nom / inf. / que+subj.</td><td>neutro/formal</td></tr>
              <tr><td><strong class="hl-qu">Quant à</strong></td><td>Tema nuevo</td><td>+ nom / pronom disjoint</td><td>neutro/formal</td></tr>
              <tr><td><strong class="hl-qu">Pour ce qui est de</strong></td><td>Aspecto concreto</td><td>+ nom / infinitif</td><td>formal</td></tr>
              <tr><td><strong class="hl-qu">En ce qui concerne</strong></td><td>Tema específico</td><td>+ nom</td><td>muy formal</td></tr>
              <tr><td><strong class="hl-pr">Moi, je…</strong></td><td>Sujeto personal</td><td>pronom disjoint + coma + sujet</td><td>oral/neutro</td></tr>
              <tr><td><strong class="hl-au">Il s'agit de</strong></td><td>Tema / asunto</td><td>+ nom / infinitif</td><td>neutro/formal</td></tr>
              <tr><td><strong class="hl-au">Dislocation</strong></td><td>Cualquier elemento</td><td>reprise par pronom</td><td>oral/informal</td></tr>
              <tr><td><strong class="hl-au">C'est que…</strong></td><td>Causa / explicación</td><td>c'est que + indicatif</td><td>oral/neutro</td></tr>
            </tbody>
          </table></div>
        </div>

      </div>
    </div></div>
  </div>

  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>

</div><!-- /panel-ref -->
</div><!-- /main-layout -->

<script>
const TRAPS = [
  {name:"C'est… qui vs. c'est… que: confundir sujeto y COD",
   wrong:"C'est lui que a fait ça. / C'est ce livre qui j'ai lu.",
   right:"C'est lui qui a fait ça. / C'est ce livre que j'ai lu.",
   expl:"<strong>Qui</strong> se usa cuando el elemento destacado es el <strong>sujeto</strong> del verbo que sigue. <strong>Que</strong> se usa cuando es el <strong>COD</strong> (o complemento no sujeto). Prueba: si puedes reemplazar por 'él hizo eso' → qui (sujeto). Si 'yo leí ese libro' → que (COD)."},
  {name:"Verbo en c'est… qui: concordancia con el elemento destacado",
   wrong:"C'est moi qui est responsable. / C'est vous qui a décidé.",
   right:"C'est moi qui suis responsable. / C'est vous qui avez décidé.",
   expl:"El verbo después de <em>qui</em> concuerda con el <strong>elemento destacado</strong>, no con <em>c'est</em>. <em>C'est moi</em> → verbo en 1ª persona: <em>qui <strong>suis</strong></em>. <em>C'est vous</em> → 2ª plural: <em>qui <strong>avez</strong></em>. <em>C'est lui/elle</em> → 3ª singular: <em>qui <strong>est</strong></em>."},
  {name:"Ce sont vs. c'est con plural",
   wrong:"C'est mes amis qui m'ont aidé. (cuando el destacado es plural)",
   right:"Ce sont mes amis qui m'ont aidé.",
   expl:"Cuando el elemento destacado es <strong>plural</strong>, se usa <em>ce sont</em> en lugar de <em>c'est</em>: <em><strong>Ce sont</strong> eux qui ont décidé</em> ✓. En oral coloquial se acepta <em>c'est</em> con plural, pero en el escrito formal del DELF se prefiere <em>ce sont</em>."},
  {name:"Quant à: confundir con quant à + verbe conjugué",
   wrong:"Quant à il viendra demain. / Quant à que tu décides.",
   right:"Quant à lui, il viendra demain. / Quant à ta décision, nous l'attendons.",
   expl:"<strong>Quant à</strong> va seguido de un <strong>sustantivo o pronom disjoint</strong>, nunca de un verbo conjugado ni de <em>que</em>. Para introducir una proposición → <em>en ce qui concerne + nom</em> o <em>pour ce qui est de + nom/inf.</em>."},
  {name:"Moi, je — pronom disjoint sin coma",
   wrong:"Moi je pense que c'est faux.",
   right:"Moi, je pense que c'est faux.",
   expl:"Cuando se usa el pronom disjoint al inicio para el énfasis (<em>Moi, je…</em>), va seguido de <strong>coma</strong>. Sin la coma, la frase suena incorrecta o demasiado coloquial en producción escrita."},
  {name:"C'est… que con complemento de temps/lieu: olvidar que",
   wrong:"C'est hier il est parti. / C'est ici nous nous sommes rencontrés.",
   right:"C'est hier qu'il est parti. / C'est ici que nous nous sommes rencontrés.",
   expl:"Con complementos de tiempo, lugar o manera, la estructura de mise en relief es <em>c'est + complément + <strong>que</strong> + phrase</em>. El <em>que</em> es obligatorio — no puede omitirse como en inglés (it's here we met ✗ en francés)."},
  {name:"Il s'agit de confundido con c'est",
   wrong:"Il s'agit de très important. / Il s'agit d'elle.",
   right:"Il s'agit d'un sujet très important. / C'est elle.",
   expl:"<strong>Il s'agit de</strong> siempre va seguido de un <strong>sustantivo o infinitivo</strong>, nunca de un adjetivo solo ni de un pronombre personal: <em>il s'agit <strong>d'un problème</strong></em> ✓ — <em>il s'agit important</em> ✗. Para destacar una persona → <em>c'est elle / c'est lui</em>."},
  {name:"Ce qui / ce que en proposición destacada",
   wrong:"Ce qui m'intéresse, c'est que tu réussis. / Ce que je veux, c'est qui tu viens.",
   right:"Ce qui m'intéresse, c'est que tu réussisses. / Ce que je veux, c'est que tu viennes.",
   expl:"En la estructura <em>ce qui/que…, c'est que + subjonctif</em>, la proposición tras <em>c'est que</em> requiere <strong>subjonctif</strong> cuando expresa un deseo o expectativa. <em>Ce que je veux, c'est que tu <strong>viennes</strong></em> ✓ — <em>que tu viens</em> ✗."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c, i) => c.classList.toggle("active", i === idx));
    }
  });
  const el = document.getElementById(ns + "-panels");
  if (el) el.querySelectorAll(":scope > .chip-panel").forEach((p, i) => p.classList.toggle("active", i === idx));
}

function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

let exType = "fill", exDiff = "B1", exQty = 5, exFoco = "mix";
let exTotal = 0, exAnswered = 0, exCorrect = 0, exWrong = 0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));
function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active","A2","B1","B2");
    if (b.textContent.trim() === d) b.classList.add("active", d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim()) === q));
}

const FOCO_DESC = {
  mix:        "todas las estructuras de mise en relief: c'est…qui (sujeto), c'est…que (COD, temps, lieu, manière), c'est…dont, c'est…où, quant à / pour ce qui est de + pronom disjoint o nom, pronoms disjoints de renforcement (moi je / lui il…), ce qui/ce que…c'est, il s'agit de",
  cest_qui:   "c'est…qui para destacar el sujeto: concordancia del verbo con el elemento destacado (c'est moi qui suis, c'est vous qui avez, c'est lui qui est), ce sont con plural, transformación de frases normales a c'est…qui",
  cest_que:   "c'est…que para destacar el COD, complementos de tiempo, lugar y manera: c'est hier que, c'est là que, c'est ainsi que; distinción qui vs. que según la función del elemento destacado",
  quant:      "quant à / pour ce qui est de / en ce qui concerne: siempre seguidos de sustantivo o pronom disjoint (nunca verbo conjugado); uso para introducir un nuevo tema o cambiar de perspectiva en producción escrita",
  disjoints:  "pronoms disjoints de renforcement: moi je, toi tu, lui il, elle elle, nous nous, vous vous, eux ils, elles elles; uso con coma; uso tras preposición; uso en respuestas cortas; combinación con même (moi-même)",
  autres:     "otras estructuras: ce qui/ce que m'intéresse c'est…, il s'agit de + nom/inf., c'est…qui/que con tous/seul/même, structures emphatiques avec c'est que (causal), inversión expresiva",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe qui/que/dont/où o la estructura completa según la función del elemento destacado",
  choice:    "elección múltiple: 4 opciones de estructuras o pronombres, solo una correcta según la función sintáctica del elemento destacado",
  transform: "transformación: reescribir la frase neutra usando la estructura de mise en relief indicada, con concordancia correcta del verbo",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS = {
  "s-intro":"Panorama","s-cest":"C'est… qui / que","s-dont":"C'est… dont / où",
  "s-quant":"Quant à / Pour ce qui est","s-disjoints":"Pronoms disjoints",
  "s-autres":"Autres structures","s-trampas":"Trampas"
};

function renderExercises(exs) {
  const area = document.getElementById("exercise-area");
  const labels = {fill:"Completar", choice:"Elección múltiple", transform:"Transformación"};
  area.innerHTML = exs.map((ex, i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex, i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex, i) => {
    const chk = document.getElementById("chk-"+i);
    if (chk) chk.addEventListener("click", () => checkAnswer(ex, i));
    const inp = document.getElementById("inp-"+i);
    if (inp) inp.addEventListener("keydown", e => { if (e.key==="Enter") checkAnswer(ex, i); });
  });
}

function buildBody(ex, i) {
  if (ex.type === "fill") {
    const parts = ex.prompt_parts || ["",""];
    return `<div class="exercise-prompt">${parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||"…"}" autocomplete="off" spellcheck="false">${parts.slice(1).join("")}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  }
  if (ex.type === "choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if (ex.type === "transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase con mise en relief…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex, i) {
  const inp = document.getElementById("inp-"+i);
  if (!inp || inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok?"ok":"err"); inp.disabled = true;
  const chk = document.getElementById("chk-"+i); if (chk) chk.disabled = true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0 || c0.disabled) return;
  for (let j=0;j<4;j++) {
    const b = document.getElementById(`ch-${idx}-${j}`);
    if (!b) continue; b.disabled = true;
    if (j===correct) b.classList.add("ok"); else if (j===chosen) b.classList.add("err");
  }
  const card = document.getElementById("ex-card-"+idx);
  showFeedback(idx, chosen===correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen===correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById("ex-st-"+i).textContent = ok?"✅":"❌";
  const fb = document.getElementById("ex-fb-"+i);
  fb.className = "ex-feedback visible "+(ok?"ok":"err");
  const link = RULE_LABELS[ruleRef] ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : "";
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans ? ` — Respuesta: <strong>${ans}</strong>` : ""}`;
  if (expl) html += `<br><span style="font-size:.88em;opacity:.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML = html;
}

function goToRule(ref) {
  switchMode("ref", document.querySelector(".mode-btn"));
  setTimeout(() => {
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:"smooth", block:"start"});
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if(ok) exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal>0 ? (exAnswered/exTotal)*100 : 0;
  document.getElementById("progress-frac").textContent = `${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width = pct+"%";
  document.getElementById("score-correct").textContent = `${exCorrect} correcta${exCorrect!==1?"s":""}`;
  document.getElementById("score-wrong").textContent = `${exWrong} error${exWrong!==1?"es":""}`;
  if (exAnswered>=exTotal && exTotal>0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect/exTotal)*100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent = `${exCorrect} / ${exTotal}`;
  const fill = document.getElementById("final-fill");
  fill.style.width = pct+"%";
  fill.style.background = pct>=80?"var(--green)":pct>=50?"var(--accent)":"var(--red)";
  const msgs = {100:"Parfait ! Dominas la mise en relief. 🎉",80:"Très bien ! Repasa los errores.",50:"Bien, refuerza los bloques señalados.",0:"Vuelve a Referencia antes de repetir."};
  document.getElementById("final-msg").textContent = msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById("score-pill").style.display = "";
  document.getElementById("score-pill-val").textContent = `${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById("exercise-area").innerHTML = `<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display = "none";
  exAnswered = 0; exCorrect = 0; exWrong = 0;
}

function esc(s) { return (s||"").replace(/"/g,"&quot;").replace(/</g,"&lt;"); }

renderTraps();
</script>
</body>
</html>
