<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Le Gérondif et le Participe Présent</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ede9df; --card:#faf7f1; --border:#c4bead;
  --text:#1a1814; --text2:#44413a; --text3:#706c64;
  --accent:#7a5a0a; --accent-light:#f0e0c0; --accent-mid:#b89050;
  --warn-bg:#fdf0cc;
  --shadow:0 2px 14px rgba(0,0,0,.11),0 1px 4px rgba(0,0,0,.06);
  --shadow-sm:0 1px 6px rgba(0,0,0,.08);
  --radius:14px; --radius-sm:8px;
  --green:#1a6028; --green-bg:#e4f2e8;
  --red:#a81e2e;   --red-bg:#fce6e8;
  --blue:#163494;  --blue-bg:#e6ebf8;
  --purple:#6a1a8a; --purple-bg:#f2e6f8;
  --ge-color:#163494; --ge-bg:#e6ebf8;
  --pp-color:#1a6028; --pp-bg:#e4f2e8;
  --us-color:#6a1a8a; --us-bg:#f2e6f8;
  --di-color:#8b1a4a; --di-bg:#f8e6ee;
  --fs:15px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:var(--fs);}
.site-header{background:var(--card);border-bottom:2px solid var(--border);padding:20px 20px 14px;}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px;flex-wrap:wrap;}
.site-header h1{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,5vw,1.9rem);font-weight:700;}
.header-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-mid);border-radius:20px;padding:3px 10px;}
.subtitle{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.stats-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;}
.stat-pill{border-radius:20px;padding:4px 11px;font-size:.76rem;font-weight:600;border:1px solid;}
.stat-pill.ge{background:var(--ge-bg);color:var(--ge-color);border-color:var(--ge-color);}
.stat-pill.pp{background:var(--pp-bg);color:var(--pp-color);border-color:var(--pp-color);}
.stat-pill.us{background:var(--us-bg);color:var(--us-color);border-color:var(--us-color);}
.stat-pill.di{background:var(--di-bg);color:var(--di-color);border-color:var(--di-color);}
.stat-pill.neu{background:var(--bg);color:var(--text2);border-color:var(--border);font-weight:500;}
.fs-wrap{display:flex;align-items:center;gap:7px;margin-left:auto;}
.fs-slider{width:76px;accent-color:var(--accent);cursor:pointer;}
.fs-sz{color:var(--text3);font-weight:700;}
.mode-toggle{display:flex;border-bottom:2px solid var(--border);background:var(--card);}
.mode-btn{flex:1;padding:12px 8px;font-family:'DM Sans',sans-serif;font-size:.84rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.mode-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.section-nav{position:sticky;top:0;z-index:200;background:var(--card);border-bottom:2px solid var(--border);box-shadow:var(--shadow-sm);}
.section-nav-inner{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.section-nav-inner::-webkit-scrollbar{display:none;}
.snav-btn{flex-shrink:0;padding:11px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;}
.snav-btn:hover{color:var(--text2);}
.snav-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.main-layout{max-width:860px;margin:0 auto;padding:16px 16px 40px;}
.panel{display:none;} .panel.active{display:block;}
.sec-block{display:none;} .sec-block.active{display:block;}
.gram-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:14px;overflow:hidden;}
.gram-card-body{padding:18px;}
.def-box{background:var(--warn-bg);border-left:4px solid var(--accent);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:12px 15px;margin-bottom:14px;line-height:1.65;}
.def-box strong{color:var(--accent);font-weight:700;}
.warn-box{background:#fff4e0;border:1px solid #c8900a;border-radius:var(--radius-sm);padding:10px 13px;margin:10px 0;font-size:.9em;display:flex;gap:8px;align-items:flex-start;}
.warn-icon{flex-shrink:0;margin-top:1px;}
.warn-text{color:var(--text2);line-height:1.55;}
.warn-text strong{color:#7a4400;font-weight:700;}
.note-box{background:var(--purple-bg);border-left:4px solid var(--purple);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.note-box strong{color:var(--purple);font-weight:700;}
.green-box{background:var(--green-bg);border-left:4px solid var(--green);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.green-box strong{color:var(--green);font-weight:700;}
.example-block{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:8px 0;}
.example-block.ge{background:var(--ge-bg);border-left:4px solid var(--ge-color);}
.example-block.pp{background:var(--pp-bg);border-left:4px solid var(--pp-color);}
.example-block.di{background:var(--di-bg);border-left:4px solid var(--di-color);}
.example-block.neu{background:var(--blue-bg);border-left:4px solid var(--blue);}
.ex-fr{font-weight:600;margin-bottom:3px;color:var(--text);}
.ege{color:var(--ge-color);font-weight:700;}
.epp{color:var(--pp-color);font-weight:700;}
.eus{color:var(--us-color);font-weight:700;}
.edi{color:var(--di-color);font-weight:700;}
.ex-es{color:var(--text2);font-size:.88em;font-style:italic;}
.ex-note{font-size:.78em;color:var(--text3);margin-top:3px;font-weight:500;}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:14px;border-radius:var(--radius-sm);border:1px solid var(--border);}
.gram-table{width:100%;border-collapse:collapse;min-width:280px;}
.gram-table th{background:var(--bg);border-bottom:2px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;text-align:left;font-size:.72em;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.gram-table td{border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;vertical-align:top;}
.gram-table tr:last-child td{border-bottom:none;}
.gram-table tr:nth-child(even) td{background:#f4f0e6;}
.gram-table td:last-child,.gram-table th:last-child{border-right:none;}
.hl-ge{color:var(--ge-color);font-weight:700;}
.hl-pp{color:var(--pp-color);font-weight:700;}
.hl-di{color:var(--di-color);font-weight:700;}
.hl{color:var(--accent);font-weight:700;}
.dim{color:var(--text3);font-size:.88em;}
.ok-cell{color:var(--green);font-weight:700;}
.err-cell{color:var(--red);font-weight:600;font-style:italic;}
.chip-bar{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.chip{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;white-space:nowrap;}
.chip:hover{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.chip.ge.active{background:var(--ge-color);border-color:var(--ge-color);}
.chip.pp.active{background:var(--pp-color);border-color:var(--pp-color);}
.chip.di.active{background:var(--di-color);border-color:var(--di-color);}
.chip-panel{display:none;} .chip-panel.active{display:block;}
.sec-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px;}
.trap-cards{display:flex;flex-direction:column;gap:10px;}
.trap-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.trap-card-header{padding:11px 14px;background:var(--bg);}
.trap-name{font-weight:700;font-size:.9em;color:var(--text);margin-bottom:7px;}
.trap-vs{display:flex;gap:8px;flex-wrap:wrap;}
.trap-wrong{background:var(--red-bg);border:1.5px solid #d09098;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--red);font-weight:500;}
.trap-right{background:var(--green-bg);border:1.5px solid #80b890;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--green);font-weight:500;}
.trap-expl{padding:10px 14px 12px;font-size:.86em;color:var(--text2);line-height:1.6;border-top:1px solid var(--border);background:var(--card);}
.trap-expl strong{color:var(--text);font-weight:700;}
.exercise-controls{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:var(--shadow-sm);}
.exercise-controls h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:14px;}
.ctrl-label{font-size:.7em;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:7px;display:block;}
.ex-options{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ex-opt-btn{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.ex-opt-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.row-btns{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.pill-btn{border:1.5px solid var(--border);border-radius:20px;padding:5px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.pill-btn:hover:not(.active){background:var(--border);}
.pill-btn.active{background:var(--text);color:var(--bg);border-color:var(--text);}
.pill-btn.diff.active.A2{background:var(--green);border-color:var(--green);color:#fff;}
.pill-btn.diff.active.B1{background:var(--blue);border-color:var(--blue);color:#fff;}
.pill-btn.diff.active.B2{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-generate{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:.92em;font-weight:700;cursor:pointer;background:var(--accent);color:white;transition:all .18s;margin-top:4px;}
.btn-generate:hover:not(:disabled){filter:brightness(1.1);box-shadow:0 4px 14px rgba(122,90,10,.32);}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;}
.spinner{display:none;animation:spin .8s linear infinite;}
.btn-generate.loading .spinner{display:inline;}
.btn-generate.loading .btn-icon{display:none;}
@keyframes spin{to{transform:rotate(360deg);}}
.progress-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:14px;display:none;}
.progress-wrap.visible{display:block;}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-size:.78em;color:var(--text3);font-weight:600;}
.progress-frac{font-size:.92em;font-weight:700;color:var(--accent);}
.progress-track{height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .35s ease;}
.progress-score{display:flex;gap:14px;margin-top:9px;font-size:.8em;flex-wrap:wrap;align-items:center;}
.score-item{display:flex;align-items:center;gap:5px;font-weight:500;color:var(--text2);}
.score-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.score-dot.g{background:var(--green);}.score-dot.r{background:var(--red);}
.btn-retry{border:1.5px solid var(--border);border-radius:20px;padding:5px 13px;font-family:'DM Sans',sans-serif;font-size:.78em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;margin-left:auto;}
.btn-retry:hover{background:var(--border);}
.final-score-bar{display:none;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;}
.final-score-bar.visible{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.final-num{font-size:1.5rem;font-weight:700;color:var(--accent);}
.final-label{font-size:.74em;color:var(--text3);}
.final-track{flex:1;min-width:80px;height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.final-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.final-msg{font-size:.84em;color:var(--text2);width:100%;font-weight:500;}
.exercise-area{display:none;}.exercise-area.visible{display:block;}
.exercise-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;}
.exercise-card-header{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg);border-bottom:1px solid var(--border);}
.ex-num{font-weight:700;color:var(--accent);font-size:.88em;}
.ex-type-badge{font-size:.68em;font-weight:700;letter-spacing:.07em;text-transform:uppercase;background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-mid);border-radius:12px;padding:2px 8px;}
.ex-diff-badge{font-size:.68em;font-weight:700;border-radius:12px;padding:2px 8px;}
.ex-diff-badge.A2{background:var(--green-bg);color:var(--green);border:1px solid #80b890;}
.ex-diff-badge.B1{background:var(--blue-bg);color:var(--blue);border:1px solid #90a8e0;}
.ex-diff-badge.B2{background:var(--warn-bg);color:var(--accent);border:1px solid var(--accent-mid);}
.ex-status{margin-left:auto;}
.exercise-body{padding:16px 18px;}
.exercise-prompt{line-height:1.7;margin-bottom:12px;color:var(--text);}
.exercise-prompt em{color:var(--accent);font-style:italic;font-weight:600;}
.fill-input{border:none;border-bottom:2px solid var(--accent-mid);background:var(--accent-light);padding:2px 8px;border-radius:4px 4px 0 0;font-family:'DM Sans',sans-serif;font-size:1em;color:var(--text);min-width:160px;outline:none;transition:border-color .15s;}
.fill-input:focus{border-bottom-color:var(--accent);}
.fill-input.ok{background:var(--green-bg);border-bottom-color:var(--green);}
.fill-input.err{background:var(--red-bg);border-bottom-color:var(--red);}
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.choice-btn{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.88em;font-weight:500;cursor:pointer;text-align:left;background:var(--bg);color:var(--text);transition:all .15s;}
.choice-btn:hover:not(:disabled){border-color:var(--accent);background:var(--accent-light);}
.choice-btn.ok{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:700;}
.choice-btn.err{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.choice-btn:disabled{cursor:default;}
.transform-input{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.9em;background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;transition:border-color .15s;}
.transform-input:focus{border-color:var(--accent);}
.transform-input.ok{background:var(--green-bg);border-color:var(--green);}
.transform-input.err{background:var(--red-bg);border-color:var(--red);}
.btn-check{border:1.5px solid var(--accent);border-radius:20px;padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:700;cursor:pointer;background:transparent;color:var(--accent);transition:all .15s;}
.btn-check:hover:not(:disabled){background:var(--accent);color:white;}
.btn-check:disabled{opacity:.35;cursor:default;}
.ex-feedback{display:none;border-radius:var(--radius-sm);padding:11px 14px;line-height:1.55;margin-top:10px;font-size:.9em;}
.ex-feedback.visible{display:block;}
.ex-feedback.ok{background:var(--green-bg);border:1.5px solid #80b890;color:#0e4818;}
.ex-feedback.err{background:var(--red-bg);border:1.5px solid #c08090;color:#700018;}
.fb-rule-link{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:.84em;font-weight:700;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;}
.skeleton-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:12px;}
.skel{background:linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.4s infinite;border-radius:4px;height:13px;margin-bottom:9px;}
@keyframes skel{to{background-position:-200% 0;}}
.state-msg{text-align:center;padding:40px 20px;color:var(--text3);}
.state-icon{font-size:2rem;margin-bottom:10px;}
.state-msg p{max-width:260px;margin:0 auto;line-height:1.6;font-weight:500;}
</style>
</head>
<body>
<header class="site-header">
  <div class="header-top">
    <h1>Le Gérondif et le Participe Présent</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1–B2</div>
  <div class="stats-row">
    <div class="stat-pill ge">Gérondif (en + -ant)</div>
    <div class="stat-pill pp">Participe présent</div>
    <div class="stat-pill di">Gér. vs. Part. présent</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>
<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>
<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-formation',this)">2. Formation</button>
    <button class="snav-btn"        onclick="showSection('s-emplois',this)">3. Emplois du gérondif</button>
    <button class="snav-btn"        onclick="showSection('s-tout',this)">4. Tout en + gérondif</button>
    <button class="snav-btn"        onclick="showSection('s-pp',this)">5. Participe présent</button>
    <button class="snav-btn"        onclick="showSection('s-distinction',this)">6. Gér. vs. Part. présent</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">7. Trampas</button>
  </div>
</div>
<div class="main-layout">
<div class="panel active" id="panel-ref">
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El <strong>gérondif</strong> y el <strong>participe présent</strong> comparten la misma forma en <em>-ant</em> pero son categorías distintas. El gérondif siempre lleva <em>en</em> delante y funciona como adverbio. El participe présent va solo y funciona como adjetivo o introduce una proposición. Dominar la diferencia es esencial para el DELF B1–B2.
      </div>

      <div class="sec-label">Comparativa fundamental</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th></th><th class="hl-ge">Gérondif</th><th class="hl-pp">Participe présent</th></tr></thead>
        <tbody>
          <tr><td><strong>Forma</strong></td><td><em>en</em> + forme en -ant</td><td>forme en -ant (solo)</td></tr>
          <tr><td><strong>Función</strong></td><td>Adverbial (modo, simultaneidad, condición, causa)</td><td>Adjetival o proposicional</td></tr>
          <tr><td><strong>Sujeto</strong></td><td>Siempre el mismo que el verbo principal</td><td>Puede ser distinto</td></tr>
          <tr><td><strong>Acuerdo</strong></td><td>Invariable</td><td>Invariable (como participe) / concuerda (como adjectif)</td></tr>
          <tr><td><strong>Ejemplo</strong></td><td><em>Il travaille <strong>en chantant</strong>.</em></td><td><em>Un enfant <strong>souriant</strong>.</em> / <em><strong>Sachant</strong> la vérité, il se tut.</em></td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Usos del gérondif — resumen</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Valor</th><th>Pregunta</th><th>Ejemplo</th></tr></thead>
        <tbody>
          <tr><td><strong class="hl-ge">Simultanéité</strong></td><td>¿Qué hacía al mismo tiempo?</td><td><em>Il écoute <strong>en prenant</strong> des notes.</em></td></tr>
          <tr><td><strong class="hl-ge">Mode / manière</strong></td><td>¿Cómo?</td><td><em>Elle a réussi <strong>en travaillant</strong> dur.</em></td></tr>
          <tr><td><strong class="hl-ge">Condition</strong></td><td>¿En qué condición?</td><td><em><strong>En partant</strong> tôt, tu éviteras les bouchons.</em></td></tr>
          <tr><td><strong class="hl-ge">Cause</strong></td><td>¿Por qué? (secundario)</td><td><em><strong>En étant</strong> attentif, il a tout compris.</em></td></tr>
        </tbody>
      </table></div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Regla de oro:</strong> el sujeto del gérondif es <em>siempre</em> el mismo que el del verbo principal. Si los sujetos son distintos, hay que usar otra construcción. <em>En arrivant, le soleil brillait</em> ✗ (el sol no llega). <em>En arrivant, nous avons vu le soleil</em> ✓.</div>
      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-formation">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La formación del gérondif sigue una regla única: <strong>en + [base] + ant</strong>, donde la base es la <strong>1ª persona plural del présent</strong> sin <em>-ons</em>. Solo tres verbos son completamente irregulares.
      </div>

      <div class="chip-bar">
        <button class="chip ge active" onclick="selectChip('form',0)">Règle générale</button>
        <button class="chip ge"        onclick="selectChip('form',1)">Verbes irréguliers</button>
        <button class="chip ge"        onclick="selectChip('form',2)">Orthographe (-cer, -ger, -ier…)</button>
        <button class="chip ge"        onclick="selectChip('form',3)">Négation et pronoms</button>
      </div>
      <div id="form-panels">

        <div class="chip-panel active" id="form-p-0">
          <div class="green-box">
            <strong>Fórmula:</strong> nous [présent] → quitar <em>-ons</em> → añadir <em>-ant</em> → añadir <em>en</em><br>
            <em>nous parlons → parl → parlant → <strong>en parlant</strong></em>
          </div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Infinitif</th><th>Nous (présent)</th><th>Base</th><th>Gérondif</th></tr></thead>
            <tbody>
              <tr><td>parler</td><td>nous parlons</td><td>parl-</td><td class="hl-ge">en parlant</td></tr>
              <tr><td>finir</td><td>nous finissons</td><td>finiss-</td><td class="hl-ge">en finissant</td></tr>
              <tr><td>prendre</td><td>nous prenons</td><td>pren-</td><td class="hl-ge">en prenant</td></tr>
              <tr><td>venir</td><td>nous venons</td><td>ven-</td><td class="hl-ge">en venant</td></tr>
              <tr><td>faire</td><td>nous faisons</td><td>faisan-</td><td class="hl-ge">en faisant</td></tr>
              <tr><td>aller</td><td>nous allons</td><td>all-</td><td class="hl-ge">en allant</td></tr>
              <tr><td>voir</td><td>nous voyons</td><td>voyant</td><td class="hl-ge">en voyant</td></tr>
              <tr><td>pouvoir</td><td>nous pouvons</td><td>pouv-</td><td class="hl-ge">en pouvant</td></tr>
              <tr><td>lire</td><td>nous lisons</td><td>lis-</td><td class="hl-ge">en lisant</td></tr>
              <tr><td>écrire</td><td>nous écrivons</td><td>écriv-</td><td class="hl-ge">en écrivant</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge">
            <div class="ex-fr">Il a appris le français <span class="ege">en regardant</span> des films.</div>
            <div class="ex-es">Aprendió francés viendo películas.</div>
            <div class="ex-note">nous regardons → regard- → en regardant</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle s'est blessée <span class="ege">en courant</span>.</div>
            <div class="ex-es">Se lesionó corriendo.</div>
            <div class="ex-note">nous courons → cour- → en courant</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-1">
          <div class="def-box">Solo tres verbos tienen gérondif completamente irregular — no siguen la regla de <em>nous</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Infinitif</th><th>Gérondif</th><th>Participe présent</th></tr></thead>
            <tbody>
              <tr><td><strong>être</strong></td><td class="hl-ge">en étant</td><td class="hl-pp">étant</td></tr>
              <tr><td><strong>avoir</strong></td><td class="hl-ge">en ayant</td><td class="hl-pp">ayant</td></tr>
              <tr><td><strong>savoir</strong></td><td class="hl-ge">en sachant</td><td class="hl-pp">sachant</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En étant</span> patient, on finit par réussir.</div>
            <div class="ex-es">Siendo paciente, uno acaba teniendo éxito.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il a pu convaincre tout le monde <span class="ege">en ayant</span> des arguments solides.</div>
            <div class="ex-es">Pudo convencer a todos teniendo argumentos sólidos.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En sachant</span> la vérité, elle a pu prendre la bonne décision.</div>
            <div class="ex-es">Sabiendo la verdad, pudo tomar la decisión correcta.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Solo estos tres son irregulares. <em>Pouvoir → en pouvant</em> ✓ (regular desde <em>nous pouvons</em>). <em>Vouloir → en voulant</em> ✓. <em>Devoir → en devant</em> ✓. No son irregulares.</div></div>
        </div>

        <div class="chip-panel" id="form-p-2">
          <div class="def-box">Algunos verbos requieren ajustes ortográficos para mantener la pronunciación correcta.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Tipo</th><th>Regla</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Verbes en <strong>-cer</strong></td><td>c → ç devant -ant</td><td>commencer → <span class="hl-ge">en commençant</span></td></tr>
              <tr><td>Verbes en <strong>-ger</strong></td><td>g + e devant -ant</td><td>manger → <span class="hl-ge">en mangeant</span></td></tr>
              <tr><td>Verbes en <strong>-ier</strong></td><td>base normale</td><td>étudier → <span class="hl-ge">en étudiant</span></td></tr>
              <tr><td>Verbes en <strong>-yer</strong></td><td>y → i</td><td>payer → <span class="hl-ge">en payant</span></td></tr>
              <tr><td>Verbes en <strong>-eler/-eter</strong></td><td>doublement ou accent</td><td>appeler → <span class="hl-ge">en appelant</span></td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge">
            <div class="ex-fr">Il a amélioré son style <span class="ege">en commençant</span> à lire davantage.</div>
            <div class="ex-es">Mejoró su estilo empezando a leer más.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a perdu du poids <span class="ege">en mangeant</span> plus équilibré.</div>
            <div class="ex-es">Perdió peso comiendo de forma más equilibrada.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">On apprend <span class="ege">en voyageant</span> et <span class="ege">en rencontrant</span> des gens différents.</div>
            <div class="ex-es">Se aprende viajando y conociendo gente diferente.</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-3">
          <div class="def-box">La negación y los pronoms van en posiciones específicas con el gérondif.</div>
          <div class="sec-label">Negación del gérondif</div>
          <div class="green-box">
            <strong>en ne [forme en -ant] pas / jamais / plus / rien</strong><br>
            <em>en <strong>ne</strong> parlant <strong>pas</strong></em> — sin hablar<br>
            <em>en <strong>ne</strong> disant <strong>rien</strong></em> — sin decir nada
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il a réussi <span class="ege">en ne travaillant pas</span> beaucoup. <span class="ex-note">(aunque parece contradictorio)</span></div>
            <div class="ex-es">Lo consiguió sin trabajar mucho.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a traversé la crise <span class="ege">en ne disant rien</span> à personne.</div>
            <div class="ex-es">Atravesó la crisis sin decirle nada a nadie.</div>
          </div>
          <div class="sec-label">Pronoms avec le gérondif</div>
          <div class="def-box">Los pronoms van antes de la forma en -ant, después de <em>en</em>.</div>
          <div class="example-block ge">
            <div class="ex-fr">Il a progressé <span class="ege">en le lisant</span> tous les jours. <span class="ex-note">(en + le + lisant)</span></div>
            <div class="ex-es">Progresó leyéndolo todos los días.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a appris la nouvelle <span class="ege">en lui téléphonant</span>.</div>
            <div class="ex-es">Supo la noticia llamándole.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Negación: <em>en ne répondant pas</em> ✓ — <em>en ne pas répondant</em> ✗. Los dos elementos de la negación rodean la forma en -ant, no van juntos antes de ella.</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-emplois">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El gérondif puede expresar cuatro relaciones entre la acción principal y la acción secundaria. Identificar el valor correcto es esencial tanto para la comprensión lectora como para la producción escrita.
      </div>

      <div class="chip-bar">
        <button class="chip ge active" onclick="selectChip('emp',0)">Simultanéité</button>
        <button class="chip ge"        onclick="selectChip('emp',1)">Mode / manière</button>
        <button class="chip ge"        onclick="selectChip('emp',2)">Condition</button>
        <button class="chip ge"        onclick="selectChip('emp',3)">Cause</button>
      </div>
      <div id="emp-panels">

        <div class="chip-panel active" id="emp-p-0">
          <div class="def-box">Dos acciones ocurren <strong>al mismo tiempo</strong>. El gérondif responde a la pregunta <em>« Que faisait-il en même temps ? »</em>. Es el uso más frecuente.</div>
          <div class="example-block ge">
            <div class="ex-fr">Il écoute la radio <span class="ege">en conduisant</span>.</div>
            <div class="ex-es">Escucha la radio mientras conduce.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle prend des notes <span class="ege">en assistant</span> à la conférence.</div>
            <div class="ex-es">Toma notas mientras asiste a la conferencia.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il siffle <span class="ege">en travaillant</span> — c'est son habitude.</div>
            <div class="ex-es">Silba mientras trabaja — es su costumbre.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a souri <span class="ege">en me voyant</span> entrer.</div>
            <div class="ex-es">Sonrió al verme entrar.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il lisait le journal <span class="ege">en buvant</span> son café du matin.</div>
            <div class="ex-es">Leía el periódico mientras bebía su café de la mañana.</div>
          </div>
          <div class="note-box"><strong>Distinción con <em>pendant que</em>:</strong> ambos expresan simultaneidad. El gérondif es más conciso y elegante; <em>pendant que</em> + indicatif es más explícito y puede tener sujetos distintos.</div>
        </div>

        <div class="chip-panel" id="emp-p-1">
          <div class="def-box">El gérondif indica <strong>cómo</strong> se realiza la acción principal. Responde a <em>« Comment ? »</em>. Es el segundo uso más frecuente y muy valorado en producción escrita.</div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a réussi son examen <span class="ege">en travaillant</span> sérieusement.</div>
            <div class="ex-es">Aprobó su examen trabajando seriamente.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il a maigri <span class="ege">en mangeant</span> moins et <span class="ege">en faisant</span> du sport.</div>
            <div class="ex-es">Adelgazó comiendo menos y haciendo deporte.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">On développe sa créativité <span class="ege">en lisant</span> beaucoup.</div>
            <div class="ex-es">Se desarrolla la creatividad leyendo mucho.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il a convaincu tout le monde <span class="ege">en présentant</span> des arguments solides.</div>
            <div class="ex-es">Convenció a todos presentando argumentos sólidos.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle s'est améliorée <span class="ege">en s'entraînant</span> chaque jour.</div>
            <div class="ex-es">Mejoró entrenando cada día.</div>
          </div>
        </div>

        <div class="chip-panel" id="emp-p-2">
          <div class="def-box">El gérondif expresa la <strong>condición</strong> necesaria para que se realice la acción principal. Equivale a «si + présent». Muy frecuente al inicio de frase.</div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En partant</span> tôt, tu éviteras les embouteillages.</div>
            <div class="ex-es">Si sales pronto, evitarás los atascos.</div>
            <div class="ex-note">= Si tu pars tôt, tu éviteras…</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En faisant</span> des efforts, on peut tout apprendre.</div>
            <div class="ex-es">Haciendo esfuerzos, se puede aprender cualquier cosa.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En appelant</span> maintenant, vous obtiendrez un tarif préférentiel.</div>
            <div class="ex-es">Llamando ahora, obtendrá una tarifa preferente.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En prenant</span> ce chemin, vous arriverez plus vite.</div>
            <div class="ex-es">Tomando este camino, llegará más rápido.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En écoutant</span> mieux, tu aurais compris.</div>
            <div class="ex-es">Si hubieras escuchado mejor, habrías entendido.</div>
          </div>
        </div>

        <div class="chip-panel" id="emp-p-3">
          <div class="def-box">El gérondif puede expresar la <strong>causa</strong>, aunque este uso es menos preciso que el participe présent sin <em>en</em>. En producción formal, preferir el participe présent o un conector causal para la causa.</div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En étant</span> attentif, il a tout compris.</div>
            <div class="ex-es">Estando atento, lo entendió todo. (causa)</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il s'est blessé <span class="ege">en tombant</span> de vélo.</div>
            <div class="ex-es">Se lesionó al caerse de la bicicleta. (causa)</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En travaillant</span> trop, il a fini par s'épuiser.</div>
            <div class="ex-es">Trabajando demasiado, acabó por agotarse.</div>
          </div>
          <div class="note-box"><strong>Gérondif causal vs. participe présent causal:</strong><br>
            <em><strong>En étant</strong> malade, il n'est pas venu.</em> (gérondif — algo ambiguo)<br>
            <em><strong>Étant</strong> malade, il n'est pas venu.</em> (participe présent — causa más clara)<br>
            Para la causa, el participe présent sin <em>en</em> es más preciso y preferido en el escrito formal.
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-tout">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        <strong>Tout en + gérondif</strong> es una estructura específica que refuerza el gérondif. Puede expresar dos valores distintos según el contexto: <strong>simultaneidad insistida</strong> (haciendo las dos cosas a la vez, con énfasis) u <strong>oposición/concesión</strong> (a pesar de hacer X, Y ocurre).
      </div>

      <div class="chip-bar">
        <button class="chip ge active" onclick="selectChip('tout',0)">Simultanéité insistée</button>
        <button class="chip ge"        onclick="selectChip('tout',1)">Opposition / concession</button>
        <button class="chip ge"        onclick="selectChip('tout',2)">Distinguir los dos valores</button>
      </div>
      <div id="tout-panels">

        <div class="chip-panel active" id="tout-p-0">
          <div class="def-box"><em>Tout en</em> refuerza la idea de que dos acciones ocurren <strong>verdaderamente al mismo tiempo</strong>, insistiendo en la simultaneidad. Equivale a "mientras, a la vez que".</div>
          <div class="example-block ge">
            <div class="ex-fr">Il écoute <span class="ege">tout en prenant</span> des notes.</div>
            <div class="ex-es">Escucha a la vez que toma notas.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle cuisine <span class="ege">tout en surveillant</span> ses enfants.</div>
            <div class="ex-es">Cocina mientras vigila a sus hijos.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il répond aux emails <span class="ege">tout en participant</span> à la réunion.</div>
            <div class="ex-es">Responde emails a la vez que participa en la reunión.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle lit <span class="ege">tout en écoutant</span> de la musique classique.</div>
            <div class="ex-es">Lee mientras escucha música clásica.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il marche <span class="ege">tout en téléphonant</span> à son associé.</div>
            <div class="ex-es">Camina a la vez que habla por teléfono con su socio.</div>
          </div>
        </div>

        <div class="chip-panel" id="tout-p-1">
          <div class="def-box"><em>Tout en</em> expresa que <strong>a pesar de</strong> hacer X, ocurre Y — las dos acciones son contradictorias o inesperadas juntas. Equivale a "aunque, a pesar de".</div>
          <div class="example-block ge">
            <div class="ex-fr">Elle a réussi <span class="ege">tout en ayant</span> très peu de temps.</div>
            <div class="ex-es">Tuvo éxito aunque tenía muy poco tiempo.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il critique le système <span class="ege">tout en en profitant</span>.</div>
            <div class="ex-es">Critica el sistema aunque se beneficia de él.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">Tout en comprenant</span> ses difficultés, je ne peux pas l'excuser.</div>
            <div class="ex-es">Aunque entiendo sus dificultades, no puedo excusarle.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Il accepte la décision <span class="ege">tout en n'étant pas</span> vraiment d'accord.</div>
            <div class="ex-es">Acepta la decisión aunque no está realmente de acuerdo.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle travaille énormément <span class="ege">tout en ne gagnant</span> presque rien.</div>
            <div class="ex-es">Trabaja muchísimo aunque no gana casi nada.</div>
          </div>
          <div class="note-box"><strong>Equivalencia con bien que:</strong> <em>Tout en comprenant ses difficultés</em> = <em>Bien qu'il comprenne ses difficultés</em>. La diferencia: <em>tout en</em> exige el mismo sujeto; <em>bien que</em> puede tener sujetos distintos.</div>
        </div>

        <div class="chip-panel" id="tout-p-2">
          <div class="def-box">El contexto determina el valor. Claves para distinguirlos:</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-ge">Simultaneidad</th><th class="hl-ge">Oposición</th></tr></thead>
            <tbody>
              <tr><td><strong>Señal</strong></td><td>Las dos acciones son compatibles y naturales juntas</td><td>Las dos acciones son contradictorias o sorprendentes</td></tr>
              <tr><td><strong>Sustitución</strong></td><td>= <em>pendant que / en même temps que</em></td><td>= <em>bien que + subjonctif / malgré</em></td></tr>
              <tr><td><strong>Negación</strong></td><td>Menos frecuente en el gérondif</td><td>Frecuente: <em>tout en ne… pas</em></td></tr>
              <tr><td><strong>Ejemplo</strong></td><td><em>Il écoute tout en prenant des notes.</em></td><td><em>Il critique tout en profitant du système.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge">
            <div class="ex-fr">Elle chante <span class="ege">tout en faisant</span> la vaisselle. <span class="ex-note">(simultanéité — acciones compatibles)</span></div>
            <div class="ex-es">Canta mientras friega.</div>
          </div>
          <div class="example-block ge">
            <div class="ex-fr">Elle chante <span class="ege">tout en étant</span> très timide. <span class="ex-note">(opposition — contradictorio)</span></div>
            <div class="ex-es">Canta aunque es muy tímida.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">💡</span><div class="warn-text">La prueba rápida: ¿las dos acciones son contradictorias o sorprendentes? → oposición. ¿Son simplemente simultáneas y compatibles? → simultaneidad insistida.</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-pp">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        El <strong>participe présent</strong> es la forma en <em>-ant</em> sin <em>en</em>. Tiene tres usos principales: como <strong>adjectif verbal</strong> (califica un sustantivo, concuerda), como <strong>participe présent propositionnel</strong> (introduce una proposición, invariable) y para expresar la <strong>causa</strong> (equivale a <em>parce que / comme</em>).
      </div>

      <div class="chip-bar">
        <button class="chip pp active" onclick="selectChip('pp',0)">Participe présent propositionnel</button>
        <button class="chip pp"        onclick="selectChip('pp',1)">Adjectif verbal (accord)</button>
        <button class="chip pp"        onclick="selectChip('pp',2)">Cause (étant donné, sachant)</button>
        <button class="chip pp"        onclick="selectChip('pp',3)">Orthographe: participe vs. adjectif</button>
      </div>
      <div id="pp-panels">

        <div class="chip-panel active" id="pp-p-0">
          <div class="def-box">El participe présent introduce una proposición participiale que equivale a una subordonnée relative o circonstancielle. Es <strong>invariable</strong>. El sujeto de la proposición puede ser diferente del sujeto principal.</div>
          <div class="example-block pp">
            <div class="ex-fr">J'ai vu une femme <span class="epp">portant</span> un grand chapeau rouge.</div>
            <div class="ex-es">Vi a una mujer que llevaba un gran sombrero rojo.</div>
            <div class="ex-note">= qui portait — califica « une femme »</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Sachant</span> qu'il était en retard, il a pris un taxi.</div>
            <div class="ex-es">Sabiendo que llegaba tarde, cogió un taxi.</div>
            <div class="ex-note">cause — mismo sujeto</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Les candidats <span class="epp">répondant</span> à ces critères seront contactés.</div>
            <div class="ex-es">Los candidatos que cumplan estos criterios serán contactados.</div>
            <div class="ex-note">= qui répondent — proposición relativa</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Voyant</span> qu'il ne viendrait pas, elle est partie sans attendre.</div>
            <div class="ex-es">Viendo que no vendría, se marchó sin esperar.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Il a trouvé une solution <span class="epp">permettant</span> de réduire les coûts.</div>
            <div class="ex-es">Encontró una solución que permite reducir los costes.</div>
            <div class="ex-note">= qui permet — proposición relativa</div>
          </div>
        </div>

        <div class="chip-panel" id="pp-p-1">
          <div class="def-box">Cuando la forma en -ant funciona como <strong>adjetivo</strong> que califica directamente un sustantivo, <strong>concuerda</strong> en género y número: <em>-ant / -ante / -ants / -antes</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Masc. sing.</th><th>Fém. sing.</th><th>Masc. pl.</th><th>Fém. pl.</th></tr></thead>
            <tbody>
              <tr><td>un résultat <span class="hl-pp">surprenant</span></td><td>une nouvelle <span class="hl-pp">surprenante</span></td><td>des résultats <span class="hl-pp">surprenants</span></td><td>des nouvelles <span class="hl-pp">surprenantes</span></td></tr>
              <tr><td>un enfant <span class="hl-pp">souriant</span></td><td>une femme <span class="hl-pp">souriante</span></td><td>des enfants <span class="hl-pp">souriants</span></td><td>des femmes <span class="hl-pp">souriantes</span></td></tr>
              <tr><td>un travail <span class="hl-pp">fatigant</span></td><td>une tâche <span class="hl-pp">fatigante</span></td><td>des travaux <span class="hl-pp">fatigants</span></td><td>des tâches <span class="hl-pp">fatigantes</span></td></tr>
            </tbody>
          </table></div>
          <div class="example-block pp">
            <div class="ex-fr">C'est une histoire vraiment <span class="epp">touchante</span>.</div>
            <div class="ex-es">Es una historia realmente conmovedora.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Les résultats sont <span class="epp">encourageants</span>.</div>
            <div class="ex-es">Los resultados son alentadores.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Elle a une personnalité très <span class="epp">attachante</span>.</div>
            <div class="ex-es">Tiene una personalidad muy entrañable.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">C'est un film <span class="epp">captivant</span> du début à la fin.</div>
            <div class="ex-es">Es una película cautivadora de principio a fin.</div>
          </div>
        </div>

        <div class="chip-panel" id="pp-p-2">
          <div class="def-box">El participe présent es preferido al gérondif para expresar la <strong>causa</strong>, especialmente cuando el sujeto no es idéntico o cuando se quiere más claridad.</div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Étant</span> malade, il n'a pas pu venir.</div>
            <div class="ex-es">Como estaba enfermo, no pudo venir.</div>
            <div class="ex-note">= Comme il était malade… — causa clara</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Sachant</span> que la réunion était annulée, nous sommes rentrés chez nous.</div>
            <div class="ex-es">Sabiendo que la reunión estaba cancelada, volvimos a casa.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">N'ayant</span> pas reçu de réponse, elle a décidé de rappeler.</div>
            <div class="ex-es">No habiendo recibido respuesta, decidió volver a llamar.</div>
            <div class="ex-note">participe présent passé con ayant — acción anterior</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Étant donné</span> la situation, des mesures s'imposent.</div>
            <div class="ex-es">Dada la situación, se imponen medidas.</div>
          </div>
          <div class="note-box"><strong>Participe présent passé (ayant / étant + p.p.):</strong> expresa una acción <em>anterior</em> a la principal. <em>Ayant fini son travail, il est sorti</em> = después de haber terminado su trabajo. Muy frecuente en escrito formal B2.</div>
        </div>

        <div class="chip-panel" id="pp-p-3">
          <div class="def-box">Algunas formas tienen ortografía diferente según sean participe présent (invariable) o adjectif verbal (concuerda). Esta distinción es examinada en producción escrita B2.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Verbo</th><th>Participe présent <span class="dim">(invariable)</span></th><th>Adjectif verbal <span class="dim">(concuerda)</span></th></tr></thead>
            <tbody>
              <tr><td><strong>convaincre</strong></td><td>convainquant</td><td>convaincant(e)(s)</td></tr>
              <tr><td><strong>fatiguer</strong></td><td>fatiguant</td><td>fatigant(e)(s)</td></tr>
              <tr><td><strong>négliger</strong></td><td>négligeant</td><td>négligent(e)(s)</td></tr>
              <tr><td><strong>différer</strong></td><td>différant</td><td>différent(e)(s)</td></tr>
              <tr><td><strong>précéder</strong></td><td>précédant</td><td>précédent(e)(s)</td></tr>
              <tr><td><strong>provoquer</strong></td><td>provoquant</td><td>provocant(e)(s)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block pp">
            <div class="ex-fr">C'est une attitude <span class="epp">négligente</span>. <span class="ex-note">(adjectif → accord -e)</span></div>
            <div class="ex-es">Es una actitud negligente.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Il a répondu, <span class="epp">négligeant</span> les avertissements. <span class="ex-note">(participe présent → invariable)</span></div>
            <div class="ex-es">Respondió, ignorando las advertencias.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">La clave: ¿va directamente unida al sustantivo sin complemento? → adjectif → acuerdo. ¿Introduce una proposición con complemento propio? → participe présent → invariable.</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-distinction">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La distinción entre gérondif y participe présent es el punto más examinado de este tema en el DELF B2. La diferencia no está solo en el <em>en</em> — hay diferencias de función, de sujeto y de acuerdo que cambian completamente el sentido.
      </div>

      <div class="chip-bar">
        <button class="chip di active" onclick="selectChip('dist',0)">Diferencias estructurales</button>
        <button class="chip di"        onclick="selectChip('dist',1)">Misma forma, distintos sentidos</button>
        <button class="chip di"        onclick="selectChip('dist',2)">Árbol de decisión</button>
        <button class="chip di"        onclick="selectChip('dist',3)">Tableau récapitulatif</button>
      </div>
      <div id="dist-panels">

        <div class="chip-panel active" id="dist-p-0">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th></th><th class="hl-ge">Gérondif</th><th class="hl-pp">Participe présent</th></tr></thead>
            <tbody>
              <tr><td><strong>Forma</strong></td><td><em>en</em> + -ant</td><td>-ant (solo)</td></tr>
              <tr><td><strong>Función</strong></td><td>Adverbio (modo, simultanéité, condition, cause)</td><td>Adjectif ou proposition participiale</td></tr>
              <tr><td><strong>Sujeto</strong></td><td>Obligatoriamente el mismo que el verbo principal</td><td>Puede ser distinto del sujeto principal</td></tr>
              <tr><td><strong>Acuerdo</strong></td><td>Siempre invariable</td><td>Invariable (proposición) / concuerda (adjectif)</td></tr>
              <tr><td><strong>Pregunta</strong></td><td>¿Cómo? ¿Cuándo? ¿En qué condición?</td><td>¿Cuál? (adjectif) / ¿Haciendo qué? (proposición)</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge">
            <div class="ex-fr">Il a répondu <span class="ege">en souriant</span>. <span class="ex-note">(gérondif — modo: respondió sonriendo)</span></div>
            <div class="ex-es">Respondió sonriendo.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">J'ai vu un enfant <span class="epp">souriant</span>. <span class="ex-note">(adjectif — califica: un niño sonriente)</span></div>
            <div class="ex-es">Vi a un niño sonriente.</div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">J'ai vu un enfant <span class="epp">souriant</span> à sa mère. <span class="ex-note">(participe présent propositionnel — que sonreía a su madre)</span></div>
            <div class="ex-es">Vi a un niño que le sonreía a su madre.</div>
          </div>
        </div>

        <div class="chip-panel" id="dist-p-1">
          <div class="def-box">La misma base en -ant puede dar tres interpretaciones completamente distintas según el contexto y la presencia de <em>en</em>.</div>
          <div class="example-block ge">
            <div class="ex-fr"><span class="ege">En chantant</span>, il a gagné le concours.</div>
            <div class="ex-es">Cantando, ganó el concurso. → <em>modo o simultaneidad</em></div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr"><span class="epp">Chantant</span> depuis l'enfance, il maîtrise parfaitement la technique.</div>
            <div class="ex-es">Cantando desde la infancia, domina perfectamente la técnica. → <em>causa</em></div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">C'est un artiste <span class="epp">chantant</span>. <span class="ex-note">(adjectif — invariable aquí pues masc.)</span></div>
            <div class="ex-es">Es un artista que canta / cantante.</div>
          </div>
          <div style="height:8px"></div>
          <div class="example-block ge">
            <div class="ex-fr">Il s'est endormi <span class="ege">en lisant</span>.</div>
            <div class="ex-es">Se quedó dormido leyendo. → <em>gérondif: simultaneidad</em></div>
          </div>
          <div class="example-block pp">
            <div class="ex-fr">Il s'est endormi, <span class="epp">laissant</span> le livre ouvert sur la table.</div>
            <div class="ex-es">Se quedó dormido, dejando el libro abierto sobre la mesa. → <em>participe: proposición</em></div>
          </div>
        </div>

        <div class="chip-panel" id="dist-p-2">
          <div class="def-box">Tres preguntas para decidir qué forma usar:</div>
          <div class="green-box">
            <strong>Pregunta 1:</strong> ¿Hay <em>en</em> delante? → <strong>Gérondif</strong> (adverbial: modo, simultaneidad, condición).<br><br>
            <strong>Pregunta 2:</strong> ¿Sin <em>en</em>? → Participe présent. ¿Califica directamente un sustantivo sin complemento propio? → <strong>Adjectif verbal</strong> → acuerdo.<br><br>
            <strong>Pregunta 3:</strong> ¿Sin <em>en</em>, con complemento propio o proposición? → <strong>Participe présent</strong> → invariable.
          </div>
          <div class="example-block neu">
            <div class="ex-fr">une histoire <em>touchante</em> → sin complemento → <span class="epp">adjectif → touchante</span> ✓</div>
          </div>
          <div class="example-block neu">
            <div class="ex-fr">une histoire <em>touchant</em> tous les publics → con complemento → <span class="epp">participe présent → invariable</span> ✓</div>
          </div>
          <div class="example-block neu">
            <div class="ex-fr">Il parle <em>en</em> gesticulant → con <em>en</em> → <span class="ege">gérondif → modo</span> ✓</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">El error más frecuente: usar gérondif cuando los sujetos son diferentes. <em>En lisant ce livre, des idées nouvelles m'ont envahi</em> ✗ (quien lee no son las ideas). <em>En lisant ce livre, j'ai eu de nouvelles idées</em> ✓.</div></div>
        </div>

        <div class="chip-panel" id="dist-p-3">
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Forma</th><th>Estructura</th><th>Función</th><th>Acuerdo</th><th>Sujeto</th></tr></thead>
            <tbody>
              <tr><td><strong class="hl-ge">Gérondif</strong></td><td>en + -ant</td><td>Adverbial (modo, simultanéité, condition, cause)</td><td class="ok-cell">Invariable</td><td>= sujeto principal</td></tr>
              <tr><td><strong class="hl-pp">Part. présent propos.</strong></td><td>-ant (solo)</td><td>Proposición relativa o circonstancielle</td><td class="ok-cell">Invariable</td><td>Puede ser distinto</td></tr>
              <tr><td><strong class="hl-pp">Adjectif verbal</strong></td><td>-ant (solo)</td><td>Califica un sustantivo</td><td class="err-cell">Concuerda</td><td>—</td></tr>
              <tr><td><strong class="hl-ge">Tout en + gérondif</strong></td><td>tout en + -ant</td><td>Simultaneidad insistida / Oposición</td><td class="ok-cell">Invariable</td><td>= sujeto principal</td></tr>
              <tr><td><strong class="hl-pp">Part. présent passé</strong></td><td>ayant/étant + p.p.</td><td>Acción anterior a la principal</td><td class="ok-cell">Invariable (ayant) / acuerda (étant)</td><td>Puede ser distinto</td></tr>
            </tbody>
          </table></div>
          <div class="example-block ge"><div class="ex-fr"><span class="ege">En travaillant</span> dur, elle a réussi. <span class="ex-note">(gérondif — modo)</span></div></div>
          <div class="example-block pp"><div class="ex-fr">Les étudiants <span class="epp">travaillant</span> le soir ont de meilleurs résultats. <span class="ex-note">(participe présent — relatif)</span></div></div>
          <div class="example-block pp"><div class="ex-fr">C'est une période <span class="epp">chargée</span> et <span class="epp">fatigante</span>. <span class="ex-note">(adjectif verbal — accord fém.)</span></div></div>
          <div class="example-block ge"><div class="ex-fr">Elle travaille <span class="ege">tout en gérant</span> sa famille. <span class="ex-note">(tout en — simultaneidad)</span></div></div>
          <div class="example-block pp"><div class="ex-fr"><span class="epp">Ayant fini</span> ses devoirs, il est sorti jouer. <span class="ex-note">(participe présent passé — anterioridad)</span></div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>
</div>

<div class="panel" id="panel-ex">
  <div class="exercise-controls">
    <h3>Generar ejercicios</h3>
    <span class="ctrl-label">Tipo</span>
    <div class="ex-options">
      <button class="ex-opt-btn active" data-type="fill">Completar huecos</button>
      <button class="ex-opt-btn" data-type="choice">Elección múltiple</button>
      <button class="ex-opt-btn" data-type="transform">Transformación</button>
      <button class="ex-opt-btn" data-type="mix">Mixto</button>
    </div>
    <span class="ctrl-label">Foco</span>
    <div class="ex-options" id="foco-btns">
      <button class="ex-opt-btn foco active" data-foco="mix">General (todo)</button>
      <button class="ex-opt-btn foco" data-foco="formation">Formation du gérondif</button>
      <button class="ex-opt-btn foco" data-foco="emplois">Emplois (simultanéité / condition / manière)</button>
      <button class="ex-opt-btn foco" data-foco="tout">Tout en + gérondif (opposition/simultanéité)</button>
      <button class="ex-opt-btn foco" data-foco="pp">Participe présent vs. adjectif verbal</button>
      <button class="ex-opt-btn foco" data-foco="distinction">Gérondif vs. participe présent</button>
    </div>
    <span class="ctrl-label">Nivel</span>
    <div class="row-btns" id="diff-btns">
      <button class="pill-btn diff A2" onclick="setDiff('A2')">A2</button>
      <button class="pill-btn diff B1 active" onclick="setDiff('B1')">B1</button>
      <button class="pill-btn diff B2" onclick="setDiff('B2')">B2</button>
    </div>
    <span class="ctrl-label">Cantidad</span>
    <div class="row-btns" id="qty-btns">
      <button class="pill-btn qty" onclick="setQty(3)">3</button>
      <button class="pill-btn qty active" onclick="setQty(5)">5</button>
      <button class="pill-btn qty" onclick="setQty(8)">8</button>
    </div>
    <button class="btn-generate" id="btn-gen" onclick="generateExercises()">
      <span class="btn-icon">✨</span>
      <span class="spinner">⟳</span>
      Generar ejercicios
    </button>
  </div>
  <div class="progress-wrap" id="progress-wrap">
    <div class="progress-top">
      <span class="progress-label">Progreso</span>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="progress-frac" id="progress-frac">0 / 0</span>
        <button class="btn-retry" onclick="resetExercises()">↺ Nuevo</button>
      </div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="progress-score">
      <div class="score-item"><div class="score-dot g"></div><span id="score-correct">0 correctas</span></div>
      <div class="score-item"><div class="score-dot r"></div><span id="score-wrong">0 errores</span></div>
    </div>
  </div>
  <div class="final-score-bar" id="final-score-bar">
    <div><div class="final-num" id="final-num">—</div><div class="final-label">resultado final</div></div>
    <div class="final-track"><div class="final-fill" id="final-fill" style="width:0%"></div></div>
    <div class="final-msg" id="final-msg"></div>
  </div>
  <div class="exercise-area" id="exercise-area">
    <div class="state-msg">
      <div class="state-icon">✏️</div>
      <p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p>
    </div>
  </div>
</div>
</div>

<script>
const TRAPS = [
  {name:"Sujeto diferente entre gerundif y verbo principal",
   wrong:"En arrivant à la gare, le train était déjà parti.",
   right:"En arrivant à la gare, nous avons vu que le train était déjà parti.",
   expl:"El sujeto del gérondif <strong>debe ser siempre el mismo</strong> que el del verbo principal. <em>En arrivant</em> implica que quien llega es el mismo que el sujeto de la frase. <em>Le train</em> no puede llegar a sí mismo a la estación — el sujeto tiene que ser una persona."},
  {name:"Confundir gérondif y participe présent: olvidar EN",
   wrong:"Il travaille chantant. / Elle étudie écoutant de la musique.",
   right:"Il travaille en chantant. / Elle étudie en écoutant de la musique.",
   expl:"El <strong>gérondif siempre lleva EN</strong> delante de la forma en -ant. Sin <em>en</em>, la forma en -ant es un <em>participe présent</em>, que tiene un uso distinto (califica un nombre o introduce una proposición). <em>Chantant</em> solo = participe présent. <em>En chantant</em> = gérondif."},
  {name:"Formas irregulares: étant, ayant, sachant",
   wrong:"En être fatigué… / En avoir fini… / En savoir la réponse…",
   right:"En étant fatigué… / En ayant fini… / En sachant la réponse…",
   expl:"Las tres formas irregulares más importantes: <strong>être → étant</strong>, <strong>avoir → ayant</strong>, <strong>savoir → sachant</strong>. No se forman sobre la base del présent como las regulares. También: <em>pouvoir → pouvant</em>, <em>vouloir → voulant</em> (regulares desde leur base de présent)."},
  {name:"Tout en: confundir simultaneidad con oposición según el contexto",
   wrong:"Il a réussi tout en travaillant beaucoup. (si se quiere expresar oposición, no es incorrecto pero puede ser ambiguo)",
   right:"Il a réussi tout en ne travaillant pas beaucoup. (oposición clara) / Il a travaillé tout en écoutant de la musique. (simultaneidad)",
   expl:"<strong>Tout en + gérondif</strong> puede expresar tanto <em>simultaneidad</em> (mientras hace X al mismo tiempo) como <em>oposición/concesión</em> (a pesar de hacer X). El contexto determina el matiz. Con negación en la proposición de gérondif → oposición más clara."},
  {name:"Adjectif verbal vs. participe présent: acuerdo",
   wrong:"une femme souriant / des enfants fatiguants (sin acuerdo, como participe)",
   right:"une femme souriante / des enfants fatigants",
   expl:"Cuando la forma en -ant funciona como <strong>adjectif</strong> (califica un sustantivo), <strong>concuerda</strong> en género y número: <em>une femme souriante, des enfants fatigants</em>. Cuando es <strong>participe présent</strong> (introduce una proposición), es <strong>invariable</strong>: <em>une femme souriant à tout le monde</em>."},
  {name:"Gérondif con negación: posición de ne pas",
   wrong:"En ne pas répondant / En pas répondant",
   right:"En ne répondant pas / En ne disant rien",
   expl:"La negación del gérondif sigue la regla estándar: <strong>ne + gérondif + pas</strong>. La estructura es <em>en ne [forme en -ant] pas</em>. <em>En ne répondant pas</em> ✓ — <em>en ne pas répondant</em> ✗. Con <em>rien/personne/jamais</em>: <em>en ne disant rien</em> ✓."},
  {name:"Usar gérondif para expresar causa cuando hay otro conector más claro",
   wrong:"En étant malade, il n'est pas venu. (ambiguo: ¿causa o modo?)",
   right:"Étant malade, il n'est pas venu. (participe présent de causa, más claro) / Comme il était malade, il n'est pas venu.",
   expl:"El gérondif (<em>en + -ant</em>) expresa principalmente modo, simultaneidad o condición. Para la <strong>causa</strong>, es más preciso usar el <em>participe présent</em> sin <em>en</em> (<em>Étant malade</em>) o conectores causales (<em>parce que, comme, puisque</em>). El gérondif causal existe pero puede resultar ambiguo."},
  {name:"Formation: base incorrecte pour les verbes en -cer/-ger",
   wrong:"en commençant (correcto) pero en mangeant (correcto) — confusión en plurales",
   right:"en commençant (nous commençons → commençant ✓) / en mangeant (nous mangeons → mangeant ✓)",
   expl:"Para los verbos en <strong>-cer</strong>: la cédille se mantiene → <em>commencer → commençant</em>. Para los verbos en <strong>-ger</strong>: la e se mantiene → <em>manger → mangeant</em>. La base siempre es la 1ª persona plural del présent: <em>nous mangeons → mangeant</em>."},
];

function renderTraps() {
  document.getElementById("trap-cards").innerHTML = TRAPS.map(t =>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

function selectChip(ns, idx) {
  document.querySelectorAll(".chip-bar").forEach(bar => {
    const first = bar.querySelector(".chip");
    if (first && first.getAttribute("onclick") && first.getAttribute("onclick").includes("'" + ns + "'")) {
      bar.querySelectorAll(".chip").forEach((c, i) => c.classList.toggle("active", i === idx));
    }
  });
  const el = document.getElementById(ns + "-panels");
  if (el) el.querySelectorAll(":scope > .chip-panel").forEach((p, i) => p.classList.toggle("active", i === idx));
}
function showSection(id, btn) {
  document.querySelectorAll(".sec-block").forEach(s => s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode, btn) {
  document.querySelectorAll(".panel").forEach(p => p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("panel-" + mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display = mode === "ref" ? "" : "none";
}
function setFontSize(v) { document.documentElement.style.setProperty("--fs", v + "px"); }

let exType = "fill", exDiff = "B1", exQty = 5, exFoco = "mix";
let exTotal = 0, exAnswered = 0, exCorrect = 0, exWrong = 0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exType = this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b => b.addEventListener("click", function() {
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x => x.classList.remove("active"));
  this.classList.add("active"); exFoco = this.dataset.foco;
}));
function setDiff(d) {
  exDiff = d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b => {
    b.classList.remove("active","A2","B1","B2");
    if (b.textContent.trim() === d) b.classList.add("active", d);
  });
}
function setQty(q) {
  exQty = q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b =>
    b.classList.toggle("active", parseInt(b.textContent.trim()) === q));
}

const FOCO_DESC = {
  mix:        "todos los aspectos: formación del gérondif (base nous + -ant, irregulares étant/ayant/sachant), usos del gérondif (simultaneidad, modo, condición, causa), tout en + gérondif (oposición y simultaneidad), participe présent vs. adjectif verbal (acuerdo), distinción gérondif vs. participe présent",
  formation:  "formación del gérondif: base = 1ª persona plural présent menos -ons + -ant (ex: nous parlons → parlant → en parlant); irregulares: être→étant, avoir→ayant, savoir→sachant; ortografía: -cer→-çant, -ger→-geant; negación: en ne [forme] pas",
  emplois:    "usos del gérondif: simultaneidad (Il travaille en chantant), modo (Elle a réussi en travaillant dur), condición (En partant tôt, tu éviteras les embouteillages), cause (En étant fatigué — menos preciso); identificar el valor correcto según contexto",
  tout:       "tout en + gérondif: simultaneidad insistida (Il écoute tout en prenant des notes) vs. oposición/concesión (Elle a réussi tout en ayant peu de temps); distinción de los dos valores según contexto",
  pp:         "participe présent como adjectif verbal: acuerdo en género y número cuando califica un sustantivo (une femme souriante, des résultats surprenants); invariable como participe présent propositionnel (une femme souriant à la caméra)",
  distinction:"distinción gérondif vs. participe présent: gérondif = en + -ant, siempre mismo sujeto que el verbo principal, función adverbial; participe présent = solo -ant, puede tener sujeto propio, función adjetival o proposicional",
};
const TYPE_DESC = {
  fill:      "completar huecos: el alumno escribe el gérondif correcto (en + forme en -ant), el participe présent o elige entre las dos formas según el contexto",
  choice:    "elección múltiple: 4 opciones (gérondif / participe présent / adjectif verbal / infinitif), solo una correcta según la función en la frase",
  transform: "transformación: reformular la frase usando el gérondif o el participe présent indicado, con el valor semántico correcto (simultaneidad/modo/condición)",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS = {
  "s-intro":"Panorama","s-formation":"Formation","s-emplois":"Emplois du gérondif",
  "s-tout":"Tout en + gérondif","s-pp":"Participe présent","s-distinction":"Gér. vs. Part. présent","s-trampas":"Trampas"
};

function renderExercises(exs) {
  const area = document.getElementById("exercise-area");
  const labels = {fill:"Completar", choice:"Elección múltiple", transform:"Transformación"};
  area.innerHTML = exs.map((ex, i) =>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex, i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex, i) => {
    const chk = document.getElementById("chk-"+i);
    if (chk) chk.addEventListener("click", () => checkAnswer(ex, i));
    const inp = document.getElementById("inp-"+i);
    if (inp) inp.addEventListener("keydown", e => { if (e.key==="Enter") checkAnswer(ex, i); });
  });
}

function buildBody(ex, i) {
  if (ex.type === "fill") {
    const parts = ex.prompt_parts || ["",""];
    return `<div class="exercise-prompt">${parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||"…"}" autocomplete="off" spellcheck="false">${parts.slice(1).join("")}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  }
  if (ex.type === "choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if (ex.type === "transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase con gérondif…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}

function checkAnswer(ex, i) {
  const inp = document.getElementById("inp-"+i);
  if (!inp || inp.disabled) return;
  const ok = inp.value.trim().toLowerCase() === ex.answer.trim().toLowerCase();
  inp.classList.add(ok?"ok":"err"); inp.disabled = true;
  const chk = document.getElementById("chk-"+i); if (chk) chk.disabled = true;
  showFeedback(i, ok, ex.answer, ex.explanation, ex.rule_ref);
  recordAnswer(ok);
}

function selectChoice(idx, chosen, correct) {
  const c0 = document.getElementById(`ch-${idx}-0`);
  if (!c0 || c0.disabled) return;
  for (let j=0;j<4;j++) {
    const b = document.getElementById(`ch-${idx}-${j}`);
    if (!b) continue; b.disabled=true;
    if (j===correct) b.classList.add("ok"); else if(j===chosen) b.classList.add("err");
  }
  const card = document.getElementById("ex-card-"+idx);
  showFeedback(idx, chosen===correct, null, card.dataset.expl, card.dataset.rule);
  recordAnswer(chosen===correct);
}

function showFeedback(i, ok, ans, expl, ruleRef) {
  document.getElementById("ex-st-"+i).textContent = ok?"✅":"❌";
  const fb = document.getElementById("ex-fb-"+i);
  fb.className = "ex-feedback visible "+(ok?"ok":"err");
  const link = RULE_LABELS[ruleRef] ? `<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>` : "";
  let html = ok ? `<strong>✓ Correcto</strong>` : `<strong>✗ Incorrecto</strong>${ans?` — Respuesta: <strong>${ans}</strong>`:""}`;
  if (expl) html += `<br><span style="font-size:.88em;opacity:.92;margin-top:3px;display:block">${expl}</span>`;
  html += link; fb.innerHTML = html;
}

function goToRule(ref) {
  switchMode("ref", document.querySelector(".mode-btn"));
  setTimeout(() => {
    showSection(ref, document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:"smooth", block:"start"});
  }, 80);
}

function recordAnswer(ok) { exAnswered++; if(ok) exCorrect++; else exWrong++; updateProgress(); }

function updateProgress() {
  const pct = exTotal>0 ? (exAnswered/exTotal)*100 : 0;
  document.getElementById("progress-frac").textContent = `${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width = pct+"%";
  document.getElementById("score-correct").textContent = `${exCorrect} correcta${exCorrect!==1?"s":""}`;
  document.getElementById("score-wrong").textContent = `${exWrong} error${exWrong!==1?"es":""}`;
  if (exAnswered>=exTotal && exTotal>0) showFinalScore();
}

function showFinalScore() {
  const pct = Math.round((exCorrect/exTotal)*100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent = `${exCorrect} / ${exTotal}`;
  const fill = document.getElementById("final-fill");
  fill.style.width = pct+"%";
  fill.style.background = pct>=80?"var(--green)":pct>=50?"var(--accent)":"var(--red)";
  const msgs = {100:"Parfait ! Dominas el gérondif. 🎉",80:"Très bien ! Repasa los errores.",50:"Bien, refuerza los bloques señalados.",0:"Vuelve a Referencia antes de repetir."};
  document.getElementById("final-msg").textContent = msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById("score-pill").style.display = "";
  document.getElementById("score-pill-val").textContent = `${exCorrect}/${exTotal}`;
}

function resetExercises() {
  document.getElementById("exercise-area").innerHTML = `<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display = "none";
  exAnswered = 0; exCorrect = 0; exWrong = 0;
}

function esc(s) { return (s||"").replace(/"/g,"&quot;").replace(/</g,"&lt;"); }

renderTraps();
</script>
</body>
</html>
