<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Grammaire · Les Adverbes</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#ede9df;--card:#faf7f1;--border:#c4bead;
  --text:#1a1814;--text2:#44413a;--text3:#706c64;
  --accent:#7a5a0a;--accent-light:#f0e0c0;--accent-mid:#b89050;
  --warn-bg:#fdf0cc;
  --shadow:0 2px 14px rgba(0,0,0,.11),0 1px 4px rgba(0,0,0,.06);
  --shadow-sm:0 1px 6px rgba(0,0,0,.08);
  --radius:14px;--radius-sm:8px;
  --green:#1a6028;--green-bg:#e4f2e8;
  --red:#a81e2e;--red-bg:#fce6e8;
  --blue:#163494;--blue-bg:#e6ebf8;
  --purple:#6a1a8a;--purple-bg:#f2e6f8;
  --fo-color:#163494;--fo-bg:#e6ebf8;
  --po-color:#1a6028;--po-bg:#e4f2e8;
  --in-color:#6a1a8a;--in-bg:#f2e6f8;
  --li-color:#8b1a4a;--li-bg:#f8e6ee;
  --fs:15px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;font-size:var(--fs);}
.site-header{background:var(--card);border-bottom:2px solid var(--border);padding:20px 20px 14px;}
.header-top{display:flex;align-items:baseline;gap:10px;margin-bottom:3px;flex-wrap:wrap;}
.site-header h1{font-family:'Playfair Display',serif;font-size:clamp(1.2rem,5vw,1.9rem);font-weight:700;}
.header-tag{font-size:.68rem;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-mid);border-radius:20px;padding:3px 10px;}
.subtitle{font-size:.7rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);margin-bottom:12px;}
.stats-row{display:flex;flex-wrap:wrap;gap:7px;align-items:center;}
.stat-pill{border-radius:20px;padding:4px 11px;font-size:.76rem;font-weight:600;border:1px solid;}
.stat-pill.fo{background:var(--fo-bg);color:var(--fo-color);border-color:var(--fo-color);}
.stat-pill.po{background:var(--po-bg);color:var(--po-color);border-color:var(--po-color);}
.stat-pill.in{background:var(--in-bg);color:var(--in-color);border-color:var(--in-color);}
.stat-pill.li{background:var(--li-bg);color:var(--li-color);border-color:var(--li-color);}
.stat-pill.neu{background:var(--bg);color:var(--text2);border-color:var(--border);font-weight:500;}
.fs-wrap{display:flex;align-items:center;gap:7px;margin-left:auto;}
.fs-slider{width:76px;accent-color:var(--accent);cursor:pointer;}
.fs-sz{color:var(--text3);font-weight:700;}
.mode-toggle{display:flex;border-bottom:2px solid var(--border);background:var(--card);}
.mode-btn{flex:1;padding:12px 8px;font-family:'DM Sans',sans-serif;font-size:.84rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;margin-bottom:-2px;}
.mode-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.section-nav{position:sticky;top:0;z-index:200;background:var(--card);border-bottom:2px solid var(--border);box-shadow:var(--shadow-sm);}
.section-nav-inner{display:flex;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;}
.section-nav-inner::-webkit-scrollbar{display:none;}
.snav-btn{flex-shrink:0;padding:11px 16px;font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:600;color:var(--text3);background:transparent;border:none;border-bottom:3px solid transparent;cursor:pointer;transition:all .15s;white-space:nowrap;}
.snav-btn:hover{color:var(--text2);}
.snav-btn.active{color:var(--accent);border-bottom-color:var(--accent);}
.main-layout{max-width:860px;margin:0 auto;padding:16px 16px 40px;}
.panel{display:none;}.panel.active{display:block;}
.sec-block{display:none;}.sec-block.active{display:block;}
.gram-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:14px;overflow:hidden;}
.gram-card-body{padding:18px;}
.def-box{background:var(--warn-bg);border-left:4px solid var(--accent);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:12px 15px;margin-bottom:14px;line-height:1.65;}
.def-box strong{color:var(--accent);font-weight:700;}
.warn-box{background:#fff4e0;border:1px solid #c8900a;border-radius:var(--radius-sm);padding:10px 13px;margin:10px 0;font-size:.9em;display:flex;gap:8px;align-items:flex-start;}
.warn-icon{flex-shrink:0;margin-top:1px;}
.warn-text{color:var(--text2);line-height:1.55;}
.warn-text strong{color:#7a4400;font-weight:700;}
.note-box{background:var(--purple-bg);border-left:4px solid var(--purple);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.note-box strong{color:var(--purple);font-weight:700;}
.green-box{background:var(--green-bg);border-left:4px solid var(--green);border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:10px 0;font-size:.9em;color:var(--text2);line-height:1.55;}
.green-box strong{color:var(--green);font-weight:700;}
.example-block{border-radius:0 var(--radius-sm) var(--radius-sm) 0;padding:10px 14px;margin:8px 0;}
.example-block.fo{background:var(--fo-bg);border-left:4px solid var(--fo-color);}
.example-block.po{background:var(--po-bg);border-left:4px solid var(--po-color);}
.example-block.in{background:var(--in-bg);border-left:4px solid var(--in-color);}
.example-block.li{background:var(--li-bg);border-left:4px solid var(--li-color);}
.example-block.neu{background:var(--blue-bg);border-left:4px solid var(--blue);}
.ex-fr{font-weight:600;margin-bottom:3px;color:var(--text);}
.efo{color:var(--fo-color);font-weight:700;}
.epo{color:var(--po-color);font-weight:700;}
.ein{color:var(--in-color);font-weight:700;}
.eli{color:var(--li-color);font-weight:700;}
.ex-es{color:var(--text2);font-size:.88em;font-style:italic;}
.ex-note{font-size:.78em;color:var(--text3);margin-top:3px;font-weight:500;}
.table-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch;margin-bottom:14px;border-radius:var(--radius-sm);border:1px solid var(--border);}
.gram-table{width:100%;border-collapse:collapse;min-width:280px;}
.gram-table th{background:var(--bg);border-bottom:2px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;text-align:left;font-size:.72em;font-weight:700;letter-spacing:.06em;text-transform:uppercase;color:var(--text3);}
.gram-table td{border-bottom:1px solid var(--border);border-right:1px solid var(--border);padding:8px 11px;vertical-align:top;}
.gram-table tr:last-child td{border-bottom:none;}
.gram-table tr:nth-child(even) td{background:#f4f0e6;}
.gram-table td:last-child,.gram-table th:last-child{border-right:none;}
.hl-fo{color:var(--fo-color);font-weight:700;}
.hl-po{color:var(--po-color);font-weight:700;}
.hl-in{color:var(--in-color);font-weight:700;}
.hl-li{color:var(--li-color);font-weight:700;}
.hl{color:var(--accent);font-weight:700;}
.dim{color:var(--text3);font-size:.88em;}
.ok-cell{color:var(--green);font-weight:700;}
.err-cell{color:var(--red);font-weight:600;font-style:italic;}
.chip-bar{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.chip{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;white-space:nowrap;}
.chip:hover{border-color:var(--accent);background:var(--accent-light);color:var(--accent);}
.chip.active{background:var(--accent);color:#fff;border-color:var(--accent);}
.chip.fo.active{background:var(--fo-color);border-color:var(--fo-color);}
.chip.po.active{background:var(--po-color);border-color:var(--po-color);}
.chip.in.active{background:var(--in-color);border-color:var(--in-color);}
.chip.li.active{background:var(--li-color);border-color:var(--li-color);}
.chip-panel{display:none;}.chip-panel.active{display:block;}
.sec-label{font-size:.7em;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--text3);margin:14px 0 7px;}
.trap-cards{display:flex;flex-direction:column;gap:10px;}
.trap-card{border:1.5px solid var(--border);border-radius:var(--radius-sm);overflow:hidden;}
.trap-card-header{padding:11px 14px;background:var(--bg);}
.trap-name{font-weight:700;font-size:.9em;color:var(--text);margin-bottom:7px;}
.trap-vs{display:flex;gap:8px;flex-wrap:wrap;}
.trap-wrong{background:var(--red-bg);border:1.5px solid #d09098;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--red);font-weight:500;}
.trap-right{background:var(--green-bg);border:1.5px solid #80b890;border-radius:6px;padding:4px 10px;font-size:.82em;color:var(--green);font-weight:500;}
.trap-expl{padding:10px 14px 12px;font-size:.86em;color:var(--text2);line-height:1.6;border-top:1px solid var(--border);background:var(--card);}
.trap-expl strong{color:var(--text);font-weight:700;}
.exercise-controls{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:14px;box-shadow:var(--shadow-sm);}
.exercise-controls h3{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;margin-bottom:14px;}
.ctrl-label{font-size:.7em;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--text3);margin-bottom:7px;display:block;}
.ex-options{display:flex;flex-wrap:wrap;gap:7px;margin-bottom:14px;}
.ex-opt-btn{border:1.5px solid var(--border);border-radius:20px;padding:6px 14px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.ex-opt-btn.active{background:var(--accent);color:white;border-color:var(--accent);}
.row-btns{display:flex;gap:7px;margin-bottom:14px;flex-wrap:wrap;}
.pill-btn{border:1.5px solid var(--border);border-radius:20px;padding:5px 14px;font-family:'DM Sans',sans-serif;font-size:.82em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;}
.pill-btn:hover:not(.active){background:var(--border);}
.pill-btn.active{background:var(--text);color:var(--bg);border-color:var(--text);}
.pill-btn.diff.active.A2{background:var(--green);border-color:var(--green);color:#fff;}
.pill-btn.diff.active.B1{background:var(--blue);border-color:var(--blue);color:#fff;}
.pill-btn.diff.active.B2{background:var(--accent);border-color:var(--accent);color:#fff;}
.btn-generate{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;border:none;border-radius:10px;padding:13px;font-family:'DM Sans',sans-serif;font-size:.92em;font-weight:700;cursor:pointer;background:var(--accent);color:white;transition:all .18s;margin-top:4px;}
.btn-generate:hover:not(:disabled){filter:brightness(1.1);box-shadow:0 4px 14px rgba(122,90,10,.32);}
.btn-generate:disabled{opacity:.5;cursor:not-allowed;}
.spinner{display:none;animation:spin .8s linear infinite;}
.btn-generate.loading .spinner{display:inline;}
.btn-generate.loading .btn-icon{display:none;}
@keyframes spin{to{transform:rotate(360deg);}}
.progress-wrap{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:14px;display:none;}
.progress-wrap.visible{display:block;}
.progress-top{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
.progress-label{font-size:.78em;color:var(--text3);font-weight:600;}
.progress-frac{font-size:.92em;font-weight:700;color:var(--accent);}
.progress-track{height:7px;background:var(--border);border-radius:4px;overflow:hidden;}
.progress-fill{height:100%;background:var(--accent);border-radius:4px;transition:width .35s ease;}
.progress-score{display:flex;gap:14px;margin-top:9px;font-size:.8em;flex-wrap:wrap;align-items:center;}
.score-item{display:flex;align-items:center;gap:5px;font-weight:500;color:var(--text2);}
.score-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.score-dot.g{background:var(--green);}.score-dot.r{background:var(--red);}
.btn-retry{border:1.5px solid var(--border);border-radius:20px;padding:5px 13px;font-family:'DM Sans',sans-serif;font-size:.78em;font-weight:600;cursor:pointer;background:var(--bg);color:var(--text2);transition:all .15s;margin-left:auto;}
.btn-retry:hover{background:var(--border);}
.final-score-bar{display:none;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:16px 18px;margin-bottom:14px;}
.final-score-bar.visible{display:flex;align-items:center;gap:14px;flex-wrap:wrap;}
.final-num{font-size:1.5rem;font-weight:700;color:var(--accent);}
.final-label{font-size:.74em;color:var(--text3);}
.final-track{flex:1;min-width:80px;height:8px;background:var(--border);border-radius:4px;overflow:hidden;}
.final-fill{height:100%;border-radius:4px;transition:width .5s ease;}
.final-msg{font-size:.84em;color:var(--text2);width:100%;font-weight:500;}
.exercise-area{display:none;}.exercise-area.visible{display:block;}
.exercise-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow);margin-bottom:12px;overflow:hidden;}
.exercise-card-header{display:flex;align-items:center;gap:8px;padding:10px 16px;background:var(--bg);border-bottom:1px solid var(--border);}
.ex-num{font-weight:700;color:var(--accent);font-size:.88em;}
.ex-type-badge{font-size:.68em;font-weight:700;letter-spacing:.07em;text-transform:uppercase;background:var(--accent-light);color:var(--accent);border:1px solid var(--accent-mid);border-radius:12px;padding:2px 8px;}
.ex-diff-badge{font-size:.68em;font-weight:700;border-radius:12px;padding:2px 8px;}
.ex-diff-badge.A2{background:var(--green-bg);color:var(--green);border:1px solid #80b890;}
.ex-diff-badge.B1{background:var(--blue-bg);color:var(--blue);border:1px solid #90a8e0;}
.ex-diff-badge.B2{background:var(--warn-bg);color:var(--accent);border:1px solid var(--accent-mid);}
.ex-status{margin-left:auto;}
.exercise-body{padding:16px 18px;}
.exercise-prompt{line-height:1.7;margin-bottom:12px;color:var(--text);}
.exercise-prompt em{color:var(--accent);font-style:italic;font-weight:600;}
.fill-input{border:none;border-bottom:2px solid var(--accent-mid);background:var(--accent-light);padding:2px 8px;border-radius:4px 4px 0 0;font-family:'DM Sans',sans-serif;font-size:1em;color:var(--text);min-width:160px;outline:none;transition:border-color .15s;}
.fill-input:focus{border-bottom-color:var(--accent);}
.fill-input.ok{background:var(--green-bg);border-bottom-color:var(--green);}
.fill-input.err{background:var(--red-bg);border-bottom-color:var(--red);}
.choices-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-bottom:10px;}
.choice-btn{border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.88em;font-weight:500;cursor:pointer;text-align:left;background:var(--bg);color:var(--text);transition:all .15s;}
.choice-btn:hover:not(:disabled){border-color:var(--accent);background:var(--accent-light);}
.choice-btn.ok{background:var(--green-bg);border-color:var(--green);color:var(--green);font-weight:700;}
.choice-btn.err{background:var(--red-bg);border-color:var(--red);color:var(--red);}
.choice-btn:disabled{cursor:default;}
.transform-input{width:100%;border:1.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;font-family:'DM Sans',sans-serif;font-size:.9em;background:var(--bg);color:var(--text);outline:none;margin-bottom:8px;transition:border-color .15s;}
.transform-input:focus{border-color:var(--accent);}
.transform-input.ok{background:var(--green-bg);border-color:var(--green);}
.transform-input.err{background:var(--red-bg);border-color:var(--red);}
.btn-check{border:1.5px solid var(--accent);border-radius:20px;padding:7px 18px;font-family:'DM Sans',sans-serif;font-size:.84em;font-weight:700;cursor:pointer;background:transparent;color:var(--accent);transition:all .15s;}
.btn-check:hover:not(:disabled){background:var(--accent);color:white;}
.btn-check:disabled{opacity:.35;cursor:default;}
.ex-feedback{display:none;border-radius:var(--radius-sm);padding:11px 14px;line-height:1.55;margin-top:10px;font-size:.9em;}
.ex-feedback.visible{display:block;}
.ex-feedback.ok{background:var(--green-bg);border:1.5px solid #80b890;color:#0e4818;}
.ex-feedback.err{background:var(--red-bg);border:1.5px solid #c08090;color:#700018;}
.fb-rule-link{display:inline-flex;align-items:center;gap:4px;margin-top:8px;font-size:.84em;font-weight:700;color:var(--accent);cursor:pointer;text-decoration:underline;text-underline-offset:2px;}
.skeleton-card{background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:18px;margin-bottom:12px;}
.skel{background:linear-gradient(90deg,var(--border) 25%,#e6e0d4 50%,var(--border) 75%);background-size:200% 100%;animation:skel 1.4s infinite;border-radius:4px;height:13px;margin-bottom:9px;}
@keyframes skel{to{background-position:-200% 0;}}
.state-msg{text-align:center;padding:40px 20px;color:var(--text3);}
.state-icon{font-size:2rem;margin-bottom:10px;}
.state-msg p{max-width:260px;margin:0 auto;line-height:1.6;font-weight:500;}
</style>
</head>
<body>
<header class="site-header">
  <div class="header-top">
    <h1>Les Adverbes</h1>
    <span class="header-tag">Grammaire</span>
  </div>
  <div class="subtitle">Gramática francesa · DELF B1</div>
  <div class="stats-row">
    <div class="stat-pill fo">Formation en -ment</div>
    <div class="stat-pill po">Position</div>
    <div class="stat-pill in">Intensité / quantité</div>
    <div class="stat-pill li">Liaison logique</div>
    <div class="stat-pill neu" id="score-pill" style="display:none">Resultado: <span id="score-pill-val">—</span></div>
    <div class="fs-wrap">
      <span class="fs-sz" style="font-size:.75rem">A</span>
      <input class="fs-slider" type="range" min="12" max="20" value="15" oninput="setFontSize(this.value)">
      <span class="fs-sz" style="font-size:1.05rem">A</span>
    </div>
  </div>
</header>
<div class="mode-toggle">
  <button class="mode-btn active" onclick="switchMode('ref',this)">📖 Referencia</button>
</div>
<div class="section-nav" id="section-nav">
  <div class="section-nav-inner">
    <button class="snav-btn active" onclick="showSection('s-intro',this)">1. Panorama</button>
    <button class="snav-btn"        onclick="showSection('s-formation',this)">2. Formation en -ment</button>
    <button class="snav-btn"        onclick="showSection('s-position',this)">3. Position</button>
    <button class="snav-btn"        onclick="showSection('s-intensite',this)">4. Intensité / quantité</button>
    <button class="snav-btn"        onclick="showSection('s-liaison',this)">5. Adverbes de liaison</button>
    <button class="snav-btn"        onclick="showSection('s-trampas',this)">6. Trampas</button>
  </div>
</div>
<div class="main-layout">
<div class="panel active" id="panel-ref">
  <div class="sec-block active" id="s-intro">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los <strong>adverbes</strong> modifican un verbo, un adjectif o otro adverbe. Son invariables. Sus puntos críticos para el B1 son: la formación en <em>-ment</em>, la posición según el tiempo verbal, y el uso preciso de los adverbios de intensidad y de los adverbios de liaison en producción escrita.
      </div>

      <div class="sec-label">Clasificación por función</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Categoría</th><th>Ejemplos</th><th>Función</th></tr></thead>
        <tbody>
          <tr><td><strong class="hl-fo">Manière</strong></td><td>bien, mal, vite, lentement, facilement, clairement</td><td>Cómo se hace la acción</td></tr>
          <tr><td><strong class="hl-in">Intensité / quantité</strong></td><td>très, trop, assez, peu, beaucoup, si, tellement</td><td>Grado o cantidad</td></tr>
          <tr><td><strong class="hl-po">Temps</strong></td><td>hier, demain, souvent, toujours, déjà, encore, enfin, bientôt</td><td>Cuándo o con qué frecuencia</td></tr>
          <tr><td><strong class="hl-po">Lieu</strong></td><td>ici, là, partout, ailleurs, loin, près, dehors</td><td>Dónde</td></tr>
          <tr><td><strong class="hl-li">Liaison logique</strong></td><td>pourtant, cependant, donc, ainsi, d'ailleurs, en effet, en fait, notamment</td><td>Conectar ideas en el discurso</td></tr>
          <tr><td><strong class="hl-li">Modalité</strong></td><td>peut-être, probablement, certainement, heureusement, malheureusement</td><td>Actitud del hablante</td></tr>
        </tbody>
      </table></div>

      <div class="sec-label">Adverbes irréguliers — los más frecuentes</div>
      <div class="table-wrap"><table class="gram-table">
        <thead><tr><th>Adjectif / base</th><th>Adverbe</th><th>Ejemplo</th></tr></thead>
        <tbody>
          <tr><td>bon</td><td class="hl-fo">bien</td><td><em>Il parle <strong>bien</strong> français.</em></td></tr>
          <tr><td>mauvais</td><td class="hl-fo">mal</td><td><em>Ça s'est <strong>mal</strong> passé.</em></td></tr>
          <tr><td>—</td><td class="hl-fo">vite</td><td><em>Parle plus <strong>vite</strong> !</em></td></tr>
          <tr><td>—</td><td class="hl-fo">déjà / encore / toujours</td><td>adverbios de temps sin forma adjectival</td></tr>
        </tbody>
      </table></div>

      <div class="warn-box"><span class="warn-icon">💡</span>
        <div class="warn-text"><strong>Para el DELF B1:</strong> los adverbios de liaison (<em>pourtant, cependant, donc, d'ailleurs, en effet, en fait</em>) son los que más impacto tienen en la nota de producción escrita. Usarlos bien demuestra coherencia argumentativa.</div>
      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-formation">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La mayoría de los adverbios de manera se forman añadiendo <strong>-ment</strong> al adjectif. La base es el adjectif en forma <strong>femenina</strong>. Hay tres reglas específicas para los adjectivos en <em>-ent</em> y <em>-ant</em>.
      </div>

      <div class="chip-bar">
        <button class="chip fo active" onclick="selectChip('form',0)">Règle générale (fém. + -ment)</button>
        <button class="chip fo"        onclick="selectChip('form',1)">-ent → -emment</button>
        <button class="chip fo"        onclick="selectChip('form',2)">-ant → -amment</button>
        <button class="chip fo"        onclick="selectChip('form',3)">Cas particuliers et irréguliers</button>
      </div>
      <div id="form-panels">

        <div class="chip-panel active" id="form-p-0">
          <div class="green-box">
            <strong>Fórmula:</strong> adjectif féminin → adverbe en -ment<br>
            <em>lent → lente → lentement / heureux → heureuse → heureusement</em>
          </div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adjectif masc.</th><th>Adjectif fém.</th><th>Adverbe</th></tr></thead>
            <tbody>
              <tr><td>lent</td><td>lente</td><td class="hl-fo">lentement</td></tr>
              <tr><td>heureux</td><td>heureuse</td><td class="hl-fo">heureusement</td></tr>
              <tr><td>doux</td><td>douce</td><td class="hl-fo">doucement</td></tr>
              <tr><td>seul</td><td>seule</td><td class="hl-fo">seulement</td></tr>
              <tr><td>clair</td><td>claire</td><td class="hl-fo">clairement</td></tr>
              <tr><td>rapide</td><td>rapide</td><td class="hl-fo">rapidement</td></tr>
              <tr><td>facile</td><td>facile</td><td class="hl-fo">facilement</td></tr>
              <tr><td>triste</td><td>triste</td><td class="hl-fo">tristement</td></tr>
            </tbody>
          </table></div>
          <div class="example-block fo">
            <div class="ex-fr">Il parle <span class="efo">doucement</span> pour ne pas réveiller les enfants.</div>
            <div class="ex-es">Habla suavemente para no despertar a los niños.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr"><span class="efo">Heureusement</span>, personne n'a été blessé dans l'accident.</div>
            <div class="ex-es">Afortunadamente, nadie resultó herido en el accidente.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Elle a <span class="efo">clairement</span> expliqué sa position lors de la réunion.</div>
            <div class="ex-es">Explicó claramente su postura en la reunión.</div>
          </div>
        </div>

        <div class="chip-panel" id="form-p-1">
          <div class="def-box">Los adjectivos terminados en <strong>-ent</strong> forman el adverbio con <strong>-emment</strong> (pronunciado /amɑ̃/, igual que -amment).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adjectif (-ent)</th><th>Adverbe (-emment)</th></tr></thead>
            <tbody>
              <tr><td>prudent</td><td class="hl-fo">prudemment</td></tr>
              <tr><td>évident</td><td class="hl-fo">évidemment</td></tr>
              <tr><td>récent</td><td class="hl-fo">récemment</td></tr>
              <tr><td>fréquent</td><td class="hl-fo">fréquemment</td></tr>
              <tr><td>violent</td><td class="hl-fo">violemment</td></tr>
              <tr><td>patient</td><td class="hl-fo">patiemment</td></tr>
              <tr><td>différent</td><td class="hl-fo">différemment</td></tr>
              <tr><td>apparent</td><td class="hl-fo">apparemment</td></tr>
            </tbody>
          </table></div>
          <div class="example-block fo">
            <div class="ex-fr">Il faut conduire <span class="efo">prudemment</span> par ce temps.</div>
            <div class="ex-es">Hay que conducir con prudencia con este tiempo.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr"><span class="efo">Évidemment</span>, ce n'était pas la meilleure décision.</div>
            <div class="ex-es">Evidentemente, no era la mejor decisión.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Ce problème se pose <span class="efo">fréquemment</span> dans ce secteur.</div>
            <div class="ex-es">Este problema se plantea con frecuencia en este sector.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text">Excepción notable: <em>lent → lentement</em> (no lentement ✓ — no sigue la regla -emment a pesar de terminar en -nt). <em>Présent → présentement</em> (arcaico). <em>Véhément → véhémentement</em> (raro).</div></div>
        </div>

        <div class="chip-panel" id="form-p-2">
          <div class="def-box">Los adjectivos terminados en <strong>-ant</strong> forman el adverbio con <strong>-amment</strong> (pronunciado /amɑ̃/, igual que -emment).</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adjectif (-ant)</th><th>Adverbe (-amment)</th></tr></thead>
            <tbody>
              <tr><td>courant</td><td class="hl-fo">couramment</td></tr>
              <tr><td>brillant</td><td class="hl-fo">brillamment</td></tr>
              <tr><td>suffisant</td><td class="hl-fo">suffisamment</td></tr>
              <tr><td>constant</td><td class="hl-fo">constamment</td></tr>
              <tr><td>savant</td><td class="hl-fo">savamment</td></tr>
              <tr><td>abondant</td><td class="hl-fo">abondamment</td></tr>
              <tr><td>élégant</td><td class="hl-fo">élégamment</td></tr>
              <tr><td>méchant</td><td class="hl-fo">méchamment</td></tr>
            </tbody>
          </table></div>
          <div class="example-block fo">
            <div class="ex-fr">Elle parle <span class="efo">couramment</span> trois langues.</div>
            <div class="ex-es">Habla tres idiomas con fluidez.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Il a <span class="efo">brillamment</span> défendu sa thèse devant le jury.</div>
            <div class="ex-es">Defendió brillantemente su tesis ante el tribunal.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Tu as <span class="efo">suffisamment</span> de temps pour finir ce soir.</div>
            <div class="ex-es">Tienes tiempo suficiente para terminar esta noche.</div>
          </div>
          <div class="note-box"><strong>Pronunciación idéntica:</strong> <em>-emment</em> y <em>-amment</em> se pronuncian igual: /amɑ̃/. <em>Prudemment = couramment</em> en cuanto a sonido.</div>
        </div>

        <div class="chip-panel" id="form-p-3">
          <div class="def-box">Algunos adverbios tienen formas especiales o se forman de manera distinta.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Base</th><th>Adverbe</th><th>Nota</th></tr></thead>
            <tbody>
              <tr><td>bon</td><td class="hl-fo">bien</td><td>irregular — no <em>bonnement</em></td></tr>
              <tr><td>mauvais</td><td class="hl-fo">mal</td><td>irregular — no <em>mauvaisement</em></td></tr>
              <tr><td>petit</td><td class="hl-fo">peu</td><td>irregular — no <em>petitement</em> (corriente)</td></tr>
              <tr><td>—</td><td class="hl-fo">vite</td><td>adverbio sin adjectif correspondiente</td></tr>
              <tr><td>gentil</td><td class="hl-fo">gentiment</td><td>gentille → supprime -le → gentiment</td></tr>
              <tr><td>précis</td><td class="hl-fo">précisément</td><td>précise + ment (regular)</td></tr>
              <tr><td>énorme</td><td class="hl-fo">énormément</td><td>énorme → ajoute -ment directement</td></tr>
              <tr><td>profond</td><td class="hl-fo">profondément</td><td>profonde → accent sur le e</td></tr>
            </tbody>
          </table></div>
          <div class="example-block fo">
            <div class="ex-fr">Il a <span class="efo">gentiment</span> proposé de nous aider.</div>
            <div class="ex-es">Amablemente se ofreció a ayudarnos.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Elle est <span class="efo">profondément</span> convaincue de ses idées.</div>
            <div class="ex-es">Está profundamente convencida de sus ideas.</div>
          </div>
          <div class="example-block fo">
            <div class="ex-fr">Il a <span class="efo">énormément</span> progressé cette année.</div>
            <div class="ex-es">Ha progresado enormemente este año.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-position">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        La posición del adverbio en francés es uno de los aspectos más problemáticos para hispanohablantes. La regla clave: en los <strong>temps composés</strong>, los adverbios cortos van <strong>entre el auxiliar y el participio</strong>.
      </div>

      <div class="chip-bar">
        <button class="chip po active" onclick="selectChip('pos',0)">Temps simples</button>
        <button class="chip po"        onclick="selectChip('pos',1)">Temps composés — adverbes courts</button>
        <button class="chip po"        onclick="selectChip('pos',2)">Temps composés — adverbes longs</button>
        <button class="chip po"        onclick="selectChip('pos',3)">Adverbes de phrase (début de frase)</button>
      </div>
      <div id="pos-panels">

        <div class="chip-panel active" id="pos-p-0">
          <div class="def-box">En temps simples, el adverbio va generalmente <strong>después del verbo conjugado</strong>. Los adverbios de temps y lieu suelen ir al final de la frase.</div>
          <div class="example-block po">
            <div class="ex-fr">Il travaille <span class="epo">beaucoup</span>.</div>
            <div class="ex-es">Trabaja mucho.</div>
            <div class="ex-note">beaucoup après le verbe ✓</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Elle parle <span class="epo">bien</span> le français.</div>
            <div class="ex-es">Habla bien el francés.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Il mange <span class="epo">vite</span> le matin.</div>
            <div class="ex-es">Come rápido por la mañana.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Ils se voient <span class="epo">souvent</span> le week-end.</div>
            <div class="ex-es">Se ven a menudo el fin de semana.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Elle comprend <span class="epo">facilement</span> les concepts abstraits.</div>
            <div class="ex-es">Entiende fácilmente los conceptos abstractos.</div>
          </div>
        </div>

        <div class="chip-panel" id="pos-p-1">
          <div class="def-box">En temps composés (passé composé, PQP…), los adverbios <strong>cortos</strong> van <strong>entre el auxiliar y el participio pasado</strong>. Esta posición es obligatoria para los adverbios de la lista.</div>
          <div class="green-box">
            <strong>Lista de adverbios cortos → entre auxiliaire y p.p.:</strong><br>
            bien, mal, vite, déjà, encore, toujours, souvent, jamais, beaucoup, peu, trop, assez, vraiment, presque, enfin, bientôt
          </div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Incorrecto ✗</th><th>Correcto ✓</th></tr></thead>
            <tbody>
              <tr><td>Il a travaillé <span class="err-cell">beaucoup</span>.</td><td>Il a <span class="hl-po">beaucoup</span> travaillé.</td></tr>
              <tr><td>Elle a parlé <span class="err-cell">bien</span>.</td><td>Elle a <span class="hl-po">bien</span> parlé.</td></tr>
              <tr><td>On a mangé <span class="err-cell">vite</span>.</td><td>On a <span class="hl-po">vite</span> mangé.</td></tr>
              <tr><td>Il a fini <span class="err-cell">déjà</span>.</td><td>Il a <span class="hl-po">déjà</span> fini.</td></tr>
            </tbody>
          </table></div>
          <div class="example-block po">
            <div class="ex-fr">Il a <span class="epo">beaucoup</span> travaillé cette semaine.</div>
            <div class="ex-es">Ha trabajado mucho esta semana.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Elle a <span class="epo">bien</span> répondu à toutes les questions.</div>
            <div class="ex-es">Ha respondido bien a todas las preguntas.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Ils ont <span class="epo">déjà</span> visité ce musée.</div>
            <div class="ex-es">Ya han visitado ese museo.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Elle avait <span class="epo">toujours</span> rêvé de voyager en Asie.</div>
            <div class="ex-es">Siempre había soñado con viajar a Asia.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">J'ai <span class="epo">vraiment</span> apprécié ce repas.</div>
            <div class="ex-es">He apreciado de verdad esta comida.</div>
          </div>
        </div>

        <div class="chip-panel" id="pos-p-2">
          <div class="def-box">Los adverbios <strong>largos</strong> (temps, lieu, manière en <em>-ment</em>) van <strong>después del participio pasado</strong> en los temps composés.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Tipo</th><th>Posición</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Adverbes de temps</td><td>après le p.p.</td><td><em>Il est arrivé <span class="hl-po">hier</span>.</em></td></tr>
              <tr><td>Adverbes de lieu</td><td>après le p.p.</td><td><em>Elle est allée <span class="hl-po">là-bas</span>.</em></td></tr>
              <tr><td>Adverbes en -ment (longs)</td><td>après le p.p.</td><td><em>Il a répondu <span class="hl-po">prudemment</span>.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block po">
            <div class="ex-fr">Elle est partie <span class="epo">hier soir</span>.</div>
            <div class="ex-es">Se marchó ayer por la noche.</div>
            <div class="ex-note">hier soir (temps) → après le p.p. ✓</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Il a répondu <span class="epo">intelligemment</span> à la question.</div>
            <div class="ex-es">Respondió de forma inteligente a la pregunta.</div>
            <div class="ex-note">intelligemment (-ment long) → après le p.p. ✓</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Ils se sont rencontrés <span class="epo">ici</span> pour la première fois.</div>
            <div class="ex-es">Se conocieron aquí por primera vez.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr">Elle a expliqué <span class="epo">clairement</span> sa position.</div>
            <div class="ex-es">Ha explicado claramente su postura.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">💡</span><div class="warn-text"><strong>Regla rápida:</strong> ¿el adverbio tiene menos de 3 sílabas y es de cantidad/frecuencia/modo básico? → va entre aux. y p.p. ¿Es un adverbio de tiempo, lugar o un -ment largo? → va después del p.p.</div></div>
        </div>

        <div class="chip-panel" id="pos-p-3">
          <div class="def-box">Algunos adverbios van al <strong>inicio de la frase</strong> (antes del sujeto) para enmarcar la modalidad o actitud del hablante. Van seguidos de coma.</div>
          <div class="example-block po">
            <div class="ex-fr"><span class="epo">Malheureusement,</span> il n'a pas pu venir.</div>
            <div class="ex-es">Desgraciadamente, no pudo venir.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr"><span class="epo">Heureusement,</span> personne n'a été blessé.</div>
            <div class="ex-es">Afortunadamente, nadie resultó herido.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr"><span class="epo">Évidemment,</span> il avait raison.</div>
            <div class="ex-es">Evidentemente, tenía razón.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr"><span class="epo">Peut-être</span> qu'il viendra demain.</div>
            <div class="ex-es">Quizás venga mañana.</div>
            <div class="ex-note">Peut-être que + ordre normal. Peut-être seul → inversión: Peut-être viendra-t-il.</div>
          </div>
          <div class="example-block po">
            <div class="ex-fr"><span class="epo">Probablement,</span> les résultats seront publiés demain.</div>
            <div class="ex-es">Probablemente, los resultados se publicarán mañana.</div>
          </div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-intensite">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los adverbios de intensidad modifican adjectivos, adverbios o verbos para expresar el grado. Sus matices y diferencias son frecuentemente examinados en el DELF B1.
      </div>

      <div class="chip-bar">
        <button class="chip in active" onclick="selectChip('int',0)">Très / trop / assez / peu</button>
        <button class="chip in"        onclick="selectChip('int',1)">Si / tellement / tant</button>
        <button class="chip in"        onclick="selectChip('int',2)">Vraiment / absolument / tout à fait</button>
        <button class="chip in"        onclick="selectChip('int',3)">Grados y escala</button>
      </div>
      <div id="int-panels">

        <div class="chip-panel active" id="int-p-0">
          <div class="def-box">Los cuatro adverbios de grado más frecuentes con sus matices precisos.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Significado</th><th>Construcción</th></tr></thead>
            <tbody>
              <tr><td class="hl-in">très</td><td>muy</td><td>très + adj/adv (no con verbe ni nombre)</td></tr>
              <tr><td class="hl-in">trop</td><td>demasiado</td><td>trop + adj/adv/verbe/nome; a menudo + pour + inf.</td></tr>
              <tr><td class="hl-in">assez</td><td>bastante</td><td>assez + adj/adv; assez de + nom</td></tr>
              <tr><td class="hl-in">peu</td><td>poco</td><td>peu + adj/adv; peu de + nom</td></tr>
            </tbody>
          </table></div>
          <div class="example-block in">
            <div class="ex-fr">Ce film est <span class="ein">très</span> intéressant.</div>
            <div class="ex-es">Esta película es muy interesante.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Il est <span class="ein">trop</span> fatigué pour sortir ce soir.</div>
            <div class="ex-es">Está demasiado cansado para salir esta noche.</div>
            <div class="ex-note">trop + adj + pour + inf. → impedimento</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Elle est <span class="ein">assez</span> compétente pour ce poste.</div>
            <div class="ex-es">Es bastante competente para ese puesto.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Il parle <span class="ein">peu</span> mais il écoute beaucoup.</div>
            <div class="ex-es">Habla poco pero escucha mucho.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">J'ai <span class="ein">trop</span> mangé — je me sens mal.</div>
            <div class="ex-es">He comido demasiado — me siento mal.</div>
            <div class="ex-note">trop + verbe = haber hecho demasiado</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><strong>Très vs. trop:</strong> <em>très</em> = muy (grado alto, neutro). <em>Trop</em> = demasiado (exceso negativo, que impide algo). <em>C'est très bon !</em> (es muy bueno). <em>C'est trop cher pour moi</em> (es demasiado caro para mí). En oral coloquial, <em>trop</em> se usa como 'muy' pero en el escrito formal es error.</div></div>
        </div>

        <div class="chip-panel" id="int-p-1">
          <div class="def-box"><strong>Si</strong> (tan) precede adjectivos y adverbios. <strong>Tellement</strong> (tanto/tan) precede adjectivos, adverbios y verbos. <strong>Tant</strong> (tanto) precede verbos. Los tres pueden ir ante <em>que</em> consecutivo.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Ante qué</th><th>Con que consecutivo</th></tr></thead>
            <tbody>
              <tr><td class="hl-in">si</td><td>adj / adv</td><td>si + adj/adv + que ✓</td></tr>
              <tr><td class="hl-in">tellement</td><td>adj / adv / verbe</td><td>tellement + adj/adv/verbe + que ✓</td></tr>
              <tr><td class="hl-in">tant</td><td>verbe</td><td>tant + verbe + que ✓</td></tr>
            </tbody>
          </table></div>
          <div class="example-block in">
            <div class="ex-fr">Il est <span class="ein">si</span> intelligent qu'il résout tout facilement.</div>
            <div class="ex-es">Es tan inteligente que lo resuelve todo con facilidad.</div>
            <div class="ex-note">si + adj (intelligent) + que consecutivo</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Elle était <span class="ein">tellement</span> fatiguée qu'elle s'est endormie en classe.</div>
            <div class="ex-es">Estaba tan cansada que se quedó dormida en clase.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Il a <span class="ein">tellement</span> travaillé qu'il est épuisé.</div>
            <div class="ex-es">Ha trabajado tanto que está agotado.</div>
            <div class="ex-note">tellement + verbe ✓ — si + verbe ✗</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Elle a <span class="ein">tant</span> souffert qu'elle ne veut plus en parler.</div>
            <div class="ex-es">Ha sufrido tanto que ya no quiere hablar de ello.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr"><span class="ein">Si</span> seulement tu m'avais écouté !</div>
            <div class="ex-es">¡Si tan solo me hubieras escuchado!</div>
            <div class="ex-note">si seulement = ojalá (sin que consecutivo)</div>
          </div>
        </div>

        <div class="chip-panel" id="int-p-2">
          <div class="def-box">Adverbios de confirmación y énfasis total. Útiles en producción escrita para argumentar.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Significado</th><th>Registro</th></tr></thead>
            <tbody>
              <tr><td class="hl-in">vraiment</td><td>verdaderamente, de verdad</td><td>neutro</td></tr>
              <tr><td class="hl-in">absolument</td><td>absolutamente</td><td>neutro/formal</td></tr>
              <tr><td class="hl-in">tout à fait</td><td>totalmente, en absoluto</td><td>neutro/formal</td></tr>
              <tr><td class="hl-in">particulièrement</td><td>particularmente, especialmente</td><td>formal</td></tr>
              <tr><td class="hl-in">notamment</td><td>especialmente, en particular</td><td>formal/escrito</td></tr>
              <tr><td class="hl-in">pas du tout</td><td>en absoluto</td><td>neutro</td></tr>
            </tbody>
          </table></div>
          <div class="example-block in">
            <div class="ex-fr">C'est <span class="ein">vraiment</span> une excellente idée.</div>
            <div class="ex-es">Es realmente una excelente idea.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Je suis <span class="ein">tout à fait</span> d'accord avec votre analyse.</div>
            <div class="ex-es">Estoy completamente de acuerdo con su análisis.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Ce phénomène touche <span class="ein">particulièrement</span> les jeunes.</div>
            <div class="ex-es">Este fenómeno afecta especialmente a los jóvenes.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">Il existe plusieurs solutions, <span class="ein">notamment</span> la formation professionnelle.</div>
            <div class="ex-es">Existen varias soluciones, en particular la formación profesional.</div>
          </div>
        </div>

        <div class="chip-panel" id="int-p-3">
          <div class="def-box">Escala de intensidad de menor a mayor, y grados comparativos de los adverbios.</div>
          <div class="sec-label">Escala de intensidad</div>
          <div class="pos-diagram" style="display:flex;align-items:center;gap:5px;flex-wrap:wrap;background:var(--bg);border:1.5px solid var(--border);border-radius:8px;padding:12px 14px;margin:10px 0;">
            <span style="background:var(--in-bg);border:1.5px solid var(--in-color);color:var(--in-color);border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82em">un peu</span>
            <span style="color:var(--text3);font-size:.9em;font-weight:700">→</span>
            <span style="background:var(--in-bg);border:1.5px solid var(--in-color);color:var(--in-color);border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82em">assez</span>
            <span style="color:var(--text3);font-size:.9em;font-weight:700">→</span>
            <span style="background:var(--in-bg);border:1.5px solid var(--in-color);color:var(--in-color);border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82em">très / vraiment</span>
            <span style="color:var(--text3);font-size:.9em;font-weight:700">→</span>
            <span style="background:var(--in-bg);border:1.5px solid var(--in-color);color:var(--in-color);border-radius:6px;padding:4px 10px;font-weight:700;font-size:.82em">trop (exceso)</span>
          </div>
          <div class="sec-label">Grados comparativos de adverbios</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Grado</th><th>Estructura</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td>Comparatif supériorité</td><td>plus + adv + que</td><td><em>Il travaille <span class="hl-in">plus vite</span> que moi.</em></td></tr>
              <tr><td>Comparatif infériorité</td><td>moins + adv + que</td><td><em>Elle parle <span class="hl-in">moins vite</span> que lui.</em></td></tr>
              <tr><td>Comparatif égalité</td><td>aussi + adv + que</td><td><em>Il réfléchit <span class="hl-in">aussi bien</span> que toi.</em></td></tr>
              <tr><td>Superlatif</td><td>le plus / le moins + adv</td><td><em>C'est lui qui travaille <span class="hl-in">le plus vite</span>.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block in">
            <div class="ex-fr">Elle court <span class="ein">plus vite</span> que son frère.</div>
            <div class="ex-es">Corre más rápido que su hermano.</div>
          </div>
          <div class="example-block in">
            <div class="ex-fr">C'est le candidat qui s'est exprimé <span class="ein">le plus clairement</span>.</div>
            <div class="ex-es">Es el candidato que se expresó con más claridad.</div>
          </div>
          <div class="note-box"><strong>Irregulares en comparatif:</strong> <em>bien → mieux</em> (mejor). <em>mal → pis / plus mal</em> (peor). <em>Je parle mieux le français qu'avant</em> ✓ — <em>plus bien</em> ✗.</div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-liaison">
    <div class="gram-card"><div class="gram-card-body">
      <div class="def-box">
        Los <strong>adverbes de liaison</strong> organizan el discurso y conectan las ideas en producción escrita. Usarlos correctamente es lo que más eleva la nota de cohésion et cohérence en el DELF. Cada uno tiene un valor argumentativo preciso — no son intercambiables.
      </div>

      <div class="chip-bar">
        <button class="chip li active" onclick="selectChip('lia',0)">Opposition (pourtant / cependant…)</button>
        <button class="chip li"        onclick="selectChip('lia',1)">Conséquence (donc / ainsi…)</button>
        <button class="chip li"        onclick="selectChip('lia',2)">Addition (de plus / d'ailleurs…)</button>
        <button class="chip li"        onclick="selectChip('lia',3)">Illustration / reformulation (en effet / en fait…)</button>
      </div>
      <div id="lia-panels">

        <div class="chip-panel active" id="lia-p-0">
          <div class="def-box">Introducen una idea que contrasta o limita lo que se acaba de decir.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Significado</th><th>Registro</th></tr></thead>
            <tbody>
              <tr><td class="hl-li">pourtant</td><td>sin embargo, pero</td><td>neutro / oral y escrito</td></tr>
              <tr><td class="hl-li">cependant</td><td>sin embargo, no obstante</td><td>formal / escrito</td></tr>
              <tr><td class="hl-li">néanmoins</td><td>no obstante, con todo</td><td>muy formal / escrito argumentativo</td></tr>
              <tr><td class="hl-li">toutefois</td><td>no obstante, sin embargo</td><td>formal / escrito</td></tr>
              <tr><td class="hl-li">quand même</td><td>de todas formas, igualmente</td><td>neutro / oral</td></tr>
            </tbody>
          </table></div>
          <div class="example-block li">
            <div class="ex-fr">Il a beaucoup travaillé ; <span class="eli">pourtant</span>, il n'a pas réussi.</div>
            <div class="ex-es">Trabajó mucho; sin embargo, no tuvo éxito.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Ce projet est ambitieux ; <span class="eli">cependant</span>, il semble réalisable.</div>
            <div class="ex-es">Este proyecto es ambicioso; sin embargo, parece realizable.</div>
            <div class="ex-note">cependant — más formal que pourtant</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Les résultats sont décevants ; <span class="eli">néanmoins</span>, des progrès ont été accomplis.</div>
            <div class="ex-es">Los resultados son decepcionantes; no obstante, se han realizado progresos.</div>
            <div class="ex-note">néanmoins — nivel B2, muy formal</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Il pleuvait ; <span class="eli">quand même</span>, ils sont sortis se promener.</div>
            <div class="ex-es">Llovía; de todas formas, salieron a pasear.</div>
          </div>
          <div class="note-box"><strong>Para el DELF B1:</strong> <em>pourtant</em> es suficiente. Usar <em>cependant</em> mejora la nota. <em>Néanmoins</em> es nivel B2.</div>
        </div>

        <div class="chip-panel" id="lia-p-1">
          <div class="def-box">Introducen la consecuencia lógica de lo que se acaba de decir.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Significado</th><th>Registro</th></tr></thead>
            <tbody>
              <tr><td class="hl-li">donc</td><td>por tanto, así que</td><td>neutro / oral y escrito</td></tr>
              <tr><td class="hl-li">ainsi</td><td>así pues, de esta manera</td><td>formal / escrito</td></tr>
              <tr><td class="hl-li">c'est pourquoi</td><td>es por eso que, por eso</td><td>neutro / escrito</td></tr>
              <tr><td class="hl-li">par conséquent</td><td>en consecuencia, por consiguiente</td><td>formal / escrito</td></tr>
              <tr><td class="hl-li">du coup</td><td>así que, entonces</td><td>oral / coloquial</td></tr>
            </tbody>
          </table></div>
          <div class="example-block li">
            <div class="ex-fr">Il n'a pas étudié ; <span class="eli">donc</span>, il a échoué à l'examen.</div>
            <div class="ex-es">No estudió; por tanto, suspendió el examen.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Il était malade ; <span class="eli">c'est pourquoi</span> il n'est pas venu.</div>
            <div class="ex-es">Estaba enfermo; es por eso que no vino.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">La situation est préoccupante ; <span class="eli">par conséquent</span>, des mesures s'imposent.</div>
            <div class="ex-es">La situación es preocupante; en consecuencia, se imponen medidas.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr"><span class="eli">Ainsi</span>, on peut conclure que cette approche est efficace.</div>
            <div class="ex-es">Así pues, se puede concluir que este enfoque es eficaz.</div>
          </div>
          <div class="note-box"><strong>Posición de donc:</strong> puede ir al inicio de la frase, después del sujeto o al final. <em>Il est donc parti</em>. <em>Donc, il est parti</em>. <em>Il est parti, donc</em>.</note-box>
        </div>

        <div class="chip-panel" id="lia-p-2">
          <div class="def-box">Añaden un argumento suplementario o una información adicional que refuerza la idea.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Significado</th><th>Registro</th></tr></thead>
            <tbody>
              <tr><td class="hl-li">de plus</td><td>además, encima</td><td>neutro / escrito</td></tr>
              <tr><td class="hl-li">en outre</td><td>además, por otra parte</td><td>formal / escrito</td></tr>
              <tr><td class="hl-li">d'ailleurs</td><td>además, por otra parte, dicho sea de paso</td><td>neutro</td></tr>
              <tr><td class="hl-li">également</td><td>también, asimismo</td><td>neutro/formal</td></tr>
              <tr><td class="hl-li">notamment</td><td>especialmente, en particular</td><td>formal / escrito</td></tr>
            </tbody>
          </table></div>
          <div class="example-block li">
            <div class="ex-fr">Ce quartier est calme ; <span class="eli">de plus</span>, il est bien desservi par les transports.</div>
            <div class="ex-es">Este barrio es tranquilo; además, está bien comunicado.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Il est compétent et, <span class="eli">d'ailleurs</span>, tout le monde le reconnaît.</div>
            <div class="ex-es">Es competente y, además, todo el mundo lo reconoce.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Ce problème touche de nombreux pays, <span class="eli">notamment</span> ceux en voie de développement.</div>
            <div class="ex-es">Este problema afecta a numerosos países, en particular los que están en vías de desarrollo.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Il parle français et <span class="eli">également</span> espagnol et italien.</div>
            <div class="ex-es">Habla francés y también español e italiano.</div>
          </div>
        </div>

        <div class="chip-panel" id="lia-p-3">
          <div class="def-box">Ilustran, confirman, corrigen o reformulan lo que se acaba de decir. Los más confundidos: <em>en effet</em> vs. <em>en fait</em>.</div>
          <div class="table-wrap"><table class="gram-table">
            <thead><tr><th>Adverbe</th><th>Función</th><th>Ejemplo</th></tr></thead>
            <tbody>
              <tr><td class="hl-li">en effet</td><td>efectivamente, en efecto (confirma)</td><td><em>Il était absent. <strong>En effet</strong>, il était malade.</em></td></tr>
              <tr><td class="hl-li">en fait</td><td>en realidad, de hecho (corrige o matiza)</td><td><em>On pensait qu'il était riche. <strong>En fait</strong>, il est endetté.</em></td></tr>
              <tr><td class="hl-li">par exemple</td><td>por ejemplo (ilustra)</td><td><em>Certains sports, <strong>par exemple</strong> la natation…</em></td></tr>
              <tr><td class="hl-li">c'est-à-dire</td><td>es decir (reformula)</td><td><em>Il est bilingue, <strong>c'est-à-dire</strong> qu'il parle deux langues.</em></td></tr>
            </tbody>
          </table></div>
          <div class="example-block li">
            <div class="ex-fr">Il n'est pas venu à la réunion. <span class="eli">En effet</span>, il avait un empêchement.</div>
            <div class="ex-es">No vino a la reunión. En efecto, tenía un impedimento.</div>
            <div class="ex-note">en effet = confirma, da la explicación de algo ya dicho</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">On pensait que c'était simple. <span class="eli">En fait</span>, c'est beaucoup plus compliqué.</div>
            <div class="ex-es">Pensábamos que era sencillo. En realidad, es mucho más complicado.</div>
            <div class="ex-note">en fait = introduce la realidad que corrige una idea previa</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Certaines activités, <span class="eli">par exemple</span> la lecture, améliorent la concentration.</div>
            <div class="ex-es">Ciertas actividades, por ejemplo la lectura, mejoran la concentración.</div>
          </div>
          <div class="example-block li">
            <div class="ex-fr">Il est autonome, <span class="eli">c'est-à-dire</span> qu'il n'a besoin d'aucune aide.</div>
            <div class="ex-es">Es autónomo, es decir, no necesita ninguna ayuda.</div>
          </div>
          <div class="warn-box"><span class="warn-icon">⚠️</span><div class="warn-text"><em>En effet</em> confirma lo ya dicho (es la explicación de algo afirmado). <em>En fait</em> introduce una corrección o la realidad opuesta a lo esperado. Confundirlos cambia el valor argumentativo del texto.</div></div>
        </div>

      </div>
    </div></div>
  </div>
  <div class="sec-block" id="s-trampas">
    <div class="gram-card"><div class="gram-card-body">
      <div class="trap-cards" id="trap-cards"></div>
    </div></div>
  </div>
</div>
<div class="panel" id="panel-ex">
  <div class="exercise-controls">
    <h3>Generar ejercicios</h3>
    <span class="ctrl-label">Tipo</span>
    <div class="ex-options">
      <button class="ex-opt-btn active" data-type="fill">Completar huecos</button>
      <button class="ex-opt-btn" data-type="choice">Elección múltiple</button>
      <button class="ex-opt-btn" data-type="transform">Transformación</button>
      <button class="ex-opt-btn" data-type="mix">Mixto</button>
    </div>
    <span class="ctrl-label">Foco</span>
    <div class="ex-options" id="foco-btns">
      <button class="ex-opt-btn foco active" data-foco="mix">General (todo)</button>
      <button class="ex-opt-btn foco" data-foco="formation">Formation en -ment (règles et irréguliers)</button>
      <button class="ex-opt-btn foco" data-foco="position">Position selon le temps verbal</button>
      <button class="ex-opt-btn foco" data-foco="intensite">Intensité : très/trop/assez/si/tellement</button>
      <button class="ex-opt-btn foco" data-foco="liaison">Adverbes de liaison (pourtant/cependant…)</button>
      <button class="ex-opt-btn foco" data-foco="choix">Choisir le bon adverbe selon le contexte</button>
    </div>
    <span class="ctrl-label">Nivel</span>
    <div class="row-btns" id="diff-btns">
      <button class="pill-btn diff A2" onclick="setDiff('A2')">A2</button>
      <button class="pill-btn diff B1 active" onclick="setDiff('B1')">B1</button>
      <button class="pill-btn diff B2" onclick="setDiff('B2')">B2</button>
    </div>
    <span class="ctrl-label">Cantidad</span>
    <div class="row-btns" id="qty-btns">
      <button class="pill-btn qty" onclick="setQty(3)">3</button>
      <button class="pill-btn qty active" onclick="setQty(5)">5</button>
      <button class="pill-btn qty" onclick="setQty(8)">8</button>
    </div>
    <button class="btn-generate" id="btn-gen" onclick="generateExercises()">
      <span class="btn-icon">✨</span>
      <span class="spinner">⟳</span>
      Generar ejercicios
    </button>
  </div>
  <div class="progress-wrap" id="progress-wrap">
    <div class="progress-top">
      <span class="progress-label">Progreso</span>
      <div style="display:flex;align-items:center;gap:10px">
        <span class="progress-frac" id="progress-frac">0 / 0</span>
        <button class="btn-retry" onclick="resetExercises()">↺ Nuevo</button>
      </div>
    </div>
    <div class="progress-track"><div class="progress-fill" id="progress-fill" style="width:0%"></div></div>
    <div class="progress-score">
      <div class="score-item"><div class="score-dot g"></div><span id="score-correct">0 correctas</span></div>
      <div class="score-item"><div class="score-dot r"></div><span id="score-wrong">0 errores</span></div>
    </div>
  </div>
  <div class="final-score-bar" id="final-score-bar">
    <div><div class="final-num" id="final-num">—</div><div class="final-label">resultado final</div></div>
    <div class="final-track"><div class="final-fill" id="final-fill" style="width:0%"></div></div>
    <div class="final-msg" id="final-msg"></div>
  </div>
  <div class="exercise-area" id="exercise-area">
    <div class="state-msg"><div class="state-icon">✏️</div>
      <p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p>
    </div>
  </div>
</div>
</div>
<script>
const TRAPS = [
  {name:"Formation: adjectif en -ent/-ant → -emment/-amment (no -entement)",
   wrong:"évidemment → évidement. / couramment → courantement.",
   right:"évident → évidemment. / courant → couramment.",
   expl:"Los adjectivos terminados en <strong>-ent</strong> dan adverbios en <strong>-emment</strong> (pronunciado /amɑ̃/): <em>évident → évidemment, prudent → prudemment, récent → récemment</em>. Los terminados en <strong>-ant</strong> dan <strong>-amment</strong>: <em>courant → couramment, brillant → brillamment</em>. Excepción: <em>lent → lentement</em> (no -emment)."},
  {name:"Position en temps composés: adverbio corto entre auxiliar y participio",
   wrong:"Il a travaillé beaucoup hier. / Elle a parlé bien.",
   right:"Il a beaucoup travaillé hier. / Elle a bien parlé.",
   expl:"Los adverbios cortos de cantidad e intensidad (<strong>bien, mal, beaucoup, trop, peu, déjà, encore, toujours, souvent, jamais, vite</strong>) van <strong>entre el auxiliar y el participio</strong> en los temps composés. Los adverbios largos (de temps o de lieu) van después del participio."},
  {name:"Très vs. trop: confusión de matiz",
   wrong:"Ce film est trop intéressant ! (queriendo decir muy) / Je suis très fatigué pour travailler.",
   right:"Ce film est très intéressant ! / Je suis trop fatigué pour travailler.",
   expl:"<strong>Très</strong> = muy (grado alto, neutro). <strong>Trop</strong> = demasiado (exceso que impide algo). <em>Trop</em> a menudo va seguido de <em>pour + infinitif</em>: <em>trop fatigué pour travailler</em>. Usar <em>trop</em> para decir 'muy' cambia el sentido por completo — en oral coloquial se usa trop como 'muy' pero en el DELF escrito es un error."},
  {name:"Si vs. aussi comme intensificateur",
   wrong:"Je suis aussi fatigué que je ne peux plus bouger. / Il est si content — moi aussi.",
   right:"Je suis si fatigué que je ne peux plus bouger. / Il est aussi content que toi.",
   expl:"<strong>Si</strong> (= tan) precede a adjectivos y adverbios en exclamaciones o antes de <em>que</em> consecutivo: <em>si fatigué qu'il est tombé</em>. <strong>Aussi</strong> se usa en comparaciones de igualdad: <em>aussi grand que</em>. No se intercambian: <em>aussi fatigué que je ne peux plus</em> ✗."},
  {name:"Adverbios de liaison: pourtant vs. cependant vs. néanmoins",
   wrong:"Usar siempre pourtant para cualquier tipo de oposición.",
   right:"C'est difficile, pourtant/cependant/néanmoins il a réussi. (todos válidos pero con matices de registro)",
   expl:"<strong>Pourtant</strong> = sin embargo, pero (oral y escrito, fuerte contraste). <strong>Cependant</strong> = sin embargo (más formal, escrito). <strong>Néanmoins</strong> = no obstante (muy formal, escrito argumentativo). Los tres expresan oposición pero con registros distintos. En el DELF B1, <em>pourtant</em> es suficiente; <em>cependant</em> y <em>néanmoins</em> mejoran la nota de producción escrita B2."},
  {name:"D'ailleurs vs. en fait vs. en effet",
   wrong:"En effet, il n'est pas venu — ce n'est pas vrai. (en effet no introduce refutación)",
   right:"En fait, il n'est pas venu. (en realidad) / En effet, il n'est pas venu. (efectivamente, confirma)",
   expl:"<strong>En effet</strong> = efectivamente, en efecto (confirma lo dicho antes). <strong>En fait</strong> = en realidad, de hecho (introduce una corrección o realidad). <strong>D'ailleurs</strong> = además, por otra parte (añade un argumento suplementario). Confundirlos cambia el valor argumentativo del texto."},
  {name:"Également vs. aussi: posición",
   wrong:"Il est aussi venu également. / Il également est venu.",
   right:"Il est également venu. / Il est venu également. / Il est venu aussi.",
   expl:"<strong>Également</strong> (también, asimismo) es más formal que <em>aussi</em> y se usa en escrito. Su posición es más flexible pero normalmente va después del auxiliar (temps composés) o antes del p.p.: <em>il est <strong>également</strong> venu</em>. No se usa con <em>aussi</em> en la misma frase."},
  {name:"Tellement vs. si: antes de adjectif o adverbe",
   wrong:"Il parle tellement vite que je ne comprends rien. (correcto) pero: Il est tellement intelligent. vs. Il est si intelligent.",
   right:"Il est si intelligent ! / Il parle tellement vite. / Il a tellement travaillé qu'il est épuisé.",
   expl:"<strong>Si</strong> precede a adjectifs y adverbios: <em>si beau, si vite</em>. <strong>Tellement</strong> precede a adjectifs, adverbios y también a verbos: <em>il travaille tellement</em>. Ambos se usan antes de <em>que</em> consecutivo, pero con verbos solo se usa <em>tellement</em>: <em>il a tellement mangé qu'il est malade</em> ✓ — <em>il a si mangé</em> ✗."},
];

function renderTraps(){
  document.getElementById("trap-cards").innerHTML=TRAPS.map(t=>
    `<div class="trap-card">
      <div class="trap-card-header">
        <div class="trap-name">${t.name}</div>
        <div class="trap-vs">
          <span class="trap-wrong">✗ ${t.wrong}</span>
          <span class="trap-right">✓ ${t.right}</span>
        </div>
      </div>
      <div class="trap-expl">${t.expl}</div>
    </div>`).join("");
}

function selectChip(ns,idx){
  document.querySelectorAll(".chip-bar").forEach(bar=>{
    const first=bar.querySelector(".chip");
    if(first&&first.getAttribute("onclick")&&first.getAttribute("onclick").includes("'"+ns+"'"))
      bar.querySelectorAll(".chip").forEach((c,i)=>c.classList.toggle("active",i===idx));
  });
  const el=document.getElementById(ns+"-panels");
  if(el) el.querySelectorAll(":scope > .chip-panel").forEach((p,i)=>p.classList.toggle("active",i===idx));
}
function showSection(id,btn){
  document.querySelectorAll(".sec-block").forEach(s=>s.classList.remove("active"));
  document.querySelectorAll(".snav-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById(id).classList.add("active");
  btn.classList.add("active");
}
function switchMode(mode,btn){
  document.querySelectorAll(".panel").forEach(p=>p.classList.remove("active"));
  document.querySelectorAll(".mode-btn").forEach(b=>b.classList.remove("active"));
  document.getElementById("panel-"+mode).classList.add("active");
  btn.classList.add("active");
  document.getElementById("section-nav").style.display=mode==="ref"?"":"none";
}
function setFontSize(v){document.documentElement.style.setProperty("--fs",v+"px");}

let exType="fill",exDiff="B1",exQty=5,exFoco="mix";
let exTotal=0,exAnswered=0,exCorrect=0,exWrong=0;

document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(b=>b.addEventListener("click",function(){
  document.querySelectorAll(".ex-opt-btn:not(.foco)").forEach(x=>x.classList.remove("active"));
  this.classList.add("active");exType=this.dataset.type;
}));
document.querySelectorAll(".ex-opt-btn.foco").forEach(b=>b.addEventListener("click",function(){
  document.querySelectorAll(".ex-opt-btn.foco").forEach(x=>x.classList.remove("active"));
  this.classList.add("active");exFoco=this.dataset.foco;
}));
function setDiff(d){
  exDiff=d;
  document.querySelectorAll("#diff-btns .pill-btn").forEach(b=>{
    b.classList.remove("active","A2","B1","B2");
    if(b.textContent.trim()===d) b.classList.add("active",d);
  });
}
function setQty(q){
  exQty=q;
  document.querySelectorAll("#qty-btns .pill-btn").forEach(b=>
    b.classList.toggle("active",parseInt(b.textContent.trim())===q));
}

const FOCO_DESC={
  mix:       "todos los aspectos: formación en -ment (reglas regulares + -ent/-ant → -emment/-amment + irregulares), posición según el tiempo verbal (adverbios cortos entre aux. y p.p., largos después del p.p.), intensidad (très/trop/assez/si/tellement/vraiment + grados), adverbios de liaison (pourtant/cependant/néanmoins/donc/ainsi/d'ailleurs/en effet/en fait/notamment)",
  formation: "formación de adverbios en -ment: adjectif fém. + -ment (lent→lentement, heureux→heureusement); -ent → -emment (prudent→prudemment, évident→évidemment, récent→récemment); -ant → -amment (courant→couramment, brillant→brillamment); irréguliers: bien, mal, peu, beaucoup, vite, loin, tard, tôt, déjà",
  position:  "posición del adverbio: adverbios cortos (bien/mal/vite/déjà/encore/toujours/souvent/jamais/beaucoup/peu/trop) entre auxiliar y p.p. en temps composés; adverbios de temps/lieu (hier/demain/ici/là/maintenant) después del p.p.; posición con verbo en temps simples (después del verbo); adverbios de phrase al inicio (malheureusement, heureusement, peut-être)",
  intensite: "adverbios de intensidad y cantidad: très (muy, ante adj/adv), trop (demasiado, ante adj/adv/nombre + para + inf.), assez (bastante), si (tan, ante adj/adv en exclamación o consecutiva), tellement (tanto, ante adj/adv/verbo), vraiment (verdaderamente), absolument, tout à fait, pas du tout; grados: un peu < assez < très < trop",
  liaison:   "adverbios de liaison para producción escrita: oposición (pourtant/cependant/néanmoins/toutefois), consecuencia (donc/ainsi/c'est pourquoi/par conséquent), adición (de plus/en outre/d'ailleurs/également/notamment), ilustración (en effet/par exemple/notamment), reformulación (en fait/autrement dit/c'est-à-dire)",
  choix:     "elegir el adverbio correcto según el contexto y matiz: très vs. trop, aussi vs. si, pourtant vs. cependant, en effet vs. en fait, d'ailleurs vs. de plus, déjà vs. encore, toujours vs. encore; el alumno selecciona el adverbio que corresponde al sentido de la frase",
};
const TYPE_DESC={
  fill:      "completar huecos: el alumno escribe el adverbio correcto (formado correctamente o elegido según el contexto) o su posición adecuada en la frase",
  choice:    "elección múltiple: 4 adverbios o posiciones, solo uno correcto según el sentido, el registro y la construcción gramatical",
  transform: "transformación: convertir un adjectif en adverbio en -ment y usarlo correctamente en la frase, o reescribir la frase colocando el adverbio en la posición correcta",
  mix:       "mixto: combina fill, choice y transform",
};

const RULE_LABELS={
  "s-intro":"Panorama","s-formation":"Formation en -ment","s-position":"Position",
  "s-intensite":"Intensité / quantité","s-liaison":"Adverbes de liaison","s-trampas":"Trampas"
};

function renderExercises(exs){
  const area=document.getElementById("exercise-area");
  const labels={fill:"Completar",choice:"Elección múltiple",transform:"Transformación"};
  area.innerHTML=exs.map((ex,i)=>
    `<div class="exercise-card" id="ex-card-${i}" data-expl="${esc(ex.explanation)}" data-rule="${ex.rule_ref||""}">
      <div class="exercise-card-header">
        <span class="ex-num">${i+1}</span>
        <span class="ex-type-badge">${labels[ex.type]||ex.type}</span>
        <span class="ex-diff-badge ${ex.diff}">${ex.diff}</span>
        <span class="ex-status" id="ex-st-${i}"></span>
      </div>
      <div class="exercise-body">
        ${buildBody(ex,i)}
        <div class="ex-feedback" id="ex-fb-${i}"></div>
      </div>
    </div>`).join("");
  exs.forEach((ex,i)=>{
    const chk=document.getElementById("chk-"+i);
    if(chk) chk.addEventListener("click",()=>checkAnswer(ex,i));
    const inp=document.getElementById("inp-"+i);
    if(inp) inp.addEventListener("keydown",e=>{if(e.key==="Enter") checkAnswer(ex,i);});
  });
}
function buildBody(ex,i){
  if(ex.type==="fill"){
    const parts=ex.prompt_parts||["",""];
    return `<div class="exercise-prompt">${parts[0]}<input class="fill-input" id="inp-${i}" type="text" placeholder="${ex.blank_hint||"…"}" autocomplete="off" spellcheck="false">${parts.slice(1).join("")}</div><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  }
  if(ex.type==="choice")
    return `<div class="exercise-prompt">${ex.prompt}</div><div class="choices-grid">${ex.options.map((o,j)=>`<button class="choice-btn" id="ch-${i}-${j}" onclick="selectChoice(${i},${j},${ex.correct_index})">${o}</button>`).join("")}</div>`;
  if(ex.type==="transform")
    return `<div class="exercise-prompt">${ex.instruction}<br><em>${ex.original}</em></div><input class="transform-input" id="inp-${i}" type="text" placeholder="Frase con adverbio correcto…" autocomplete="off" spellcheck="false"><button class="btn-check" id="chk-${i}">Comprobar</button>`;
  return "";
}
function checkAnswer(ex,i){
  const inp=document.getElementById("inp-"+i);
  if(!inp||inp.disabled) return;
  const ok=inp.value.trim().toLowerCase()===ex.answer.trim().toLowerCase();
  inp.classList.add(ok?"ok":"err");inp.disabled=true;
  const chk=document.getElementById("chk-"+i);if(chk) chk.disabled=true;
  showFeedback(i,ok,ex.answer,ex.explanation,ex.rule_ref);
  recordAnswer(ok);
}
function selectChoice(idx,chosen,correct){
  const c0=document.getElementById(`ch-${idx}-0`);
  if(!c0||c0.disabled) return;
  for(let j=0;j<4;j++){
    const b=document.getElementById(`ch-${idx}-${j}`);
    if(!b) continue;b.disabled=true;
    if(j===correct) b.classList.add("ok");else if(j===chosen) b.classList.add("err");
  }
  const card=document.getElementById("ex-card-"+idx);
  showFeedback(idx,chosen===correct,null,card.dataset.expl,card.dataset.rule);
  recordAnswer(chosen===correct);
}
function showFeedback(i,ok,ans,expl,ruleRef){
  document.getElementById("ex-st-"+i).textContent=ok?"✅":"❌";
  const fb=document.getElementById("ex-fb-"+i);
  fb.className="ex-feedback visible "+(ok?"ok":"err");
  const link=RULE_LABELS[ruleRef]?`<span class="fb-rule-link" onclick="goToRule('${ruleRef}')">📖 Ver: ${RULE_LABELS[ruleRef]}</span>`:"";
  let html=ok?`<strong>✓ Correcto</strong>`:`<strong>✗ Incorrecto</strong>${ans?` — Respuesta: <strong>${ans}</strong>`:""}`;
  if(expl) html+=`<br><span style="font-size:.88em;opacity:.92;margin-top:3px;display:block">${expl}</span>`;
  html+=link;fb.innerHTML=html;
}
function goToRule(ref){
  switchMode("ref",document.querySelector(".mode-btn"));
  setTimeout(()=>{
    showSection(ref,document.querySelector(`.snav-btn[onclick*="${ref}"]`));
    document.getElementById(ref).scrollIntoView({behavior:"smooth",block:"start"});
  },80);
}
function recordAnswer(ok){exAnswered++;if(ok)exCorrect++;else exWrong++;updateProgress();}
function updateProgress(){
  const pct=exTotal>0?(exAnswered/exTotal)*100:0;
  document.getElementById("progress-frac").textContent=`${exAnswered} / ${exTotal}`;
  document.getElementById("progress-fill").style.width=pct+"%";
  document.getElementById("score-correct").textContent=`${exCorrect} correcta${exCorrect!==1?"s":""}`;
  document.getElementById("score-wrong").textContent=`${exWrong} error${exWrong!==1?"es":""}`;
  if(exAnswered>=exTotal&&exTotal>0) showFinalScore();
}
function showFinalScore(){
  const pct=Math.round((exCorrect/exTotal)*100);
  document.getElementById("final-score-bar").classList.add("visible");
  document.getElementById("final-num").textContent=`${exCorrect} / ${exTotal}`;
  const fill=document.getElementById("final-fill");
  fill.style.width=pct+"%";
  fill.style.background=pct>=80?"var(--green)":pct>=50?"var(--accent)":"var(--red)";
  const msgs={100:"Parfait ! Dominas los adverbios. 🎉",80:"Très bien ! Repasa los errores.",50:"Bien, refuerza los bloques señalados.",0:"Vuelve a Referencia antes de repetir."};
  document.getElementById("final-msg").textContent=msgs[pct===100?100:pct>=80?80:pct>=50?50:0];
  document.getElementById("score-pill").style.display="";
  document.getElementById("score-pill-val").textContent=`${exCorrect}/${exTotal}`;
}
function resetExercises(){
  document.getElementById("exercise-area").innerHTML=`<div class="state-msg"><div class="state-icon">✏️</div><p>Elige tipo, foco, nivel y cantidad, y pulsa <strong>Generar ejercicios</strong>.</p></div>`;
  document.getElementById("progress-wrap").classList.remove("visible");
  document.getElementById("final-score-bar").classList.remove("visible");
  document.getElementById("score-pill").style.display="none";
  exAnswered=0;exCorrect=0;exWrong=0;
}
function esc(s){return(s||"").replace(/"/g,"&quot;").replace(/</g,"&lt;");}
renderTraps();
</script>
</body>
</html>
